      $70F0 = $A1
      $70F1 = $A9
      $70F2 = $00
      $70F3 = $60
      $70F4 = $A9
      $70F5 = $01
      $70F6 = $60
      resume()
      wait_ready()
      basic("10 SYS 28672")
      run()
      assert(peekbyte($2280) == 0, "nic_copy_name accepted a valid host name")
      assert(peekbyte($2281) == 110, "nic_copy_name copied first host byte")
      assert(peekbyte($2282) == 0, "nic_copy_name NUL-terminated the host name")
      assert(peekbyte($2283) == 1, "nic_copy_name rejected empty names")
      assert((peekbyte($2284) & $04) == $04, "nic_status reports send-ready on an idle slot")
      assert(peekbyte($2285) == 0, "nic_ready reports no pending data on an idle slot")
      assert(peekbyte($2286) == 2, "nic_disconnect issued command 2")
      assert(peekbyte($2287) == 3, "nic_send issued command 3")
      assert((peekbyte($2288) & $08) == $08, "nic_send on an unconnected slot reports an error")
      assert(peekbyte($2289) == 0, "nic_length reports zero before a receive")
      assert(peekbyte($228F) == $AA, "assembly NIC fixture reached completion")
    }
  }
}
