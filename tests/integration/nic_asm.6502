; NIC assembly integration tests.
; Run: sim6502 -s tests/integration/nic_asm.6502 --backend novavm
;
; The fixture is built from tests/integration/asm/nic_runtime.s and installed
; after pause() so the NovaVM runner cold-starts before each test.

suites {
  suite("NIC Assembly Runtime") {
    test("asm-nic-entrypoints", "Assembly ABI can copy names, query status, and issue NIC commands") {
