      $73B5 = $4C
      $73B6 = $88
      $73B7 = $71
      resume()
      wait_ready()
      basic("10 SYS 28672")
      run()
      assert(peekbyte($2200) == 0, "xram_write8 returned OK")
      assert(peekbyte($2201) == 0, "xram_read8 returned OK")
      assert(peekbyte($2202) == $5A, "xram_read8 returned written byte")
      assert(peekbyte($2203) == 0, "xram_copy_from_ram returned OK")
      assert(peekbyte($2204) == 0, "xram_copy_to_ram returned OK")
      assert(peekbyte($2310) == $A0, "copy first byte restored")
      assert(peekbyte($231F) == $AF, "copy last byte restored")
      assert(peekbyte($2205) == 0, "xram_fill returned OK")
      assert(peekbyte($2206) == 0, "fill copy-back returned OK")
      assert(peekbyte($2320) == $7E, "fill first byte restored")
      assert(peekbyte($2327) == $7E, "fill last byte restored")
      assert(peekbyte($2207) == 1, "out-of-range read returned error")
      assert(peekbyte($2208) == 1, "out-of-range read set range error code")
      assert(peekbyte($220F) == $AA, "assembly DMA fixture reached completion")
    }

