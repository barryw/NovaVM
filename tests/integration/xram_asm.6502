      run()
      assert(peekbyte($2220) == 0, "file source copy to XRAM returned OK")
      assert(peekbyte($2221) == 0, "xram_xsave returned OK")
      assert(peekbyte($2222) == 0, "xram_xload returned OK")
      assert(peekbyte($2223) == 4, "xram_xload reported four bytes")
