      assert(peekbyte($2225) == 0, "file destination copy-back returned OK")
      assert(peekbyte($2226) == 0, "source XRAM clear returned OK")
      assert(peekbyte($2350) == $11, "file byte 0 restored")
      assert(peekbyte($2351) == $22, "file byte 1 restored")
      assert(peekbyte($2352) == $33, "file byte 2 restored")
      assert(peekbyte($2353) == $44, "file byte 3 restored")
      assert(peekbyte($222F) == $AA, "assembly file fixture reached completion")
