      $73A0 = $C9
      $73A1 = $02
      $73A2 = $F0
      $73A3 = $11
      $73A4 = $AD
      $73A5 = $65
      $73A6 = $BA
      $73A7 = $C9
      $73A8 = $03
      $73A9 = $F0
      $73AA = $05
      $73AB = $A9
      $73AC = $02
