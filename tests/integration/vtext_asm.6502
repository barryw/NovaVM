      basic("10 SYS 28672")
      run()
      assert(peekbyte($2240) == 0, "status region define returned OK")
      assert(peekbyte($2241) == 0, "story region define returned OK")
      assert(peekbyte($2242) == 0, "status region select returned OK")
      assert(peekbyte($2243) == 0, "status region clear returned OK")
      assert(peekbyte($2244) == 0, "story region select returned OK")
      assert(peekbyte($2245) == 0, "story region clear returned OK")
      assert(peekbyte($2246) == 0, "story text write returned OK")
      assert(peekbyte($2247) == 0, "story region store returned OK")
      assert(peekbyte($2248) == 48, "story cursor remains on bottom row after 100-line scroll")
      assert(peekbyte($2249) == 7, "story cursor advanced after LINE100")
      assert(peekbyte($2250) == $F0, "status line color is inverse")
      assert(peekbyte($2251) == $0F, "story line color is normal")
      assert(peekbyte($2252) == $00, "status line text attrs remain clear")
      assert(peekbyte($224F) == $AA, "assembly vtext fixture reached completion")
      assert(screen_line(0, "WEST OF HOUSE"), "status location remains on row 0")
      assert(screen_line(0, "SCORE: 0 MOVES: 1"), "status score remains on row 0")
      assert(screen_line(1, "LINE52"), "first scrolling row shows line 52 after 100 writes")
      assert(screen_line(25, "LINE76"), "middle scrolling row shows line 76 after 100 writes")
      assert(screen_line(49, "LINE100"), "bottom scrolling row shows line 100")
    }
  }
