; Copper Integration Tests — raster effects programming
; Run: sim6502 -s tests/integration/copper.6502 --backend novavm
;
; Assertion pattern: POKE-sentinel ($0100) to verify BASIC ran the
; COPPER command sequence without error. Copper-side-effects (bg
; color changing at specific raster lines) aren't directly observable
; via peek since the color-change is transient per-frame.

suites {
  suite("Copper") {

    test("copper-add-and-run", "COPPERADD + COPPERON executes without error") {
      basic("10 POKE $A001,0")
      basic("20 POKE $0100,$FF")
      basic("30 COPPERADD 0,50,1,6")
      basic("40 COPPERON")
      basic("50 FOR I=1 TO 500:NEXT")
      basic("60 COPPEROFF")
      basic("70 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "copper add/on/off cycle ran without error")
    }

    test("copper-off-stops", "COPPEROFF disables copper") {
      basic("10 POKE $0100,$FF")
      basic("20 COPPERADD 0,10,1,3")
      basic("30 COPPERON")
      basic("40 FOR I=1 TO 100:NEXT")
      basic("50 COPPEROFF")
      basic("60 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "COPPEROFF cleared cleanly")
    }

    test("copper-clear", "COPPERCLEAR removes all events") {
      basic("10 POKE $0100,$FF")
      basic("20 COPPERADD 0,10,1,2")
      basic("30 COPPERADD 0,50,1,5")
      basic("40 COPPERADD 0,100,1,8")
      basic("50 COPPERCLEAR")
      basic("60 COPPERON")
      basic("70 FOR I=1 TO 200:NEXT")
      basic("80 COPPEROFF")
      basic("90 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "COPPERCLEAR + run ran without error")
    }

    test("copper-multiple-events", "Multiple copper events at different raster lines") {
      basic("10 POKE $A001,0")
      basic("20 POKE $0100,$FF")
      basic("30 COPPERADD 0,0,1,2")
      basic("40 COPPERADD 0,50,1,4")
      basic("50 COPPERADD 0,100,1,6")
      basic("60 COPPERADD 0,150,1,8")
      basic("70 COPPERON")
      basic("80 FOR I=1 TO 1000:NEXT")
      basic("90 COPPEROFF")
      basic("100 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "multi-event copper ran without error")
    }

    test("copper-on-off-cycle", "Repeated ON/OFF cycling") {
      basic("10 POKE $0100,$FF")
      basic("20 COPPERADD 0,50,1,5")
      basic("30 FOR J=1 TO 3")
      basic("40 COPPERON")
      basic("50 FOR I=1 TO 200:NEXT")
      basic("60 COPPEROFF")
      basic("70 NEXT")
      basic("80 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "ON/OFF cycling ran without error")
    }
  }
}
