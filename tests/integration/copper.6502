; Copper Integration Tests — raster effects programming
; Run: sim6502 -s tests/integration/copper.6502 --backend novavm

suites {
  suite("Copper") {

    test("copper-add-and-run", "COPPERADD + COPPERON executes without error") {
      basic("10 POKE $A001,0")
      basic("20 COPPERADD 0,50,1,6")
      basic("30 COPPERON")
      basic("40 FOR I=1 TO 500:NEXT")
      basic("50 COPPEROFF")
      run()
      assert(screen_contains("Ready"), "copper cycle completed")
    }

    test("copper-off-stops", "COPPEROFF disables copper") {
      basic("10 COPPERADD 0,10,1,3")
      basic("20 COPPERON")
      basic("30 FOR I=1 TO 100:NEXT")
      basic("40 COPPEROFF")
      run()
      assert(screen_contains("Ready"), "copper stopped cleanly")
    }

    test("copper-clear", "COPPERCLEAR removes all events") {
      basic("10 COPPERADD 0,10,1,2")
      basic("20 COPPERADD 0,50,1,5")
      basic("30 COPPERADD 0,100,1,8")
      basic("40 COPPERCLEAR")
      basic("50 COPPERON")
      basic("60 FOR I=1 TO 200:NEXT")
      basic("70 COPPEROFF")
      run()
      assert(screen_contains("Ready"), "copper clear + run completed")
    }

    test("copper-multiple-events", "Multiple copper events at different raster lines") {
      basic("10 POKE $A001,0")
      basic("20 COPPERADD 0,0,1,2")
      basic("30 COPPERADD 0,50,1,4")
      basic("40 COPPERADD 0,100,1,6")
      basic("50 COPPERADD 0,150,1,8")
      basic("60 COPPERON")
      basic("70 FOR I=1 TO 1000:NEXT")
      basic("80 COPPEROFF")
      run()
      assert(screen_contains("Ready"), "multi-event copper completed")
    }

    test("copper-on-off-cycle", "Repeated ON/OFF cycling") {
      basic("10 COPPERADD 0,50,1,5")
      basic("20 FOR J=1 TO 3")
      basic("30 COPPERON")
      basic("40 FOR I=1 TO 200:NEXT")
      basic("50 COPPEROFF")
      basic("60 NEXT")
      run()
      assert(screen_contains("Ready"), "on/off cycling completed")
    }
  }
}
