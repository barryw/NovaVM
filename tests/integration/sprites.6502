; Sprite Integration Tests — define, position, enable, flip, priority
; Run: sim6502 -s tests/integration/sprites.6502 --backend novavm
;
; Syntax: SPRITE n,ON / SPRITE n,OFF / SPRITE n,x,y
;         SPRITEDATA n,row,d0,...,d7
;         SPRITESET n,field,value  (field: 0=X,1=XH,2=Y,3=YH,4=shape,5=flags,6=pri)
;
; Sprite register map — $A040-$A0BF, 8 bytes per sprite:
;   +0 X lo     +1 X hi
;   +2 Y lo     +3 Y hi
;   +4 shape (4-bit)
;   +5 flags — bit 7 = enable, bit 1 = flip_v, bit 0 = flip_h
;   +6 priority (2-bit: 0=behind, 1=mid, 2=front)
;   +7 trans color (4-bit)
;
; Sprite registers are readable (CPU PEEK and debug-peek) as of the
; sprite-readback fix.  Tests now assert against the actual register
; contents rather than just the POKE-sentinel pattern.
;
; Each sprite command is on its own BASIC line. EhBASIC's SPRITE/
; SPRITEDATA tokenizer doesn't reliably accept colon-chaining with
; a trailing POKE, so the sentinel POKE gets its own numbered line.

suites {
  suite("Sprites") {

    test("sprite-enable-disable", "SPRITE n,ON/OFF toggle sprite visibility") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 SPRITE 0,ON")
      basic("40 SPRITE 0,OFF")
      basic("50 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "SPRITE ON/OFF ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
      ; Sprite 0 flags byte: bit 7 = enable. After OFF it must be clear.
      assert((peekbyte($A045) & $80) == 0, "sprite 0 enable bit cleared after OFF")
    }

    test("sprite-position", "SPRITE n,x,y sets position") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 SPRITE 0,100,50")
      basic("40 SPRITE 0,ON")
      basic("50 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "SPRITE position ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
      ; Sprite 0: X=100 ($64), Y=50 ($32), enabled.
      assert(peekbyte($A040) == 100, "sprite 0 X lo = 100")
      assert(peekbyte($A041) == 0,   "sprite 0 X hi = 0")
      assert(peekbyte($A042) == 50,  "sprite 0 Y lo = 50")
      assert(peekbyte($A043) == 0,   "sprite 0 Y hi = 0")
      assert((peekbyte($A045) & $80) == $80, "sprite 0 enable bit set")
    }

    test("sprite-define-pixel", "SPRITESET sets individual sprite register") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 SPRITESET 0,4,7")
      basic("40 SPRITESET 0,5,3")
      basic("50 SPRITESET 0,6,2")
      basic("60 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "SPRITESET ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
      ; Shape=7, flags=3 (both flip bits), priority=2
      assert(peekbyte($A044) == 7, "sprite 0 shape = 7")
      assert((peekbyte($A045) & 3) == 3, "sprite 0 flip_h+flip_v set")
      assert(peekbyte($A046) == 2, "sprite 0 priority = 2")
    }

    test("sprite-define-row", "SPRITEDATA defines full row") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 SPRITEDATA 0,0,$77,$77,$77,$77,$77,$77,$77,$77")
      basic("40 SPRITE 0,ON")
      basic("50 SPRITE 0,100,50")
      basic("60 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "SPRITEDATA ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
    }

    test("sprite-flip", "SPRITESET field 5 sets flip flags") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 SPRITESET 0,5,1")
      basic("40 SPRITESET 0,5,2")
      basic("50 SPRITESET 0,5,3")
      basic("60 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "SPRITESET flip variants ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
    }

    test("sprite-priority", "SPRITESET field 6 sets rendering priority") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 SPRITESET 0,6,0")
      basic("40 SPRITESET 0,6,1")
      basic("50 SPRITESET 0,6,2")
      basic("60 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "SPRITESET priority variants ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
    }

    test("multiple-sprites", "Multiple sprites at different positions") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 FOR I=0 TO 7")
      basic("40 SPRITEDATA I,0,$FF,$FF,$FF,$FF,$FF,$FF,$FF,$FF")
      basic("50 SPRITE I,I*20+10,I*20+10")
      basic("60 SPRITE I,ON")
      basic("70 NEXT")
      basic("80 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "8-sprite loop ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
    }

    test("sprite-move-sequence", "Move sprite across screen") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 SPRITEDATA 0,0,$FF,$FF,$FF,$FF,$FF,$FF,$FF,$FF")
      basic("40 SPRITE 0,ON")
      basic("50 FOR I=0 TO 100 STEP 10")
      basic("60 SPRITE 0,I,50")
      basic("70 NEXT")
      basic("80 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "sprite motion loop ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
    }

    test("sprite-clear-and-redefine", "Clear sprite then redefine") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 SPRITEDATA 0,0,$FF,$FF,$FF,$FF,$FF,$FF,$FF,$FF")
      basic("40 SPRITE 0,ON")
      basic("50 SPRITE 0,OFF")
      basic("60 SPRITEDATA 0,0,$11,$22,$33,$44,$55,$66,$77,$88")
      basic("70 SPRITE 0,ON")
      basic("80 SPRITE 0,160,100")
      basic("90 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "sprite redefine ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
      ; Final state: sprite 0 at X=160 ($A0), Y=100 ($64), enabled.
      assert(peekbyte($A040) == $A0, "sprite 0 X lo = 160")
      assert(peekbyte($A042) == $64, "sprite 0 Y lo = 100")
      assert((peekbyte($A045) & $80) == $80, "sprite 0 enabled")
    }

    test("sprite-visual-demo", "Full 16-row shape visible on-screen, moving") {
      ; 1-second demo: 4 sprites with full shapes arranged left-to-right,
      ; then moved. Visible on HDMI. Final positions asserted via PEEK.
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      ; Fill all 16 rows of sprite 0 with solid fill. Each SPRITEDATA row is
      ; 8 bytes of 4-bit nibble-packed pixels → solid $FF = color 15 across 2px.
      basic("30 FOR R=0 TO 15")
      basic("40 SPRITEDATA 0,R,$FF,$FF,$FF,$FF,$FF,$FF,$FF,$FF")
      basic("50 NEXT R")
      ; Place and enable 4 sprites at visible coords.
      basic("60 SPRITE 0,40,60:SPRITE 0,ON")
      basic("70 SPRITE 1,120,60:SPRITE 1,ON")
      basic("80 SPRITE 2,200,60:SPRITE 2,ON")
      basic("90 SPRITE 3,280,60:SPRITE 3,ON")
      ; Give the renderer a few frames to latch and display before moving.
      basic("100 FOR F=0 TO 60:NEXT F")
      ; Move sprite 0 across (simple diagonal sweep, 10 steps).
      basic("110 FOR S=0 TO 100 STEP 10")
      basic("120 SPRITE 0,40+S,60+S")
      basic("130 FOR F=0 TO 20:NEXT F")
      basic("140 NEXT S")
      ; Park sprite 1 off-screen (X=$0190=400 > 320) — enable bit still set
      ; but pixel shouldn't render. A good visual "disappear" check.
      basic("150 SPRITESET 1,1,1")
      basic("160 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "visual demo ran without error")
      assert(peekbyte($A010) == 0, "VGC idle")
      ; Sprite 0 final position: X = 40 + 100 = 140, Y = 60 + 100 = 160
      assert(peekbyte($A040) == 140, "sprite 0 final X = 140")
      assert(peekbyte($A042) == 160, "sprite 0 final Y = 160")
      ; Sprite 1 X hi = 1 (offscreen), enable still set.
      assert(peekbyte($A049) == 1, "sprite 1 X hi = 1 (offscreen)")
      assert((peekbyte($A04D) & $80) == $80, "sprite 1 enable persists")
      ; Sprites 2 and 3 remain at their original positions.
      assert(peekbyte($A050) == 200, "sprite 2 X = 200")
      ; Sprite 3 X=280 → X lo = 24, X hi = 1
      assert(peekbyte($A058) == 24, "sprite 3 X lo = 24 (280 & $FF)")
      assert(peekbyte($A059) == 1,  "sprite 3 X hi = 1  (280 >> 8)")
    }
  }
}
