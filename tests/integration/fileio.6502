; File I/O Integration Tests — GSAVE, GLOAD, DIR, DEL
; Run: sim6502 -s tests/integration/fileio.6502 --backend novavm
; Note: File commands require string args — use CHR$-built strings
; Save directory: ~/e6502-programs
; GSAVE/GLOAD spaces: 0=screen, 1=color, 2=gfx, 3=sprite, 4=tile
; Known issue: PEEK after GLOAD may not reflect restored VGC memory via CPU bus.
;              GSAVE/GLOAD operate on VGC internal spaces; CPU PEEK reads through
;              the bus which may not see GLOAD writes. Verify via screen output instead.
;
; Assertion pattern: POKE-sentinel ($0100) after each BASIC line group
; to verify the file-I/O command ran without error.

suites {
  suite("File IO") {

    test("dir-lists-programs", "DIR completes without error") {
      basic("10 POKE $0100,$FF")
      basic("20 DIR")
      basic("30 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "DIR ran without error")
    }

    test("gsave-completes", "GSAVE saves screen data without error") {
      basic("10 POKE $0100,$FF")
      basic("20 FOR I=0 TO 9:POKE $AA00+I,65+I:NEXT")
      basic("30 A$=CHR$(84)+CHR$(83)+CHR$(84)")
      basic("40 GSAVE A$,0,0,10")
      basic("50 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "GSAVE ran without error")
    }

    test("gload-completes", "GLOAD loads data without error") {
      ; First save, then load
      basic("10 POKE $0100,$FF")
      basic("20 A$=CHR$(71)+CHR$(76)+CHR$(68)")
      basic("30 GSAVE A$,0,0,10")
      basic("40 GLOAD A$,0,0,10")
      basic("50 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "GLOAD ran without error")
    }

    test("gsave-gload-cpu-ram-verify", "GSAVE/GLOAD round-trip verified via BASIC PEEK") {
      ; Write pattern to char-RAM, GSAVE it, zero char-RAM, GLOAD it back.
      ; PRINT PEEK($AA00) — if GLOAD restores correctly AND CPU peek sees
      ; VGC char-RAM, the value 65 should come back.
      basic("10 POKE $0100,$FF")
      basic("20 FOR I=0 TO 9:POKE $AA00+I,65+I:NEXT")
      basic("30 A$=CHR$(82)+CHR$(78)+CHR$(68)")
      basic("40 GSAVE A$,0,0,10")
      basic("50 FOR I=0 TO 9:POKE $AA00+I,0:NEXT")
      basic("60 GLOAD A$,0,0,10")
      basic("70 PRINT PEEK($AA00)")
      basic("80 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "round-trip ran without error")
      ; Note: the "65" assertion below documents expected behavior — if
      ; GLOAD does NOT propagate through the bus this will fail and
      ; pinpoint the limitation per the file header comment.
      assert(screen_contains("65"), "GLOAD restored char-RAM byte visible to PEEK")
    }

    test("del-removes-file", "DEL removes a saved file") {
      basic("10 POKE $0100,$FF")
      basic("20 POKE $AA00,$42")
      basic("30 A$=CHR$(68)+CHR$(69)+CHR$(76)+CHR$(84)")
      basic("40 GSAVE A$,0,0,1")
      basic("50 DEL A$")
      basic("60 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "DEL ran without error")
    }

    test("gsave-color-ram", "GSAVE color RAM space completes") {
      basic("10 POKE $0100,$FF")
      basic("20 FOR I=0 TO 9:POKE $B1D0+I,I+1:NEXT")
      basic("30 A$=CHR$(67)+CHR$(76)+CHR$(82)")
      basic("40 GSAVE A$,1,0,10")
      basic("50 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "color GSAVE ran without error")
    }
  }
}
