; VGC Integration Tests — graphics mode, colors, drawing primitives
; Run: sim6502 -s tests/integration/vgc.6502 --backend novavm

suites {
  suite("VGC Graphics") {

    test("mode-register", "MODE sets display mode register") {
      basic("10 MODE 0")
      run()
      assert(peekbyte($A000) == 0, "mode 0 set")

      basic("10 MODE 3")
      run()
      assert(peekbyte($A000) == 3, "mode 3 set")
    }

    test("mode-switch-all", "All four display modes") {
      basic("10 MODE 1")
      run()
      assert(peekbyte($A000) == 1, "mode 1")

      basic("10 MODE 2")
      run()
      assert(peekbyte($A000) == 2, "mode 2")
    }

    ; -------------------------------------------------------------------------
    ; POKE-sentinel pattern for commands without directly peekable output:
    ; write a known byte AFTER the command; if BASIC errored on the command
    ; (syntax/runtime error), subsequent statements do not execute, so the
    ; sentinel remains unwritten. peekbyte asserts the sentinel landed +
    ; VGC is idle ($A010 == 0). Real verification of graphics memory would
    ; require CMD_MEMREAD through the VGC — left as follow-up for the RTL
    ; bug-hunt phase.
    ; -------------------------------------------------------------------------

    test("gcolor-sets-draw-color", "GCOLOR sets drawing color") {
      basic("10 MODE 3")
      basic("20 POKE $0100,$FF")
      basic("30 GCOLOR 5:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "GCOLOR ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after GCOLOR")
    }

    test("plot-completes", "PLOT executes without error") {
      basic("10 MODE 3")
      basic("20 GCOLOR 7")
      basic("30 POKE $0100,$FF")
      basic("40 PLOT 100,50:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "PLOT ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after PLOT")
    }

    test("line-completes", "LINE draws without error") {
      basic("10 MODE 3")
      basic("20 GCOLOR 4")
      basic("30 POKE $0100,$FF")
      basic("40 LINE 0,0,319,199:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "LINE ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after LINE")
    }

    test("rect-completes", "RECT draws rectangle outline") {
      basic("10 MODE 3")
      basic("20 GCOLOR 2")
      basic("30 POKE $0100,$FF")
      basic("40 RECT 10,10,50,50:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "RECT ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after RECT")
    }

    test("fill-completes", "FILL draws solid rectangle") {
      basic("10 MODE 3")
      basic("20 GCOLOR 3")
      basic("30 POKE $0100,$FF")
      basic("40 FILL 10,10,50,50:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "FILL ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after FILL")
    }

    test("circle-completes", "CIRCLE draws without error") {
      basic("10 MODE 3")
      basic("20 GCOLOR 6")
      basic("30 POKE $0100,$FF")
      basic("40 CIRCLE 160,100,50:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "CIRCLE ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after CIRCLE")
    }

    test("ellipse-completes", "CIRCLE with two radii draws ellipse") {
      basic("10 MODE 3")
      basic("20 GCOLOR 1")
      basic("30 POKE $0100,$FF")
      basic("40 CIRCLE 160,100,80,40:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "CIRCLE+radii ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after CIRCLE")
    }

    test("gcls-clears", "GCLS clears graphics layer") {
      basic("10 MODE 3")
      basic("20 GCOLOR 5")
      basic("30 FILL 0,0,319,199")
      basic("40 POKE $0100,$FF")
      basic("50 GCLS:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "GCLS ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after GCLS")
    }

    test("paint-completes", "PAINT flood-fills from seed") {
      basic("10 MODE 3")
      basic("20 GCOLOR 2")
      basic("30 RECT 10,10,50,50")
      basic("40 GCOLOR 5")
      basic("50 POKE $0100,$FF")
      basic("60 PAINT 30,30:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "PAINT ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after PAINT")
    }

    test("bgcolor-register", "Background color via POKE") {
      basic("10 POKE $A001,6")
      run()
      assert(peekbyte($A001) == 6, "bg color set to 6")
    }

    test("multiple-primitives", "Multiple drawing commands in sequence") {
      basic("10 MODE 3")
      basic("20 GCOLOR 1:FILL 0,0,319,199")
      basic("30 GCOLOR 7:LINE 0,0,319,199:LINE 319,0,0,199")
      basic("40 CIRCLE 160,100,80:RECT 60,40,260,160")
      basic("50 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "all primitives ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after multi-primitive")
    }

    test("unplot-completes", "UNPLOT clears a pixel") {
      basic("10 MODE 3")
      basic("20 GCOLOR 5")
      basic("30 PLOT 100,50")
      basic("40 POKE $0100,$FF")
      basic("50 UNPLOT 100,50:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "UNPLOT ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after UNPLOT")
    }

    test("plot-unplot-roundtrip", "PLOT then UNPLOT sequence") {
      basic("10 MODE 3")
      basic("20 GCOLOR 7")
      basic("30 FOR I=0 TO 9:PLOT I*10,50:NEXT")
      basic("40 FOR I=0 TO 9:UNPLOT I*10,50:NEXT")
      basic("50 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "plot/unplot cycle ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after round-trip")
    }

    test("gtext-draws-text", "GTEXT draws text on graphics layer") {
      ; GTEXT x, y, font, scale, string
      ; String via CHR$ to avoid quote issues
      basic("10 MODE 3")
      basic("20 GCOLOR 7")
      basic("30 A$=CHR$(72)+CHR$(73)")
      basic("40 POKE $0100,$FF")
      basic("50 GTEXT 10,10,0,1,A$:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "GTEXT ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after GTEXT")
    }

    test("gtext-scaled", "GTEXT with larger scale") {
      basic("10 MODE 3")
      basic("20 GCOLOR 3")
      basic("30 A$=CHR$(65)")
      basic("40 POKE $0100,$FF")
      basic("50 GTEXT 50,50,0,4,A$:POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "GTEXT scaled ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after scaled GTEXT")
    }

    test("mode-boundary-coords", "Drawing at screen boundaries") {
      basic("10 MODE 3")
      basic("20 GCOLOR 1")
      basic("30 PLOT 0,0:PLOT 319,0:PLOT 0,199:PLOT 319,199")
      basic("40 POKE $0100,$AA")
      run()
      assert(peekbyte($0100) == $AA, "boundary PLOTs ran without error")
      assert(peekbyte($A010) == 0, "VGC idle after boundary plots")
    }

    test("fgcolor-register", "Foreground color register via POKE") {
      basic("10 POKE $A002,12")
      run()
      assert(peekbyte($A002) == 12, "fg color set to 12")
    }
  }
}
