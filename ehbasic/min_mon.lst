00E956  2               ; perform SPRITE n, ON/OFF  or  SPRITE n, x, y
00E956  2               ; sprite number 0-15, ON/OFF enables/disables, x,y sets position
00E956  2               ; Uses command-driven VGC interface:
00E956  2               ;   SPRENA ($15): P0=sprite
00E956  2               ;   SPRDIS ($16): P0=sprite
00E956  2               ;   SPRPOS ($14): P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00E956  2               
00E956  2               LAB_SPRCMD
00E956  2  20 00 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00E959  2  86 11              STX   Itempl            ; save sprite number
00E95B  2  20 66 CD           JSR   LAB_1C01          ; require comma
00E95E  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00E961  2  C9 93              CMP   #TK_ON            ; is it ON?
00E963  2  F0 2C              BEQ   @spr_on
00E965  2  C9 CB              CMP   #TK_OFF           ; is it OFF?
00E967  2  F0 36              BEQ   @spr_off
