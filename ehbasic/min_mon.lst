00E82C  2               ; --- Unified DMA controller registers ---
00E82C  2               
00E82C  2               DMA_CMD       = $BA63          ; write triggers transfer
00E82C  2               DMA_STATUS    = $BA64          ; 1=busy, 2=ok, 3=error
00E82C  2               DMA_ERRCODE   = $BA65          ; DMA error code
00E82C  2               DMA_SRCSPACE  = $BA66          ; source space id
00E82C  2               DMA_DSTSPACE  = $BA67          ; destination space id
00E82C  2               DMA_SRCL      = $BA68          ; source addr low
00E82C  2               DMA_SRCM      = $BA69          ; source addr mid
00E82C  2               DMA_SRCH      = $BA6A          ; source addr high
00E82C  2               DMA_DSTL      = $BA6B          ; destination addr low
00E82C  2               DMA_DSTM      = $BA6C          ; destination addr mid
00E82C  2               DMA_DSTH      = $BA6D          ; destination addr high
00E82C  2               DMA_LENL      = $BA6E          ; length low
00E82C  2               DMA_LENM      = $BA6F          ; length mid
00E82C  2               DMA_LENH      = $BA70          ; length high
00E82C  2               DMA_MODE      = $BA71          ; mode flags
00E82C  2               DMA_FILL      = $BA72          ; fill byte (when mode bit0 set)
00E82C  2               DMA_CNTL      = $BA73          ; transferred count low
00E82C  2               DMA_CNTM      = $BA74          ; transferred count mid
00E82C  2               DMA_CNTH      = $BA75          ; transferred count high
00E82C  2               
00E82C  2               DMA_CMD_START = $01
00E82C  2               DMA_BUSY      = $01
00E82C  2               DMA_OK        = $02
00E82C  2               DMA_MODE_FILL = $01
00E82C  2               DMA_SPACE_XRAM = $05
00E82C  2               
00E82C  2               ; --- Blitter controller registers ---
00E82C  2               
00E82C  2               BLT_CMD       = $BA83          ; write triggers blit
00E82C  2               BLT_STATUS    = $BA84          ; 1=busy, 2=ok, 3=error
00E82C  2               BLT_ERRCODE   = $BA85          ; blitter error code
00E82C  2               BLT_SRCSPACE  = $BA86          ; source space id
00E82C  2               BLT_DSTSPACE  = $BA87          ; destination space id
00E82C  2               BLT_SRCL      = $BA88          ; source addr low
00E82C  2               BLT_SRCM      = $BA89          ; source addr mid
00E82C  2               BLT_SRCH      = $BA8A          ; source addr high
00E82C  2               BLT_DSTL      = $BA8B          ; destination addr low
00E82C  2               BLT_DSTM      = $BA8C          ; destination addr mid
00E82C  2               BLT_DSTH      = $BA8D          ; destination addr high
00E82C  2               BLT_WIDTHL    = $BA8E          ; width low
00E82C  2               BLT_WIDTHH    = $BA8F          ; width high
00E82C  2               BLT_HEIGHTL   = $BA90          ; height low
00E82C  2               BLT_HEIGHTH   = $BA91          ; height high
00E82C  2               BLT_SRCSTRL   = $BA92          ; source stride low
00E82C  2               BLT_SRCSTRH   = $BA93          ; source stride high
00E82C  2               BLT_DSTSTRL   = $BA94          ; destination stride low
00E82C  2               BLT_DSTSTRH   = $BA95          ; destination stride high
00E82C  2               BLT_MODE      = $BA96          ; mode flags
00E82C  2               BLT_FILL      = $BA97          ; fill byte (when mode bit0 set)
00E82C  2               BLT_CKEY      = $BA98          ; color key (when mode bit1 set)
00E82C  2               BLT_CNTL      = $BA99          ; written count low
00E82C  2               BLT_CNTM      = $BA9A          ; written count mid
00E82C  2               BLT_CNTH      = $BA9B          ; written count high
00E82C  2               
00E82C  2               BLT_CMD_START = $01
00E82C  2               BLT_BUSY      = $01
00E82C  2               BLT_OK        = $02
00E82C  2               BLT_MODE_FILL = $01
00E82C  2               BLT_SPACE_XRAM = $05
00E82C  2               
00E82C  2               ; --- Tile engine registers ---
00E82C  2               
00E82C  2               TileConfig     = $A0C0
00E82C  2               TileTransColor = $A0C1
00E82C  2               TileScrollXL   = $A0C2
00E82C  2               TileScrollXH   = $A0C3
00E82C  2               TileScrollYL   = $A0C4
00E82C  2               TileScrollYH   = $A0C5
00E82C  2               TileCmd        = $A0C7
00E82C  2               TileP0         = $A0C8
00E82C  2               TileP1         = $A0C9
00E82C  2               TileP2         = $A0CA
00E82C  2               TileP3         = $A0CB
00E82C  2               TileAddrL      = $A0CC
00E82C  2               TileAddrH      = $A0CD
00E82C  2               TilePalP0      = $A0CE
00E82C  2               TilePalP1      = $A0CF
00E82C  2               TileColL       = $A0D0
00E82C  2               TileColH       = $A0D1
00E82C  2               TilePeekVal    = $A0D2
00E82C  2               TilePeekAttr   = $A0D3
00E82C  2               TileCfgSize16  = $01
00E82C  2               TileCmdDef     = $01
00E82C  2               TileCmdDefBulk = $02
00E82C  2               TileCmdPut     = $03
00E82C  2               TileCmdAttr    = $04
00E82C  2               TileCmdFill    = $05
00E82C  2               TileCmdRow     = $06
00E82C  2               TileCmdCol     = $07
00E82C  2               TileCmdLoad    = $08
00E82C  2               TileCmdPal     = $0A
00E82C  2               TileCmdPalC    = $0B
00E82C  2               TileCmdPeek    = $0C
00E82C  2               TileCmdCls     = $0F
00E82C  2               FioCmdTSave    = $16
00E82C  2               FioCmdTLoad    = $17
