00F1DD  2               
00F1DD  2               ; helper: evaluate filename expression and copy into FIO_NAME/FIO_NAMELEN
00F1DD  2               ; on invalid/empty/too-long name, jumps directly to LAB_FIO_ERRIO
00F1DD  2               
00F1DD  2               LAB_FIO_GETNAME
00F1DD  2  20 D9 CC           JSR   LAB_EVEX
00F1E0  2  20 41 D7           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00F1E3  2  85 28              STA   FIO_ARG_NAMELEN
00F1E5  2  A5 71              LDA   ut1_pl
00F1E7  2  85 29              STA   FIO_ARG_NAMEPTR_L
00F1E9  2  A5 72              LDA   ut1_ph
00F1EB  2  85 2A              STA   FIO_ARG_NAMEPTR_H
