00EE7A  2  20 C4 ED           JSR   fio_exec
00EE7D  2  D0 42              BNE   @ld_chk_err
00EE7F  2                     ; check file type — host sets FIO_DIRTYPE after load
00EE7F  2  AD AF B9           LDA   FIO_DIRTYPE
00EE82  2  C9 02              CMP   #$02              ; .bin file?
00EE84  2  F0 1E              BEQ   @ld_bin_ok
00EE86  2                     ; .bas file — update Svarl/Svarh = Smeml + FIO_SIZE
00EE86  2  18                 CLC
00EE87  2  A5 79              LDA   Smeml
00EE89  2  6D A8 B9           ADC   FIO_SIZEL
00EE8C  2  85 7B              STA   Svarl
00EE8E  2  A5 7A              LDA   Smemh
00EE90  2  6D A9 B9           ADC   FIO_SIZEH
00EE93  2  85 7C              STA   Svarh
00EE95  2                     ; reset array/var pointers so LIST works correctly
00EE95  2  A5 7B              LDA   Svarl
00EE97  2  85 7D              STA   Sarryl
00EE99  2  85 7F              STA   Earryl
00EE9B  2  A5 7C              LDA   Svarh
00EE9D  2  85 7E              STA   Sarryh
00EE9F  2  85 80              STA   Earryh
00EEA1  2  4C 74 C1           JMP   LAB_1274          ; print Ready, return to command loop
00EEA4  2               @ld_bin_ok
00EEA4  2                     ; In program mode, silently continue; in immediate mode, print address
00EEA4  2  A5 88              LDA   Clineh
00EEA6  2  C9 FF              CMP   #$FF
00EEA8  2  D0 16              BNE   @ld_bin_done      ; running from a program — just return
00EEAA  2  A9 C4              LDA   #<@s_loaded
00EEAC  2  A0 EE              LDY   #>@s_loaded
00EEAE  2  20 D9 CA           JSR   LAB_18C3          ; print string
00EEB1  2  AD A5 B9           LDA   FIO_SRCH          ; high byte of load address
00EEB4  2  20 63 F3           JSR   LAB_PRHEX
00EEB7  2  AD A4 B9           LDA   FIO_SRCL          ; low byte
00EEBA  2  20 63 F3           JSR   LAB_PRHEX
00EEBD  2  4C 74 C1           JMP   LAB_1274          ; print Ready, return to command loop
00EEC0  2               @ld_bin_done
00EEC0  2  60                 RTS
00EEC1  2               @ld_chk_err
00EEC1  2  4C 79 F3           JMP   LAB_FIO_ERRHND
00EEC4  2  0D 0A 4C 6F  @s_loaded .byte $0D,$0A,"Loaded at $",0
00EEC8  2  61 64 65 64  
