00ECD3  2  0A                 ASL                     ; *4
00ECD4  2  0A                 ASL                     ; *8
00ECD5  2  AA                 TAX                     ; X = sprite * 8
00ECD6  2  BC 42 A0           LDY   $A042,X           ; Y = Y position low byte
00ECD9  2  BD 43 A0           LDA   $A043,X           ; A = Y position high byte
00ECDC  2  4C 20 D4           JMP   LAB_AYFC          ; return AY as signed integer
00ECDF  2               
00ECDF  2               ; perform COLLISION(n) — return sprite-sprite collision register
00ECDF  2               ; argument already consumed by preprocessor
00ECDF  2               
00ECDF  2               LAB_COLLISION
00ECDF  2  A9 00              LDA   #$00              ; high byte = 0
00ECE1  2  AC 0B A0           LDY   VGC_COLLST        ; read collision register
00ECE4  2  4C 20 D4           JMP   LAB_AYFC
00ECE7  2               
00ECE7  2               ; perform BUMPED(n) — return sprite-background collision register
00ECE7  2               
00ECE7  2               LAB_BUMPED
00ECE7  2  A9 00              LDA   #$00
00ECE9  2  AC 0C A0           LDY   VGC_COLLBG
00ECEC  2  4C 20 D4           JMP   LAB_AYFC
