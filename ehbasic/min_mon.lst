00EE8A  2  A9 01              LDA   #$01              ; field offset 1 = X high
00EE8C  2  4C C1 EE           JMP   @c_spr_idx
00EE8F  2               
00EE8F  2               @cs_y
00EE8F  2  20 BC 00           JSR   LAB_IGBY          ; consume Y
00EE92  2  20 C2 00           JSR   LAB_GBYT          ; peek: H or (
00EE95  2  C9 48              CMP   #'H'
00EE97  2  F0 05              BEQ   @cs_yh
00EE99  2  A9 02              LDA   #$02              ; field offset 2 = Y low
00EE9B  2  4C C1 EE           JMP   @c_spr_idx
00EE9E  2               
00EE9E  2               @cs_yh
00EE9E  2  20 BC 00           JSR   LAB_IGBY          ; consume H
00EEA1  2  A9 03              LDA   #$03              ; field offset 3 = Y high
00EEA3  2  4C C1 EE           JMP   @c_spr_idx
00EEA6  2               
00EEA6  2               @cs_shape
00EEA6  2  A2 05              LDX   #5
00EEA8  2  20 92 EC           JSR   LAB_SKIPX          ; SHAPE
00EEAB  2  A9 04              LDA   #$04              ; field offset 4 = Shape
00EEAD  2  4C C1 EE           JMP   @c_spr_idx
00EEB0  2               
00EEB0  2               @cs_flags
