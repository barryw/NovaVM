00E8AD  2                     .include "lib/vgc.s"
00E8AD  3               ; Shared Nova VGC helper routines.
00E8AD  3               ;
00E8AD  3               ; BASIC should parse language syntax and load VGC registers; assembly callers
00E8AD  3               ; can use the same routines directly after setting VGC_P* arguments.
00E8AD  3               
00E8AD  3               .include "vgc.inc"
00E8AD  4               ; Shared Nova VGC helper declarations.
00E8AD  4               ;
00E8AD  4               ; The command helpers use the VGC hardware parameter registers directly:
00E8AD  4               ; callers load VGC_P0..VGC_P14 as needed, then call a vgc_* routine.
00E8AD  4               ; Routines return through the hardware status model; command completion can be
00E8AD  4               ; checked with vgc_wait_cmd when the caller needs a synchronous operation.
00E8AD  4               
00E8AD  4               .ifndef VGC_INC_INCLUDED
00E8AD  4               VGC_INC_INCLUDED = 1
00E8AD  4               
00E8AD  4               .include "nova.inc"
00E8AD  5               ; Shared Nova hardware constants for BASIC, assembly, and runtime libraries.
00E8AD  5               ;
00E8AD  5               ; This include is deliberately guarded per symbol so it can coexist with older
00E8AD  5               ; source files that still define a subset of these names locally.
00E8AD  5               
00E8AD  5               .ifndef NOVA_INC_INCLUDED
00E8AD  5               NOVA_INC_INCLUDED = 1
00E8AD  5               
00E8AD  5               ; Nova pseudo-register mailbox. These bytes are available to callers and
00E8AD  5               ; runtime helpers as ephemeral argument/scratch storage only. A routine may
00E8AD  5               ; clobber them unless its documentation explicitly says otherwise; persistent
00E8AD  5               ; library state must be allocated in a linker segment such as BSS/ZEROPAGE.
00E8AD  5               .ifndef NVR0L
00E8AD  5               NVR0L             = $20
00E8AD  5               .endif
00E8AD  5               .ifndef NVR0H
00E8AD  5               NVR0H             = $21
00E8AD  5               .endif
00E8AD  5               .ifndef NVR1L
00E8AD  5               NVR1L             = $22
00E8AD  5               .endif
00E8AD  5               .ifndef NVR1H
00E8AD  5               NVR1H             = $23
00E8AD  5               .endif
00E8AD  5               .ifndef NVR2L
00E8AD  5               NVR2L             = $24
00E8AD  5               .endif
