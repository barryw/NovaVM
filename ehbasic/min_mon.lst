00E9D5  2  85 11              STA   Itempl            ; save register offset
00E9D7  2  20 66 CD           JSR   LAB_1C01          ; require comma
00E9DA  2  A5 12              LDA   Itemph            ; check field number
00E9DC  2  C9 00              CMP   #$00              ; field 0 = X position?
00E9DE  2  F0 16              BEQ   @word_val
00E9E0  2  C9 02              CMP   #$02              ; field 2 = Y position?
00E9E2  2  F0 12              BEQ   @word_val
