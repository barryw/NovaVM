00ECEB  4               ; @summary MML string length for AUDIO.MUSIC_SEQUENCE.
00ECEB  4               AUDIO_STRLEN     = FIO_NAMELEN
00ECEB  4               
00ECEB  4               .endif
00ECEB  4               
00ECEB  3               
