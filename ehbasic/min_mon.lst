00F18C  2  4C 08 F0           JMP   LAB_EXT_FCER
00F18F  2               
00F18F  2               ; BLITFILL dstSpace,dstAddr,dstStride,width,height,value
00F18F  2               ; Address argument is a 16-bit offset. For XRAM space (5), current XBANK
00F18F  2               ; is used as the high address byte.
00F18F  2               LAB_BLITFILL
00F18F  2  A9 0A              LDA   #EXT_CMD_BLTFILL
00F191  2  4C 08 F0           JMP   LAB_EXT_FCER
