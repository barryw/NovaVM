00EC8F  2               
00EC8F  2               LAB_MIDPLAY
00EC8F  2  20 A9 F2           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EC92  2  A9 00              LDA   #$00
00EC94  2  8D A4 B9           STA   FIO_SRCL            ; no explicit mapping (auto-select)
00EC97  2  A9 13              LDA   #FIO_CMD_MIDPLAY
00EC99  2  4C A2 EC           JMP   LAB_FIO_EXEC       ; issue command, check status, return
00EC9C  2               
