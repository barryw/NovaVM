00EBFB  2  A5 7B              LDA   Svarl
00EBFD  2  85 7D              STA   Sarryl
00EBFF  2  85 7F              STA   Earryl
00EC01  2  A5 7C              LDA   Svarh
00EC03  2  85 7E              STA   Sarryh
00EC05  2  85 80              STA   Earryh
