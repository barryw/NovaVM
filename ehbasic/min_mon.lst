00ECEB  5               ; @summary Low byte of XRAM address argument for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_ADDRL     = NVR0L
00ECEB  5               ; @label FIO.ARG_ADDRM
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_ADDRM
00ECEB  5               ; @summary Middle byte of XRAM address argument for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_ADDRM     = NVR0H
00ECEB  5               ; @label FIO.ARG_ADDRH
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_ADDRH
00ECEB  5               ; @summary High byte of XRAM address argument for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_ADDRH     = NVR1L
00ECEB  5               ; @label FIO.ARG_LENL
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_LENL
00ECEB  5               ; @summary Low byte of transfer length for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_LENL      = NVR3L
00ECEB  5               ; @label FIO.ARG_LENH
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_LENH
00ECEB  5               ; @summary High byte of transfer length for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_LENH      = NVR3H
00ECEB  5               ; @label FIO.ARG_NAMELEN
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_NAMELEN
00ECEB  5               ; @summary Filename length for FIO.COPY_NAME.
00ECEB  5               FIO_ARG_NAMELEN   = NVR4L
00ECEB  5               ; @label FIO.ARG_NAMEPTR_L
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_NAMEPTR_L
00ECEB  5               ; @summary Low byte of filename pointer for FIO.COPY_NAME.
