000000r 2               XTK_TPEEK          = $64              ; TPEEK(nt,x,y) — function
000000r 2               XTK_TPEEKATTR      = $65              ; TPEEKATTR(nt,x,y) — function
000000r 2               XTK_TILECOL        = $66              ; TILECOL — function (no args)
