00EE60  2  A9 01              LDA   #FIO_CMD_SAVE
00EE62  2  20 C4 ED           JSR   fio_exec
00EE65  2  F0 03              BEQ   @sv_ok
00EE67  2  4C 80 F3           JMP   LAB_FIO_ERRIO
00EE6A  2               @sv_ok
00EE6A  2  60                 RTS
00EE6B  2               
00EE6B  2               ; perform LOAD "filename"
00EE6B  2               ; File type is auto-detected by extension:
00EE6B  2               ;   .bas — loaded into BASIC program space, pointers updated
00EE6B  2               ;   .bin — loaded at embedded address (from 2-byte file header)
00EE6B  2               
00EE6B  2               LAB_FLOAD
00EE6B  2  20 4B F3           JSR   LAB_FIO_GETNAME   ; parse filename into FIO_NAME (errors internally)
00EE6E  2                     ; set default load address to BASIC program start
00EE6E  2  A5 79              LDA   Smeml
00EE70  2  8D A4 B9           STA   FIO_SRCL
00EE73  2  A5 7A              LDA   Smemh
00EE75  2  8D A5 B9           STA   FIO_SRCH
