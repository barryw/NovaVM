00EF61  2               @gs_ok
00EF61  2  60                 RTS
00EF62  2               
00EF62  2               ; perform GLOAD "filename", space, offset [,length]
00EF62  2               
00EF62  2               LAB_GLOAD
00EF62  2  20 DD F1           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EF65  2  20 FA CD           JSR   LAB_1C01          ; comma
00EF68  2  20 A2 D8           JSR   LAB_GTBY          ; graphics space id
00EF6B  2  8E AA B9           STX   FIO_GSPACE
00EF6E  2  20 FA CD           JSR   LAB_1C01          ; comma
00EF71  2  20 90 D8           JSR   LAB_GTWRD         ; graphics offset
00EF74  2  A5 AF              LDA   FAC1_3
00EF76  2  8D AB B9           STA   FIO_GADDRL
00EF79  2  A5 AE              LDA   FAC1_2
00EF7B  2  8D AC B9           STA   FIO_GADDRH
00EF7E  2  9C AD B9           STZ   FIO_GLENL         ; default: load full file
00EF81  2  9C AE B9           STZ   FIO_GLENH
00EF84  2  20 C2 00           JSR   LAB_GBYT          ; optional comma,length
00EF87  2  C9 2C              CMP   #','
00EF89  2  D0 10              BNE   @gl_go
00EF8B  2  20 FA CD           JSR   LAB_1C01
00EF8E  2  20 90 D8           JSR   LAB_GTWRD
00EF91  2  A5 AF              LDA   FAC1_3
00EF93  2  8D AD B9           STA   FIO_GLENL
00EF96  2  A5 AE              LDA   FAC1_2
00EF98  2  8D AE B9           STA   FIO_GLENH
00EF9B  2               @gl_go
00EF9B  2  20 69 ED           JSR   fio_gload
00EF9E  2  F0 03              BEQ   @gl_ok
00EFA0  2  4C 0B F2           JMP   LAB_FIO_ERRHND
00EFA3  2               @gl_ok
00EFA3  2  60                 RTS
00EFA4  2               
00EFA4  2               ; parse 16-bit XRAM offset into FIO flat-address registers
00EFA4  2               ; BASIC supplies the high byte through current XBANK.
00EFA4  2               
00EFA4  2               LAB_XFIO_SETOFF
00EFA4  2  20 90 D8           JSR   LAB_GTWRD
00EFA7  2  A5 AF              LDA   FAC1_3
00EFA9  2  8D AB B9           STA   FIO_GADDRL
00EFAC  2  A5 AE              LDA   FAC1_2
00EFAE  2  8D AC B9           STA   FIO_GADDRH
00EFB1  2  AD 0C BA           LDA   XMC_BANK
00EFB4  2  8D AA B9           STA   FIO_GSPACE
00EFB7  2  60                 RTS
00EFB8  2               
00EFB8  2               ; perform XLOAD "filename", offset [,length]
00EFB8  2               
00EFB8  2               LAB_XLOAD
00EFB8  2  20 DD F1           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EFBB  2  20 FA CD           JSR   LAB_1C01          ; comma
00EFBE  2  20 A4 EF           JSR   LAB_XFIO_SETOFF   ; XRAM destination offset + bank
00EFC1  2  9C AD B9           STZ   FIO_GLENL         ; default: load full file
00EFC4  2  9C AE B9           STZ   FIO_GLENH
00EFC7  2  20 C2 00           JSR   LAB_GBYT          ; optional comma,length
00EFCA  2  C9 2C              CMP   #','
00EFCC  2  D0 10              BNE   @xl_go
00EFCE  2  20 FA CD           JSR   LAB_1C01
00EFD1  2  20 90 D8           JSR   LAB_GTWRD
00EFD4  2  A5 AF              LDA   FAC1_3
00EFD6  2  8D AD B9           STA   FIO_GLENL
00EFD9  2  A5 AE              LDA   FAC1_2
00EFDB  2  8D AE B9           STA   FIO_GLENH
00EFDE  2               @xl_go
00EFDE  2  A9 0D              LDA   #EXT_CMD_XLOAD
00EFE0  2  80 1D              BRA   LAB_XFIO_EXEC     ; issue command through shared XRAM runtime
00EFE2  2               
00EFE2  2               ; perform XSAVE "filename", offset, length
00EFE2  2               
00EFE2  2               LAB_XSAVE
00EFE2  2  20 DD F1           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EFE5  2  20 FA CD           JSR   LAB_1C01          ; comma
00EFE8  2  20 A4 EF           JSR   LAB_XFIO_SETOFF   ; XRAM source offset + bank
00EFEB  2  20 FA CD           JSR   LAB_1C01          ; comma
00EFEE  2  20 90 D8           JSR   LAB_GTWRD
00EFF1  2  A5 AF              LDA   FAC1_3
00EFF3  2  8D AD B9           STA   FIO_GLENL
00EFF6  2  A5 AE              LDA   FAC1_2
00EFF8  2  8D AE B9           STA   FIO_GLENH
00EFFB  2  A9 0E              LDA   #EXT_CMD_XSAVE
00EFFD  2  80 00              BRA   LAB_XFIO_EXEC     ; issue command through shared XRAM runtime
00EFFF  2               
00EFFF  2               LAB_XFIO_EXEC
00EFFF  2  20 21 02           JSR   EXT_vec
00F002  2  D0 01              BNE   @xerr
00F004  2  60                 RTS
