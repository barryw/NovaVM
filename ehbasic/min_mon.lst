00E7E2  2               XMC_W3AH      = $BA23          ; window 3 xaddr high
00E7E2  2               XMC_NAME      = $BA24          ; name buffer start
00E7E2  2               XMC_NAME_MAX  = 28             ; bytes in name buffer
00E7E2  2               
