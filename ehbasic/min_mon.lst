00EB87  2               
00EB87  2               ; perform SPRITE n, ON/OFF  or  SPRITE n, x, y
00EB87  2               ; sprite number 0-15, ON/OFF enables/disables, x,y sets position
00EB87  2               ; Uses command-driven VGC interface:
00EB87  2               ;   SPRENA ($15): P0=sprite
00EB87  2               ;   SPRDIS ($16): P0=sprite
00EB87  2               ;   SPRPOS ($14): P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00EB87  2               
00EB87  2               LAB_SPRCMD
00EB87  2  20 A9 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB8A  2  86 11              STX   Itempl            ; save sprite number
00EB8C  2  20 A1 CD           JSR   LAB_1C01          ; require comma
00EB8F  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00EB92  2  C9 93              CMP   #TK_ON            ; is it ON?
00EB94  2  F0 2C              BEQ   @spr_on
00EB96  2  C9 CB              CMP   #TK_OFF           ; is it OFF?
00EB98  2  F0 36              BEQ   @spr_off
00EB9A  2                     ; not ON/OFF — parse x, y position
00EB9A  2  A5 11              LDA   Itempl            ; get sprite number
00EB9C  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EB9F  2  20 A0 D8           JSR   LAB_GTSW          ; get signed x as 16-bit
00EBA2  2  A5 AF              LDA   FAC1_3
00EBA4  2  8D 12 A0           STA   VGC_P1             ; P1 = x low
00EBA7  2  A5 AE              LDA   FAC1_2
00EBA9  2  8D 13 A0           STA   VGC_P2             ; P2 = x high
00EBAC  2  20 A1 CD           JSR   LAB_1C01          ; require comma
00EBAF  2  20 A0 D8           JSR   LAB_GTSW          ; get signed y as 16-bit
00EBB2  2  A5 AF              LDA   FAC1_3
00EBB4  2  8D 14 A0           STA   VGC_P3             ; P3 = y low
00EBB7  2  A5 AE              LDA   FAC1_2
00EBB9  2  8D 15 A0           STA   VGC_P4             ; P4 = y high
00EBBC  2  A9 14              LDA   #VCMD_SPRPOS      ; SPRPOS command
00EBBE  2  8D 10 A0           STA   VGC_CMD            ; trigger
00EBC1  2  60                 RTS
00EBC2  2               
00EBC2  2               @spr_on
00EBC2  2  20 BC 00           JSR   LAB_IGBY          ; consume the ON token
00EBC5  2  A5 11              LDA   Itempl            ; get sprite number
00EBC7  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EBCA  2  A9 15              LDA   #VCMD_SPRENA      ; SPRENA command
00EBCC  2  8D 10 A0           STA   VGC_CMD            ; trigger
00EBCF  2  60                 RTS
00EBD0  2               
00EBD0  2               @spr_off
00EBD0  2  20 BC 00           JSR   LAB_IGBY          ; consume the OFF token
00EBD3  2  A5 11              LDA   Itempl            ; get sprite number
00EBD5  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EBD8  2  A9 16              LDA   #VCMD_SPRDIS      ; SPRDIS command
00EBDA  2  8D 10 A0           STA   VGC_CMD            ; trigger
00EBDD  2  60                 RTS
00EBDE  2               
00EBDE  2               ; perform SPRITESHAPE n, shape
00EBDE  2               ; Writes shape index to sprite register $A044 + n*8
00EBDE  2               
00EBDE  2               LAB_SPRSHAPE
00EBDE  2  20 A9 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EBE1  2  8A                 TXA
00EBE2  2  0A                 ASL                     ; *2
00EBE3  2  0A                 ASL                     ; *4
00EBE4  2  0A                 ASL                     ; *8
00EBE5  2  A8                 TAY                     ; Y = sprite * 8
00EBE6  2  20 A1 CD           JSR   LAB_1C01          ; require comma
00EBE9  2  20 A9 D8           JSR   LAB_GTBY          ; get shape index in X
00EBEC  2  8A                 TXA
00EBED  2  99 44 A0           STA   $A044,Y           ; write to shape register ($A044 + n*8)
00EBF0  2  60                 RTS
00EBF1  2               
00EBF1  2               ; perform SPRITESET sprite, field, value — set sprite register with vblank sync
00EBF1  2               ; Fields 0 (X) and 2 (Y) accept a signed word and write both lo/hi bytes.
00EBF1  2               ; All other fields accept a byte value.
00EBF1  2               ; Waits for vblank before writing to avoid visual glitching.
00EBF1  2               
00EBF1  2               LAB_SPRCOLOR
00EBF1  2  20 A9 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EBF4  2  8A                 TXA
00EBF5  2  0A                 ASL                     ; *2
00EBF6  2  0A                 ASL                     ; *4
00EBF7  2  0A                 ASL                     ; *8
00EBF8  2  85 11              STA   Itempl            ; save base offset (sprite * 8)
00EBFA  2  20 A1 CD           JSR   LAB_1C01          ; require comma
00EBFD  2  20 A9 D8           JSR   LAB_GTBY          ; get field (0-7) in X
00EC00  2  86 12              STX   Itemph            ; save field number
00EC02  2  8A                 TXA
00EC03  2  18                 CLC
00EC04  2  65 11              ADC   Itempl            ; base + field = register offset
00EC06  2  85 11              STA   Itempl            ; save register offset
00EC08  2  20 A1 CD           JSR   LAB_1C01          ; require comma
00EC0B  2  A5 12              LDA   Itemph            ; check field number
00EC0D  2  C9 00              CMP   #$00              ; field 0 = X position?
