00EF4F  2  A5 AE              LDA   FAC1_2
00EF51  2  8D AC B9           STA   FIO_GADDRH
00EF54  2  AD 0C BA           LDA   XMC_BANK
00EF57  2  8D AA B9           STA   FIO_GSPACE
