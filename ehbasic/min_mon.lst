00EEE8  2  A9 01              LDA   #$01              ; default song = 1
00EEEA  2  8D A4 B9           STA   FIO_SRCL
00EEED  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00EEF0  2  C9 2C              CMP   #','
00EEF2  2  D0 09              BNE   @sp_go
00EEF4  2  20 A1 CD           JSR   LAB_1C01          ; consume comma
00EEF7  2  20 A9 D8           JSR   LAB_GTBY          ; evaluate song number → X
00EEFA  2  8E A4 B9           STX   FIO_SRCL
00EEFD  2               @sp_go
00EEFD  2  A9 08              LDA   #FIO_CMD_SIDPLAY
00EEFF  2  20 1D EF           JSR   LAB_FIO_EXEC      ; issue command and check status
00EF02  2  58                 CLI                     ; enable interrupts so timer IRQ can fire
00EF03  2  60                 RTS
00EF04  2               
00EF04  2               ; perform SIDSTOP
00EF04  2               
00EF04  2               LAB_SIDSTOP
00EF04  2  A9 09              LDA   #FIO_CMD_SIDSTOP
00EF06  2  8D A0 B9           STA   FIO_CMD
00EF09  2  60                 RTS
00EF0A  2               
00EF0A  2               ; perform MIDPLAY "filename"
00EF0A  2               ; MIDPLAY "song"  — auto-select 6 busiest MIDI channels
00EF0A  2               
00EF0A  2               LAB_MIDPLAY
00EF0A  2  20 55 F4           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EF0D  2  A9 00              LDA   #$00
00EF0F  2  8D A4 B9           STA   FIO_SRCL            ; no explicit mapping (auto-select)
00EF12  2  A9 13              LDA   #FIO_CMD_MIDPLAY
00EF14  2  4C 1D EF           JMP   LAB_FIO_EXEC       ; issue command, check status, return
00EF17  2               
00EF17  2               ; perform MIDSTOP
00EF17  2               
00EF17  2               LAB_MIDSTOP
00EF17  2  A9 14              LDA   #FIO_CMD_MIDSTOP
00EF19  2  8D A0 B9           STA   FIO_CMD
00EF1C  2  60                 RTS
00EF1D  2               
00EF1D  2               ; common: issue FIO command in A, check status, error on fail
00EF1D  2               
00EF1D  2               LAB_FIO_EXEC
00EF1D  2  8D A0 B9           STA   FIO_CMD
00EF20  2  AD A1 B9           LDA   FIO_STATUS
00EF23  2  C9 02              CMP   #FIO_OK
00EF25  2  D0 01              BNE   @fio_chk_err
00EF27  2  60                 RTS
00EF28  2               @fio_chk_err
00EF28  2  4C 8A F4           JMP   LAB_FIO_ERRHND
00EF2B  2               
00EF2B  2               ; Skip X characters from BASIC input
00EF2B  2               LAB_SKIPX
00EF2B  2  20 BC 00           JSR   LAB_IGBY
00EF2E  2  CA                 DEX
00EF2F  2  D0 FA              BNE   LAB_SKIPX
00EF31  2  60                 RTS
00EF32  2               
00EF32  2               ; perform MUSIC subcommand
00EF32  2               ; MUSIC voice, "mml"
00EF32  2               ; MUSIC PLAY | STOP | TEMPO bpm | LOOP ON|OFF | PRIORITY v1[,v2[,v3]]
00EF32  2               
00EF32  2               LAB_MUSIC
00EF32  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte (after MUSIC token consumed)
00EF35  2  C9 50              CMP   #'P'
00EF37  2  F0 0F              BEQ   @m_chk_p
00EF39  2  C9 92              CMP   #TK_STOP           ; STOP is tokenized by BASIC
00EF3B  2  F0 1E              BEQ   @m_stop_tok
00EF3D  2  C9 54              CMP   #'T'
00EF3F  2  F0 23              BEQ   @m_tempo
00EF41  2  C9 9E              CMP   #TK_LOOP           ; LOOP is tokenized by BASIC
00EF43  2  F0 37              BEQ   @m_loop_tok
00EF45  2                     ; Not a subcommand — must be a number (voice 1-6)
00EF45  2  4C D8 EF           JMP   @m_seq
00EF48  2               
00EF48  2               ; --- MUSIC PLAY or PRIORITY ---
00EF48  2               @m_chk_p
00EF48  2                     ; Consume P, then check next char to distinguish PLAY vs PRIORITY
00EF48  2  20 BC 00           JSR   LAB_IGBY          ; consume P, A = next char
00EF4B  2  C9 52              CMP   #'R'              ; PRIORITY has R after P
00EF4D  2  F0 57              BEQ   @m_priority
00EF4F  2                     ; else PLAY — consume remaining "LAY" (3 chars, P already consumed)
00EF4F  2  A2 03              LDX   #3
00EF51  2  20 2B EF           JSR   LAB_SKIPX          ; LAY
00EF54  2  A9 0E              LDA   #FIO_CMD_MPLAY
00EF56  2  8D A0 B9           STA   FIO_CMD
00EF59  2  58                 CLI                     ; enable interrupts for music
00EF5A  2  60                 RTS
00EF5B  2               
00EF5B  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00EF5B  2               @m_stop_tok
00EF5B  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00EF5E  2  A9 0F              LDA   #FIO_CMD_MSTOP
00EF60  2  8D A0 B9           STA   FIO_CMD
00EF63  2  60                 RTS
00EF64  2               
00EF64  2               ; --- MUSIC TEMPO bpm ---
00EF64  2               @m_tempo
00EF64  2  A2 05              LDX   #5
00EF66  2  20 2B EF           JSR   LAB_SKIPX          ; TEMPO
00EF69  2  20 97 D8           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00EF6C  2  A5 AF              LDA   FAC1_3
00EF6E  2  8D A4 B9           STA   FIO_SRCL
00EF71  2  A5 AE              LDA   FAC1_2
00EF73  2  8D A5 B9           STA   FIO_SRCH
00EF76  2  A9 10              LDA   #FIO_CMD_MTEMPO
00EF78  2  8D A0 B9           STA   FIO_CMD
00EF7B  2  60                 RTS
00EF7C  2               
00EF7C  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00EF7C  2               @m_loop_tok
00EF7C  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00EF7F  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00EF82  2  C9 93              CMP   #TK_ON
00EF84  2  F0 07              BEQ   @m_loop_on
00EF86  2  C9 CB              CMP   #TK_OFF
00EF88  2  F0 0E              BEQ   @m_loop_off
00EF8A  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00EF8D  2               @m_loop_on
00EF8D  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00EF90  2  A9 01              LDA   #$01
00EF92  2  8D A4 B9           STA   FIO_SRCL
00EF95  2  4C A0 EF           JMP   @m_loop_go
00EF98  2               @m_loop_off
00EF98  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00EF9B  2  A9 00              LDA   #$00
00EF9D  2  8D A4 B9           STA   FIO_SRCL
00EFA0  2               @m_loop_go
00EFA0  2  A9 11              LDA   #FIO_CMD_MLOOP
00EFA2  2  8D A0 B9           STA   FIO_CMD
00EFA5  2  60                 RTS
00EFA6  2               
00EFA6  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00EFA6  2               @m_priority
00EFA6  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00EFA6  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00EFA6  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00EFA6  2               @m_pri_skip
00EFA6  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00EFA9  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00EFAB  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00EFAD  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00EFAD  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00EFAD  2                     ; Clear all 6 voice slots
00EFAD  2  A9 00              LDA   #$00
00EFAF  2  A0 05              LDY   #$05
00EFB1  2               @m_pri_clr
00EFB1  2  99 A4 B9           STA   FIO_SRCL,Y
00EFB4  2  88                 DEY
00EFB5  2  10 FA              BPL   @m_pri_clr
00EFB7  2                     ; Parse up to 6 comma-separated voice values
00EFB7  2  A0 00              LDY   #$00              ; slot index
00EFB9  2               @m_pri_nxt
00EFB9  2  20 A9 D8           JSR   LAB_GTBY          ; get voice number → X
00EFBC  2  8A                 TXA
00EFBD  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00EFC0  2  C8                 INY
00EFC1  2  C0 06              CPY   #$06
00EFC3  2  B0 0D              BCS   @m_pri_go         ; all 6 parsed
00EFC5  2  20 C2 00           JSR   LAB_GBYT          ; peek next char
00EFC8  2  C9 2C              CMP   #','
00EFCA  2  D0 06              BNE   @m_pri_go         ; no more commas
00EFCC  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EFCF  2  4C B9 EF           JMP   @m_pri_nxt
00EFD2  2               @m_pri_go
00EFD2  2  A9 12              LDA   #FIO_CMD_MPRI
00EFD4  2  8D A0 B9           STA   FIO_CMD
00EFD7  2  60                 RTS
00EFD8  2               
00EFD8  2               ; --- MUSIC voice, "mml" ---
00EFD8  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00EFD8  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
00EFD8  2               @m_seq
00EFD8  2  20 A9 D8           JSR   LAB_GTBY          ; voice number (1-14) → X
00EFDB  2  8E A4 B9           STX   FIO_SRCL          ; store voice
00EFDE  2  20 A1 CD           JSR   LAB_1C01          ; comma
00EFE1  2  20 7D CC           JSR   LAB_EVEX          ; evaluate expression
00EFE4  2  20 46 D7           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00EFE7  2  AA                 TAX
00EFE8  2  F0 1A              BEQ   @m_seq_err        ; empty string = error
00EFEA  2  8E A3 B9           STX   FIO_NAMELEN       ; string length (1-255)
00EFED  2  A5 71              LDA   ut1_pl
00EFEF  2  8D A6 B9           STA   FIO_ENDL          ; string pointer low
00EFF2  2  A5 72              LDA   ut1_ph
00EFF4  2  8D A7 B9           STA   FIO_ENDH          ; string pointer high
00EFF7  2  A9 0D              LDA   #FIO_CMD_MSEQ
00EFF9  2  8D A0 B9           STA   FIO_CMD
00EFFC  2  AD A1 B9           LDA   FIO_STATUS
00EFFF  2  C9 02              CMP   #FIO_OK
00F001  2  D0 01              BNE   @m_seq_err
00F003  2  60                 RTS
00F004  2               @m_seq_err
00F004  2  4C 91 F4           JMP   LAB_FIO_ERRIO
00F007  2               
00F007  2               ; perform COPPER subcommand
00F007  2               ; COPPER ADD x, y, reg, value
00F007  2               ; COPPER CLEAR | ON | OFF
00F007  2               
00F007  2               LAB_COPPER
00F007  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte
00F00A  2  C9 A2              CMP   #TK_CLEAR
00F00C  2  F0 17              BEQ   @c_clear
00F00E  2  C9 93              CMP   #TK_ON
00F010  2  F0 1C              BEQ   @c_on
00F012  2  C9 CB              CMP   #TK_OFF
00F014  2  F0 21              BEQ   @c_off
00F016  2  C9 41              CMP   #'A'
00F018  2  F0 56              BEQ   @c_add
00F01A  2  C9 A1              CMP   #TK_LIST
00F01C  2  F0 22              BEQ   @c_list
00F01E  2  C9 55              CMP   #'U'
00F020  2  F0 3D              BEQ   @c_use
00F022  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F025  2               
00F025  2               ; --- COPPER CLEAR ---
00F025  2               @c_clear
00F025  2  20 BC 00           JSR   LAB_IGBY          ; consume CLEAR token
00F028  2  A9 1C              LDA   #VCMD_COPPERCLR
00F02A  2  8D 10 A0           STA   VGC_CMD
00F02D  2  60                 RTS
00F02E  2               
00F02E  2               ; --- COPPER ON ---
00F02E  2               @c_on
00F02E  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00F031  2  A9 1D              LDA   #VCMD_COPPERENA
00F033  2  8D 10 A0           STA   VGC_CMD
00F036  2  60                 RTS
00F037  2               
00F037  2               ; --- COPPER OFF ---
00F037  2               @c_off
00F037  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00F03A  2  A9 1E              LDA   #VCMD_COPPERDIS
00F03C  2  8D 10 A0           STA   VGC_CMD
00F03F  2  60                 RTS
00F040  2               
00F040  2               ; --- COPPER LIST n / COPPER LIST END ---
00F040  2               @c_list
00F040  2  20 BC 00           JSR   LAB_IGBY          ; consume LIST token
00F043  2  20 C2 00           JSR   LAB_GBYT          ; peek next
00F046  2  C9 80              CMP   #TK_END
00F048  2  F0 0C              BEQ   @c_list_end
00F04A  2                     ; LIST n — parse list index
00F04A  2  20 A9 D8           JSR   LAB_GTBY          ; 8-bit → X
00F04D  2  8E 11 A0           STX   VGC_P0             ; list index
00F050  2  A9 20              LDA   #VCMD_COPPERLIST
00F052  2  8D 10 A0           STA   VGC_CMD
00F055  2  60                 RTS
00F056  2               
00F056  2               @c_list_end
00F056  2  20 BC 00           JSR   LAB_IGBY          ; consume END token
00F059  2  A9 22              LDA   #VCMD_COPPEREND
00F05B  2  8D 10 A0           STA   VGC_CMD
00F05E  2  60                 RTS
00F05F  2               
00F05F  2               ; --- COPPER USE n ---
00F05F  2               @c_use
00F05F  2  A2 03              LDX   #3
00F061  2  20 2B EF           JSR   LAB_SKIPX          ; USE
00F064  2  20 A9 D8           JSR   LAB_GTBY          ; list index → X
00F067  2  8E 11 A0           STX   VGC_P0
00F06A  2  A9 21              LDA   #VCMD_COPPERUSE
00F06C  2  8D 10 A0           STA   VGC_CMD
00F06F  2  60                 RTS
00F070  2               
00F070  2               ; --- COPPER ADD x, y, reg, value ---
00F070  2               @c_add
00F070  2  A2 03              LDX   #3
00F072  2  20 2B EF           JSR   LAB_SKIPX          ; ADD
00F075  2  20 97 D8           JSR   LAB_GTWRD         ; x (16-bit) → FAC1_3(lo), FAC1_2(hi)
00F078  2  A5 AF              LDA   FAC1_3
00F07A  2  8D 11 A0           STA   VGC_P0             ; x low
00F07D  2  A5 AE              LDA   FAC1_2
00F07F  2  8D 12 A0           STA   VGC_P1             ; x high
00F082  2  20 A1 CD           JSR   LAB_1C01          ; comma
00F085  2  20 A9 D8           JSR   LAB_GTBY          ; y (8-bit) → X
00F088  2  8E 13 A0           STX   VGC_P2             ; y
00F08B  2  20 A1 CD           JSR   LAB_1C01          ; comma
00F08E  2                     ; parse register name: BGCOL, MODE, SCROLLX, SCROLLY,
00F08E  2                     ; SPRX(n), SPRXH(n), SPRY(n), SPRYH(n), SPRSHAPE(n), SPRFLAGS(n), SPRPRI(n)
00F08E  2  20 C2 00           JSR   LAB_GBYT          ; peek
00F091  2  C9 42              CMP   #'B'
00F093  2  F0 0B              BEQ   @c_bgcol
00F095  2  C9 B5              CMP   #TK_GMODE
00F097  2  F0 11              BEQ   @c_mode
00F099  2  C9 53              CMP   #'S'
00F09B  2  F0 15              BEQ   @c_s_dispatch
00F09D  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F0A0  2               
00F0A0  2               @c_bgcol
00F0A0  2  A2 05              LDX   #5
00F0A2  2  20 2B EF           JSR   LAB_SKIPX          ; BGCOL
00F0A5  2  A9 01              LDA   #$01              ; reg index 1 = BGCOL
00F0A7  2  4C E6 F0           JMP   @c_store_idx
00F0AA  2               
00F0AA  2               @c_mode
00F0AA  2  20 BC 00           JSR   LAB_IGBY          ; consume MODE token
00F0AD  2  A9 00              LDA   #$00              ; reg index 0 = MODE
00F0AF  2  4C E6 F0           JMP   @c_store_idx
00F0B2  2               
00F0B2  2               @c_s_dispatch
00F0B2  2  20 BC 00           JSR   LAB_IGBY          ; consume S
00F0B5  2  20 C2 00           JSR   LAB_GBYT          ; peek next: C=scroll, P=sprite
00F0B8  2  C9 43              CMP   #'C'
00F0BA  2  F0 07              BEQ   @c_scroll
00F0BC  2  C9 50              CMP   #'P'
00F0BE  2  F0 31              BEQ   @c_spr
00F0C0  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F0C3  2               
00F0C3  2               @c_scroll
00F0C3  2  A2 05              LDX   #5
00F0C5  2  20 2B EF           JSR   LAB_SKIPX          ; CROLL
00F0C8  2  20 C2 00           JSR   LAB_GBYT          ; peek X or Y
00F0CB  2  C9 58              CMP   #'X'
00F0CD  2  F0 07              BEQ   @c_scrollx
00F0CF  2  C9 59              CMP   #'Y'
00F0D1  2  F0 0B              BEQ   @c_scrolly
00F0D3  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F0D6  2               
00F0D6  2               @c_scrollx
00F0D6  2  20 BC 00           JSR   LAB_IGBY          ; consume X
00F0D9  2  A9 05              LDA   #$05              ; reg index 5 = SCROLLX
00F0DB  2  4C E6 F0           JMP   @c_store_idx
00F0DE  2               
00F0DE  2               @c_scrolly
00F0DE  2  20 BC 00           JSR   LAB_IGBY          ; consume Y
00F0E1  2  A9 06              LDA   #$06              ; reg index 6 = SCROLLY
00F0E3  2  4C E6 F0           JMP   @c_store_idx
00F0E6  2               
00F0E6  2               @c_store_idx
00F0E6  2  8D 14 A0           STA   VGC_P3             ; register index (low byte)
00F0E9  2  A9 00              LDA   #$00
00F0EB  2  8D 15 A0           STA   VGC_P4             ; high byte = 0
00F0EE  2  4C 83 F1           JMP   @c_store_val
00F0F1  2               
00F0F1  2                     ; --- Sprite register names: SPR + field + (n) ---
00F0F1  2                     ; SPRX(n)=$A040+n*8+0, SPRXH(n)=+1, SPRY(n)=+2, SPRYH(n)=+3,
00F0F1  2                     ; SPRSHAPE(n)=+4, SPRFLAGS(n)=+5, SPRPRI(n)=+6
00F0F1  2               @c_spr
00F0F1  2  20 BC 00           JSR   LAB_IGBY          ; consume P
00F0F4  2  20 BC 00           JSR   LAB_IGBY          ; consume R
00F0F7  2  20 C2 00           JSR   LAB_GBYT          ; peek field start: X, Y, S, F, P
00F0FA  2  C9 58              CMP   #'X'
00F0FC  2  F0 13              BEQ   @cs_x
00F0FE  2  C9 59              CMP   #'Y'
00F100  2  F0 26              BEQ   @cs_y
00F102  2  C9 53              CMP   #'S'
00F104  2  F0 39              BEQ   @cs_shape
00F106  2  C9 46              CMP   #'F'
00F108  2  F0 3F              BEQ   @cs_flags
00F10A  2  C9 50              CMP   #'P'
00F10C  2  F0 45              BEQ   @cs_pri
00F10E  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F111  2               
00F111  2               @cs_x
00F111  2  20 BC 00           JSR   LAB_IGBY          ; consume X
00F114  2  20 C2 00           JSR   LAB_GBYT          ; peek: H or (
00F117  2  C9 48              CMP   #'H'
00F119  2  F0 05              BEQ   @cs_xh
00F11B  2  A9 00              LDA   #$00              ; field offset 0 = X low
00F11D  2  4C 5A F1           JMP   @c_spr_idx
00F120  2               
00F120  2               @cs_xh
00F120  2  20 BC 00           JSR   LAB_IGBY          ; consume H
00F123  2  A9 01              LDA   #$01              ; field offset 1 = X high
00F125  2  4C 5A F1           JMP   @c_spr_idx
00F128  2               
00F128  2               @cs_y
00F128  2  20 BC 00           JSR   LAB_IGBY          ; consume Y
00F12B  2  20 C2 00           JSR   LAB_GBYT          ; peek: H or (
00F12E  2  C9 48              CMP   #'H'
00F130  2  F0 05              BEQ   @cs_yh
00F132  2  A9 02              LDA   #$02              ; field offset 2 = Y low
00F134  2  4C 5A F1           JMP   @c_spr_idx
00F137  2               
00F137  2               @cs_yh
00F137  2  20 BC 00           JSR   LAB_IGBY          ; consume H
00F13A  2  A9 03              LDA   #$03              ; field offset 3 = Y high
00F13C  2  4C 5A F1           JMP   @c_spr_idx
00F13F  2               
00F13F  2               @cs_shape
00F13F  2  A2 05              LDX   #5
00F141  2  20 2B EF           JSR   LAB_SKIPX          ; SHAPE
00F144  2  A9 04              LDA   #$04              ; field offset 4 = Shape
00F146  2  4C 5A F1           JMP   @c_spr_idx
00F149  2               
00F149  2               @cs_flags
00F149  2  A2 05              LDX   #5
00F14B  2  20 2B EF           JSR   LAB_SKIPX          ; FLAGS
00F14E  2  A9 05              LDA   #$05              ; field offset 5 = Flags
00F150  2  4C 5A F1           JMP   @c_spr_idx
00F153  2               
00F153  2               @cs_pri
00F153  2  A2 03              LDX   #3
00F155  2  20 2B EF           JSR   LAB_SKIPX          ; PRI
00F158  2  A9 06              LDA   #$06              ; field offset 6 = Priority
00F15A  2                     ; fall through to @c_spr_idx
00F15A  2               
00F15A  2                     ; A = field offset, now parse (n) and compute address $A040 + n*8 + A
