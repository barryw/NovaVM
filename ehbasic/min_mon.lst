00F35A  2  60                 RTS
00F35B  2               
00F35B  2               ; BLITFILL dstSpace,dstAddr,dstStride,width,height,value
00F35B  2               ; Address argument is a 16-bit offset. For XRAM space (5), current XBANK
00F35B  2               ; is used as the high address byte.
00F35B  2               LAB_BLITFILL
00F35B  2                     ; dst space
00F35B  2  20 0F D9           JSR   LAB_GTBY
00F35E  2  8E 87 BA           STX   BLT_DSTSPACE
00F361  2  86 11              STX   Itempl
