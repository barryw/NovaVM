00F720  2               ; character get subroutine for zero page
00F720  2               
00F720  2               ; For a 1.8432MHz 6502 including the JSR and RTS
00F720  2               ; fastest (>=":") =  29 cycles =  15.7uS
00F720  2               ; slowest (<":")  =  40 cycles =  21.7uS
00F720  2               ; space skip      = +21 cycles = +11.4uS
00F720  2               ; inc across page =  +4 cycles =  +2.2uS
00F720  2               
00F720  2               ; the target address for the LDA at LAB_2CF4 becomes the BASIC execute pointer once the
00F720  2               ; block is copied to it's destination, any non zero page address will do at assembly
00F720  2               ; time, to assemble a three byte instruction.
00F720  2               
00F720  2               ; page 0 initialisation table from $BC
00F720  2               ; increment and scan memory
00F720  2               
00F720  2               LAB_2CEE
00F720  2  E6 C3              INC   Bpntrl            ; increment BASIC execute pointer low byte
00F722  2  D0 02              BNE   LAB_2CF4          ; branch if no carry
00F724  2                                             ; else
00F724  2  E6 C4              INC   Bpntrh            ; increment BASIC execute pointer high byte
00F726  2               
00F726  2               ; page 0 initialisation table from $C2
00F726  2               ; scan memory
00F726  2               
00F726  2               LAB_2CF4
00F726  2  AD FF FF           LDA   $FFFF             ; get byte to scan (addr set by call routine)
00F729  2  C9 C2              CMP   #TK_ELSE          ; compare with the token for ELSE
00F72B  2  F0 0E              BEQ   LAB_2D05          ; exit if ELSE, not numeric, carry set
00F72D  2               
00F72D  2  C9 3A              CMP   #':'              ; compare with ":"
00F72F  2  B0 0A              BCS   LAB_2D05          ; exit if >= ":", not numeric, carry set
00F731  2               
00F731  2  C9 20              CMP   #' '              ; compare with " "
00F733  2  F0 EB              BEQ   LAB_2CEE          ; if " " go do next
00F735  2               
00F735  2  38                 SEC                     ; set carry for SBC
00F736  2  E9 30              SBC   #'0'              ; subtract "0"
00F738  2  38                 SEC                     ; set carry for SBC
00F739  2  E9 D0              SBC   #$D0              ; subtract -"0"
00F73B  2                                             ; clear carry if byte = "0"-"9"
