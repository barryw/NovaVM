00F1BB  2  20 78 ED           JSR   fio_rmdir
00F1BE  2  F0 03              BEQ   @rd_ok
00F1C0  2  4C 0B F2           JMP   LAB_FIO_ERRHND
00F1C3  2               @rd_ok
