00E90C  2               
00E90C  2               ; perform SPRITE n, ON/OFF  or  SPRITE n, x, y
00E90C  2               ; sprite number 0-15, ON/OFF enables/disables, x,y sets position
00E90C  2               ; Uses command-driven VGC interface:
00E90C  2               ;   SPRENA ($15): P0=sprite
00E90C  2               ;   SPRDIS ($16): P0=sprite
00E90C  2               ;   SPRPOS ($14): P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00E90C  2               
00E90C  2               LAB_SPRCMD
00E90C  2  20 FE D7           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00E90F  2  86 11              STX   Itempl            ; save sprite number
00E911  2  20 64 CD           JSR   LAB_1C01          ; require comma
00E914  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00E917  2  C9 93              CMP   #TK_ON            ; is it ON?
00E919  2  F0 2C              BEQ   @spr_on
00E91B  2  C9 CB              CMP   #TK_OFF           ; is it OFF?
00E91D  2  F0 36              BEQ   @spr_off
00E91F  2                     ; not ON/OFF — parse x, y position
00E91F  2  A5 11              LDA   Itempl            ; get sprite number
00E921  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00E924  2  20 F5 D7           JSR   LAB_GTSW          ; get signed x as 16-bit
00E927  2  A5 AF              LDA   FAC1_3
00E929  2  8D 12 A0           STA   VGC_P1             ; P1 = x low
00E92C  2  A5 AE              LDA   FAC1_2
00E92E  2  8D 13 A0           STA   VGC_P2             ; P2 = x high
00E931  2  20 64 CD           JSR   LAB_1C01          ; require comma
00E934  2  20 F5 D7           JSR   LAB_GTSW          ; get signed y as 16-bit
00E937  2  A5 AF              LDA   FAC1_3
00E939  2  8D 14 A0           STA   VGC_P3             ; P3 = y low
00E93C  2  A5 AE              LDA   FAC1_2
00E93E  2  8D 15 A0           STA   VGC_P4             ; P4 = y high
00E941  2  A9 14              LDA   #VCMD_SPRPOS      ; SPRPOS command
00E943  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E946  2  60                 RTS
00E947  2               
00E947  2               @spr_on
00E947  2  20 BC 00           JSR   LAB_IGBY          ; consume the ON token
00E94A  2  A5 11              LDA   Itempl            ; get sprite number
00E94C  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00E94F  2  A9 15              LDA   #VCMD_SPRENA      ; SPRENA command
00E951  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E954  2  60                 RTS
00E955  2               
00E955  2               @spr_off
00E955  2  20 BC 00           JSR   LAB_IGBY          ; consume the OFF token
00E958  2  A5 11              LDA   Itempl            ; get sprite number
00E95A  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00E95D  2  A9 16              LDA   #VCMD_SPRDIS      ; SPRDIS command
00E95F  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E962  2  60                 RTS
00E963  2               
00E963  2               ; perform SPRITESHAPE n, shape
00E963  2               ; Writes shape index to sprite register $A044 + n*8
00E963  2               
00E963  2               LAB_SPRSHAPE
00E963  2  20 FE D7           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00E966  2  8A                 TXA
00E967  2  0A                 ASL                     ; *2
00E968  2  0A                 ASL                     ; *4
00E969  2  0A                 ASL                     ; *8
00E96A  2  A8                 TAY                     ; Y = sprite * 8
00E96B  2  20 64 CD           JSR   LAB_1C01          ; require comma
00E96E  2  20 FE D7           JSR   LAB_GTBY          ; get shape index in X
00E971  2  8A                 TXA
00E972  2  99 44 A0           STA   $A044,Y           ; write to shape register ($A044 + n*8)
00E975  2  60                 RTS
00E976  2               
00E976  2               ; perform SPRITESET sprite, field, value — set sprite register with vblank sync
00E976  2               ; Fields 0 (X) and 2 (Y) accept a signed word and write both lo/hi bytes.
00E976  2               ; All other fields accept a byte value.
00E976  2               ; Waits for vblank before writing to avoid visual glitching.
00E976  2               
00E976  2               LAB_SPRCOLOR
00E976  2  20 FE D7           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00E979  2  8A                 TXA
00E97A  2  0A                 ASL                     ; *2
00E97B  2  0A                 ASL                     ; *4
00E97C  2  0A                 ASL                     ; *8
00E97D  2  85 11              STA   Itempl            ; save base offset (sprite * 8)
00E97F  2  20 64 CD           JSR   LAB_1C01          ; require comma
00E982  2  20 FE D7           JSR   LAB_GTBY          ; get field (0-7) in X
00E985  2  86 12              STX   Itemph            ; save field number
00E987  2  8A                 TXA
00E988  2  18                 CLC
00E989  2  65 11              ADC   Itempl            ; base + field = register offset
00E98B  2  85 11              STA   Itempl            ; save register offset
00E98D  2  20 64 CD           JSR   LAB_1C01          ; require comma
00E990  2  A5 12              LDA   Itemph            ; check field number
00E992  2  C9 00              CMP   #$00              ; field 0 = X position?
00E994  2  F0 16              BEQ   @word_val
00E996  2  C9 02              CMP   #$02              ; field 2 = Y position?
00E998  2  F0 12              BEQ   @word_val
00E99A  2                     ; --- byte field: parse byte value ---
00E99A  2  20 FE D7           JSR   LAB_GTBY          ; get value (0-255) in X
00E99D  2  AD 08 A0           LDA   VGC_FRAME         ; wait for vblank
00E9A0  2               @bwait
00E9A0  2  CD 08 A0           CMP   VGC_FRAME
00E9A3  2  F0 FB              BEQ   @bwait
00E9A5  2  A4 11              LDY   Itempl            ; Y = register offset
00E9A7  2  8A                 TXA                     ; A = value
00E9A8  2  99 40 A0           STA   $A040,Y           ; write to sprite register
00E9AB  2  60                 RTS
00E9AC  2               @word_val
00E9AC  2                     ; --- word field (X or Y): parse signed word, write lo+hi ---
00E9AC  2  20 F5 D7           JSR   LAB_GTSW          ; get signed 16-bit value, lo in FAC1_3, hi in FAC1_2
00E9AF  2  AD 08 A0           LDA   VGC_FRAME         ; wait for vblank
00E9B2  2               @wwait
00E9B2  2  CD 08 A0           CMP   VGC_FRAME
00E9B5  2  F0 FB              BEQ   @wwait
00E9B7  2  A4 11              LDY   Itempl            ; Y = register offset (points to lo byte)
00E9B9  2  A5 AF              LDA   FAC1_3            ; low byte
00E9BB  2  99 40 A0           STA   $A040,Y           ; write lo
00E9BE  2  C8                 INY
00E9BF  2  A5 AE              LDA   FAC1_2            ; high byte
00E9C1  2  99 40 A0           STA   $A040,Y           ; write hi
00E9C4  2  60                 RTS
00E9C5  2               
00E9C5  2               ; perform SPRITEDATA sprite, row, b1, b2 [, b3 [, b4 [, b5 [, b6 [, b7 [, b8]]]]]]
00E9C5  2               ; Uses CmdSprRow ($11): P0=sprite, P1=row, P2-P9=8 bytes of row data.
00E9C5  2               ; Unprovided bytes are zeroed.
00E9C5  2               
00E9C5  2               LAB_SPRDATA
00E9C5  2  20 FE D7           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00E9C8  2  8E 11 A0           STX   VGC_P0             ; P0 = sprite index
00E9CB  2  20 64 CD           JSR   LAB_1C01          ; comma
00E9CE  2  20 FE D7           JSR   LAB_GTBY          ; get row (0-15) in X
00E9D1  2  8E 12 A0           STX   VGC_P1             ; P1 = row
00E9D4  2                     ; zero all 8 data bytes first
00E9D4  2  A9 00              LDA   #$00
00E9D6  2  8D 13 A0           STA   VGC_P2
00E9D9  2  8D 14 A0           STA   VGC_P3
00E9DC  2  8D 15 A0           STA   VGC_P4
00E9DF  2  8D 16 A0           STA   VGC_P5
00E9E2  2  8D 17 A0           STA   VGC_P6
00E9E5  2  8D 18 A0           STA   VGC_P7
00E9E8  2  8D 19 A0           STA   VGC_P8
00E9EB  2  8D 1A A0           STA   VGC_P9
00E9EE  2                     ; parse b1 (required)
00E9EE  2  20 64 CD           JSR   LAB_1C01          ; comma
00E9F1  2  20 FE D7           JSR   LAB_GTBY          ; b1 → X
00E9F4  2  8E 13 A0           STX   VGC_P2
00E9F7  2                     ; parse b2 (required)
00E9F7  2  20 64 CD           JSR   LAB_1C01          ; comma
00E9FA  2  20 FE D7           JSR   LAB_GTBY          ; b2 → X
00E9FD  2  8E 14 A0           STX   VGC_P3
00EA00  2                     ; parse optional b3-b8
00EA00  2  20 C2 00           JSR   LAB_GBYT
00EA03  2  C9 2C              CMP   #','
00EA05  2  D0 59              BNE   @sd_done
00EA07  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EA0A  2  20 FE D7           JSR   LAB_GTBY          ; b3 → X
00EA0D  2  8E 15 A0           STX   VGC_P4
00EA10  2  20 C2 00           JSR   LAB_GBYT
00EA13  2  C9 2C              CMP   #','
00EA15  2  D0 49              BNE   @sd_done
00EA17  2  20 BC 00           JSR   LAB_IGBY
00EA1A  2  20 FE D7           JSR   LAB_GTBY          ; b4 → X
00EA1D  2  8E 16 A0           STX   VGC_P5
00EA20  2  20 C2 00           JSR   LAB_GBYT
00EA23  2  C9 2C              CMP   #','
00EA25  2  D0 39              BNE   @sd_done
00EA27  2  20 BC 00           JSR   LAB_IGBY
00EA2A  2  20 FE D7           JSR   LAB_GTBY          ; b5 → X
00EA2D  2  8E 17 A0           STX   VGC_P6
00EA30  2  20 C2 00           JSR   LAB_GBYT
00EA33  2  C9 2C              CMP   #','
00EA35  2  D0 29              BNE   @sd_done
00EA37  2  20 BC 00           JSR   LAB_IGBY
00EA3A  2  20 FE D7           JSR   LAB_GTBY          ; b6 → X
00EA3D  2  8E 18 A0           STX   VGC_P7
00EA40  2  20 C2 00           JSR   LAB_GBYT
00EA43  2  C9 2C              CMP   #','
00EA45  2  D0 19              BNE   @sd_done
00EA47  2  20 BC 00           JSR   LAB_IGBY
00EA4A  2  20 FE D7           JSR   LAB_GTBY          ; b7 → X
00EA4D  2  8E 19 A0           STX   VGC_P8
00EA50  2  20 C2 00           JSR   LAB_GBYT
00EA53  2  C9 2C              CMP   #','
00EA55  2  D0 09              BNE   @sd_done
00EA57  2  20 BC 00           JSR   LAB_IGBY
00EA5A  2  20 FE D7           JSR   LAB_GTBY          ; b8 → X
00EA5D  2  8E 1A A0           STX   VGC_P9
