00FF65  2               
00FF65  2               AA_end_basic
00FF65  2               
00FF65  1               
00FF65  1               ; put the IRQ and NMI code in RAM so that it can be changed
00FF65  1               
00FF65  1               IRQ_vec     = VEC_SV+2        ; IRQ code vector
00FF65  1               NMI_vec     = IRQ_vec+$0A     ; NMI code vector
00FF65  1               ; EXT_vec defined in basic.asm (= VEC_SV+$16 = $0221)
00FF65  1               EXT_RST     = EXT_vec+$12     ; extension ROM reset recovery in RAM
00FF65  1               
00FF65  1               ; setup for the 6502 simulator environment
00FF65  1               
00FF65  1               IO_AREA     = $F000           ; set I/O area for this monitor
00FF65  1               
00FF65  1               ACIAsimwr   = $A00E           ; VGC CHAROUT
00FF65  1               ACIAsimrd   = $A00F           ; VGC CHARIN
00FF65  1               
00FF65  1               ; --- Data block copied to RAM at boot (vectors + interrupt + extension code) ---
00FF65  1               ; This block is stored in ROM (CODE segment) and copied to VEC_IN at init.
00FF65  1               
00FF65  1               LAB_vec
00FF65  1  D3 FF              .word ACIAin            ; byte in from simulated ACIA
00FF67  1  CF FF              .word ACIAout           ; byte out to simulated ACIA
00FF69  1  82 EB              .word LAB_FLOAD         ; load vector for EhBASIC
00FF6B  1  2A EB              .word LAB_FSAVE         ; save vector for EhBASIC
00FF6D  1               
00FF6D  1               ; EhBASIC IRQ support
00FF6D  1               
00FF6D  1               IRQ_CODE
00FF6D  1  48                 PHA                     ; save A
00FF6E  1  A5 DF              LDA   IrqBase           ; get the IRQ flag byte
00FF70  1  4A                 LSR                     ; shift the set b7 to b6, and on down ...
00FF71  1  05 DF              ORA   IrqBase           ; OR the original back in
00FF73  1  85 DF              STA   IrqBase           ; save the new IRQ flag byte
00FF75  1  68                 PLA                     ; restore A
00FF76  1  40                 RTI
00FF77  1               
00FF77  1               ; EhBASIC NMI support
00FF77  1               
00FF77  1               NMI_CODE
00FF77  1  48                 PHA                     ; save A
00FF78  1  A5 DC              LDA   NmiBase           ; get the NMI flag byte
00FF7A  1  4A                 LSR                     ; shift the set b7 to b6, and on down ...
00FF7B  1  05 DC              ORA   NmiBase           ; OR the original back in
00FF7D  1  85 DC              STA   NmiBase           ; save the new NMI flag byte
00FF7F  1  68                 PLA                     ; restore A
00FF80  1  40                 RTI
00FF81  1               
00FF81  1               ; Extension ROM call trampoline (runs from RAM)
00FF81  1               ; Called with command ID in A. Swaps to extension ROM, calls $C000,
00FF81  1               ; swaps back to BASIC ROM, returns with handler result in A.
00FF81  1               
00FF81  1               EXT_CODE
00FF81  1  85 E4              STA   ExtCmdId          ; save command ID to ZP
00FF83  1  A9 04              LDA   #$04              ; RomSwapExtension
00FF85  1  8D 3F A0           STA   $A03F             ; swap to extension ROM
00FF88  1  20 00 C0           JSR   $C000             ; call extension entry point
00FF8B  1  48                 PHA                     ; save handler return value
00FF8C  1  A9 02              LDA   #$02              ; RomSwapBasic
00FF8E  1  8D 3F A0           STA   $A03F             ; swap back to BASIC ROM
00FF91  1  68                 PLA                     ; restore handler return value
00FF92  1  60                 RTS
00FF93  1               
00FF93  1               ; Extension ROM reset recovery (runs from RAM)
00FF93  1               ; If RESET fires while extension ROM is active, extension ROM's reset
00FF93  1               ; handler jumps here. Swaps back to BASIC ROM and continues reset.
00FF93  1               
00FF93  1               EXT_RESET_CODE
00FF93  1  A9 02              LDA   #$02              ; RomSwapBasic
00FF95  1  8D 3F A0           STA   $A03F             ; swap to BASIC ROM
00FF98  1  4C BD FF           JMP   $FFBD             ; jump to BASIC reset handler (RES_vec)
00FF9B  1               
00FF9B  1               END_CODE
00FF9B  1               
00FF9B  1               ; --- Monitor code (in MONITOR segment at $FFBD) ---
00FF9B  1               
00FF9B  1                     .segment "MONITOR"
00FF9B  1                     .org    $FFBD
00FFBD  1               
00FFBD  1               ; reset vector points here
00FFBD  1               
00FFBD  1               RES_vec
00FFBD  1  D8                 CLD                     ; clear decimal mode
00FFBE  1  A2 FF              LDX   #$FF              ; empty stack
00FFC0  1  9A                 TXS                     ; set the stack
00FFC1  1               
00FFC1  1               ; set up vectors, interrupt code, and extension trampoline — copy to page 2
00FFC1  1               
00FFC1  1  A0 36              LDY   #END_CODE-LAB_vec ; set index/count
00FFC3  1               LAB_stlp
00FFC3  1  B9 64 FF           LDA   LAB_vec-1,Y       ; get byte from ROM data block
00FFC6  1  99 04 02           STA   VEC_IN-1,Y        ; save to RAM
00FFC9  1  88                 DEY                     ; decrement index/count
00FFCA  1  D0 F7              BNE   LAB_stlp          ; loop if more to do
00FFCC  1               
00FFCC  1  4C 00 C0           JMP   LAB_COLD          ; always do EhBASIC cold start
00FFCF  1               
00FFCF  1               ; byte out to simulated ACIA
00FFCF  1               
00FFCF  1               ACIAout
00FFCF  1  8D 0E A0           STA   ACIAsimwr         ; save byte to simulated ACIA
00FFD2  1  60                 RTS
00FFD3  1               
00FFD3  1               ; byte in from simulated ACIA
00FFD3  1               
00FFD3  1               ACIAin
00FFD3  1  AD 0F A0           LDA   ACIAsimrd         ; get byte from simulated ACIA
00FFD6  1  F0 02              BEQ   LAB_nobyw         ; branch if no byte waiting
00FFD8  1               
00FFD8  1  38                 SEC                     ; flag byte received
00FFD9  1  60                 RTS
00FFDA  1               
00FFDA  1               LAB_nobyw
00FFDA  1  18                 CLC                     ; flag no byte received
00FFDB  1  60                 RTS
00FFDC  1               
00FFDC  1               ; system vectors
00FFDC  1               
00FFDC  1                     .segment "VECTORS"
00FFDC  1                     .org    $FFFA
00FFFA  1               
00FFFA  1  17 02              .word NMI_vec           ; NMI vector
00FFFC  1  BD FF              .word RES_vec           ; RESET vector
00FFFE  1  0D 02              .word IRQ_vec           ; IRQ vector
00FFFE  1               
