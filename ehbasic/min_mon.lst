00E8AD  5               ; BASIC SYS register bridge. SYS addr[,A[,X[,Y]]] loads A/X/Y from these
00E8AD  5               ; bytes before jumping and stores A/X/Y back here when the routine returns.
00E8AD  5               ; @label SYS.REGA
00E8AD  5               ; @kind u8
00E8AD  5               ; @symbol SYS_REGA
00E8AD  5               ; @summary Returned A register from the most recent SYS call.
00E8AD  5               .ifndef SYS_REGA
00E8AD  5               SYS_REGA          = $E7
00E8AD  5               .endif
00E8AD  5               ; @label SYS.REGX
00E8AD  5               ; @kind u8
00E8AD  5               ; @symbol SYS_REGX
00E8AD  5               ; @summary Returned X register from the most recent SYS call.
00E8AD  5               .ifndef SYS_REGX
00E8AD  5               SYS_REGX          = $E8
00E8AD  5               .endif
00E8AD  5               ; @label SYS.REGY
00E8AD  5               ; @kind u8
00E8AD  5               ; @symbol SYS_REGY
00E8AD  5               ; @summary Returned Y register from the most recent SYS call.
00E8AD  5               .ifndef SYS_REGY
00E8AD  5               SYS_REGY          = $E9
00E8AD  5               .endif
