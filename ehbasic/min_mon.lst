00E4FA  2  4C 5E D4           JMP   LAB_AYFC          ; save and convert integer AY to FAC1 and return
00E4FD  2               
00E4FD  2               ; perform PI
00E4FD  2               
00E4FD  2               LAB_PI
00E4FD  2  A9 D5              LDA   #<LAB_2C7C        ; set (2*pi) pointer low byte
00E4FF  2  A0 F7              LDY   #>LAB_2C7C        ; set (2*pi) pointer high byte
00E501  2  20 A1 DC           JSR   LAB_UFAC          ; unpack memory (AY) into FAC1
00E504  2  C6 AC              DEC   FAC1_e            ; make result = PI
00E506  2  60                 RTS
00E507  2               
00E507  2               ; perform TWOPI
00E507  2               
00E507  2               LAB_TWOPI
00E507  2  A9 D5              LDA   #<LAB_2C7C        ; set (2*pi) pointer low byte
00E509  2  A0 F7              LDY   #>LAB_2C7C        ; set (2*pi) pointer high byte
00E50B  2  4C A1 DC           JMP   LAB_UFAC          ; unpack memory (AY) into FAC1 and return
00E50E  2               
