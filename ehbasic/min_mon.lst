00EBBC  2  A9 01              LDA   #FIO_CMD_SAVE
00EBBE  2  8D A0 B9           STA   FIO_CMD
00EBC1  2                     ; check status
00EBC1  2  AD A1 B9           LDA   FIO_STATUS
00EBC4  2  C9 02              CMP   #FIO_OK
00EBC6  2  F0 03              BEQ   @sv_ok
00EBC8  2  4C 12 F3           JMP   LAB_FIO_ERRIO
00EBCB  2               @sv_ok
00EBCB  2  60                 RTS
00EBCC  2               
00EBCC  2               ; perform LOAD "filename"
00EBCC  2               ; File type is auto-detected by extension:
00EBCC  2               ;   .bas — loaded into BASIC program space, pointers updated
00EBCC  2               ;   .bin — loaded at embedded address (from 2-byte file header)
00EBCC  2               
00EBCC  2               LAB_FLOAD
