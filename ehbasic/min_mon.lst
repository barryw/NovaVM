00EBCF  2                     ; set default load address to BASIC program start
00EBCF  2  A5 79              LDA   Smeml
00EBD1  2  8D A4 B9           STA   FIO_SRCL
00EBD4  2  A5 7A              LDA   Smemh
00EBD6  2  8D A5 B9           STA   FIO_SRCH
