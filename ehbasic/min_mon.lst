00E7B6  2               ; --- VGC I/O register addresses ---
00E7B6  2               
00E7B6  2               VGC_MODE      = $A000
00E7B6  2               VGC_BGCOL     = $A001
00E7B6  2               VGC_FGCOL     = $A002
00E7B6  2               VGC_CURSX     = $A003
00E7B6  2               VGC_CURSY     = $A004
00E7B6  2               VGC_FONT      = $A007          ; font register
00E7B6  2               VGC_FRAME     = $A008          ; frame counter (read-only, incremented by host)
00E7B6  2               VGC_COLLST    = $A00B          ; sprite-sprite collision (read-only)
00E7B6  2               VGC_COLLBG    = $A00C          ; sprite-background collision (read-only)
00E7B6  2               VGC_BORDER    = $A00D          ; border color
00E7B6  2               VGC_CHAROUT   = $A00E
00E7B6  2               
00E7B6  2               ; --- VGC unified command register and parameters ---
00E7B6  2               
00E7B6  2               VGC_CMD       = $A010          ; command register (write triggers execution)
00E7B6  2               VGC_P0        = $A011          ; parameter 0
00E7B6  2               VGC_P1        = $A012          ; parameter 1
00E7B6  2               VGC_P2        = $A013          ; parameter 2
00E7B6  2               VGC_P3        = $A014          ; parameter 3
00E7B6  2               VGC_P4        = $A015          ; parameter 4
00E7B6  2               VGC_P5        = $A016          ; parameter 5
00E7B6  2               VGC_P6        = $A017          ; parameter 6
00E7B6  2               VGC_P7        = $A018          ; parameter 7
00E7B6  2               VGC_P8        = $A019          ; parameter 8
00E7B6  2               VGC_P9        = $A01A          ; parameter 9
00E7B6  2               
00E7B6  2               ; --- VGC graphics command codes ---
00E7B6  2               
00E7B6  2               VCMD_PLOT     = $01
00E7B6  2               VCMD_UNPLOT   = $02
00E7B6  2               VCMD_LINE     = $03
00E7B6  2               VCMD_CIRCLE   = $04
00E7B6  2               VCMD_RECT     = $05
00E7B6  2               VCMD_FILL     = $06
00E7B6  2               VCMD_GCLS     = $07
00E7B6  2               VCMD_GCOLOR   = $08
00E7B6  2               VCMD_PAINT    = $09
00E7B6  2               
00E7B6  2               ; --- VGC sprite command codes ---
00E7B6  2               
00E7B6  2               VCMD_SPRDEF   = $10            ; P0=sprite, P1=x, P2=y, P3=color
00E7B6  2               VCMD_SPRROW   = $11            ; P0=sprite, P1=row, P2-P9=8 bytes
00E7B6  2               VCMD_SPRCLR   = $12            ; P0=sprite (clears shape data)
00E7B6  2               VCMD_SPRCOPY  = $13            ; P0=src, P1=dest
00E7B6  2               VCMD_SPRPOS   = $14            ; P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00E7B6  2               VCMD_SPRENA   = $15            ; P0=sprite
00E7B6  2               VCMD_SPRDIS   = $16            ; P0=sprite
00E7B6  2               VCMD_SPRFLIP  = $17            ; P0=sprite, P1=flags
00E7B6  2               VCMD_SPRPRI   = $18            ; P0=sprite, P1=priority
00E7B6  2               
00E7B6  2               VCMD_COPPERADD = $1B           ; P0/P1=x, P2=y, P3=reg, P4=0, P5=value
00E7B6  2               VCMD_COPPERCLR = $1C           ; no params
00E7B6  2               VCMD_COPPERENA = $1D           ; no params
00E7B6  2               VCMD_COPPERDIS = $1E           ; no params
00E7B6  2               VCMD_SYSRESET  = $1F           ; full system reset (VGC+SID+music)
00E7B6  2               VCMD_COPPERLIST = $20          ; P0=list index (0-127)
00E7B6  2               VCMD_COPPERUSE = $21           ; P0=list index (0-127)
00E7B6  2               VCMD_COPPEREND = $22           ; reset target to active list
00E7B6  2               
00E7B6  2               ; --- File I/O coprocessor registers ---
00E7B6  2               
00E7B6  2               FIO_CMD       = $B9A0          ; command register (write triggers)
00E7B6  2               FIO_STATUS    = $B9A1          ; status: 0=idle, 2=ok, 3=error
00E7B6  2               FIO_ERRCODE   = $B9A2          ; error: 0=none, 1=not found, 2=io error
00E7B6  2               FIO_NAMELEN   = $B9A3          ; filename length (1-63)
00E7B6  2               FIO_SRCL      = $B9A4          ; source/dest addr low
00E7B6  2               FIO_SRCH      = $B9A5          ; source/dest addr high
00E7B6  2               FIO_ENDL      = $B9A6          ; end addr low (SAVE only)
00E7B6  2               FIO_ENDH      = $B9A7          ; end addr high (SAVE only)
00E7B6  2               FIO_SIZEL     = $B9A8          ; loaded size low (set by host after LOAD)
00E7B6  2               FIO_SIZEH     = $B9A9          ; loaded size high
00E7B6  2               FIO_GSPACE    = $B9AA          ; graphics space selector (0=screen,1=color,2=gfx,3=sprite)
00E7B6  2               FIO_GADDRL    = $B9AB          ; graphics offset low
00E7B6  2               FIO_GADDRH    = $B9AC          ; graphics offset high
00E7B6  2               FIO_GLENL     = $B9AD          ; graphics transfer length low
00E7B6  2               FIO_GLENH     = $B9AE          ; graphics transfer length high
00E7B6  2               FIO_DIRTYPE   = $B9AF          ; dir entry type: 0=BAS, 1=SID, 2=BIN, 3=MID
00E7B6  2               FIO_NAME      = $B9B0          ; filename buffer (64 bytes)
00E7B6  2               
00E7B6  2               META_BASE       = $BAB0          ; metadata string buffer (80 bytes)
00E7B6  2               AUTOBOOT_SKIP = $B9F0          ; C# sets to $FF to skip autoboot
00E7B6  2               
00E7B6  2               FIO_CMD_SAVE  = $01            ; save program
00E7B6  2               FIO_CMD_LOAD  = $02            ; load program
00E7B6  2               FIO_OK        = $02            ; status: success
00E7B6  2               FIO_ERR       = $03            ; status: error
00E7B6  2               FIO_CMD_DIROPEN = $03          ; enumerate *.bas files, populate first entry
00E7B6  2               FIO_CMD_DIRREAD = $04          ; advance to next entry
00E7B6  2               FIO_CMD_DELETE = $05           ; delete a single *.bas file by name
00E7B6  2               FIO_CMD_GSAVE = $06            ; save VGC memory block to *.gfx
00E7B6  2               FIO_CMD_GLOAD = $07            ; load *.gfx into VGC memory block
00E7B6  2               FIO_CMD_SIDPLAY = $08          ; load .sid and start playback
00E7B6  2               FIO_CMD_SIDSTOP = $09          ; stop SID playback
00E7B6  2               FIO_CMD_INSTRUMENT = $0A       ; define instrument preset
00E7B6  2               FIO_CMD_SOUND  = $0B           ; play SFX (note, duration, instrument)
00E7B6  2               FIO_CMD_VOLUME = $0C           ; set master volume
00E7B6  2               FIO_CMD_MSEQ   = $0D           ; set voice MML sequence
00E7B6  2               FIO_CMD_MPLAY  = $0E           ; start music playback
00E7B6  2               FIO_CMD_MSTOP  = $0F           ; stop music playback
00E7B6  2               FIO_CMD_MTEMPO = $10           ; set music tempo (BPM)
00E7B6  2               FIO_CMD_MLOOP  = $11           ; set music loop on/off
00E7B6  2               FIO_CMD_MPRI   = $12           ; set SFX voice steal priority
00E7B6  2               FIO_CMD_MIDPLAY = $13          ; load .mid and start playback
00E7B6  2               FIO_CMD_MIDSTOP = $14          ; stop MIDI playback
00E7B6  2               FIO_CMD_SFLOAD  = $15          ; load soundfont (.sf2)
00E7B6  2               
00E7B6  2               ; --- Extension ROM command IDs (dispatched via EXT_vec trampoline) ---
00E7B6  2               EXT_CMD_NCC     = $00          ; NCC confirmation dialog
00E7B6  2               EXT_CMD_SFLOAD  = $01          ; soundfont load
00E7B6  2               FIO_CMD_CD      = $20              ; change directory
00E7B6  2               FIO_CMD_MKDIR   = $21              ; make directory
00E7B6  2               FIO_CMD_RMDIR   = $22              ; remove directory
00E7B6  2               FIO_CMD_FORMAT  = $23              ; format disk image
00E7B6  2               FIO_CMD_MOUNT   = $24              ; mount disk image
00E7B6  2               FIO_CMD_UNMOUNT = $25              ; unmount device
00E7B6  2               FIO_CMD_PWD     = $26              ; print working directory
00E7B6  2               MUSIC_STATUS   = $BA50         ; bit 0=SFX playing, bit 1=music playing
00E7B6  2               MUSIC_NOTE1    = $BA51         ; voice 1 current MIDI note (0=silent)
00E7B6  2               MUSIC_NOTE2    = $BA52         ; voice 2 current MIDI note
00E7B6  2               MUSIC_NOTE3    = $BA53         ; voice 3 current MIDI note
00E7B6  2               MUSIC_NOTE4    = $BA54         ; voice 4 current MIDI note (SID2)
00E7B6  2               MUSIC_NOTE5    = $BA55         ; voice 5 current MIDI note (SID2)
00E7B6  2               MUSIC_NOTE6    = $BA56         ; voice 6 current MIDI note (SID2)
00E7B6  2               FIO_ERR_EOD   = $03            ; end of directory
00E7B6  2               
00E7B6  2               ; --- XMC expansion memory controller registers ---
00E7B6  2               
00E7B6  2               XMC_CMD       = $BA00          ; command register (write triggers)
00E7B6  2               XMC_STATUS    = $BA01          ; status: 0=idle, 2=ok, 3=error
00E7B6  2               XMC_ERRCODE   = $BA02          ; error: 0=none
00E7B6  2               XMC_CFG       = $BA03          ; config flags (reserved)
00E7B6  2               XMC_XAL       = $BA04          ; expansion addr low
00E7B6  2               XMC_XAM       = $BA05          ; expansion addr mid
00E7B6  2               XMC_XAH       = $BA06          ; expansion addr high
00E7B6  2               XMC_RAML      = $BA07          ; cpu addr low
00E7B6  2               XMC_RAMH      = $BA08          ; cpu addr high
00E7B6  2               XMC_LENL      = $BA09          ; transfer length low
00E7B6  2               XMC_LENH      = $BA0A          ; transfer length high
00E7B6  2               XMC_DATA      = $BA0B          ; data port
00E7B6  2               XMC_BANK      = $BA0C          ; current 64KB bank
00E7B6  2               XMC_BANKS     = $BA0D          ; total banks
00E7B6  2               XMC_USEDL     = $BA0E          ; used pages low (future allocator)
00E7B6  2               XMC_USEDH     = $BA0F          ; used pages high
00E7B6  2               XMC_FREEL     = $BA10          ; free pages low
00E7B6  2               XMC_FREEH     = $BA11          ; free pages high
00E7B6  2               XMC_NAMELEN   = $BA12          ; name length (0-27)
00E7B6  2               XMC_HANDLE    = $BA13          ; block handle
00E7B6  2               XMC_DIRCOUNTL = $BA14          ; named block count low
00E7B6  2               XMC_DIRCOUNTH = $BA15          ; named block count high
00E7B6  2               XMC_WINCTL    = $BA16          ; mapped window enable bits
00E7B6  2               XMC_W0AL      = $BA18          ; window 0 xaddr low
00E7B6  2               XMC_W0AM      = $BA19          ; window 0 xaddr mid
00E7B6  2               XMC_W0AH      = $BA1A          ; window 0 xaddr high
00E7B6  2               XMC_W1AL      = $BA1B          ; window 1 xaddr low
00E7B6  2               XMC_W1AM      = $BA1C          ; window 1 xaddr mid
00E7B6  2               XMC_W1AH      = $BA1D          ; window 1 xaddr high
00E7B6  2               XMC_W2AL      = $BA1E          ; window 2 xaddr low
00E7B6  2               XMC_W2AM      = $BA1F          ; window 2 xaddr mid
00E7B6  2               XMC_W2AH      = $BA20          ; window 2 xaddr high
00E7B6  2               XMC_W3AL      = $BA21          ; window 3 xaddr low
00E7B6  2               XMC_W3AM      = $BA22          ; window 3 xaddr mid
00E7B6  2               XMC_W3AH      = $BA23          ; window 3 xaddr high
00E7B6  2               XMC_NAME      = $BA24          ; name buffer start
00E7B6  2               XMC_NAME_MAX  = 28             ; bytes in name buffer
00E7B6  2               
00E7B6  2               XMC_CMD_GET   = $01            ; read byte at XADDR into XMC_DATA
00E7B6  2               XMC_CMD_PUT   = $02            ; write XMC_DATA to XADDR
00E7B6  2               XMC_CMD_STASH = $03            ; copy RAM -> XRAM
00E7B6  2               XMC_CMD_FETCH = $04            ; copy XRAM -> RAM
00E7B6  2               XMC_CMD_FILL  = $05            ; fill XRAM with XMC_DATA
00E7B6  2               XMC_CMD_STATS = $07            ; refresh stats
00E7B6  2               XMC_CMD_RSTUS = $08            ; clear usage tracking metadata
00E7B6  2               XMC_CMD_REL   = $09            ; mark range as free in usage tracking
00E7B6  2               XMC_CMD_ALLOC = $0A            ; allocate block (len -> xaddr/handle)
00E7B6  2               XMC_CMD_NSTSH = $0B            ; named stash RAM->XRAM
00E7B6  2               XMC_CMD_NFETC = $0C            ; named fetch XRAM->RAM
00E7B6  2               XMC_CMD_NDEL  = $0D            ; named delete
00E7B6  2               XMC_CMD_NDIRO = $0E            ; named dir open
00E7B6  2               XMC_CMD_NDIRR = $0F            ; named dir read
00E7B6  2               XMC_OK        = $02            ; command success status
00E7B6  2               XMC_ERR_NF    = $03            ; not found
00E7B6  2               XMC_ERR_EOD   = $06            ; end of directory
00E7B6  2               
00E7B6  2               ; --- NIC network interface controller registers ---
00E7B6  2               
00E7B6  2               NIC_CMD        = $A100          ; command register (write triggers)
00E7B6  2               NIC_STATUS     = $A101          ; global status
00E7B6  2               NIC_SLOT       = $A102          ; active slot ID (0-3)
00E7B6  2               NIC_RPORTL     = $A108          ; remote port low
00E7B6  2               NIC_RPORTH     = $A109          ; remote port high
00E7B6  2               NIC_LPORTL     = $A10A          ; local port low (for listen)
00E7B6  2               NIC_LPORTH     = $A10B          ; local port high
00E7B6  2               NIC_DMAL       = $A110          ; DMA RAM address low
00E7B6  2               NIC_DMAH       = $A111          ; DMA RAM address high
00E7B6  2               NIC_DMALEN     = $A112          ; DMA length
00E7B6  2               NIC_MSGLEN     = $A113          ; received message length (read-only)
00E7B6  2               NIC_SLOTST0    = $A118          ; slot 0 status
00E7B6  2               NIC_NAMEBUF    = $A120          ; hostname buffer (32 bytes, null-terminated)
00E7B6  2               
00E7B6  2               NIC_CMD_CONNECT    = $01
00E7B6  2               NIC_CMD_DISCONNECT = $02
00E7B6  2               NIC_CMD_SEND       = $03
00E7B6  2               NIC_CMD_RECV       = $04
00E7B6  2               NIC_CMD_LISTEN     = $05
00E7B6  2               NIC_CMD_ACCEPT     = $06
00E7B6  2               
00E7B6  2               NIC_ST_CONNECTED   = $01
00E7B6  2               NIC_ST_DATAREADY   = $02
00E7B6  2               NIC_ST_ERROR       = $08
00E7B6  2               
00E7B6  2               ; --- Unified DMA controller registers ---
00E7B6  2               
00E7B6  2               DMA_CMD       = $BA63          ; write triggers transfer
00E7B6  2               DMA_STATUS    = $BA64          ; 1=busy, 2=ok, 3=error
00E7B6  2               DMA_ERRCODE   = $BA65          ; DMA error code
00E7B6  2               DMA_SRCSPACE  = $BA66          ; source space id
00E7B6  2               DMA_DSTSPACE  = $BA67          ; destination space id
00E7B6  2               DMA_SRCL      = $BA68          ; source addr low
00E7B6  2               DMA_SRCM      = $BA69          ; source addr mid
00E7B6  2               DMA_SRCH      = $BA6A          ; source addr high
00E7B6  2               DMA_DSTL      = $BA6B          ; destination addr low
00E7B6  2               DMA_DSTM      = $BA6C          ; destination addr mid
00E7B6  2               DMA_DSTH      = $BA6D          ; destination addr high
00E7B6  2               DMA_LENL      = $BA6E          ; length low
00E7B6  2               DMA_LENM      = $BA6F          ; length mid
00E7B6  2               DMA_LENH      = $BA70          ; length high
00E7B6  2               DMA_MODE      = $BA71          ; mode flags
00E7B6  2               DMA_FILL      = $BA72          ; fill byte (when mode bit0 set)
00E7B6  2               DMA_CNTL      = $BA73          ; transferred count low
00E7B6  2               DMA_CNTM      = $BA74          ; transferred count mid
00E7B6  2               DMA_CNTH      = $BA75          ; transferred count high
00E7B6  2               
00E7B6  2               DMA_CMD_START = $01
00E7B6  2               DMA_BUSY      = $01
00E7B6  2               DMA_OK        = $02
00E7B6  2               DMA_MODE_FILL = $01
00E7B6  2               DMA_SPACE_XRAM = $05
00E7B6  2               
00E7B6  2               ; --- Blitter controller registers ---
00E7B6  2               
00E7B6  2               BLT_CMD       = $BA83          ; write triggers blit
00E7B6  2               BLT_STATUS    = $BA84          ; 1=busy, 2=ok, 3=error
00E7B6  2               BLT_ERRCODE   = $BA85          ; blitter error code
00E7B6  2               BLT_SRCSPACE  = $BA86          ; source space id
00E7B6  2               BLT_DSTSPACE  = $BA87          ; destination space id
00E7B6  2               BLT_SRCL      = $BA88          ; source addr low
00E7B6  2               BLT_SRCM      = $BA89          ; source addr mid
00E7B6  2               BLT_SRCH      = $BA8A          ; source addr high
00E7B6  2               BLT_DSTL      = $BA8B          ; destination addr low
00E7B6  2               BLT_DSTM      = $BA8C          ; destination addr mid
00E7B6  2               BLT_DSTH      = $BA8D          ; destination addr high
00E7B6  2               BLT_WIDTHL    = $BA8E          ; width low
00E7B6  2               BLT_WIDTHH    = $BA8F          ; width high
00E7B6  2               BLT_HEIGHTL   = $BA90          ; height low
00E7B6  2               BLT_HEIGHTH   = $BA91          ; height high
00E7B6  2               BLT_SRCSTRL   = $BA92          ; source stride low
00E7B6  2               BLT_SRCSTRH   = $BA93          ; source stride high
00E7B6  2               BLT_DSTSTRL   = $BA94          ; destination stride low
00E7B6  2               BLT_DSTSTRH   = $BA95          ; destination stride high
00E7B6  2               BLT_MODE      = $BA96          ; mode flags
00E7B6  2               BLT_FILL      = $BA97          ; fill byte (when mode bit0 set)
00E7B6  2               BLT_CKEY      = $BA98          ; color key (when mode bit1 set)
00E7B6  2               BLT_CNTL      = $BA99          ; written count low
00E7B6  2               BLT_CNTM      = $BA9A          ; written count mid
00E7B6  2               BLT_CNTH      = $BA9B          ; written count high
00E7B6  2               
00E7B6  2               BLT_CMD_START = $01
00E7B6  2               BLT_BUSY      = $01
00E7B6  2               BLT_OK        = $02
00E7B6  2               BLT_MODE_FILL = $01
00E7B6  2               BLT_SPACE_XRAM = $05
00E7B6  2               
00E7B6  2               ; --- VGC command handlers ---
00E7B6  2               
00E7B6  2               ; draw a text-only cold-start splash screen
00E7B6  2               
00E7B6  2               LAB_SPLASH
00E7B6  2  A9 06              LDA   #$06              ; blue background
00E7B8  2  8D 01 A0           STA   VGC_BGCOL
00E7BB  2  A9 01              LDA   #$01              ; white text
00E7BD  2  8D 02 A0           STA   VGC_FGCOL
00E7C0  2  A9 06              LDA   #$06              ; blue border
00E7C2  2  8D 0D A0           STA   VGC_BORDER
00E7C5  2  A9 00              LDA   #$00              ; mode 0: text only
00E7C7  2  8D 00 A0           STA   VGC_MODE
00E7CA  2               
00E7CA  2  A9 0C              LDA   #$0C              ; clear text layer and home cursor
00E7CC  2  20 A8 E7           JSR   V_OUTP
00E7CF  2  A9 21              LDA   #$21              ; centered x for "NovaBASIC v1.0"
00E7D1  2  8D 03 A0           STA   VGC_CURSX
00E7D4  2  85 0E              STA   TPos
00E7D6  2  A9 00              LDA   #$00
00E7D8  2  8D 04 A0           STA   VGC_CURSY
00E7DB  2  A9 02              LDA   #<LAB_BNR1
00E7DD  2  A0 E8              LDY   #>LAB_BNR1
00E7DF  2  20 41 CA           JSR   LAB_18C3
00E7E2  2               
00E7E2  2  A9 1A              LDA   #$1A              ; centered x for "Derived from EhBASIC 2.22p5"
00E7E4  2  8D 03 A0           STA   VGC_CURSX
00E7E7  2  85 0E              STA   TPos
00E7E9  2  A9 02              LDA   #$02              ; one empty row between lines
00E7EB  2  8D 04 A0           STA   VGC_CURSY
00E7EE  2  A9 11              LDA   #<LAB_BNR2
00E7F0  2  A0 E8              LDY   #>LAB_BNR2
00E7F2  2  20 41 CA           JSR   LAB_18C3
00E7F5  2               
00E7F5  2  A9 11              LDA   #$11              ; centered x for "xxxxx BASIC bytes free  xxxK expansion memory"
00E7F7  2  8D 03 A0           STA   VGC_CURSX
00E7FA  2  85 0E              STA   TPos
00E7FC  2  A9 04              LDA   #$04              ; one empty row between lines
00E7FE  2  8D 04 A0           STA   VGC_CURSY
00E801  2  60                 RTS
00E802  2               
00E802  2               LAB_BNR1
00E802  2  4E 6F 76 61        .byte "NovaBASIC v1.0",$00
00E806  2  42 41 53 49  
00E80A  2  43 20 76 31  
00E811  2               LAB_BNR2
00E811  2  44 65 72 69        .byte "Derived from EhBASIC 2.22p5",$00
00E815  2  76 65 64 20  
00E819  2  66 72 6F 6D  
00E82D  2               
00E82D  2               ; perform CLS — clear screen, no arguments
00E82D  2               
00E82D  2               LAB_CLS
00E82D  2  A9 0C              LDA   #$0C              ; form feed character
00E82F  2  8D 0E A0           STA   VGC_CHAROUT       ; write to CHAROUT register
00E832  2  60                 RTS
00E833  2               
00E833  2               ; perform COLOR fg [,bg]
00E833  2               
00E833  2               LAB_COLOR
00E833  2  20 FE D7           JSR   LAB_GTBY          ; get fg color byte in X
00E836  2  8E 02 A0           STX   VGC_FGCOL         ; store foreground color
00E839  2  20 C2 00           JSR   LAB_GBYT          ; peek at current byte
00E83C  2  C9 2C              CMP   #','              ; comma follows?
00E83E  2  D0 09              BNE   @done             ; no, just fg was given
00E840  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E843  2  20 FE D7           JSR   LAB_GTBY          ; get bg color byte in X
00E846  2  8E 01 A0           STX   VGC_BGCOL         ; store background color
00E849  2               @done
00E849  2  60                 RTS
00E84A  2               
00E84A  2               ; perform LOCATE x, y
00E84A  2               
00E84A  2               LAB_LOCATE
00E84A  2  20 FE D7           JSR   LAB_GTBY          ; get x in X
00E84D  2  8E 03 A0           STX   VGC_CURSX         ; store cursor X
00E850  2  20 64 CD           JSR   LAB_1C01          ; require comma
00E853  2  20 FE D7           JSR   LAB_GTBY          ; get y in X
00E856  2  8E 04 A0           STX   VGC_CURSY         ; store cursor Y
00E859  2  60                 RTS
00E85A  2               
00E85A  2               ; perform MODE n
00E85A  2               
00E85A  2               LAB_GMODE
00E85A  2  20 FE D7           JSR   LAB_GTBY          ; get mode byte in X
00E85D  2  8E 00 A0           STX   VGC_MODE          ; store graphics mode
00E860  2  60                 RTS
00E861  2               
00E861  2               ; perform FONT n — select active font slot (0-7)
00E861  2               
00E861  2               LAB_FONT
00E861  2  20 FE D7           JSR   LAB_GTBY          ; get font index byte (0-7) in X
00E864  2  8E 07 A0           STX   VGC_FONT          ; write to $A007
00E867  2  60                 RTS
00E868  2               
00E868  2               ; perform GCLS — clear the graphics bitmap layer
00E868  2               
00E868  2               LAB_GCLS
00E868  2  A9 07              LDA   #VCMD_GCLS        ; GCLS command
00E86A  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E86D  2  60                 RTS
00E86E  2               
00E86E  2               ; perform GCOLOR c — set graphics draw color (0-15)
00E86E  2               
00E86E  2               LAB_GCOLOR
00E86E  2  20 FE D7           JSR   LAB_GTBY          ; get color byte in X
00E871  2  8E 11 A0           STX   VGC_P0             ; color in P0
00E874  2  A9 00              LDA   #$00
00E876  2  8D 12 A0           STA   VGC_P1             ; high byte = 0
00E879  2  A9 08              LDA   #VCMD_GCOLOR      ; GCOLOR command
00E87B  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E87E  2  60                 RTS
00E87F  2               
00E87F  2               ; shared: load x(word),y(byte) into VGC_P0-P3
00E87F  2               
00E87F  2               LAB_VGC_XY
00E87F  2  20 EC D7           JSR   LAB_GTWRD         ; get x as 16-bit
00E882  2  A5 AF              LDA   FAC1_3
00E884  2  8D 11 A0           STA   VGC_P0             ; x low
00E887  2  A5 AE              LDA   FAC1_2
00E889  2  8D 12 A0           STA   VGC_P1             ; x high
00E88C  2  20 64 CD           JSR   LAB_1C01          ; require comma
00E88F  2  20 FE D7           JSR   LAB_GTBY          ; get y as byte
00E892  2  8E 13 A0           STX   VGC_P2             ; y low
00E895  2  A9 00              LDA   #$00
00E897  2  8D 14 A0           STA   VGC_P3             ; y high = 0
00E89A  2  60                 RTS
00E89B  2               
00E89B  2               ; shared: load x0,y0,x1,y1 into VGC_P0-P7
00E89B  2               
00E89B  2               LAB_VGC_XYXY
00E89B  2  20 7F E8           JSR   LAB_VGC_XY        ; x0,y0 → P0-P3
00E89E  2  20 64 CD           JSR   LAB_1C01          ; comma
00E8A1  2  20 EC D7           JSR   LAB_GTWRD         ; x1 as 16-bit
00E8A4  2  A5 AF              LDA   FAC1_3
00E8A6  2  8D 15 A0           STA   VGC_P4             ; x1 low
00E8A9  2  A5 AE              LDA   FAC1_2
00E8AB  2  8D 16 A0           STA   VGC_P5             ; x1 high
00E8AE  2  20 64 CD           JSR   LAB_1C01          ; comma
00E8B1  2  20 FE D7           JSR   LAB_GTBY          ; y1
00E8B4  2  8E 17 A0           STX   VGC_P6             ; y1 low
00E8B7  2  A9 00              LDA   #$00
00E8B9  2  8D 18 A0           STA   VGC_P7             ; y1 high = 0
00E8BC  2  60                 RTS
00E8BD  2               
00E8BD  2               ; perform PLOT x, y
00E8BD  2               
00E8BD  2               LAB_PLOT
00E8BD  2  20 7F E8           JSR   LAB_VGC_XY
00E8C0  2  A9 01              LDA   #VCMD_PLOT        ; PLOT command
00E8C2  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E8C5  2  60                 RTS
00E8C6  2               
00E8C6  2               ; perform UNPLOT x, y
00E8C6  2               
00E8C6  2               LAB_UNPLOT
00E8C6  2  20 7F E8           JSR   LAB_VGC_XY
00E8C9  2  A9 02              LDA   #VCMD_UNPLOT      ; UNPLOT command
00E8CB  2  8D 10 A0           STA   VGC_CMD
00E8CE  2  60                 RTS
00E8CF  2               
00E8CF  2               ; perform LINE x0, y0, x1, y1
00E8CF  2               
00E8CF  2               LAB_GLINE
00E8CF  2  20 9B E8           JSR   LAB_VGC_XYXY
00E8D2  2  A9 03              LDA   #VCMD_LINE        ; LINE command
00E8D4  2  8D 10 A0           STA   VGC_CMD
00E8D7  2  60                 RTS
00E8D8  2               
00E8D8  2               ; perform CIRCLE cx, cy, r
00E8D8  2               
00E8D8  2               LAB_CIRCLE
00E8D8  2  20 7F E8           JSR   LAB_VGC_XY        ; cx,cy → P0-P3
00E8DB  2  20 64 CD           JSR   LAB_1C01          ; comma
00E8DE  2  20 EC D7           JSR   LAB_GTWRD         ; r as 16-bit
00E8E1  2  A5 AF              LDA   FAC1_3
00E8E3  2  8D 15 A0           STA   VGC_P4             ; r low
00E8E6  2  A5 AE              LDA   FAC1_2
00E8E8  2  8D 16 A0           STA   VGC_P5             ; r high
00E8EB  2  A9 04              LDA   #VCMD_CIRCLE      ; CIRCLE command
00E8ED  2  8D 10 A0           STA   VGC_CMD
00E8F0  2  60                 RTS
00E8F1  2               
00E8F1  2               ; perform RECT x0, y0, x1, y1
00E8F1  2               
00E8F1  2               LAB_RECT
00E8F1  2  20 9B E8           JSR   LAB_VGC_XYXY
00E8F4  2  A9 05              LDA   #VCMD_RECT        ; RECT command
00E8F6  2  8D 10 A0           STA   VGC_CMD
00E8F9  2  60                 RTS
00E8FA  2               
00E8FA  2               ; perform FILL x0, y0, x1, y1
00E8FA  2               
00E8FA  2               LAB_FILLRECT
00E8FA  2  20 9B E8           JSR   LAB_VGC_XYXY
00E8FD  2  A9 06              LDA   #VCMD_FILL        ; FILL command
00E8FF  2  8D 10 A0           STA   VGC_CMD
00E902  2  60                 RTS
00E903  2               
00E903  2               ; perform PAINT x, y
00E903  2               
00E903  2               LAB_PAINT
00E903  2  20 7F E8           JSR   LAB_VGC_XY
00E906  2  A9 09              LDA   #VCMD_PAINT       ; PAINT command
00E908  2  8D 10 A0           STA   VGC_CMD
