00F3D9  2               ; character get subroutine for zero page
00F3D9  2               
00F3D9  2               ; For a 1.8432MHz 6502 including the JSR and RTS
00F3D9  2               ; fastest (>=":") =  29 cycles =  15.7uS
00F3D9  2               ; slowest (<":")  =  40 cycles =  21.7uS
00F3D9  2               ; space skip      = +21 cycles = +11.4uS
00F3D9  2               ; inc across page =  +4 cycles =  +2.2uS
00F3D9  2               
00F3D9  2               ; the target address for the LDA at LAB_2CF4 becomes the BASIC execute pointer once the
00F3D9  2               ; block is copied to it's destination, any non zero page address will do at assembly
00F3D9  2               ; time, to assemble a three byte instruction.
00F3D9  2               
00F3D9  2               ; page 0 initialisation table from $BC
00F3D9  2               ; increment and scan memory
00F3D9  2               
00F3D9  2               LAB_2CEE
00F3D9  2  E6 C3              INC   Bpntrl            ; increment BASIC execute pointer low byte
00F3DB  2  D0 02              BNE   LAB_2CF4          ; branch if no carry
00F3DD  2                                             ; else
00F3DD  2  E6 C4              INC   Bpntrh            ; increment BASIC execute pointer high byte
00F3DF  2               
00F3DF  2               ; page 0 initialisation table from $C2
00F3DF  2               ; scan memory
00F3DF  2               
00F3DF  2               LAB_2CF4
00F3DF  2  AD FF FF           LDA   $FFFF             ; get byte to scan (addr set by call routine)
00F3E2  2  C9 C2              CMP   #TK_ELSE          ; compare with the token for ELSE
00F3E4  2  F0 0E              BEQ   LAB_2D05          ; exit if ELSE, not numeric, carry set
00F3E6  2               
00F3E6  2  C9 3A              CMP   #':'              ; compare with ":"
00F3E8  2  B0 0A              BCS   LAB_2D05          ; exit if >= ":", not numeric, carry set
00F3EA  2               
00F3EA  2  C9 20              CMP   #' '              ; compare with " "
00F3EC  2  F0 EB              BEQ   LAB_2CEE          ; if " " go do next
00F3EE  2               
00F3EE  2  38                 SEC                     ; set carry for SBC
00F3EF  2  E9 30              SBC   #'0'              ; subtract "0"
00F3F1  2  38                 SEC                     ; set carry for SBC
00F3F2  2  E9 D0              SBC   #$D0              ; subtract -"0"
00F3F4  2                                             ; clear carry if byte = "0"-"9"
00F3F4  2               LAB_2D05
00F3F4  2  60                 RTS
