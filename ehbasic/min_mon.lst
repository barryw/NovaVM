00EB72  2               ; perform SPRITESHAPE n, shape
00EB72  2               ; Writes shape index to sprite register $A044 + n*8
00EB72  2               
00EB72  2               LAB_SPRSHAPE
00EB72  2  20 A1 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB75  2  8A                 TXA
00EB76  2  0A                 ASL                     ; *2
00EB77  2  0A                 ASL                     ; *4
00EB78  2  0A                 ASL                     ; *8
00EB79  2  A8                 TAY                     ; Y = sprite * 8
00EB7A  2  20 99 CD           JSR   LAB_1C01          ; require comma
00EB7D  2  20 A1 D8           JSR   LAB_GTBY          ; get shape index in X
00EB80  2  8A                 TXA
00EB81  2  99 44 A0           STA   $A044,Y           ; write to shape register ($A044 + n*8)
00EB84  2  60                 RTS
00EB85  2               
00EB85  2               ; perform SPRITESET sprite, field, value — set sprite register with vblank sync
00EB85  2               ; Fields 0 (X) and 2 (Y) accept a signed word and write both lo/hi bytes.
00EB85  2               ; All other fields accept a byte value.
00EB85  2               ; Waits for vblank before writing to avoid visual glitching.
00EB85  2               
00EB85  2               LAB_SPRCOLOR
00EB85  2  20 A1 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB88  2  8A                 TXA
00EB89  2  0A                 ASL                     ; *2
00EB8A  2  0A                 ASL                     ; *4
00EB8B  2  0A                 ASL                     ; *8
00EB8C  2  85 11              STA   Itempl            ; save base offset (sprite * 8)
00EB8E  2  20 99 CD           JSR   LAB_1C01          ; require comma
00EB91  2  20 A1 D8           JSR   LAB_GTBY          ; get field (0-7) in X
00EB94  2  86 12              STX   Itemph            ; save field number
00EB96  2  8A                 TXA
00EB97  2  18                 CLC
00EB98  2  65 11              ADC   Itempl            ; base + field = register offset
00EB9A  2  85 11              STA   Itempl            ; save register offset
00EB9C  2  20 99 CD           JSR   LAB_1C01          ; require comma
00EB9F  2  A5 12              LDA   Itemph            ; check field number
00EBA1  2  C9 00              CMP   #$00              ; field 0 = X position?
00EBA3  2  F0 16              BEQ   @word_val
00EBA5  2  C9 02              CMP   #$02              ; field 2 = Y position?
00EBA7  2  F0 12              BEQ   @word_val
00EBA9  2                     ; --- byte field: parse byte value ---
00EBA9  2  20 A1 D8           JSR   LAB_GTBY          ; get value (0-255) in X
00EBAC  2  AD 08 A0           LDA   VGC_FRAME         ; wait for vblank
00EBAF  2               @bwait
00EBAF  2  CD 08 A0           CMP   VGC_FRAME
00EBB2  2  F0 FB              BEQ   @bwait
00EBB4  2  A4 11              LDY   Itempl            ; Y = register offset
00EBB6  2  8A                 TXA                     ; A = value
00EBB7  2  99 40 A0           STA   $A040,Y           ; write to sprite register
00EBBA  2  60                 RTS
00EBBB  2               @word_val
00EBBB  2                     ; --- word field (X or Y): parse signed word, write lo+hi ---
00EBBB  2  20 98 D8           JSR   LAB_GTSW          ; get signed 16-bit value, lo in FAC1_3, hi in FAC1_2
00EBBE  2  AD 08 A0           LDA   VGC_FRAME         ; wait for vblank
00EBC1  2               @wwait
00EBC1  2  CD 08 A0           CMP   VGC_FRAME
00EBC4  2  F0 FB              BEQ   @wwait
00EBC6  2  A4 11              LDY   Itempl            ; Y = register offset (points to lo byte)
00EBC8  2  A5 AF              LDA   FAC1_3            ; low byte
00EBCA  2  99 40 A0           STA   $A040,Y           ; write lo
00EBCD  2  C8                 INY
00EBCE  2  A5 AE              LDA   FAC1_2            ; high byte
00EBD0  2  99 40 A0           STA   $A040,Y           ; write hi
00EBD3  2  60                 RTS
