00E9A7  2               ; perform SPRITEDATA sprite, row, b1, b2 [, b3 [, b4 [, b5 [, b6 [, b7 [, b8]]]]]]
00E9A7  2               ; Uses CmdSprRow ($11): P0=sprite, P1=row, P2-P9=8 bytes of row data.
00E9A7  2               ; Unprovided bytes are zeroed.
00E9A7  2               
00E9A7  2               LAB_SPRDATA
