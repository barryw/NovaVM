00EDB3  4               
00EDB3  4               FIO_RESULT_OK    = $00
00EDB3  4               FIO_RESULT_ERROR = $01
00EDB3  4               FIO_NAME_LIMIT   = $3F
00EDB3  4               
00EDB3  4               ; Match the XRAM streaming ABI so xram_xload/xram_xsave can call directly.
00EDB3  4               FIO_ARG_ADDRL     = NVR0L
00EDB3  4               FIO_ARG_ADDRM     = NVR0H
00EDB3  4               FIO_ARG_ADDRH     = NVR1L
00EDB3  4               FIO_ARG_LENL      = NVR3L
00EDB3  4               FIO_ARG_LENH      = NVR3H
00EDB3  4               FIO_ARG_NAMELEN   = NVR4L
00EDB3  4               FIO_ARG_NAMEPTR_L = NVR4H
00EDB3  4               FIO_ARG_NAMEPTR_H = NVR5L
00EDB3  4               
00EDB3  4               .endif
00EDB3  4               
00EDB3  3               
00EDB3  3               .ifndef FIO_IMPLEMENTATION_INCLUDED
00EDB3  3               FIO_IMPLEMENTATION_INCLUDED = 1
00EDB3  3               
00EDB3  3                     .segment "CODE"
00EDB3  3               
00EDB3  3                     .export fio_issue
00EDB3  3                     .export fio_check
00EDB3  3                     .export fio_exec
00EDB3  3                     .export fio_copy_name
00EDB3  3                     .export fio_set_io_error
00EDB3  3               .ifndef FIO_NO_STREAMING
00EDB3  3                     .export fio_run
00EDB3  3                     .export fio_prepare_xram_transfer
00EDB3  3               .endif
00EDB3  3               
00EDB3  3               ; Input: A = FIO command. Does not check completion/status.
00EDB3  3               fio_issue:
00EDB3  3  8D A0 B9           STA   FIO_CMD
00EDB6  3  60                 RTS
00EDB7  3               
00EDB7  3               ; Check current FIO_STATUS.
00EDB7  3               fio_check:
00EDB7  3  AD A1 B9           LDA   FIO_STATUS
00EDBA  3  C9 02              CMP   #FIO_OK
00EDBC  3  F0 03              BEQ   @ok
00EDBE  3  A9 01              LDA   #FIO_RESULT_ERROR
00EDC0  3  60                 RTS
00EDC1  3               @ok:
00EDC1  3  A9 00              LDA   #FIO_RESULT_OK
00EDC3  3  60                 RTS
00EDC4  3               
00EDC4  3               ; Input: A = FIO command. Issue and check current status.
00EDC4  3               fio_exec:
00EDC4  3  8D A0 B9           STA   FIO_CMD
00EDC7  3  4C B7 ED           JMP   fio_check
00EDCA  3               
00EDCA  3               ; Mark an argument/host I/O error in the hardware status registers.
00EDCA  3               fio_set_io_error:
00EDCA  3  A9 03              LDA   #FIO_STATUS_ERROR
00EDCC  3  8D A1 B9           STA   FIO_STATUS
00EDCF  3  A9 02              LDA   #FIO_ERR_IO
00EDD1  3  8D A2 B9           STA   FIO_ERRCODE
00EDD4  3  A9 01              LDA   #FIO_RESULT_ERROR
00EDD6  3  60                 RTS
00EDD7  3               
00EDD7  3               ; Copy filename from FIO_ARG_NAMEPTR_L/H into FIO_NAME.
00EDD7  3               fio_copy_name:
00EDD7  3  A5 28              LDA   FIO_ARG_NAMELEN
00EDD9  3  F0 16              BEQ   @bad
00EDDB  3  C9 40              CMP   #FIO_NAME_LIMIT + 1
00EDDD  3  B0 12              BCS   @bad
00EDDF  3  8D A3 B9           STA   FIO_NAMELEN
00EDE2  3  AA                 TAX
00EDE3  3  A0 00              LDY   #$00
00EDE5  3               @copy:
00EDE5  3  B1 29              LDA   (FIO_ARG_NAMEPTR_L),Y
00EDE7  3  99 B0 B9           STA   FIO_NAME,Y
00EDEA  3  C8                 INY
00EDEB  3  CA                 DEX
00EDEC  3  D0 F7              BNE   @copy
00EDEE  3  A9 00              LDA   #FIO_RESULT_OK
00EDF0  3  60                 RTS
00EDF1  3               @bad:
00EDF1  3  4C CA ED           JMP   fio_set_io_error
00EDF4  3               
00EDF4  3               .ifndef FIO_NO_STREAMING
00EDF4  3               ; Input: A = FIO command. Issue, wait for non-idle status, and check it.
00EDF4  3               fio_run:
00EDF4  3                     PHA
00EDF4  3                     STZ   FIO_STATUS
00EDF4  3                     STZ   FIO_ERRCODE
00EDF4  3                     PLA
00EDF4  3                     STA   FIO_CMD
00EDF4  3               @wait:
00EDF4  3                     LDA   FIO_STATUS
00EDF4  3                     BEQ   @wait
00EDF4  3                     JMP   fio_check
00EDF4  3               
00EDF4  3               ; Prepare the FIO hardware registers for XLOAD/XSAVE-style direct XRAM I/O.
00EDF4  3               fio_prepare_xram_transfer:
00EDF4  3                     JSR   fio_copy_name
00EDF4  3                     BNE   @done
00EDF4  3                     LDA   FIO_ARG_ADDRL
00EDF4  3                     STA   FIO_GADDRL
00EDF4  3                     LDA   FIO_ARG_ADDRM
00EDF4  3                     STA   FIO_GADDRH
00EDF4  3                     LDA   FIO_ARG_ADDRH
00EDF4  3                     STA   FIO_GSPACE
00EDF4  3                     LDA   FIO_ARG_LENL
00EDF4  3                     STA   FIO_GLENL
00EDF4  3                     LDA   FIO_ARG_LENH
00EDF4  3                     STA   FIO_GLENH
00EDF4  3                     LDA   #FIO_RESULT_OK
00EDF4  3               @done:
00EDF4  3                     RTS
00EDF4  3               .endif
00EDF4  3               
00EDF4  3               .endif
00EDF4  3               
00EDF4  2               
00EDF4  2               ; WAVE is deprecated — use INSTRUMENT instead
00EDF4  2               
00EDF4  2               LAB_WAVE
00EDF4  2  4C DE C5           JMP   LAB_15D9          ; syntax error
00EDF7  2               
00EDF7  2               ; --- VGC function handlers ---
00EDF7  2               
00EDF7  2               ; perform SPRITEX(n) — return X position of sprite n as unsigned word
00EDF7  2               
00EDF7  2               LAB_SPRITEX
00EDF7  2  20 7D D9           JSR   LAB_F2FX          ; convert FAC1 to integer, low byte in Itempl
00EDFA  2  A6 11              LDX   Itempl            ; get sprite number
00EDFC  2  20 FB E9           JSR   sprite_get_x      ; Y = X low byte, A = X high byte
00EDFF  2  4C D8 D4           JMP   LAB_AYFC          ; return AY as numeric value
00EE02  2               
00EE02  2               ; perform SPRITEY(n) — return Y position of sprite n as unsigned byte
00EE02  2               
00EE02  2               LAB_SPRITEY
00EE02  2  20 7D D9           JSR   LAB_F2FX          ; convert FAC1 to integer, low byte in Itempl
