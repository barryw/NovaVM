00E7E2  2               DMA_DSTSPACE  = $BA67          ; destination space id
00E7E2  2               DMA_SRCL      = $BA68          ; source addr low
00E7E2  2               DMA_SRCM      = $BA69          ; source addr mid
00E7E2  2               DMA_SRCH      = $BA6A          ; source addr high
00E7E2  2               DMA_DSTL      = $BA6B          ; destination addr low
00E7E2  2               DMA_DSTM      = $BA6C          ; destination addr mid
00E7E2  2               DMA_DSTH      = $BA6D          ; destination addr high
00E7E2  2               DMA_LENL      = $BA6E          ; length low
00E7E2  2               DMA_LENM      = $BA6F          ; length mid
00E7E2  2               DMA_LENH      = $BA70          ; length high
00E7E2  2               DMA_MODE      = $BA71          ; mode flags
00E7E2  2               DMA_FILL      = $BA72          ; fill byte (when mode bit0 set)
00E7E2  2               DMA_CNTL      = $BA73          ; transferred count low
00E7E2  2               DMA_CNTM      = $BA74          ; transferred count mid
00E7E2  2               DMA_CNTH      = $BA75          ; transferred count high
00E7E2  2               
