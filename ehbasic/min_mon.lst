00ED54  2  4C 3E ED           JMP   @m_pri_nxt
00ED57  2               @m_pri_go
00ED57  2  A9 12              LDA   #FIO_CMD_MPRI
00ED59  2  8D A0 B9           STA   FIO_CMD
00ED5C  2  60                 RTS
00ED5D  2               
00ED5D  2               ; --- MUSIC voice, "mml" ---
00ED5D  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00ED5D  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
