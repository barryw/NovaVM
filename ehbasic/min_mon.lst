00EE3C  2  20 0D D9           JSR   LAB_GTWRD         ; source address
00EE3F  2  A5 AF              LDA   FAC1_3
00EE41  2  8D A4 B9           STA   FIO_SRCL
00EE44  2  A5 AE              LDA   FAC1_2
00EE46  2  8D A5 B9           STA   FIO_SRCH
00EE49  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EE4C  2  20 0D D9           JSR   LAB_GTWRD         ; length
00EE4F  2  18                 CLC
00EE50  2  AD A4 B9           LDA   FIO_SRCL
00EE53  2  65 AF              ADC   FAC1_3
00EE55  2  8D A6 B9           STA   FIO_ENDL
00EE58  2  AD A5 B9           LDA   FIO_SRCH
00EE5B  2  65 AE              ADC   FAC1_2
00EE5D  2  8D A7 B9           STA   FIO_ENDH
