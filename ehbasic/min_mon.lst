00EC38  2               ; perform GSAVE "filename", space, offset, length
00EC38  2               
00EC38  2               LAB_GSAVE
00EC38  2  20 D6 F2           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EC3B  2  20 66 CD           JSR   LAB_1C01          ; comma
00EC3E  2  20 00 D8           JSR   LAB_GTBY          ; graphics space id
00EC41  2  8E AA B9           STX   FIO_GSPACE
00EC44  2  20 66 CD           JSR   LAB_1C01          ; comma
00EC47  2  20 EE D7           JSR   LAB_GTWRD         ; graphics offset
00EC4A  2  A5 AF              LDA   FAC1_3
00EC4C  2  8D AB B9           STA   FIO_GADDRL
00EC4F  2  A5 AE              LDA   FAC1_2
00EC51  2  8D AC B9           STA   FIO_GADDRH
00EC54  2  20 66 CD           JSR   LAB_1C01          ; comma
00EC57  2  20 EE D7           JSR   LAB_GTWRD         ; graphics length
00EC5A  2  A5 AF              LDA   FAC1_3
00EC5C  2  8D AD B9           STA   FIO_GLENL
00EC5F  2  A5 AE              LDA   FAC1_2
00EC61  2  8D AE B9           STA   FIO_GLENH
00EC64  2  A9 06              LDA   #FIO_CMD_GSAVE
00EC66  2  8D A0 B9           STA   FIO_CMD
00EC69  2  AD A1 B9           LDA   FIO_STATUS
00EC6C  2  C9 02              CMP   #FIO_OK
00EC6E  2  F0 03              BEQ   @gs_ok
00EC70  2  4C 12 F3           JMP   LAB_FIO_ERRIO
00EC73  2               @gs_ok
00EC73  2  60                 RTS
00EC74  2               
00EC74  2               ; perform GLOAD "filename", space, offset [,length]
00EC74  2               
00EC74  2               LAB_GLOAD
00EC74  2  20 D6 F2           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EC77  2  20 66 CD           JSR   LAB_1C01          ; comma
00EC7A  2  20 00 D8           JSR   LAB_GTBY          ; graphics space id
00EC7D  2  8E AA B9           STX   FIO_GSPACE
00EC80  2  20 66 CD           JSR   LAB_1C01          ; comma
00EC83  2  20 EE D7           JSR   LAB_GTWRD         ; graphics offset
00EC86  2  A5 AF              LDA   FAC1_3
00EC88  2  8D AB B9           STA   FIO_GADDRL
00EC8B  2  A5 AE              LDA   FAC1_2
00EC8D  2  8D AC B9           STA   FIO_GADDRH
00EC90  2  A9 00              LDA   #$00              ; default: load full file
00EC92  2  8D AD B9           STA   FIO_GLENL
00EC95  2  8D AE B9           STA   FIO_GLENH
00EC98  2  20 C2 00           JSR   LAB_GBYT          ; optional comma,length
00EC9B  2  C9 2C              CMP   #','
00EC9D  2  D0 10              BNE   @gl_go
00EC9F  2  20 66 CD           JSR   LAB_1C01
00ECA2  2  20 EE D7           JSR   LAB_GTWRD
00ECA5  2  A5 AF              LDA   FAC1_3
00ECA7  2  8D AD B9           STA   FIO_GLENL
00ECAA  2  A5 AE              LDA   FAC1_2
00ECAC  2  8D AE B9           STA   FIO_GLENH
00ECAF  2               @gl_go
00ECAF  2  A9 07              LDA   #FIO_CMD_GLOAD
00ECB1  2  4C EC EC           JMP   LAB_FIO_EXEC      ; issue command, check status, return
00ECB4  2               
00ECB4  2               ; perform SIDPLAY "filename" [, song]
00ECB4  2               
00ECB4  2               LAB_SIDPLAY
00ECB4  2  20 D6 F2           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00ECB7  2  A9 01              LDA   #$01              ; default song = 1
00ECB9  2  8D A4 B9           STA   FIO_SRCL
00ECBC  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00ECBF  2  C9 2C              CMP   #','
00ECC1  2  D0 09              BNE   @sp_go
00ECC3  2  20 66 CD           JSR   LAB_1C01          ; consume comma
00ECC6  2  20 00 D8           JSR   LAB_GTBY          ; evaluate song number → X
00ECC9  2  8E A4 B9           STX   FIO_SRCL
00ECCC  2               @sp_go
00ECCC  2  A9 08              LDA   #FIO_CMD_SIDPLAY
00ECCE  2  20 EC EC           JSR   LAB_FIO_EXEC      ; issue command and check status
00ECD1  2  58                 CLI                     ; enable interrupts so timer IRQ can fire
00ECD2  2  60                 RTS
00ECD3  2               
00ECD3  2               ; perform SIDSTOP
00ECD3  2               
00ECD3  2               LAB_SIDSTOP
00ECD3  2  A9 09              LDA   #FIO_CMD_SIDSTOP
00ECD5  2  8D A0 B9           STA   FIO_CMD
00ECD8  2  60                 RTS
00ECD9  2               
00ECD9  2               ; perform MIDPLAY "filename"
00ECD9  2               ; MIDPLAY "song"  — auto-select 6 busiest MIDI channels
00ECD9  2               
00ECD9  2               LAB_MIDPLAY
00ECD9  2  20 D6 F2           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00ECDC  2  A9 00              LDA   #$00
00ECDE  2  8D A4 B9           STA   FIO_SRCL            ; no explicit mapping (auto-select)
00ECE1  2  A9 13              LDA   #FIO_CMD_MIDPLAY
00ECE3  2  4C EC EC           JMP   LAB_FIO_EXEC       ; issue command, check status, return
00ECE6  2               
00ECE6  2               ; perform MIDSTOP
00ECE6  2               
00ECE6  2               LAB_MIDSTOP
00ECE6  2  A9 14              LDA   #FIO_CMD_MIDSTOP
00ECE8  2  8D A0 B9           STA   FIO_CMD
00ECEB  2  60                 RTS
00ECEC  2               
00ECEC  2               ; common: issue FIO command in A, check status, error on fail
00ECEC  2               
00ECEC  2               LAB_FIO_EXEC
00ECEC  2  8D A0 B9           STA   FIO_CMD
00ECEF  2  AD A1 B9           LDA   FIO_STATUS
00ECF2  2  C9 02              CMP   #FIO_OK
00ECF4  2  D0 01              BNE   @fio_chk_err
00ECF6  2  60                 RTS
00ECF7  2               @fio_chk_err
00ECF7  2  4C 0B F3           JMP   LAB_FIO_ERRHND
00ECFA  2               
00ECFA  2               ; Skip X characters from BASIC input
00ECFA  2               LAB_SKIPX
00ECFA  2  20 BC 00           JSR   LAB_IGBY
00ECFD  2  CA                 DEX
00ECFE  2  D0 FA              BNE   LAB_SKIPX
00ED00  2  60                 RTS
00ED01  2               
00ED01  2               ; perform MUSIC subcommand
00ED01  2               ; MUSIC voice, "mml"
00ED01  2               ; MUSIC PLAY | STOP | TEMPO bpm | LOOP ON|OFF | PRIORITY v1[,v2[,v3]]
00ED01  2               
00ED01  2               LAB_MUSIC
00ED01  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte (after MUSIC token consumed)
00ED04  2  C9 50              CMP   #'P'
00ED06  2  F0 0F              BEQ   @m_chk_p
00ED08  2  C9 92              CMP   #TK_STOP           ; STOP is tokenized by BASIC
00ED0A  2  F0 1E              BEQ   @m_stop_tok
00ED0C  2  C9 54              CMP   #'T'
00ED0E  2  F0 23              BEQ   @m_tempo
00ED10  2  C9 9E              CMP   #TK_LOOP           ; LOOP is tokenized by BASIC
00ED12  2  F0 37              BEQ   @m_loop_tok
00ED14  2                     ; Not a subcommand — must be a number (voice 1-6)
00ED14  2  4C A7 ED           JMP   @m_seq
00ED17  2               
00ED17  2               ; --- MUSIC PLAY or PRIORITY ---
00ED17  2               @m_chk_p
00ED17  2                     ; Consume P, then check next char to distinguish PLAY vs PRIORITY
00ED17  2  20 BC 00           JSR   LAB_IGBY          ; consume P, A = next char
00ED1A  2  C9 52              CMP   #'R'              ; PRIORITY has R after P
00ED1C  2  F0 57              BEQ   @m_priority
00ED1E  2                     ; else PLAY — consume remaining "LAY" (3 chars, P already consumed)
00ED1E  2  A2 03              LDX   #3
00ED20  2  20 FA EC           JSR   LAB_SKIPX          ; LAY
00ED23  2  A9 0E              LDA   #FIO_CMD_MPLAY
00ED25  2  8D A0 B9           STA   FIO_CMD
00ED28  2  58                 CLI                     ; enable interrupts for music
00ED29  2  60                 RTS
00ED2A  2               
00ED2A  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00ED2A  2               @m_stop_tok
00ED2A  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00ED2D  2  A9 0F              LDA   #FIO_CMD_MSTOP
00ED2F  2  8D A0 B9           STA   FIO_CMD
00ED32  2  60                 RTS
00ED33  2               
00ED33  2               ; --- MUSIC TEMPO bpm ---
00ED33  2               @m_tempo
00ED33  2  A2 05              LDX   #5
00ED35  2  20 FA EC           JSR   LAB_SKIPX          ; TEMPO
00ED38  2  20 EE D7           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00ED3B  2  A5 AF              LDA   FAC1_3
00ED3D  2  8D A4 B9           STA   FIO_SRCL
00ED40  2  A5 AE              LDA   FAC1_2
00ED42  2  8D A5 B9           STA   FIO_SRCH
00ED45  2  A9 10              LDA   #FIO_CMD_MTEMPO
00ED47  2  8D A0 B9           STA   FIO_CMD
00ED4A  2  60                 RTS
00ED4B  2               
00ED4B  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00ED4B  2               @m_loop_tok
00ED4B  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00ED4E  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00ED51  2  C9 93              CMP   #TK_ON
00ED53  2  F0 07              BEQ   @m_loop_on
00ED55  2  C9 CB              CMP   #TK_OFF
00ED57  2  F0 0E              BEQ   @m_loop_off
00ED59  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00ED5C  2               @m_loop_on
00ED5C  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00ED5F  2  A9 01              LDA   #$01
00ED61  2  8D A4 B9           STA   FIO_SRCL
00ED64  2  4C 6F ED           JMP   @m_loop_go
00ED67  2               @m_loop_off
00ED67  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00ED6A  2  A9 00              LDA   #$00
00ED6C  2  8D A4 B9           STA   FIO_SRCL
00ED6F  2               @m_loop_go
00ED6F  2  A9 11              LDA   #FIO_CMD_MLOOP
00ED71  2  8D A0 B9           STA   FIO_CMD
00ED74  2  60                 RTS
00ED75  2               
00ED75  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00ED75  2               @m_priority
00ED75  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00ED75  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00ED75  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00ED75  2               @m_pri_skip
00ED75  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00ED78  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00ED7A  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00ED7C  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00ED7C  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00ED7C  2                     ; Clear all 6 voice slots
00ED7C  2  A9 00              LDA   #$00
00ED7E  2  A0 05              LDY   #$05
00ED80  2               @m_pri_clr
00ED80  2  99 A4 B9           STA   FIO_SRCL,Y
00ED83  2  88                 DEY
00ED84  2  10 FA              BPL   @m_pri_clr
00ED86  2                     ; Parse up to 6 comma-separated voice values
00ED86  2  A0 00              LDY   #$00              ; slot index
00ED88  2               @m_pri_nxt
00ED88  2  20 00 D8           JSR   LAB_GTBY          ; get voice number → X
00ED8B  2  8A                 TXA
00ED8C  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00ED8F  2  C8                 INY
00ED90  2  C0 06              CPY   #$06
00ED92  2  B0 0D              BCS   @m_pri_go         ; all 6 parsed
00ED94  2  20 C2 00           JSR   LAB_GBYT          ; peek next char
00ED97  2  C9 2C              CMP   #','
00ED99  2  D0 06              BNE   @m_pri_go         ; no more commas
00ED9B  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00ED9E  2  4C 88 ED           JMP   @m_pri_nxt
00EDA1  2               @m_pri_go
00EDA1  2  A9 12              LDA   #FIO_CMD_MPRI
00EDA3  2  8D A0 B9           STA   FIO_CMD
00EDA6  2  60                 RTS
00EDA7  2               
00EDA7  2               ; --- MUSIC voice, "mml" ---
00EDA7  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00EDA7  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
00EDA7  2               @m_seq
00EDA7  2  20 00 D8           JSR   LAB_GTBY          ; voice number (1-14) → X
00EDAA  2  8E A4 B9           STX   FIO_SRCL          ; store voice
00EDAD  2  20 66 CD           JSR   LAB_1C01          ; comma
00EDB0  2  20 42 CC           JSR   LAB_EVEX          ; evaluate expression
00EDB3  2  20 9D D6           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00EDB6  2  AA                 TAX
00EDB7  2  F0 1A              BEQ   @m_seq_err        ; empty string = error
00EDB9  2  8E A3 B9           STX   FIO_NAMELEN       ; string length (1-255)
00EDBC  2  A5 71              LDA   ut1_pl
00EDBE  2  8D A6 B9           STA   FIO_ENDL          ; string pointer low
00EDC1  2  A5 72              LDA   ut1_ph
00EDC3  2  8D A7 B9           STA   FIO_ENDH          ; string pointer high
00EDC6  2  A9 0D              LDA   #FIO_CMD_MSEQ
00EDC8  2  8D A0 B9           STA   FIO_CMD
00EDCB  2  AD A1 B9           LDA   FIO_STATUS
00EDCE  2  C9 02              CMP   #FIO_OK
00EDD0  2  D0 01              BNE   @m_seq_err
00EDD2  2  60                 RTS
00EDD3  2               @m_seq_err
00EDD3  2  4C 12 F3           JMP   LAB_FIO_ERRIO
00EDD6  2               
00EDD6  2               ; perform COPPER subcommand
00EDD6  2               ; COPPER ADD x, y, reg, value
00EDD6  2               ; COPPER CLEAR | ON | OFF
00EDD6  2               
00EDD6  2               LAB_COPPER
00EDD6  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte
00EDD9  2  C9 A2              CMP   #TK_CLEAR
00EDDB  2  F0 17              BEQ   @c_clear
00EDDD  2  C9 93              CMP   #TK_ON
00EDDF  2  F0 1C              BEQ   @c_on
00EDE1  2  C9 CB              CMP   #TK_OFF
00EDE3  2  F0 21              BEQ   @c_off
00EDE5  2  C9 41              CMP   #'A'
00EDE7  2  F0 56              BEQ   @c_add
00EDE9  2  C9 A1              CMP   #TK_LIST
00EDEB  2  F0 22              BEQ   @c_list
00EDED  2  C9 55              CMP   #'U'
00EDEF  2  F0 3D              BEQ   @c_use
00EDF1  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EDF4  2               
00EDF4  2               ; --- COPPER CLEAR ---
00EDF4  2               @c_clear
00EDF4  2  20 BC 00           JSR   LAB_IGBY          ; consume CLEAR token
00EDF7  2  A9 1C              LDA   #VCMD_COPPERCLR
00EDF9  2  8D 10 A0           STA   VGC_CMD
00EDFC  2  60                 RTS
00EDFD  2               
00EDFD  2               ; --- COPPER ON ---
00EDFD  2               @c_on
00EDFD  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00EE00  2  A9 1D              LDA   #VCMD_COPPERENA
00EE02  2  8D 10 A0           STA   VGC_CMD
00EE05  2  60                 RTS
00EE06  2               
00EE06  2               ; --- COPPER OFF ---
00EE06  2               @c_off
00EE06  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00EE09  2  A9 1E              LDA   #VCMD_COPPERDIS
00EE0B  2  8D 10 A0           STA   VGC_CMD
00EE0E  2  60                 RTS
00EE0F  2               
00EE0F  2               ; --- COPPER LIST n / COPPER LIST END ---
00EE0F  2               @c_list
00EE0F  2  20 BC 00           JSR   LAB_IGBY          ; consume LIST token
00EE12  2  20 C2 00           JSR   LAB_GBYT          ; peek next
00EE15  2  C9 80              CMP   #TK_END
00EE17  2  F0 0C              BEQ   @c_list_end
00EE19  2                     ; LIST n — parse list index
00EE19  2  20 00 D8           JSR   LAB_GTBY          ; 8-bit → X
00EE1C  2  8E 11 A0           STX   VGC_P0             ; list index
00EE1F  2  A9 20              LDA   #VCMD_COPPERLIST
00EE21  2  8D 10 A0           STA   VGC_CMD
