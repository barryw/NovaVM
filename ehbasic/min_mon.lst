00E82C  2               NIC_RPORTL     = $A108          ; remote port low
00E82C  2               NIC_RPORTH     = $A109          ; remote port high
00E82C  2               NIC_LPORTL     = $A10A          ; local port low (for listen)
00E82C  2               NIC_LPORTH     = $A10B          ; local port high
00E82C  2               NIC_DMAL       = $A110          ; DMA RAM address low
00E82C  2               NIC_DMAH       = $A111          ; DMA RAM address high
00E82C  2               NIC_DMALEN     = $A112          ; DMA length
00E82C  2               NIC_MSGLEN     = $A113          ; received message length (read-only)
00E82C  2               NIC_SLOTST0    = $A118          ; slot 0 status
00E82C  2               NIC_NAMEBUF    = $A120          ; hostname buffer (32 bytes, null-terminated)
00E82C  2               
