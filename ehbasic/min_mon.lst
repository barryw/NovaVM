00E530  2               
00E530  2               LAB_VARPTR
00E530  2  20 BC 00           JSR   LAB_IGBY          ; increment and scan memory
00E533  2  20 06 D1           JSR   LAB_GVAR          ; get var address
00E536  2  20 57 CD           JSR   LAB_1BFB          ; scan for ")" , else do syntax error then warm start
00E539  2  A4 95              LDY   Cvaral            ; get var address low byte
00E53B  2  A5 96              LDA   Cvarah            ; get var address high byte
00E53D  2  4C B5 D3           JMP   LAB_AYFC          ; save and convert integer AY to FAC1 and return
00E540  2               
00E540  2               ; perform PI
00E540  2               
00E540  2               LAB_PI
00E540  2  A9 56              LDA   #<LAB_2C7C        ; set (2*pi) pointer low byte
00E542  2  A0 F6              LDY   #>LAB_2C7C        ; set (2*pi) pointer high byte
00E544  2  20 F8 DB           JSR   LAB_UFAC          ; unpack memory (AY) into FAC1
00E547  2  C6 AC              DEC   FAC1_e            ; make result = PI
00E549  2  60                 RTS
00E54A  2               
00E54A  2               ; perform TWOPI
00E54A  2               
00E54A  2               LAB_TWOPI
00E54A  2  A9 56              LDA   #<LAB_2C7C        ; set (2*pi) pointer low byte
00E54C  2  A0 F6              LDY   #>LAB_2C7C        ; set (2*pi) pointer high byte
00E54E  2  4C F8 DB           JMP   LAB_UFAC          ; unpack memory (AY) into FAC1 and return
