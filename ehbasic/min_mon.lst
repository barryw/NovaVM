00EAFF  2  BC 40 A0           LDY   $A040,X           ; Y = X position low byte
00EB02  2  BD 41 A0           LDA   $A041,X           ; A = X position high byte
00EB05  2  4C B3 D3           JMP   LAB_AYFC          ; return AY as signed integer
00EB08  2               
00EB08  2               ; perform SPRITEY(n) — return Y position of sprite n as signed word
00EB08  2               
