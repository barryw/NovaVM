00E97E  2  20 F7 D7           JSR   LAB_GTSW          ; get signed y as 16-bit
00E981  2  A5 AF              LDA   FAC1_3
00E983  2  8D 14 A0           STA   VGC_P3             ; P3 = y low
00E986  2  A5 AE              LDA   FAC1_2
00E988  2  8D 15 A0           STA   VGC_P4             ; P4 = y high
00E98B  2  A9 14              LDA   #VCMD_SPRPOS      ; SPRPOS command
00E98D  2  8D 10 A0           STA   VGC_CMD            ; trigger
