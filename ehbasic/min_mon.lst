00EEC6  2               
00EEC6  2               LAB_MUSIC
00EEC6  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte (after MUSIC token consumed)
00EEC9  2  C9 50              CMP   #'P'
00EECB  2  F0 0F              BEQ   @m_chk_p
00EECD  2  C9 92              CMP   #TK_STOP           ; STOP is tokenized by BASIC
00EECF  2  F0 1E              BEQ   @m_stop_tok
00EED1  2  C9 54              CMP   #'T'
00EED3  2  F0 23              BEQ   @m_tempo
00EED5  2  C9 9E              CMP   #TK_LOOP           ; LOOP is tokenized by BASIC
00EED7  2  F0 37              BEQ   @m_loop_tok
00EED9  2                     ; Not a subcommand — must be a number (voice 1-6)
00EED9  2  4C 6C EF           JMP   @m_seq
00EEDC  2               
00EEDC  2               ; --- MUSIC PLAY or PRIORITY ---
00EEDC  2               @m_chk_p
00EEDC  2                     ; Consume P, then check next char to distinguish PLAY vs PRIORITY
00EEDC  2  20 BC 00           JSR   LAB_IGBY          ; consume P, A = next char
00EEDF  2  C9 52              CMP   #'R'              ; PRIORITY has R after P
00EEE1  2  F0 57              BEQ   @m_priority
00EEE3  2                     ; else PLAY — consume remaining "LAY" (3 chars, P already consumed)
00EEE3  2  A2 03              LDX   #3
00EEE5  2  20 BF EE           JSR   LAB_SKIPX          ; LAY
00EEE8  2  A9 0E              LDA   #FIO_CMD_MPLAY
00EEEA  2  8D A0 B9           STA   FIO_CMD
00EEED  2  58                 CLI                     ; enable interrupts for music
00EEEE  2  60                 RTS
00EEEF  2               
00EEEF  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00EEEF  2               @m_stop_tok
00EEEF  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00EEF2  2  A9 0F              LDA   #FIO_CMD_MSTOP
00EEF4  2  8D A0 B9           STA   FIO_CMD
00EEF7  2  60                 RTS
00EEF8  2               
00EEF8  2               ; --- MUSIC TEMPO bpm ---
00EEF8  2               @m_tempo
00EEF8  2  A2 05              LDX   #5
00EEFA  2  20 BF EE           JSR   LAB_SKIPX          ; TEMPO
00EEFD  2  20 8F D8           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00EF00  2  A5 AF              LDA   FAC1_3
00EF02  2  8D A4 B9           STA   FIO_SRCL
00EF05  2  A5 AE              LDA   FAC1_2
00EF07  2  8D A5 B9           STA   FIO_SRCH
00EF0A  2  A9 10              LDA   #FIO_CMD_MTEMPO
00EF0C  2  8D A0 B9           STA   FIO_CMD
00EF0F  2  60                 RTS
00EF10  2               
00EF10  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00EF10  2               @m_loop_tok
00EF10  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00EF13  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00EF16  2  C9 93              CMP   #TK_ON
00EF18  2  F0 07              BEQ   @m_loop_on
00EF1A  2  C9 CB              CMP   #TK_OFF
00EF1C  2  F0 0E              BEQ   @m_loop_off
00EF1E  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00EF21  2               @m_loop_on
00EF21  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00EF24  2  A9 01              LDA   #$01
00EF26  2  8D A4 B9           STA   FIO_SRCL
00EF29  2  4C 34 EF           JMP   @m_loop_go
00EF2C  2               @m_loop_off
00EF2C  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00EF2F  2  A9 00              LDA   #$00
00EF31  2  8D A4 B9           STA   FIO_SRCL
00EF34  2               @m_loop_go
00EF34  2  A9 11              LDA   #FIO_CMD_MLOOP
00EF36  2  8D A0 B9           STA   FIO_CMD
00EF39  2  60                 RTS
00EF3A  2               
00EF3A  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00EF3A  2               @m_priority
00EF3A  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00EF3A  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00EF3A  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00EF3A  2               @m_pri_skip
00EF3A  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00EF3D  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00EF3F  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00EF41  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00EF41  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00EF41  2                     ; Clear all 6 voice slots
00EF41  2  A9 00              LDA   #$00
00EF43  2  A0 05              LDY   #$05
00EF45  2               @m_pri_clr
00EF45  2  99 A4 B9           STA   FIO_SRCL,Y
00EF48  2  88                 DEY
00EF49  2  10 FA              BPL   @m_pri_clr
00EF4B  2                     ; Parse up to 6 comma-separated voice values
00EF4B  2  A0 00              LDY   #$00              ; slot index
00EF4D  2               @m_pri_nxt
00EF4D  2  20 A1 D8           JSR   LAB_GTBY          ; get voice number → X
00EF50  2  8A                 TXA
00EF51  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00EF54  2  C8                 INY
00EF55  2  C0 06              CPY   #$06
00EF57  2  B0 0D              BCS   @m_pri_go         ; all 6 parsed
00EF59  2  20 C2 00           JSR   LAB_GBYT          ; peek next char
00EF5C  2  C9 2C              CMP   #','
00EF5E  2  D0 06              BNE   @m_pri_go         ; no more commas
00EF60  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EF63  2  4C 4D EF           JMP   @m_pri_nxt
00EF66  2               @m_pri_go
00EF66  2  A9 12              LDA   #FIO_CMD_MPRI
00EF68  2  8D A0 B9           STA   FIO_CMD
00EF6B  2  60                 RTS
00EF6C  2               
00EF6C  2               ; --- MUSIC voice, "mml" ---
00EF6C  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00EF6C  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
00EF6C  2               @m_seq
00EF6C  2  20 A1 D8           JSR   LAB_GTBY          ; voice number (1-14) → X
00EF6F  2  8E A4 B9           STX   FIO_SRCL          ; store voice
00EF72  2  20 99 CD           JSR   LAB_1C01          ; comma
00EF75  2  20 75 CC           JSR   LAB_EVEX          ; evaluate expression
00EF78  2  20 3E D7           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00EF7B  2  AA                 TAX
00EF7C  2  F0 1A              BEQ   @m_seq_err        ; empty string = error
00EF7E  2  8E A3 B9           STX   FIO_NAMELEN       ; string length (1-255)
00EF81  2  A5 71              LDA   ut1_pl
00EF83  2  8D A6 B9           STA   FIO_ENDL          ; string pointer low
00EF86  2  A5 72              LDA   ut1_ph
00EF88  2  8D A7 B9           STA   FIO_ENDH          ; string pointer high
00EF8B  2  A9 0D              LDA   #FIO_CMD_MSEQ
00EF8D  2  8D A0 B9           STA   FIO_CMD
00EF90  2  AD A1 B9           LDA   FIO_STATUS
00EF93  2  C9 02              CMP   #FIO_OK
00EF95  2  D0 01              BNE   @m_seq_err
00EF97  2  60                 RTS
00EF98  2               @m_seq_err
00EF98  2  4C 96 F4           JMP   LAB_FIO_ERRIO
00EF9B  2               
00EF9B  2               ; perform COPPER subcommand
00EF9B  2               ; COPPER ADD x, y, reg, value
00EF9B  2               ; COPPER CLEAR | ON | OFF
00EF9B  2               
00EF9B  2               LAB_COPPER
00EF9B  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte
00EF9E  2  C9 A2              CMP   #TK_CLEAR
00EFA0  2  F0 17              BEQ   @c_clear
00EFA2  2  C9 93              CMP   #TK_ON
00EFA4  2  F0 1C              BEQ   @c_on
00EFA6  2  C9 CB              CMP   #TK_OFF
00EFA8  2  F0 21              BEQ   @c_off
00EFAA  2  C9 41              CMP   #'A'
00EFAC  2  F0 56              BEQ   @c_add
00EFAE  2  C9 A1              CMP   #TK_LIST
00EFB0  2  F0 22              BEQ   @c_list
00EFB2  2  C9 55              CMP   #'U'
00EFB4  2  F0 3D              BEQ   @c_use
00EFB6  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00EFB9  2               
00EFB9  2               ; --- COPPER CLEAR ---
00EFB9  2               @c_clear
00EFB9  2  20 BC 00           JSR   LAB_IGBY          ; consume CLEAR token
00EFBC  2  A9 1C              LDA   #VCMD_COPPERCLR
00EFBE  2  8D 10 A0           STA   VGC_CMD
00EFC1  2  60                 RTS
00EFC2  2               
00EFC2  2               ; --- COPPER ON ---
00EFC2  2               @c_on
00EFC2  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00EFC5  2  A9 1D              LDA   #VCMD_COPPERENA
00EFC7  2  8D 10 A0           STA   VGC_CMD
00EFCA  2  60                 RTS
00EFCB  2               
00EFCB  2               ; --- COPPER OFF ---
00EFCB  2               @c_off
00EFCB  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00EFCE  2  A9 1E              LDA   #VCMD_COPPERDIS
00EFD0  2  8D 10 A0           STA   VGC_CMD
00EFD3  2  60                 RTS
00EFD4  2               
00EFD4  2               ; --- COPPER LIST n / COPPER LIST END ---
00EFD4  2               @c_list
00EFD4  2  20 BC 00           JSR   LAB_IGBY          ; consume LIST token
00EFD7  2  20 C2 00           JSR   LAB_GBYT          ; peek next
00EFDA  2  C9 80              CMP   #TK_END
00EFDC  2  F0 0C              BEQ   @c_list_end
00EFDE  2                     ; LIST n — parse list index
00EFDE  2  20 A1 D8           JSR   LAB_GTBY          ; 8-bit → X
00EFE1  2  8E 11 A0           STX   VGC_P0             ; list index
00EFE4  2  A9 20              LDA   #VCMD_COPPERLIST
00EFE6  2  8D 10 A0           STA   VGC_CMD
00EFE9  2  60                 RTS
00EFEA  2               
00EFEA  2               @c_list_end
00EFEA  2  20 BC 00           JSR   LAB_IGBY          ; consume END token
00EFED  2  A9 22              LDA   #VCMD_COPPEREND
00EFEF  2  8D 10 A0           STA   VGC_CMD
00EFF2  2  60                 RTS
00EFF3  2               
00EFF3  2               ; --- COPPER USE n ---
00EFF3  2               @c_use
00EFF3  2  A2 03              LDX   #3
00EFF5  2  20 BF EE           JSR   LAB_SKIPX          ; USE
00EFF8  2  20 A1 D8           JSR   LAB_GTBY          ; list index → X
00EFFB  2  8E 11 A0           STX   VGC_P0
00EFFE  2  A9 21              LDA   #VCMD_COPPERUSE
00F000  2  8D 10 A0           STA   VGC_CMD
00F003  2  60                 RTS
00F004  2               
00F004  2               ; --- COPPER ADD x, y, reg, value ---
00F004  2               @c_add
00F004  2  A2 03              LDX   #3
00F006  2  20 BF EE           JSR   LAB_SKIPX          ; ADD
00F009  2  20 8F D8           JSR   LAB_GTWRD         ; x (16-bit) → FAC1_3(lo), FAC1_2(hi)
00F00C  2  A5 AF              LDA   FAC1_3
00F00E  2  8D 11 A0           STA   VGC_P0             ; x low
00F011  2  A5 AE              LDA   FAC1_2
00F013  2  8D 12 A0           STA   VGC_P1             ; x high
00F016  2  20 99 CD           JSR   LAB_1C01          ; comma
00F019  2  20 A1 D8           JSR   LAB_GTBY          ; y (8-bit) → X
00F01C  2  8E 13 A0           STX   VGC_P2             ; y
00F01F  2  20 99 CD           JSR   LAB_1C01          ; comma
00F022  2                     ; parse register name: BGCOL, MODE, SCROLLX, SCROLLY,
00F022  2                     ; SPRX(n), SPRXH(n), SPRY(n), SPRYH(n), SPRSHAPE(n), SPRFLAGS(n), SPRPRI(n)
00F022  2  20 C2 00           JSR   LAB_GBYT          ; peek
00F025  2  C9 42              CMP   #'B'
00F027  2  F0 0B              BEQ   @c_bgcol
00F029  2  C9 B5              CMP   #TK_GMODE
00F02B  2  F0 11              BEQ   @c_mode
00F02D  2  C9 53              CMP   #'S'
00F02F  2  F0 15              BEQ   @c_s_dispatch
00F031  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F034  2               
00F034  2               @c_bgcol
00F034  2  A2 05              LDX   #5
00F036  2  20 BF EE           JSR   LAB_SKIPX          ; BGCOL
00F039  2  A9 01              LDA   #$01              ; reg index 1 = BGCOL
00F03B  2  4C 7A F0           JMP   @c_store_idx
00F03E  2               
00F03E  2               @c_mode
00F03E  2  20 BC 00           JSR   LAB_IGBY          ; consume MODE token
00F041  2  A9 00              LDA   #$00              ; reg index 0 = MODE
00F043  2  4C 7A F0           JMP   @c_store_idx
00F046  2               
00F046  2               @c_s_dispatch
00F046  2  20 BC 00           JSR   LAB_IGBY          ; consume S
00F049  2  20 C2 00           JSR   LAB_GBYT          ; peek next: C=scroll, P=sprite
00F04C  2  C9 43              CMP   #'C'
00F04E  2  F0 07              BEQ   @c_scroll
00F050  2  C9 50              CMP   #'P'
00F052  2  F0 31              BEQ   @c_spr
00F054  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F057  2               
00F057  2               @c_scroll
00F057  2  A2 05              LDX   #5
00F059  2  20 BF EE           JSR   LAB_SKIPX          ; CROLL
00F05C  2  20 C2 00           JSR   LAB_GBYT          ; peek X or Y
00F05F  2  C9 58              CMP   #'X'
00F061  2  F0 07              BEQ   @c_scrollx
00F063  2  C9 59              CMP   #'Y'
00F065  2  F0 0B              BEQ   @c_scrolly
00F067  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F06A  2               
00F06A  2               @c_scrollx
00F06A  2  20 BC 00           JSR   LAB_IGBY          ; consume X
00F06D  2  A9 05              LDA   #$05              ; reg index 5 = SCROLLX
00F06F  2  4C 7A F0           JMP   @c_store_idx
00F072  2               
00F072  2               @c_scrolly
00F072  2  20 BC 00           JSR   LAB_IGBY          ; consume Y
00F075  2  A9 06              LDA   #$06              ; reg index 6 = SCROLLY
00F077  2  4C 7A F0           JMP   @c_store_idx
00F07A  2               
00F07A  2               @c_store_idx
00F07A  2  8D 14 A0           STA   VGC_P3             ; register index (low byte)
00F07D  2  A9 00              LDA   #$00
00F07F  2  8D 15 A0           STA   VGC_P4             ; high byte = 0
00F082  2  4C 17 F1           JMP   @c_store_val
00F085  2               
00F085  2                     ; --- Sprite register names: SPR + field + (n) ---
00F085  2                     ; SPRX(n)=$A040+n*8+0, SPRXH(n)=+1, SPRY(n)=+2, SPRYH(n)=+3,
00F085  2                     ; SPRSHAPE(n)=+4, SPRFLAGS(n)=+5, SPRPRI(n)=+6
00F085  2               @c_spr
00F085  2  20 BC 00           JSR   LAB_IGBY          ; consume P
00F088  2  20 BC 00           JSR   LAB_IGBY          ; consume R
00F08B  2  20 C2 00           JSR   LAB_GBYT          ; peek field start: X, Y, S, F, P
00F08E  2  C9 58              CMP   #'X'
00F090  2  F0 13              BEQ   @cs_x
00F092  2  C9 59              CMP   #'Y'
00F094  2  F0 26              BEQ   @cs_y
00F096  2  C9 53              CMP   #'S'
00F098  2  F0 39              BEQ   @cs_shape
00F09A  2  C9 46              CMP   #'F'
00F09C  2  F0 3F              BEQ   @cs_flags
00F09E  2  C9 50              CMP   #'P'
00F0A0  2  F0 45              BEQ   @cs_pri
00F0A2  2  4C 84 C5           JMP   LAB_15D9          ; syntax error
00F0A5  2               
00F0A5  2               @cs_x
00F0A5  2  20 BC 00           JSR   LAB_IGBY          ; consume X
00F0A8  2  20 C2 00           JSR   LAB_GBYT          ; peek: H or (
00F0AB  2  C9 48              CMP   #'H'
00F0AD  2  F0 05              BEQ   @cs_xh
00F0AF  2  A9 00              LDA   #$00              ; field offset 0 = X low
00F0B1  2  4C EE F0           JMP   @c_spr_idx
00F0B4  2               
00F0B4  2               @cs_xh
00F0B4  2  20 BC 00           JSR   LAB_IGBY          ; consume H
00F0B7  2  A9 01              LDA   #$01              ; field offset 1 = X high
00F0B9  2  4C EE F0           JMP   @c_spr_idx
00F0BC  2               
00F0BC  2               @cs_y
00F0BC  2  20 BC 00           JSR   LAB_IGBY          ; consume Y
00F0BF  2  20 C2 00           JSR   LAB_GBYT          ; peek: H or (
00F0C2  2  C9 48              CMP   #'H'
00F0C4  2  F0 05              BEQ   @cs_yh
00F0C6  2  A9 02              LDA   #$02              ; field offset 2 = Y low
00F0C8  2  4C EE F0           JMP   @c_spr_idx
00F0CB  2               
00F0CB  2               @cs_yh
00F0CB  2  20 BC 00           JSR   LAB_IGBY          ; consume H
00F0CE  2  A9 03              LDA   #$03              ; field offset 3 = Y high
00F0D0  2  4C EE F0           JMP   @c_spr_idx
00F0D3  2               
00F0D3  2               @cs_shape
00F0D3  2  A2 05              LDX   #5
00F0D5  2  20 BF EE           JSR   LAB_SKIPX          ; SHAPE
00F0D8  2  A9 04              LDA   #$04              ; field offset 4 = Shape
00F0DA  2  4C EE F0           JMP   @c_spr_idx
00F0DD  2               
00F0DD  2               @cs_flags
00F0DD  2  A2 05              LDX   #5
00F0DF  2  20 BF EE           JSR   LAB_SKIPX          ; FLAGS
00F0E2  2  A9 05              LDA   #$05              ; field offset 5 = Flags
00F0E4  2  4C EE F0           JMP   @c_spr_idx
00F0E7  2               
00F0E7  2               @cs_pri
00F0E7  2  A2 03              LDX   #3
00F0E9  2  20 BF EE           JSR   LAB_SKIPX          ; PRI
00F0EC  2  A9 06              LDA   #$06              ; field offset 6 = Priority
00F0EE  2                     ; fall through to @c_spr_idx
00F0EE  2               
00F0EE  2                     ; A = field offset, now parse (n) and compute address $A040 + n*8 + A
00F0EE  2               @c_spr_idx
00F0EE  2  48                 PHA                     ; save field offset
00F0EF  2  20 BC 00           JSR   LAB_IGBY          ; consume '('
00F0F2  2  20 A1 D8           JSR   LAB_GTBY          ; sprite index (0-15) → X
00F0F5  2  E0 10              CPX   #$10
00F0F7  2  90 03              BCC   @cs_idx_ok
00F0F9  2  4C 84 C5           JMP   LAB_15D9          ; syntax error if n > 15
00F0FC  2               @cs_idx_ok
00F0FC  2  20 BC 00           JSR   LAB_IGBY          ; consume ')'
00F0FF  2                     ; compute address: $A040 + X*8 + field
00F0FF  2  8A                 TXA                     ; A = sprite index
00F100  2  0A                 ASL                     ; *2
00F101  2  0A                 ASL                     ; *4
00F102  2  0A                 ASL                     ; *8
00F103  2  8D 14 A0           STA   VGC_P3             ; temp = n*8
00F106  2  68                 PLA                     ; A = field offset
00F107  2  18                 CLC
00F108  2  6D 14 A0           ADC   VGC_P3             ; A = n*8 + field
00F10B  2  69 40              ADC   #$40              ; A = n*8 + field + $40 (low byte of $A040)
00F10D  2  8D 14 A0           STA   VGC_P3             ; P3 = address low byte
00F110  2  A9 A0              LDA   #$A0              ; high byte of $A040
00F112  2  69 00              ADC   #$00              ; add carry if low byte wrapped
00F114  2  8D 15 A0           STA   VGC_P4             ; P4 = address high byte
00F117  2               
00F117  2               @c_store_val
00F117  2  20 99 CD           JSR   LAB_1C01          ; comma
00F11A  2  20 A1 D8           JSR   LAB_GTBY          ; value (8-bit) → X
00F11D  2  8E 16 A0           STX   VGC_P5             ; value
00F120  2  A9 1B              LDA   #VCMD_COPPERADD
00F122  2  8D 10 A0           STA   VGC_CMD            ; trigger
00F125  2  60                 RTS
00F126  2               
00F126  2               ; perform RESET — full system reset (VGC, SID, music) + cold start BASIC
00F126  2               
00F126  2               LAB_RESET
00F126  2  A9 1F              LDA   #VCMD_SYSRESET
00F128  2  8D 10 A0           STA   VGC_CMD            ; trigger hardware reset
00F12B  2  6C FC FF           JMP   ($FFFC)            ; jump through reset vector
00F12E  2               
00F12E  2               ; --- NIC BASIC keyword handlers ---
00F12E  2               
00F12E  2               ; NOPEN slot,"host",port — connect slot to remote host
00F12E  2               LAB_NOPEN
00F12E  2  20 A1 D8           JSR   LAB_GTBY          ; slot → X
00F131  2  8E 02 A1           STX   NIC_SLOT
00F134  2  20 99 CD           JSR   LAB_1C01          ; comma
00F137  2  20 75 CC           JSR   LAB_EVEX          ; evaluate string expression
00F13A  2  20 3E D7           JSR   LAB_EVST          ; pop: A=len, ut1_pl/ph=ptr
00F13D  2  AA                 TAX                     ; len → X
00F13E  2  F0 2A              BEQ   @nopen_err        ; empty hostname = error
00F140  2  E0 20              CPX   #32
00F142  2  B0 26              BCS   @nopen_err        ; too long
00F144  2  A0 00              LDY   #$00
