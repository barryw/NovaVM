00E968  3               
00E968  3               .ifndef VGC_IMPLEMENTATION_INCLUDED
00E968  3               VGC_IMPLEMENTATION_INCLUDED = 1
00E968  3               
00E968  3                     .segment "CODE"
00E968  3               
00E968  3                     .export vgc_cmd
00E968  3                     .export vgc_wait_cmd
00E968  3               .ifndef VGC_NO_EXEC
00E968  3                     .export vgc_exec
00E968  3               .endif
00E968  3                     .export vgc_vsync
00E968  3                     .export vgc_mem_read
00E968  3                     .export vgc_mem_write
00E968  3                     .export vgc_reverse_default
00E968  3                     .export vgc_reverse_explicit
00E968  3                     .export vgc_reverse_off
00E968  3                     .export vgc_flash_on
00E968  3                     .export vgc_flash_off
00E968  3               .ifndef VGC_NO_PRIMITIVES
00E968  3                     .export vgc_gcls
00E968  3                     .export vgc_gcolor
00E968  3                     .export vgc_plot
00E968  3                     .export vgc_unplot
00E968  3                     .export vgc_line
00E968  3                     .export vgc_circle
00E968  3                     .export vgc_gtext
00E968  3                     .export vgc_rect
00E968  3                     .export vgc_fill
00E968  3                     .export vgc_paint
00E968  3               .endif
00E968  3               
00E968  3               ; Input: A = VGC command. Does not wait for completion.
00E968  3               vgc_cmd:
00E968  3  8D 10 A0           STA   VGC_CMD
00E96B  3  60                 RTS
00E96C  3               
00E96C  3               ; Wait until the command busy bit clears.
00E96C  3               vgc_wait_cmd:
00E96C  3               @wait:
00E96C  3  AD 10 A0           LDA   VGC_CMD
00E96F  3  29 01              AND   #$01
00E971  3  D0 F9              BNE   @wait
00E973  3  60                 RTS
00E974  3               
00E974  3               ; Input: A = VGC command. Issue and wait for completion.
00E974  3               .ifndef VGC_NO_EXEC
00E974  3               vgc_exec:
00E974  3                     JSR   vgc_cmd
00E974  3                     JMP   vgc_wait_cmd
00E974  3               .endif
00E974  3               
00E974  3               ; Wait for the next frame counter tick.
00E974  3               vgc_vsync:
00E974  3  AD 08 A0           LDA   VGC_FRAME
00E977  3               @wait:
00E977  3  CD 08 A0           CMP   VGC_FRAME
00E97A  3  F0 FB              BEQ   @wait
00E97C  3  60                 RTS
00E97D  3               
00E97D  3               vgc_mem_read:
00E97D  3  A9 19              LDA   #VCMD_MEMREAD
00E97F  3  2C                 .byte $2C
00E980  3               
00E980  3               vgc_mem_write:
00E980  3  A9 1A              LDA   #VCMD_MEMWRITE
00E982  3  8D 10 A0           STA   VGC_CMD
00E985  3  4C 6C E9           JMP   vgc_wait_cmd
00E988  3               
00E988  3               ; Enable reverse text by swapping the current foreground/background colours.
00E988  3               vgc_reverse_default:
00E988  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E98B  3  29 FC              AND   #$FC
00E98D  3  09 01              ORA   #VTXT_REV
00E98F  3  8D E6 A0           STA   VGC_TXTFLAGS
00E992  3  60                 RTS
00E993  3               
00E993  3               ; Input: A = packed reverse attribute, low nibble fg and high nibble bg.
00E993  3               vgc_reverse_explicit:
00E993  3  8D E7 A0           STA   VGC_TXTREVATTR
00E996  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E999  3  29 FC              AND   #$FC
00E99B  3  09 03              ORA   #(VTXT_REV | VTXT_REVEX)
00E99D  3  8D E6 A0           STA   VGC_TXTFLAGS
00E9A0  3  60                 RTS
00E9A1  3               
00E9A1  3               vgc_reverse_off:
00E9A1  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E9A4  3  29 FC              AND   #$FC
00E9A6  3  8D E6 A0           STA   VGC_TXTFLAGS
00E9A9  3  60                 RTS
00E9AA  3               
00E9AA  3               vgc_flash_on:
00E9AA  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E9AD  3  09 04              ORA   #VTXT_FLASH
00E9AF  3  8D E6 A0           STA   VGC_TXTFLAGS
00E9B2  3  60                 RTS
00E9B3  3               
00E9B3  3               vgc_flash_off:
00E9B3  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E9B6  3  29 FB              AND   #$FB
00E9B8  3  8D E6 A0           STA   VGC_TXTFLAGS
00E9BB  3  60                 RTS
00E9BC  3               
00E9BC  3               .ifndef VGC_NO_PRIMITIVES
00E9BC  3               vgc_gcls:
00E9BC  3                     LDA   #VCMD_GCLS
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_gcolor:
00E9BC  3                     LDA   #VCMD_GCOLOR
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_plot:
00E9BC  3                     LDA   #VCMD_PLOT
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_unplot:
00E9BC  3                     LDA   #VCMD_UNPLOT
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_line:
00E9BC  3                     LDA   #VCMD_LINE
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_circle:
00E9BC  3                     LDA   #VCMD_CIRCLE
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_gtext:
00E9BC  3                     LDA   #VCMD_GTEXT
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_rect:
00E9BC  3                     LDA   #VCMD_RECT
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_fill:
00E9BC  3                     LDA   #VCMD_FILL
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               
00E9BC  3               vgc_paint:
00E9BC  3                     LDA   #VCMD_PAINT
00E9BC  3                     JMP   vgc_cmd
00E9BC  3               .endif
00E9BC  3               
00E9BC  3               .endif
00E9BC  3               
00E9BC  2                     .include "lib/sprite.s"
00E9BC  3               ; Shared Nova sprite helper routines.
00E9BC  3               ;
00E9BC  3               ; Assembly callers can load VGC_P* and call the command helpers, or use the
00E9BC  3               ; direct register helpers for the VGC sprite attribute block.
00E9BC  3               
00E9BC  3               .include "sprite.inc"
00E9BC  4               ; Shared Nova sprite helper declarations.
00E9BC  4               ;
00E9BC  4               ; Command helpers use VGC_P* registers directly. Direct sprite-register helpers
00E9BC  4               ; use the public sprite attribute register block at VGC_SPR_BASE.
00E9BC  4               
00E9BC  4               .ifndef SPRITE_INC_INCLUDED
00E9BC  4               SPRITE_INC_INCLUDED = 1
00E9BC  4               
00E9BC  4               .include "vgc.inc"
00E9BC  5               ; Shared Nova VGC helper declarations.
00E9BC  5               ;
00E9BC  5               ; The command helpers use the VGC hardware parameter registers directly:
00E9BC  5               ; callers load VGC_P0..VGC_P14 as needed, then call a vgc_* routine.
00E9BC  5               ; Routines return through the hardware status model; command completion can be
00E9BC  5               ; checked with vgc_wait_cmd when the caller needs a synchronous operation.
00E9BC  5               
00E9BC  5               .ifndef VGC_INC_INCLUDED
00E9BC  5               VGC_INC_INCLUDED = 1
00E9BC  5               
00E9BC  5               .include "nova.inc"
00E9BC  5               
00E9BC  5               VGC_RESULT_OK    = $00
00E9BC  5               VGC_RESULT_ERROR = $01
00E9BC  5               
00E9BC  5               .endif
00E9BC  5               
00E9BC  4               
00E9BC  4               SPRITE_RESULT_OK    = $00
00E9BC  4               SPRITE_RESULT_ERROR = $01
00E9BC  4               
00E9BC  4               .endif
00E9BC  4               
00E9BC  3               
00E9BC  3               .ifndef SPRITE_IMPLEMENTATION_INCLUDED
00E9BC  3               SPRITE_IMPLEMENTATION_INCLUDED = 1
00E9BC  3               
00E9BC  3                     .segment "CODE"
00E9BC  3               
00E9BC  3                     .export sprite_command
00E9BC  3                     .export sprite_pos
00E9BC  3                     .export sprite_enable
00E9BC  3                     .export sprite_disable
00E9BC  3                     .export sprite_row
00E9BC  3               .ifndef SPRITE_NO_EXTRA
00E9BC  3                     .export sprite_clear
00E9BC  3                     .export sprite_copy
00E9BC  3                     .export sprite_flip
00E9BC  3                     .export sprite_priority
00E9BC  3               .endif
00E9BC  3                     .export sprite_reg_offset
00E9BC  3                     .export sprite_set_shape
00E9BC  3                     .export sprite_set_reg8
00E9BC  3                     .export sprite_set_reg16
00E9BC  3                     .export sprite_get_x
00E9BC  3                     .export sprite_get_y
00E9BC  3               
00E9BC  3               ; Input: A = sprite VGC command. Does not wait for completion.
00E9BC  3               sprite_command:
00E9BC  3  8D 10 A0           STA   VGC_CMD
00E9BF  3  60                 RTS
00E9C0  3               
00E9C0  3               ; Command wrappers. Callers load VGC_P* per the hardware command ABI.
00E9C0  3               sprite_pos:
00E9C0  3  A9 14              LDA   #VCMD_SPRPOS
00E9C2  3  4C BC E9           JMP   sprite_command
00E9C5  3               
00E9C5  3               sprite_enable:
00E9C5  3  A9 15              LDA   #VCMD_SPRENA
00E9C7  3  4C BC E9           JMP   sprite_command
00E9CA  3               
00E9CA  3               sprite_disable:
00E9CA  3  A9 16              LDA   #VCMD_SPRDIS
00E9CC  3  4C BC E9           JMP   sprite_command
00E9CF  3               
00E9CF  3               sprite_row:
00E9CF  3  A9 11              LDA   #VCMD_SPRROW
00E9D1  3  4C BC E9           JMP   sprite_command
00E9D4  3               
00E9D4  3               .ifndef SPRITE_NO_EXTRA
00E9D4  3               sprite_clear:
00E9D4  3                     LDA   #VCMD_SPRCLR
00E9D4  3                     JMP   sprite_command
00E9D4  3               
00E9D4  3               sprite_copy:
00E9D4  3                     LDA   #VCMD_SPRCOPY
00E9D4  3                     JMP   sprite_command
00E9D4  3               
00E9D4  3               sprite_flip:
00E9D4  3                     LDA   #VCMD_SPRFLIP
00E9D4  3                     JMP   sprite_command
00E9D4  3               
00E9D4  3               sprite_priority:
00E9D4  3                     LDA   #VCMD_SPRPRI
00E9D4  3                     JMP   sprite_command
00E9D4  3               .endif
00E9D4  3               
00E9D4  3               ; Input: X = sprite index, Y = sprite register field offset.
00E9D4  3               ; Output: Y = VGC_SPR_BASE-relative register offset.
00E9D4  3               ; Clobbers: A, NVR7L.
00E9D4  3               sprite_reg_offset:
00E9D4  3  84 2E              STY   NVR7L
00E9D6  3  8A                 TXA
00E9D7  3  0A                 ASL
00E9D8  3  0A                 ASL
00E9D9  3  0A                 ASL
00E9DA  3  18                 CLC
00E9DB  3  65 2E              ADC   NVR7L
00E9DD  3  A8                 TAY
00E9DE  3  60                 RTS
00E9DF  3               
00E9DF  3               ; Input: X = sprite index, A = shape.
00E9DF  3               sprite_set_shape:
00E9DF  3  A0 04              LDY   #VGC_SPR_SHAPE_OFF
00E9E1  3                     ; fall through
00E9E1  3               
00E9E1  3               ; Input: X = sprite index, Y = field offset, A = value.
00E9E1  3               ; Clobbers: A, Y, NVR7L/NVR7H.
00E9E1  3               sprite_set_reg8:
00E9E1  3  85 2F              STA   NVR7H
00E9E3  3  20 D4 E9           JSR   sprite_reg_offset
00E9E6  3  A5 2F              LDA   NVR7H
00E9E8  3  99 40 A0           STA   VGC_SPR_BASE,Y
00E9EB  3  60                 RTS
00E9EC  3               
00E9EC  3               ; Input: X = sprite index, Y = field offset, NVR0L/NVR0H = little-endian value.
00E9EC  3               ; Clobbers: A, Y, NVR7L.
00E9EC  3               sprite_set_reg16:
00E9EC  3  20 D4 E9           JSR   sprite_reg_offset
00E9EF  3  A5 20              LDA   NVR0L
00E9F1  3  99 40 A0           STA   VGC_SPR_BASE,Y
00E9F4  3  C8                 INY
00E9F5  3  A5 21              LDA   NVR0H
00E9F7  3  99 40 A0           STA   VGC_SPR_BASE,Y
00E9FA  3  60                 RTS
00E9FB  3               
00E9FB  3               ; Input: X = sprite index. Output: A = X high byte, Y = X low byte.
00E9FB  3               sprite_get_x:
00E9FB  3  A0 00              LDY   #VGC_SPR_XL_OFF
00E9FD  3  20 D4 E9           JSR   sprite_reg_offset
00EA00  3  B9 40 A0           LDA   VGC_SPR_BASE,Y
00EA03  3  85 2E              STA   NVR7L
00EA05  3  C8                 INY
00EA06  3  B9 40 A0           LDA   VGC_SPR_BASE,Y
00EA09  3  A4 2E              LDY   NVR7L
00EA0B  3  60                 RTS
00EA0C  3               
00EA0C  3               ; Input: X = sprite index. Output: Y = Y low byte.
00EA0C  3               sprite_get_y:
00EA0C  3  A0 02              LDY   #VGC_SPR_YL_OFF
00EA0E  3  20 D4 E9           JSR   sprite_reg_offset
00EA11  3  B9 40 A0           LDA   VGC_SPR_BASE,Y
00EA14  3  A8                 TAY
00EA15  3  60                 RTS
00EA16  3               
00EA16  3               .endif
00EA16  3               
00EA16  2               
00EA16  2               LAB_VGC_CMD_RTS = vgc_cmd
00EA16  2               LAB_VSYNC       = vgc_vsync
00EA16  2               
00EA16  2               ; perform CLS — clear screen, no arguments
00EA16  2               
00EA16  2               LAB_CLS
00EA16  2  A9 0C              LDA   #$0C              ; form feed character
00EA18  2  8D 0E A0           STA   VGC_CHAROUT       ; write to CHAROUT register
00EA1B  2  60                 RTS
00EA1C  2               
00EA1C  2               ; perform COLOR fg [,bg [,border]]
00EA1C  2               
00EA1C  2               LAB_COLOR
00EA1C  2  20 1F D9           JSR   LAB_GTBY          ; get fg color byte in X
00EA1F  2  8E 02 A0           STX   VGC_FGCOL         ; store foreground color
00EA22  2  20 C2 00           JSR   LAB_GBYT          ; peek at current byte
00EA25  2  C9 2C              CMP   #','              ; comma follows?
00EA27  2  D0 19              BNE   @done             ; no, just fg was given
00EA29  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EA2C  2  20 1F D9           JSR   LAB_GTBY          ; get bg color byte in X
00EA2F  2  8E 01 A0           STX   VGC_BGCOL         ; store background color
00EA32  2  20 C2 00           JSR   LAB_GBYT          ; peek for optional border color
00EA35  2  C9 2C              CMP   #','              ; second comma follows?
00EA37  2  D0 09              BNE   @done             ; no, fg/bg only
00EA39  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EA3C  2  20 1F D9           JSR   LAB_GTBY          ; get border color byte in X
00EA3F  2  8E 0D A0           STX   VGC_BORDER        ; store border color
00EA42  2               @done
00EA42  2  60                 RTS
00EA43  2               
00EA43  2               ; perform REVERSE [fg,bg]
00EA43  2               
00EA43  2               LAB_REVERSE
00EA43  2  20 C2 00           JSR   LAB_GBYT          ; optional explicit reverse colours?
00EA46  2  F0 20              BEQ   @swap
00EA48  2  C9 3A              CMP   #':'              ; no args before next statement
00EA4A  2  F0 1C              BEQ   @swap
00EA4C  2  20 1F D9           JSR   LAB_GTBY          ; reverse foreground in X
00EA4F  2  8A                 TXA
00EA50  2  29 0F              AND   #$0F
00EA52  2  48                 PHA
00EA53  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EA56  2  20 1F D9           JSR   LAB_GTBY          ; reverse background in X
00EA59  2  8A                 TXA
00EA5A  2  29 0F              AND   #$0F
00EA5C  2  0A                 ASL
00EA5D  2  0A                 ASL
00EA5E  2  0A                 ASL
00EA5F  2  0A                 ASL
00EA60  2  85 78              STA   TempB
00EA62  2  68                 PLA
00EA63  2  05 78              ORA   TempB
00EA65  2  4C 93 E9           JMP   vgc_reverse_explicit
00EA68  2               @swap
00EA68  2  4C 88 E9           JMP   vgc_reverse_default
00EA6B  2               
00EA6B  2               ; perform REVERSEOFF
00EA6B  2               
00EA6B  2               LAB_REVERSEOFF
00EA6B  2  4C A1 E9           JMP   vgc_reverse_off
00EA6E  2               
00EA6E  2               ; perform FLASH
00EA6E  2               
00EA6E  2               LAB_FLASH
00EA6E  2  4C AA E9           JMP   vgc_flash_on
00EA71  2               
00EA71  2               ; perform FLASHOFF
00EA71  2               
00EA71  2               LAB_FLASHOFF
00EA71  2  4C B3 E9           JMP   vgc_flash_off
00EA74  2               
00EA74  2               ; perform VPOKE plane,addr,value — write a byte to VGC memory
00EA74  2               
00EA74  2               LAB_VPOKE
00EA74  2  20 1F D9           JSR   LAB_GTBY
00EA77  2  8E 11 A0           STX   VGC_P0
00EA7A  2  20 F6 CD           JSR   LAB_1C01
00EA7D  2  20 0D D9           JSR   LAB_GTWRD
00EA80  2  A5 AF              LDA   FAC1_3
00EA82  2  8D 12 A0           STA   VGC_P1
00EA85  2  A5 AE              LDA   FAC1_2
00EA87  2  8D 13 A0           STA   VGC_P2
00EA8A  2  20 F6 CD           JSR   LAB_1C01
00EA8D  2  20 1F D9           JSR   LAB_GTBY
00EA90  2  8E 14 A0           STX   VGC_P3
00EA93  2  9C 15 A0           STZ   VGC_P4
00EA96  2  4C 80 E9           JMP   vgc_mem_write
00EA99  2               
00EA99  2               ; perform LOCATE x, y
00EA99  2               
00EA99  2               LAB_LOCATE
00EA99  2  20 1F D9           JSR   LAB_GTBY          ; get x in X
00EA9C  2  8E 03 A0           STX   VGC_CURSX         ; store cursor X
00EA9F  2  20 F6 CD           JSR   LAB_1C01          ; require comma
00EAA2  2  20 1F D9           JSR   LAB_GTBY          ; get y in X
00EAA5  2  8E 04 A0           STX   VGC_CURSY         ; store cursor Y
00EAA8  2  60                 RTS
00EAA9  2               
00EAA9  2               ; perform MODE n
00EAA9  2               
00EAA9  2               LAB_GMODE
00EAA9  2  20 1F D9           JSR   LAB_GTBY          ; get mode byte in X
00EAAC  2  8E 00 A0           STX   VGC_MODE          ; store graphics mode
00EAAF  2  60                 RTS
00EAB0  2               
00EAB0  2               ; perform FONT n — select active font slot (0-7)
00EAB0  2               
00EAB0  2               LAB_FONT
00EAB0  2  20 1F D9           JSR   LAB_GTBY          ; get font index byte (0-7) in X
00EAB3  2  8E 07 A0           STX   VGC_FONT          ; select active font
00EAB6  2  60                 RTS
00EAB7  2               
00EAB7  2               ; perform GCLS — clear the graphics bitmap layer
00EAB7  2               
00EAB7  2               LAB_GCLS
00EAB7  2  20 74 E9           JSR   LAB_VSYNC         ; BASIC hides visible VGC draw tearing
00EABA  2  A9 07              LDA   #VCMD_GCLS        ; GCLS command
00EABC  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EABF  2               
00EABF  2               ; perform GCOLOR c — set graphics draw color (0-15)
00EABF  2               
00EABF  2               LAB_GCOLOR
00EABF  2  20 1F D9           JSR   LAB_GTBY          ; get color byte in X
00EAC2  2  8E 11 A0           STX   VGC_P0             ; color in P0
00EAC5  2  9C 12 A0           STZ   VGC_P1             ; high byte = 0
00EAC8  2  A9 08              LDA   #VCMD_GCOLOR      ; GCOLOR command
00EACA  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EACD  2               
00EACD  2               ; shared: load x(word),y(byte) into VGC_P0-P3
00EACD  2               
00EACD  2               LAB_VGC_XY
00EACD  2  20 0D D9           JSR   LAB_GTWRD         ; get x as 16-bit
00EAD0  2  A5 AF              LDA   FAC1_3
00EAD2  2  8D 11 A0           STA   VGC_P0             ; x low
00EAD5  2  A5 AE              LDA   FAC1_2
00EAD7  2  8D 12 A0           STA   VGC_P1             ; x high
00EADA  2  20 F6 CD           JSR   LAB_1C01          ; require comma
00EADD  2  20 1F D9           JSR   LAB_GTBY          ; get y as byte
00EAE0  2  8E 13 A0           STX   VGC_P2             ; y low
00EAE3  2  9C 14 A0           STZ   VGC_P3             ; y high = 0
00EAE6  2  60                 RTS
00EAE7  2               
00EAE7  2               ; shared: load x0,y0,x1,y1 into VGC_P0-P7
00EAE7  2               
00EAE7  2               LAB_VGC_XYXY
00EAE7  2  20 CD EA           JSR   LAB_VGC_XY        ; x0,y0 → P0-P3
00EAEA  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EAED  2  20 0D D9           JSR   LAB_GTWRD         ; x1 as 16-bit
00EAF0  2  A5 AF              LDA   FAC1_3
00EAF2  2  8D 15 A0           STA   VGC_P4             ; x1 low
00EAF5  2  A5 AE              LDA   FAC1_2
00EAF7  2  8D 16 A0           STA   VGC_P5             ; x1 high
00EAFA  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EAFD  2  20 1F D9           JSR   LAB_GTBY          ; y1
00EB00  2  8E 17 A0           STX   VGC_P6             ; y1 low
00EB03  2  9C 18 A0           STZ   VGC_P7             ; y1 high = 0
00EB06  2  60                 RTS
00EB07  2               
00EB07  2               ; perform PLOT x, y
00EB07  2               
00EB07  2               LAB_PLOT
00EB07  2  20 CD EA           JSR   LAB_VGC_XY
00EB0A  2  20 74 E9           JSR   LAB_VSYNC         ; wait before visible graphics mutation
00EB0D  2  A9 01              LDA   #VCMD_PLOT        ; PLOT command
00EB0F  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EB12  2               
00EB12  2               ; perform UNPLOT x, y
00EB12  2               
00EB12  2               LAB_UNPLOT
00EB12  2  20 CD EA           JSR   LAB_VGC_XY
00EB15  2  20 74 E9           JSR   LAB_VSYNC
00EB18  2  A9 02              LDA   #VCMD_UNPLOT      ; UNPLOT command
00EB1A  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EB1D  2               
00EB1D  2               ; perform LINE x0, y0, x1, y1
00EB1D  2               
00EB1D  2               LAB_GLINE
00EB1D  2  20 E7 EA           JSR   LAB_VGC_XYXY
00EB20  2  20 74 E9           JSR   LAB_VSYNC
00EB23  2  A9 03              LDA   #VCMD_LINE        ; LINE command
00EB25  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EB28  2               
00EB28  2               ; perform CIRCLE cx, cy, rx [, ry]
00EB28  2               ; 3 args = circle (rx=ry), 4 args = ellipse
00EB28  2               
00EB28  2               LAB_CIRCLE
00EB28  2  20 CD EA           JSR   LAB_VGC_XY        ; cx,cy → P0-P3
00EB2B  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EB2E  2  20 0D D9           JSR   LAB_GTWRD         ; rx as 16-bit
00EB31  2  A5 AF              LDA   FAC1_3
00EB33  2  8D 15 A0           STA   VGC_P4             ; rx low
00EB36  2  A5 AE              LDA   FAC1_2
00EB38  2  8D 16 A0           STA   VGC_P5             ; rx high
00EB3B  2  9C 17 A0           STZ   VGC_P6             ; ry low = 0 (circle)
00EB3E  2  9C 18 A0           STZ   VGC_P7             ; ry high = 0
00EB41  2  20 C2 00           JSR   LAB_GBYT          ; peek next
00EB44  2  C9 2C              CMP   #','
00EB46  2  D0 10              BNE   @circ_go
00EB48  2  20 F6 CD           JSR   LAB_1C01          ; consume comma
00EB4B  2  20 0D D9           JSR   LAB_GTWRD         ; ry as 16-bit
00EB4E  2  A5 AF              LDA   FAC1_3
00EB50  2  8D 17 A0           STA   VGC_P6             ; ry low
00EB53  2  A5 AE              LDA   FAC1_2
00EB55  2  8D 18 A0           STA   VGC_P7             ; ry high
00EB58  2               @circ_go
00EB58  2  20 74 E9           JSR   LAB_VSYNC
00EB5B  2  A9 04              LDA   #VCMD_CIRCLE      ; CIRCLE command
00EB5D  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EB60  2               
00EB60  2               ; perform GTEXT x, y, font, scale, "string"
00EB60  2               
00EB60  2               LAB_GTEXT
00EB60  2  20 CD EA           JSR   LAB_VGC_XY        ; x,y → P0-P3
00EB63  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EB66  2  20 1F D9           JSR   LAB_GTBY          ; font (0-7) → X
00EB69  2  8E 15 A0           STX   VGC_P4             ; P4 = font index
00EB6C  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EB6F  2  20 1F D9           JSR   LAB_GTBY          ; scale (1-8) → X
00EB72  2  8E 16 A0           STX   VGC_P5             ; P5 = scale
00EB75  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EB78  2  20 4B F3           JSR   LAB_FIO_GETNAME   ; string → FIO_NAME/FIO_NAMELEN
00EB7B  2  20 74 E9           JSR   LAB_VSYNC
00EB7E  2  A9 0A              LDA   #VCMD_GTEXT
00EB80  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EB83  2               
00EB83  2               ; ── Tile engine BASIC commands ────────────────────────────────
00EB83  2               ; Full tile command parsing lives in the extension ROM and dispatches through
00EB83  2               ; the shared tile library.
00EB83  2               
00EB83  2               LAB_TILESIZE
00EB83  2  A9 11              LDA   #EXT_CMD_TILESIZE
00EB85  2  4C 21 02           JMP   EXT_vec
00EB88  2               LAB_MIRROR
00EB88  2  A9 12              LDA   #EXT_CMD_TMIRROR
00EB8A  2  4C 21 02           JMP   EXT_vec
00EB8D  2               LAB_TTRANS
00EB8D  2  A9 13              LDA   #EXT_CMD_TTRANS
00EB8F  2  4C 21 02           JMP   EXT_vec
00EB92  2               LAB_TDEF
00EB92  2  A9 14              LDA   #EXT_CMD_TDEF
00EB94  2  4C 21 02           JMP   EXT_vec
00EB97  2               LAB_TPUT
00EB97  2  A9 15              LDA   #EXT_CMD_TPUT
00EB99  2  4C 21 02           JMP   EXT_vec
00EB9C  2               LAB_TATTR
00EB9C  2  A9 16              LDA   #EXT_CMD_TATTR
00EB9E  2  4C 21 02           JMP   EXT_vec
00EBA1  2               LAB_TFILL
00EBA1  2  A9 17              LDA   #EXT_CMD_TFILL
00EBA3  2  4C 21 02           JMP   EXT_vec
00EBA6  2               LAB_TROW
00EBA6  2  A9 18              LDA   #EXT_CMD_TROW
00EBA8  2  4C 21 02           JMP   EXT_vec
00EBAB  2               LAB_TCOL
00EBAB  2  A9 19              LDA   #EXT_CMD_TCOL
00EBAD  2  4C 21 02           JMP   EXT_vec
00EBB0  2               LAB_TNTLOAD
00EBB0  2  A9 1A              LDA   #EXT_CMD_TNTLOAD
00EBB2  2  4C 21 02           JMP   EXT_vec
00EBB5  2               LAB_TCLS
00EBB5  2  A9 1B              LDA   #EXT_CMD_TCLS
00EBB7  2  4C 21 02           JMP   EXT_vec
00EBBA  2               LAB_TBUF
00EBBA  2  A9 1C              LDA   #EXT_CMD_TBUF
00EBBC  2  4C 21 02           JMP   EXT_vec
00EBBF  2               LAB_TBSET
00EBBF  2  A9 1D              LDA   #EXT_CMD_TBSET
00EBC1  2  4C 21 02           JMP   EXT_vec
00EBC4  2               LAB_TBPUT
00EBC4  2  A9 1E              LDA   #EXT_CMD_TBPUT
00EBC6  2  4C 21 02           JMP   EXT_vec
00EBC9  2               LAB_TBFILL
00EBC9  2  A9 1F              LDA   #EXT_CMD_TBFILL
00EBCB  2  4C 21 02           JMP   EXT_vec
00EBCE  2               LAB_TSCROLL
00EBCE  2  A9 20              LDA   #EXT_CMD_TSCROLL
00EBD0  2  4C 21 02           JMP   EXT_vec
00EBD3  2               LAB_TPAL
00EBD3  2  A9 21              LDA   #EXT_CMD_TPAL
00EBD5  2  4C 21 02           JMP   EXT_vec
00EBD8  2               LAB_TPALC
00EBD8  2  A9 22              LDA   #EXT_CMD_TPALC
00EBDA  2  4C 21 02           JMP   EXT_vec
00EBDD  2               LAB_TSAVE
00EBDD  2  A9 16              LDA   #FioCmdTSave
00EBDF  2  2C                 .byte $2C
00EBE0  2               LAB_TLOAD
00EBE0  2  A9 17              LDA   #FioCmdTLoad
00EBE2  2  48                 PHA
00EBE3  2  20 4B F3           JSR   LAB_FIO_GETNAME
00EBE6  2  68                 PLA
00EBE7  2  20 C4 ED           JSR   fio_exec
00EBEA  2  F0 03              BEQ   @tfio_ok
00EBEC  2  4C 79 F3           JMP   LAB_FIO_ERRHND
00EBEF  2               @tfio_ok
00EBEF  2  60                 RTS
00EBF0  2               
00EBF0  2               ; perform RECT x0, y0, x1, y1
00EBF0  2               
00EBF0  2               LAB_RECT
00EBF0  2  20 E7 EA           JSR   LAB_VGC_XYXY
00EBF3  2  20 74 E9           JSR   LAB_VSYNC
00EBF6  2  A9 05              LDA   #VCMD_RECT        ; RECT command
00EBF8  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EBFB  2               
00EBFB  2               ; perform FILL x0, y0, x1, y1
00EBFB  2               
00EBFB  2               LAB_FILLRECT
00EBFB  2  20 E7 EA           JSR   LAB_VGC_XYXY
00EBFE  2  20 74 E9           JSR   LAB_VSYNC
00EC01  2  A9 06              LDA   #VCMD_FILL        ; FILL command
00EC03  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EC06  2               
00EC06  2               ; perform PAINT x, y
00EC06  2               
00EC06  2               LAB_PAINT
00EC06  2  20 CD EA           JSR   LAB_VGC_XY
00EC09  2  20 74 E9           JSR   LAB_VSYNC
00EC0C  2  A9 09              LDA   #VCMD_PAINT       ; PAINT command
00EC0E  2  4C 68 E9           JMP   LAB_VGC_CMD_RTS
00EC11  2               
00EC11  2               ; perform SPRITE n, ON/OFF  or  SPRITE n, x, y
00EC11  2               ; sprite number 0-15, ON/OFF enables/disables, x,y sets position
00EC11  2               ; Uses command-driven VGC interface:
00EC11  2               ;   SPRENA ($15): P0=sprite
00EC11  2               ;   SPRDIS ($16): P0=sprite
00EC11  2               ;   SPRPOS ($14): P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4 reserved
00EC11  2               
00EC11  2               LAB_SPRCMD
00EC11  2  20 1F D9           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EC14  2  86 11              STX   Itempl            ; save sprite number
00EC16  2  20 F6 CD           JSR   LAB_1C01          ; require comma
00EC19  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00EC1C  2  C9 93              CMP   #TK_ON            ; is it ON?
00EC1E  2  F0 25              BEQ   @spr_on
00EC20  2  C9 CB              CMP   #TK_OFF           ; is it OFF?
00EC22  2  F0 2C              BEQ   @spr_off
00EC24  2                     ; not ON/OFF — parse x, y position
00EC24  2  A5 11              LDA   Itempl            ; get sprite number
00EC26  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EC29  2  20 0D D9           JSR   LAB_GTWRD         ; get unsigned x as 16-bit
00EC2C  2  A5 AF              LDA   FAC1_3
00EC2E  2  8D 12 A0           STA   VGC_P1             ; P1 = x low
00EC31  2  A5 AE              LDA   FAC1_2
00EC33  2  8D 13 A0           STA   VGC_P2             ; P2 = x high
00EC36  2  20 F6 CD           JSR   LAB_1C01          ; require comma
00EC39  2  20 1F D9           JSR   LAB_GTBY          ; get unsigned y byte
00EC3C  2  8E 14 A0           STX   VGC_P3             ; P3 = y
00EC3F  2  9C 15 A0           STZ   VGC_P4             ; P4 reserved
00EC42  2  4C C0 E9           JMP   sprite_pos         ; trigger and return
00EC45  2               
00EC45  2               @spr_on
00EC45  2  20 BC 00           JSR   LAB_IGBY          ; consume the ON token
00EC48  2  A5 11              LDA   Itempl            ; get sprite number
00EC4A  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EC4D  2  4C C5 E9           JMP   sprite_enable      ; trigger and return
00EC50  2               
00EC50  2               @spr_off
00EC50  2  20 BC 00           JSR   LAB_IGBY          ; consume the OFF token
00EC53  2  A5 11              LDA   Itempl            ; get sprite number
00EC55  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EC58  2  4C CA E9           JMP   sprite_disable     ; trigger and return
00EC5B  2               
00EC5B  2               ; perform SPRITESHAPE n, shape
00EC5B  2               ; Writes shape index to sprite register VGC_SPR_SHAPE + n*8
00EC5B  2               
00EC5B  2               LAB_SPRSHAPE
00EC5B  2  20 1F D9           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EC5E  2  86 11              STX   Itempl
00EC60  2  20 F6 CD           JSR   LAB_1C01          ; require comma
00EC63  2  20 1F D9           JSR   LAB_GTBY          ; get shape index in X
00EC66  2  8A                 TXA
00EC67  2  A6 11              LDX   Itempl
00EC69  2  4C DF E9           JMP   sprite_set_shape
00EC6C  2               
00EC6C  2               ; perform SPRITESET sprite, field, value — set sprite register
00EC6C  2               ; Field 0 (X) accepts an unsigned word and writes lo+hi bytes.
00EC6C  2               ; Field 2 (Y) and all other fields accept a byte value.
00EC6C  2               ; Hardware vblank-buffers sprite attribute writes; software writes immediately.
00EC6C  2               
00EC6C  2               LAB_SPRCOLOR
00EC6C  2  20 1F D9           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EC6F  2  86 11              STX   Itempl            ; save sprite number
00EC71  2  20 F6 CD           JSR   LAB_1C01          ; require comma
00EC74  2  20 1F D9           JSR   LAB_GTBY          ; get field (0-7) in X
00EC77  2  86 12              STX   Itemph            ; save field number
00EC79  2  20 F6 CD           JSR   LAB_1C01          ; require comma
00EC7C  2  A5 12              LDA   Itemph            ; check field number
00EC7E  2  F0 0B              BEQ   @word_val
00EC80  2                     ; --- byte field: parse byte value ---
00EC80  2  20 1F D9           JSR   LAB_GTBY          ; get value (0-255) in X
00EC83  2  8A                 TXA                     ; A = value
00EC84  2  A6 11              LDX   Itempl            ; X = sprite number
00EC86  2  A4 12              LDY   Itemph            ; Y = field
00EC88  2  4C E1 E9           JMP   sprite_set_reg8
00EC8B  2               @word_val
00EC8B  2                     ; --- word field: parse unsigned word, write lo+hi ---
00EC8B  2  20 0D D9           JSR   LAB_GTWRD         ; get unsigned 16-bit value, lo in FAC1_3, hi in FAC1_2
00EC8E  2  A5 AF              LDA   FAC1_3
00EC90  2  85 20              STA   NVR0L
00EC92  2  A5 AE              LDA   FAC1_2
00EC94  2  85 21              STA   NVR0H
00EC96  2  A6 11              LDX   Itempl            ; X = sprite number
00EC98  2  A4 12              LDY   Itemph            ; Y = field
00EC9A  2  4C EC E9           JMP   sprite_set_reg16
00EC9D  2               
00EC9D  2               ; perform SPRITEDATA sprite, row, b1, b2 [, b3 [, b4 [, b5 [, b6 [, b7 [, b8]]]]]]
00EC9D  2               ; Uses CmdSprRow ($11): P0=sprite, P1=row, P2-P9=8 bytes of row data.
00EC9D  2               ; Unprovided bytes are zeroed.
00EC9D  2               
00EC9D  2               LAB_SPRDATA
00EC9D  2  20 1F D9           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00ECA0  2  8E 11 A0           STX   VGC_P0             ; P0 = sprite index
00ECA3  2  20 F6 CD           JSR   LAB_1C01          ; comma
00ECA6  2  20 1F D9           JSR   LAB_GTBY          ; get row (0-15) in X
00ECA9  2  8E 12 A0           STX   VGC_P1             ; P1 = row
00ECAC  2                     ; zero all 8 data bytes first
00ECAC  2  9C 13 A0           STZ   VGC_P2
00ECAF  2  9C 14 A0           STZ   VGC_P3
00ECB2  2  9C 15 A0           STZ   VGC_P4
00ECB5  2  9C 16 A0           STZ   VGC_P5
00ECB8  2  9C 17 A0           STZ   VGC_P6
00ECBB  2  9C 18 A0           STZ   VGC_P7
00ECBE  2  9C 19 A0           STZ   VGC_P8
00ECC1  2  9C 1A A0           STZ   VGC_P9
00ECC4  2                     ; parse b1 (required)
00ECC4  2  20 F6 CD           JSR   LAB_1C01          ; comma
00ECC7  2  20 1F D9           JSR   LAB_GTBY          ; b1 → X
00ECCA  2  8E 13 A0           STX   VGC_P2
00ECCD  2                     ; parse b2 (required)
00ECCD  2  20 F6 CD           JSR   LAB_1C01          ; comma
00ECD0  2  20 1F D9           JSR   LAB_GTBY          ; b2 → X
00ECD3  2  8E 14 A0           STX   VGC_P3
00ECD6  2                     ; parse optional b3-b8
00ECD6  2  20 C2 00           JSR   LAB_GBYT
00ECD9  2  C9 2C              CMP   #','
00ECDB  2  D0 59              BNE   @sd_done
00ECDD  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00ECE0  2  20 1F D9           JSR   LAB_GTBY          ; b3 → X
00ECE3  2  8E 15 A0           STX   VGC_P4
00ECE6  2  20 C2 00           JSR   LAB_GBYT
00ECE9  2  C9 2C              CMP   #','
00ECEB  2  D0 49              BNE   @sd_done
00ECED  2  20 BC 00           JSR   LAB_IGBY
00ECF0  2  20 1F D9           JSR   LAB_GTBY          ; b4 → X
00ECF3  2  8E 16 A0           STX   VGC_P5
00ECF6  2  20 C2 00           JSR   LAB_GBYT
00ECF9  2  C9 2C              CMP   #','
00ECFB  2  D0 39              BNE   @sd_done
00ECFD  2  20 BC 00           JSR   LAB_IGBY
00ED00  2  20 1F D9           JSR   LAB_GTBY          ; b5 → X
00ED03  2  8E 17 A0           STX   VGC_P6
00ED06  2  20 C2 00           JSR   LAB_GBYT
00ED09  2  C9 2C              CMP   #','
00ED0B  2  D0 29              BNE   @sd_done
00ED0D  2  20 BC 00           JSR   LAB_IGBY
00ED10  2  20 1F D9           JSR   LAB_GTBY          ; b6 → X
00ED13  2  8E 18 A0           STX   VGC_P7
00ED16  2  20 C2 00           JSR   LAB_GBYT
00ED19  2  C9 2C              CMP   #','
00ED1B  2  D0 19              BNE   @sd_done
00ED1D  2  20 BC 00           JSR   LAB_IGBY
00ED20  2  20 1F D9           JSR   LAB_GTBY          ; b7 → X
00ED23  2  8E 19 A0           STX   VGC_P8
00ED26  2  20 C2 00           JSR   LAB_GBYT
00ED29  2  C9 2C              CMP   #','
00ED2B  2  D0 09              BNE   @sd_done
00ED2D  2  20 BC 00           JSR   LAB_IGBY
00ED30  2  20 1F D9           JSR   LAB_GTBY          ; b8 → X
00ED33  2  8E 1A A0           STX   VGC_P9
00ED36  2               @sd_done
00ED36  2  4C CF E9           JMP   sprite_row         ; trigger and return
00ED39  2               
00ED39  2               ; perform SOUND note, duration [, instrument]
00ED39  2               ; SOUND 60, 10          — MIDI note 60, 10 frames, default instrument 0
00ED39  2               ; SOUND 60, 10, 3       — MIDI note 60, 10 frames, instrument 3
00ED39  2               
00ED39  2               LAB_FIO_CMD_RTS = fio_issue
00ED39  2               
00ED39  2               LAB_SOUND
00ED39  2  20 1F D9           JSR   LAB_GTBY          ; midi note → X
00ED3C  2  8E A4 B9           STX   FIO_SRCL          ; note
00ED3F  2  20 F6 CD           JSR   LAB_1C01          ; comma
00ED42  2  20 1F D9           JSR   LAB_GTBY          ; duration → X
00ED45  2  8E A5 B9           STX   FIO_SRCH          ; duration
00ED48  2  9C A6 B9           STZ   FIO_ENDL          ; default instrument = 0
00ED4B  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00ED4E  2  C9 2C              CMP   #','
00ED50  2  D0 09              BNE   @snd_go
00ED52  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00ED55  2  20 1F D9           JSR   LAB_GTBY          ; instrument id → X
00ED58  2  8E A6 B9           STX   FIO_ENDL
00ED5B  2               @snd_go
00ED5B  2  A9 0B              LDA   #FIO_CMD_SOUND
00ED5D  2  80 54              BRA   LAB_FIO_CMD_RTS
00ED5F  2               
00ED5F  2               ; perform VOLUME level (0-15)               — set master volume
00ED5F  2               ; perform VOLUME level, voice (0-255, 1-6)  — set per-voice volume
00ED5F  2               
00ED5F  2               LAB_VOLUME
00ED5F  2  20 1F D9           JSR   LAB_GTBY          ; level → X
00ED62  2  8E A4 B9           STX   FIO_SRCL
00ED65  2  9C A5 B9           STZ   FIO_SRCH          ; default voice = 0 (master)
00ED68  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00ED6B  2  C9 2C              CMP   #','
00ED6D  2  D0 09              BNE   @vol_go
00ED6F  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00ED72  2  20 1F D9           JSR   LAB_GTBY          ; voice → X
00ED75  2  8E A5 B9           STX   FIO_SRCH
00ED78  2               @vol_go
00ED78  2  A9 0C              LDA   #FIO_CMD_VOLUME
00ED7A  2  80 37              BRA   LAB_FIO_CMD_RTS
00ED7C  2               
00ED7C  2               ; perform INSTRUMENT id, waveform, a, d, s, r
00ED7C  2               ; Waveform: $10=TRI, $20=SAW, $40=PULSE, $80=NOISE
00ED7C  2               ; INSTRUMENT 1, $40, 0, 9, 0, 0
00ED7C  2               
00ED7C  2               LAB_ENVELOPE
00ED7C  2  20 1F D9           JSR   LAB_GTBY          ; id → X
00ED7F  2  8E A4 B9           STX   FIO_SRCL
00ED82  2  20 F6 CD           JSR   LAB_1C01          ; comma
00ED85  2  20 1F D9           JSR   LAB_GTBY          ; waveform → X
00ED88  2  8E A5 B9           STX   FIO_SRCH
00ED8B  2  20 F6 CD           JSR   LAB_1C01          ; comma
00ED8E  2  20 1F D9           JSR   LAB_GTBY          ; attack → X
00ED91  2  8E A6 B9           STX   FIO_ENDL
00ED94  2  20 F6 CD           JSR   LAB_1C01          ; comma
00ED97  2  20 1F D9           JSR   LAB_GTBY          ; decay → X
00ED9A  2  8E A7 B9           STX   FIO_ENDH
00ED9D  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EDA0  2  20 1F D9           JSR   LAB_GTBY          ; sustain → X
00EDA3  2  8E A8 B9           STX   FIO_SIZEL
00EDA6  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EDA9  2  20 1F D9           JSR   LAB_GTBY          ; release → X
00EDAC  2  8E A9 B9           STX   FIO_SIZEH
00EDAF  2  A9 0A              LDA   #FIO_CMD_INSTRUMENT
00EDB1  2  80 00              BRA   LAB_FIO_CMD_RTS
00EDB3  2               
00EDB3  2               FIO_NO_STREAMING = 1
00EDB3  2                     .include "lib/fio.s"
00EDB3  3               ; Shared Nova File I/O helper routines.
00EDB3  3               ;
00EDB3  3               ; This file is BASIC-agnostic. BASIC is still responsible for parsing language
00EDB3  3               ; expressions; assembly callers can load the FIO_ARG_* pseudo-registers and use
00EDB3  3               ; these helpers directly.
00EDB3  3               
00EDB3  3               .include "fio.inc"
00EDB3  4               ; Shared Nova File I/O helper declarations.
00EDB3  4               ;
00EDB3  4               ; Calling convention for pointer-based filename helpers:
00EDB3  4               ;   FIO_ARG_NAMELEN      filename length, 1..63
00EDB3  4               ;   FIO_ARG_NAMEPTR_L/H  CPU pointer to filename bytes
00EDB3  4               ;
00EDB3  4               ; Calling convention for XRAM streaming setup:
00EDB3  4               ;   FIO_ARG_ADDRL/M/H    flat 24-bit XRAM address
00EDB3  4               ;   FIO_ARG_LENL/H       transfer length; zero means full file for XLOAD
00EDB3  4               ;
00EDB3  4               ; Routines return A=0 on success and A=1 on error. Detailed status remains
00EDB3  4               ; in the FIO_STATUS/FIO_ERRCODE hardware registers.
00EDB3  4               
00EDB3  4               .ifndef FIO_INC_INCLUDED
00EDB3  4               FIO_INC_INCLUDED = 1
00EDB3  4               
00EDB3  4               .include "nova.inc"
00EDB3  5               ; Shared Nova hardware constants for BASIC, assembly, and runtime libraries.
00EDB3  5               ;
00EDB3  5               ; This include is deliberately guarded per symbol so it can coexist with older
00EDB3  5               ; source files that still define a subset of these names locally.
00EDB3  5               
00EDB3  5               .ifndef NOVA_INC_INCLUDED
00EDB3  5               NOVA_INC_INCLUDED = 1
00EDB3  5               
00EDB3  5               .ifndef NVR0L
00EDB3  5               NVR0L             = $20
