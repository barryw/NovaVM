00ECEB  6               
00ECEB  6               ; BASIC SYS register bridge. SYS addr[,A[,X[,Y]]] loads A/X/Y from these
00ECEB  6               ; bytes before jumping and stores A/X/Y back here when the routine returns.
00ECEB  6               ; @label SYS.REGA
00ECEB  6               ; @kind u8
00ECEB  6               ; @symbol SYS_REGA
00ECEB  6               ; @summary Returned A register from the most recent SYS call.
00ECEB  6               .ifndef SYS_REGA
00ECEB  6               SYS_REGA          = $E7
00ECEB  6               .endif
00ECEB  6               ; @label SYS.REGX
00ECEB  6               ; @kind u8
00ECEB  6               ; @symbol SYS_REGX
00ECEB  6               ; @summary Returned X register from the most recent SYS call.
00ECEB  6               .ifndef SYS_REGX
00ECEB  6               SYS_REGX          = $E8
00ECEB  6               .endif
00ECEB  6               ; @label SYS.REGY
00ECEB  6               ; @kind u8
00ECEB  6               ; @symbol SYS_REGY
00ECEB  6               ; @summary Returned Y register from the most recent SYS call.
00ECEB  6               .ifndef SYS_REGY
00ECEB  6               SYS_REGY          = $E9
00ECEB  6               .endif
00ECEB  6               
