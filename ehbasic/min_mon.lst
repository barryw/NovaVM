00E83A  2               ; --- VGC command handlers ---
00E83A  2               
00E83A  2               ; draw a text-only cold-start splash screen
00E83A  2               
00E83A  2               LAB_SPLASH
00E83A  2  9C 01 A0           STZ   VGC_BGCOL         ; black background
00E83D  2  A9 0F              LDA   #$0F              ; light grey text
00E83F  2  8D 02 A0           STA   VGC_FGCOL
00E842  2  A9 0B              LDA   #$0B              ; dark grey border
00E844  2  8D 0D A0           STA   VGC_BORDER
00E847  2  9C 00 A0           STZ   VGC_MODE          ; mode 0: text only
00E84A  2               
00E84A  2  A9 0C              LDA   #$0C              ; clear text layer and home cursor
00E84C  2  20 2C E8           JSR   V_OUTP
00E84F  2  A9 21              LDA   #$21              ; centered x for "NovaBASIC v1.0"
00E851  2  8D 03 A0           STA   VGC_CURSX
00E854  2  85 0E              STA   TPos
00E856  2  A9 01              LDA   #$01              ; leave breathing room on the first row
00E858  2  8D 04 A0           STA   VGC_CURSY
00E85B  2  A9 82              LDA   #<LAB_BNR1
00E85D  2  A0 E8              LDY   #>LAB_BNR1
00E85F  2  20 DD CA           JSR   LAB_18C3
00E862  2               
00E862  2  A9 1A              LDA   #$1A              ; centered x for "Derived from EhBASIC 2.22p5"
00E864  2  8D 03 A0           STA   VGC_CURSX
00E867  2  85 0E              STA   TPos
00E869  2  A9 03              LDA   #$03              ; one empty row between lines
00E86B  2  8D 04 A0           STA   VGC_CURSY
00E86E  2  A9 91              LDA   #<LAB_BNR2
00E870  2  A0 E8              LDY   #>LAB_BNR2
00E872  2  20 DD CA           JSR   LAB_18C3
00E875  2               
00E875  2  A9 11              LDA   #$11              ; centered x for "xxxxx BASIC bytes free  xxxK expansion memory"
00E877  2  8D 03 A0           STA   VGC_CURSX
00E87A  2  85 0E              STA   TPos
00E87C  2  A9 05              LDA   #$05              ; one empty row between lines
00E87E  2  8D 04 A0           STA   VGC_CURSY
