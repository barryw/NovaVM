00EF5B  2               
00EF5B  2               ; perform XLOAD "filename", offset [,length]
00EF5B  2               
00EF5B  2               LAB_XLOAD
00EF5B  2  20 4B F3           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EF5E  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EF61  2  20 47 EF           JSR   LAB_XFIO_SETOFF   ; XRAM destination offset + bank
00EF64  2  9C AD B9           STZ   FIO_GLENL         ; default: load full file
00EF67  2  9C AE B9           STZ   FIO_GLENH
00EF6A  2  20 C2 00           JSR   LAB_GBYT          ; optional comma,length
00EF6D  2  C9 2C              CMP   #','
00EF6F  2  D0 10              BNE   @xl_go
00EF71  2  20 F6 CD           JSR   LAB_1C01
00EF74  2  20 0D D9           JSR   LAB_GTWRD
00EF77  2  A5 AF              LDA   FAC1_3
00EF79  2  8D AD B9           STA   FIO_GLENL
