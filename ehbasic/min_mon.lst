00ED2B  2               
00ED2B  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00ED2B  2               @m_priority
00ED2B  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00ED2B  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00ED2B  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00ED2B  2               @m_pri_skip
00ED2B  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00ED2E  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00ED30  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00ED32  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00ED32  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00ED32  2                     ; Clear all 6 voice slots
00ED32  2  A9 00              LDA   #$00
00ED34  2  A0 05              LDY   #$05
00ED36  2               @m_pri_clr
