00E854  2               TileP1         = $A0C9
00E854  2               TileP2         = $A0CA
00E854  2               TileP3         = $A0CB
00E854  2               TileAddrL      = $A0CC
00E854  2               TileAddrH      = $A0CD
00E854  2               TilePalP0      = $A0CE
00E854  2               TilePalP1      = $A0CF
00E854  2               TileColL       = $A0D0
00E854  2               TileColH       = $A0D1
00E854  2               TilePeekVal    = $A0D2
00E854  2               TilePeekAttr   = $A0D3
00E854  2               TileCfgSize16  = $01
00E854  2               TileCmdDef     = $01
00E854  2               TileCmdDefBulk = $02
00E854  2               TileCmdPut     = $03
00E854  2               TileCmdAttr    = $04
00E854  2               TileCmdFill    = $05
00E854  2               TileCmdRow     = $06
00E854  2               TileCmdCol     = $07
00E854  2               TileCmdLoad    = $08
00E854  2               TileCmdPal     = $0A
00E854  2               TileCmdPalC    = $0B
00E854  2               TileCmdPeek    = $0C
00E854  2               TileCmdCls     = $0F
00E854  2               TileCmdBufFill = $10
00E854  2               TileCmdBufSet  = $11
