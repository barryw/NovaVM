00E82C  2               NIC_CMD_DISCONNECT = $02
00E82C  2               NIC_CMD_SEND       = $03
00E82C  2               NIC_CMD_RECV       = $04
00E82C  2               NIC_CMD_LISTEN     = $05
00E82C  2               NIC_CMD_ACCEPT     = $06
00E82C  2               
00E82C  2               NIC_ST_CONNECTED   = $01
00E82C  2               NIC_ST_DATAREADY   = $02
00E82C  2               NIC_ST_ERROR       = $08
