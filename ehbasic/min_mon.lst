00FF6C  2               
00FF6C  2               AA_end_basic
00FF6C  2               
00FF6C  1               
00FF6C  1               ; put the IRQ and NMI code in RAM so that it can be changed
00FF6C  1               
00FF6C  1               IRQ_vec     = VEC_SV+2        ; IRQ code vector
00FF6C  1               NMI_vec     = IRQ_vec+$0A     ; NMI code vector
00FF6C  1               ; EXT_vec defined in basic.asm (= VEC_SV+$16 = $0221)
00FF6C  1               EXT_RST     = EXT_vec+$12     ; extension ROM reset recovery in RAM
00FF6C  1               EXT_GTBY    = EXT_RST+$08     ; bridge: extension → BASIC LAB_GTBY → extension
00FF6C  1               EXT_GTWRD   = EXT_GTBY+$0E    ; bridge: extension → BASIC LAB_GTWRD → extension
00FF6C  1               EXT_SNERR   = EXT_GTWRD+$0E   ; bridge: extension → BASIC LAB_15D9 (syntax error)
00FF6C  1               
00FF6C  1               ; setup for the 6502 simulator environment
00FF6C  1               
00FF6C  1               IO_AREA     = $F000           ; set I/O area for this monitor
00FF6C  1               
00FF6C  1               ACIAsimwr   = $A00E           ; VGC CHAROUT
00FF6C  1               ACIAsimrd   = $A00F           ; VGC CHARIN
00FF6C  1               
00FF6C  1               ; --- Data block copied to RAM at boot (vectors + interrupt + extension code) ---
00FF6C  1               ; This block is stored in ROM (CODE segment) and copied to VEC_IN at init.
00FF6C  1               
00FF6C  1               LAB_vec
00FF6C  1  ED FF              .word ACIAin            ; byte in from simulated ACIA
00FF6E  1  E9 FF              .word ACIAout           ; byte out to simulated ACIA
00FF70  1  2A EF              .word LAB_FLOAD         ; load vector for EhBASIC
00FF72  1  D3 EE              .word LAB_FSAVE         ; save vector for EhBASIC
00FF74  1               
00FF74  1               ; EhBASIC IRQ support
00FF74  1               
00FF74  1               IRQ_CODE
00FF74  1  48                 PHA                     ; save A
00FF75  1  A5 DF              LDA   IrqBase           ; get the IRQ flag byte
00FF77  1  4A                 LSR                     ; shift the set b7 to b6, and on down ...
00FF78  1  05 DF              ORA   IrqBase           ; OR the original back in
00FF7A  1  85 DF              STA   IrqBase           ; save the new IRQ flag byte
00FF7C  1  68                 PLA                     ; restore A
00FF7D  1  40                 RTI
00FF7E  1               
00FF7E  1               ; EhBASIC NMI support
00FF7E  1               
00FF7E  1               NMI_CODE
00FF7E  1  48                 PHA                     ; save A
00FF7F  1  A5 DC              LDA   NmiBase           ; get the NMI flag byte
00FF81  1  4A                 LSR                     ; shift the set b7 to b6, and on down ...
00FF82  1  05 DC              ORA   NmiBase           ; OR the original back in
00FF84  1  85 DC              STA   NmiBase           ; save the new NMI flag byte
00FF86  1  68                 PLA                     ; restore A
00FF87  1  40                 RTI
00FF88  1               
00FF88  1               ; Extension ROM call trampoline (runs from RAM)
00FF88  1               ; Called with command ID in A. Swaps to extension ROM, calls $C000,
00FF88  1               ; swaps back to BASIC ROM, returns with handler result in A.
00FF88  1               
00FF88  1               EXT_CODE
00FF88  1  85 E4              STA   ExtCmdId          ; save command ID to ZP
00FF8A  1  A9 04              LDA   #$04              ; RomSwapExtension
00FF8C  1  8D 3F A0           STA   $A03F             ; swap to extension ROM
00FF8F  1  20 00 C0           JSR   $C000             ; call extension entry point
00FF92  1  48                 PHA                     ; save handler return value
00FF93  1  A9 02              LDA   #$02              ; RomSwapBasic
00FF95  1  8D 3F A0           STA   $A03F             ; swap back to BASIC ROM
00FF98  1  68                 PLA                     ; restore handler return value
00FF99  1  60                 RTS
00FF9A  1               
00FF9A  1               ; Extension ROM reset recovery (runs from RAM)
00FF9A  1               ; If RESET fires while extension ROM is active, extension ROM's reset
00FF9A  1               ; handler jumps here. Swaps back to BASIC ROM and continues reset.
00FF9A  1               
00FF9A  1               EXT_RESET_CODE
00FF9A  1  A9 02              LDA   #$02              ; RomSwapBasic
00FF9C  1  8D 3F A0           STA   $A03F             ; swap to BASIC ROM
00FF9F  1  4C D7 FF           JMP   $FFD7             ; jump to BASIC reset handler (RES_vec)
00FFA2  1               
00FFA2  1               ; Extension → BASIC bridges (run from RAM at $0236, $0244, $0252).
00FFA2  1               ; Extension ROM handlers JSR these to invoke BASIC parser helpers
00FFA2  1               ; (numeric expression eval, syntax error) without losing access to
00FFA2  1               ; the active ROM bank. Each trampoline maps BASIC, calls the helper,
00FFA2  1               ; remaps extension, and returns. Result conventions match the wrapped
00FFA2  1               ; BASIC routines: GTBY → X, GTWRD → FAC1_3 (lo) / FAC1_2 (hi). SNERR
00FFA2  1               ; never returns — jumps into BASIC's standard syntax-error path.
00FFA2  1               
00FFA2  1               EXT_GTBY_CODE
00FFA2  1  A9 02              LDA   #$02              ; RomSwapBasic
00FFA4  1  8D 3F A0           STA   $A03F             ; swap to BASIC ROM
00FFA7  1  20 0F D9           JSR   LAB_GTBY          ; parse byte expression → X
00FFAA  1  A9 04              LDA   #$04              ; RomSwapExtension
00FFAC  1  8D 3F A0           STA   $A03F             ; swap back
00FFAF  1  60                 RTS                     ; X holds parsed byte
00FFB0  1               
00FFB0  1               EXT_GTWRD_CODE
00FFB0  1  A9 02              LDA   #$02
00FFB2  1  8D 3F A0           STA   $A03F
00FFB5  1  20 FD D8           JSR   LAB_GTWRD         ; parse 16-bit expression → FAC1_3 (lo), FAC1_2 (hi)
00FFB8  1  A9 04              LDA   #$04
00FFBA  1  8D 3F A0           STA   $A03F
00FFBD  1  60                 RTS
00FFBE  1               
00FFBE  1               EXT_SNERR_CODE
00FFBE  1  A9 02              LDA   #$02              ; RomSwapBasic
00FFC0  1  8D 3F A0           STA   $A03F             ; swap to BASIC ROM
00FFC3  1  4C C0 C5           JMP   LAB_15D9          ; jump to BASIC syntax-error path (no return)
00FFC6  1               
00FFC6  1               END_CODE
00FFC6  1               
00FFC6  1               ; --- Monitor code (in MONITOR segment at $FFD7) ---
00FFC6  1               
00FFC6  1                     .segment "MONITOR"
00FFC6  1                     .org    $FFD7
00FFD7  1               
00FFD7  1               ; reset vector points here
00FFD7  1               
00FFD7  1               RES_vec
00FFD7  1  D8                 CLD                     ; clear decimal mode
00FFD8  1  A2 FF              LDX   #$FF              ; empty stack
00FFDA  1  9A                 TXS                     ; set the stack
00FFDB  1               
00FFDB  1               ; set up vectors, interrupt code, and extension trampoline — copy to page 2
00FFDB  1               
00FFDB  1  A0 5A              LDY   #END_CODE-LAB_vec ; set index/count
00FFDD  1               LAB_stlp
00FFDD  1  B9 6B FF           LDA   LAB_vec-1,Y       ; get byte from ROM data block
00FFE0  1  99 04 02           STA   VEC_IN-1,Y        ; save to RAM
00FFE3  1  88                 DEY                     ; decrement index/count
00FFE4  1  D0 F7              BNE   LAB_stlp          ; loop if more to do
00FFE6  1               
00FFE6  1  4C 00 C0           JMP   LAB_COLD          ; always do EhBASIC cold start
00FFE9  1               
00FFE9  1               ; byte out to simulated ACIA
00FFE9  1               
00FFE9  1               ACIAout
00FFE9  1  8D 0E A0           STA   ACIAsimwr         ; save byte to simulated ACIA
00FFEC  1  60                 RTS
00FFED  1               
00FFED  1               ; byte in from simulated ACIA
00FFED  1               
00FFED  1               ACIAin
00FFED  1  AD 0F A0           LDA   ACIAsimrd         ; get byte from simulated ACIA
00FFF0  1  F0 02              BEQ   LAB_nobyw         ; branch if no byte waiting
00FFF2  1               
00FFF2  1  38                 SEC                     ; flag byte received
00FFF3  1  60                 RTS
00FFF4  1               
00FFF4  1               LAB_nobyw
00FFF4  1  18                 CLC                     ; flag no byte received
00FFF5  1  60                 RTS
00FFF6  1               
00FFF6  1               ; system vectors
00FFF6  1               
00FFF6  1                     .segment "VECTORS"
00FFF6  1                     .org    $FFFA
00FFFA  1               
00FFFA  1  17 02              .word NMI_vec           ; NMI vector
00FFFC  1  D7 FF              .word RES_vec           ; RESET vector
00FFFE  1  0D 02              .word IRQ_vec           ; IRQ vector
00FFFE  1               
