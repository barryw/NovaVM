00E8AD  3                     .segment "CODE"
00E8AD  3               
00E8AD  3                     .export vgc_cmd
00E8AD  3                     .export vgc_wait_cmd
00E8AD  3               .ifndef VGC_NO_EXEC
00E8AD  3                     .export vgc_exec
00E8AD  3               .endif
00E8AD  3                     .export vgc_vsync
00E8AD  3                     .export vgc_cls
00E8AD  3                     .export vgc_set_fg
00E8AD  3                     .export vgc_set_bg
00E8AD  3                     .export vgc_set_border
00E8AD  3                     .export vgc_locate
00E8AD  3                     .export vgc_set_mode
00E8AD  3                     .export vgc_set_font
00E8AD  3                     .export vgc_mem_read
00E8AD  3                     .export vgc_mem_write
00E8AD  3                     .export vgc_reverse_default
00E8AD  3                     .export vgc_reverse_explicit
00E8AD  3                     .export vgc_reverse_off
00E8AD  3                     .export vgc_flash_on
00E8AD  3                     .export vgc_flash_off
