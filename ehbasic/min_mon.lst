00F1C4  2               ; perform PWD — print working directory
00F1C4  2               
00F1C4  2               LAB_PWD
00F1C4  2  A9 03              LDA   #EXT_CMD_PWD
00F1C6  2  4C 21 02           JMP   EXT_vec            ; extension ROM handles output
00F1C9  2               
