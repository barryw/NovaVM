00EE51  2               
00EE51  2               LAB_WAVE
00EE51  2  4C DE C5           JMP   LAB_15D9          ; syntax error
00EE54  2               
00EE54  2               ; --- VGC function handlers ---
00EE54  2               
00EE54  2               ; perform SPRITEX(n) — return X position of sprite n as unsigned word
00EE54  2               
00EE54  2               LAB_SPRITEX
00EE54  2  20 00 D9           JSR   LAB_F2FX          ; convert FAC1 to integer, low byte in Itempl
00EE57  2  A6 11              LDX   Itempl            ; get sprite number
00EE59  2  20 67 E9           JSR   sprite_get_x      ; Y = X low byte, A = X high byte
00EE5C  2  4C 5B D4           JMP   LAB_AYFC          ; return AY as numeric value
00EE5F  2               
00EE5F  2               ; perform SPRITEY(n) — return Y position of sprite n as unsigned byte
00EE5F  2               
00EE5F  2               LAB_SPRITEY
00EE5F  2  20 00 D9           JSR   LAB_F2FX          ; convert FAC1 to integer, low byte in Itempl
00EE62  2  A6 11              LDX   Itempl            ; get sprite number
00EE64  2  20 78 E9           JSR   sprite_get_y      ; Y = Y position
00EE67  2  4C 8F D1           JMP   LAB_RET_0AY       ; return AY as numeric value
00EE6A  2               
00EE6A  2               ; perform COLLISION(n) — return sprite-sprite collision register
00EE6A  2               ; argument already consumed by preprocessor
00EE6A  2               
00EE6A  2               LAB_COLLISION
00EE6A  2  20 82 E9           JSR   sprite_collision_status
00EE6D  2  A8                 TAY
00EE6E  2  4C 8F D1           JMP   LAB_RET_0AY
00EE71  2               
00EE71  2               ; perform BUMPED(n) — return sprite-background collision register
00EE71  2               
00EE71  2               LAB_BUMPED
00EE71  2  20 86 E9           JSR   sprite_background_collision_status
00EE74  2  A8                 TAY
00EE75  2  4C 8F D1           JMP   LAB_RET_0AY
00EE78  2               
00EE78  2               ; --- File I/O command handlers ---
00EE78  2               
00EE78  2               ; perform SAVE "filename"                     (program save)
