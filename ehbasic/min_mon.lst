000000r 2               ; opperator tokens
000000r 2               
000000r 2               TK_PLUS           = TK_OFF+1        ; + token
000000r 2               TK_MINUS          = TK_PLUS+1       ; - token
000000r 2               TK_MUL            = TK_MINUS+1      ; * token
000000r 2               TK_DIV            = TK_MUL+1        ; / token
000000r 2               TK_POWER          = TK_DIV+1        ; ^ token
000000r 2               TK_AND            = TK_POWER+1      ; AND token
000000r 2               TK_EOR            = TK_AND+1        ; EOR token
000000r 2               TK_OR             = TK_EOR+1        ; OR token
000000r 2               TK_RSHIFT         = TK_OR+1         ; RSHIFT token
000000r 2               TK_LSHIFT         = TK_RSHIFT+1     ; LSHIFT token
000000r 2               TK_GT             = TK_LSHIFT+1     ; > token
000000r 2               TK_EQUAL          = TK_GT+1         ; = token
000000r 2               TK_LT             = TK_EQUAL+1      ; < token
000000r 2               
000000r 2               ; functions tokens
000000r 2               
000000r 2               TK_SGN            = TK_LT+1         ; SGN token
000000r 2               TK_INT            = TK_SGN+1        ; INT token
000000r 2               TK_ABS            = TK_INT+1        ; ABS token
000000r 2               TK_USR            = TK_ABS+1        ; USR token
000000r 2               TK_FRE            = TK_USR+1        ; FRE token
000000r 2               TK_POS            = TK_FRE+1        ; POS token
000000r 2               TK_SQR            = TK_POS+1        ; SQR token
000000r 2               TK_RND            = TK_SQR+1        ; RND token
000000r 2               TK_LOG            = TK_RND+1        ; LOG token
000000r 2               TK_EXP            = TK_LOG+1        ; EXP token
000000r 2               TK_COS            = TK_EXP+1        ; COS token
000000r 2               TK_SIN            = TK_COS+1        ; SIN token
000000r 2               TK_TAN            = TK_SIN+1        ; TAN token
000000r 2               TK_ATN            = TK_TAN+1        ; ATN token
000000r 2               TK_PEEK           = TK_ATN+1        ; PEEK token
000000r 2               TK_DEEK           = TK_PEEK+1       ; DEEK token
000000r 2               TK_SADD           = TK_DEEK+1       ; SADD token
000000r 2               TK_LEN            = TK_SADD+1       ; LEN token
000000r 2               TK_STRS           = TK_LEN+1        ; STR$ token
000000r 2               TK_VAL            = TK_STRS+1       ; VAL token
000000r 2               TK_ASC            = TK_VAL+1        ; ASC token
000000r 2               TK_UCASES         = TK_ASC+1        ; UCASE$ token
000000r 2               TK_LCASES         = TK_UCASES+1     ; LCASE$ token
000000r 2               TK_CHRS           = TK_LCASES+1     ; CHR$ token
000000r 2               TK_HEXS           = TK_CHRS+1       ; HEX$ token
000000r 2               TK_BINS           = TK_HEXS+1       ; BIN$ token
000000r 2               TK_BITTST         = TK_BINS+1       ; BITTST token
000000r 2               TK_MAX            = TK_BITTST+1     ; MAX token
000000r 2               TK_MIN            = TK_MAX+1        ; MIN token
000000r 2               TK_PI             = TK_MIN+1        ; PI token
000000r 2               TK_TWOPI          = TK_PI+1         ; TWOPI token
000000r 2               TK_VPTR           = TK_TWOPI+1      ; VARPTR token
000000r 2               TK_LEFTS          = TK_VPTR+1       ; LEFT$ token
000000r 2               TK_RIGHTS         = TK_LEFTS+1      ; RIGHT$ token
000000r 2               TK_MIDS           = TK_RIGHTS+1     ; MID$ token
000000r 2               
000000r 2               ; --- VGC Function Tokens ---
000000r 2               TK_SPRITEX        = TK_MIDS+1       ; SPRITEX(
000000r 2               TK_SPRITEY        = TK_SPRITEX+1    ; SPRITEY(
000000r 2               TK_COLLISION      = TK_SPRITEY+1    ; COLLISION(
000000r 2               TK_BUMPED         = TK_COLLISION+1   ; BUMPED(
000000r 2               
000000r 2               ; --- Extended 2-byte tokens ---
000000r 2               ; First byte is a prefix marker in tokenized BASIC text, second byte is ext id.
000000r 2               
000000r 2               TKX_PREFIX        = $01              ; extended token prefix byte
000000r 2               XTK_DIR           = $01              ; extended token id: DIR
000000r 2               XTK_DEL           = $02              ; extended token id: DEL
000000r 2               XTK_XMEM          = $03              ; extended token id: XMEM
000000r 2               XTK_XBANK         = $04              ; extended token id: XBANK
000000r 2               XTK_XPOKE         = $05              ; extended token id: XPOKE
000000r 2               XTK_XPEEK         = $06              ; extended token id: XPEEK(
000000r 2               XTK_STASH         = $07              ; extended token id: STASH
000000r 2               XTK_FETCH         = $08              ; extended token id: FETCH
000000r 2               XTK_XFREE         = $09              ; extended token id: XFREE
000000r 2               XTK_XRESET        = $0A              ; extended token id: XRESET
000000r 2               XTK_XALLOC        = $0B              ; extended token id: XALLOC
000000r 2               XTK_XDIR          = $0C              ; extended token id: XDIR
000000r 2               XTK_XDEL          = $0D              ; extended token id: XDEL
000000r 2               XTK_XMAP          = $0E              ; extended token id: XMAP
000000r 2               XTK_XUNMAP        = $0F              ; extended token id: XUNMAP
000000r 2               XTK_GSAVE         = $10              ; extended token id: GSAVE
000000r 2               XTK_GLOAD         = $11              ; extended token id: GLOAD
000000r 2               XTK_SIDPLAY       = $12              ; extended token id: SIDPLAY
000000r 2               XTK_SIDSTOP       = $13              ; extended token id: SIDSTOP
000000r 2               XTK_MUSIC         = $14              ; extended token id: MUSIC
000000r 2               XTK_PLAYING       = $15              ; extended token id: PLAYING (function)
000000r 2               XTK_MNOTE         = $16              ; extended token id: MNOTE( (function)
000000r 2               XTK_COPPER        = $17              ; extended token id: COPPER
000000r 2               XTK_RESET         = $18              ; extended token id: RESET
000000r 2               XTK_NOPEN         = $19              ; NOPEN slot,"host",port
000000r 2               XTK_NCLOSE        = $1A              ; NCLOSE slot
000000r 2               XTK_NLISTEN       = $1B              ; NLISTEN slot,port
000000r 2               XTK_NACCEPT       = $1C              ; NACCEPT slot
000000r 2               XTK_NSEND         = $1D              ; NSEND slot,A$
000000r 2               XTK_NRECV         = $1E              ; NRECV$(slot) — string function
000000r 2               XTK_NSTATUS       = $1F              ; NSTATUS(slot) — numeric function
000000r 2                                                     ; $20 reserved — collides with ASCII space
000000r 2                                                     ; (LAB_IGBY skips $20 during scan)
000000r 2               XTK_NREADY        = $21              ; NREADY(slot) — numeric function
000000r 2               XTK_NLEN          = $22              ; NLEN — numeric function (no args)
000000r 2               XTK_DMACOPY       = $23              ; DMACOPY srcSpace,srcAddr,dstSpace,dstAddr,len
000000r 2               XTK_DMAFILL       = $24              ; DMAFILL dstSpace,dstAddr,len,value
000000r 2               XTK_DMASTATUS     = $25              ; DMASTATUS — numeric function (no args)
000000r 2                                                     ; $26 reserved — maps to AND token in scanner
000000r 2               XTK_DMAERR        = $27              ; DMAERR — numeric function (no args)
000000r 2               XTK_DMACOUNT      = $28              ; DMACOUNT — numeric function (no args)
000000r 2               XTK_MIDPLAY       = $29              ; MIDPLAY "filename" — play MIDI file
000000r 2               XTK_MIDSTOP       = $2A              ; MIDSTOP — stop MIDI playback
000000r 2                                                     ; $2B-$30 directory/metadata tokens
000000r 2               XTK_XLOAD         = $31              ; XLOAD "filename",offset[,length]
000000r 2               XTK_XSAVE         = $32              ; XSAVE "filename",offset,length
000000r 2                                                     ; $33-$3F reserved
000000r 2               XTK_BLITCOPY      = $40              ; BLITCOPY srcSpace,srcAddr,srcStride,dstSpace,dstAddr,dstStride,width,height
000000r 2               XTK_BLITFILL      = $41              ; BLITFILL dstSpace,dstAddr,dstStride,width,height,value
000000r 2               XTK_BLITSTATUS    = $42              ; BLITSTATUS — numeric function (no args)
000000r 2               XTK_BLITERR       = $43              ; BLITERR — numeric function (no args)
000000r 2               XTK_BLITCOUNT     = $44              ; BLITCOUNT — numeric function (no args)
000000r 2               XTK_BITTGL        = $45              ; BITTGL addr,mask — toggle bits
000000r 2               XTK_HELP           = $46              ; HELP [keyword] — open help panel
000000r 2               XTK_NCC            = $47              ; NCC — activate NCC editor
000000r 2               XTK_FONT           = $48              ; FONT n — select font slot (0-7)
000000r 2               XTK_CD             = $49              ; CD "path"
000000r 2               XTK_MKDIR          = $4A              ; MKDIR "path"
000000r 2               XTK_RMDIR          = $4B              ; RMDIR "path"
000000r 2               XTK_FORMAT         = $4C              ; FORMAT "dev:",size
000000r 2               XTK_MOUNT          = $4D              ; MOUNT "dev:","image"
000000r 2               XTK_UNMOUNT        = $4E              ; UNMOUNT "dev:"
000000r 2               XTK_PWD            = $4F              ; PWD
000000r 2               XTK_SFLOAD         = $50              ; SFLOAD "filename" — load soundfont
000000r 2               XTK_GTEXT          = $51              ; GTEXT x,y,font,scale,"string"
000000r 2               XTK_TILESIZE       = $52              ; TILESIZE n
000000r 2               XTK_MIRROR         = $53              ; MIRROR n
000000r 2               XTK_TTRANS         = $54              ; TTRANS n
000000r 2               XTK_TDEF           = $55              ; TDEF tile#,addr / TDEF start,count,addr
000000r 2               XTK_TPUT           = $56              ; TPUT nt,x,y,tile#
000000r 2               XTK_TATTR          = $57              ; TATTR nt,x,y,attr
000000r 2               XTK_TFILL          = $58              ; TFILL nt,tile#
000000r 2               XTK_TROW           = $59              ; TROW nt,y,addr
000000r 2               XTK_TCOL           = $5A              ; TCOL nt,x,addr
000000r 2               XTK_TNTLOAD        = $5B              ; TNTLOAD nt,addr
000000r 2               XTK_TCLS           = $5C              ; TCLS
000000r 2               XTK_TSCROLLX       = $5D              ; TSCROLLX — function (no args)
000000r 2               XTK_TSCROLLY       = $5E              ; TSCROLLY — function (no args)
000000r 2               XTK_TSCROLL        = $5F              ; TSCROLL x,y
000000r 2               XTK_TPALC          = $60              ; TPALC sub,color,r,g,b
000000r 2               XTK_TPAL           = $61              ; TPAL sub,addr
000000r 2               XTK_TSAVE          = $62              ; TSAVE "file"
000000r 2               XTK_TLOAD          = $63              ; TLOAD "file"
000000r 2               XTK_TPEEK          = $64              ; TPEEK(nt,x,y) — function
000000r 2               XTK_TPEEKATTR      = $65              ; TPEEKATTR(nt,x,y) — function
000000r 2               XTK_TILECOL        = $66              ; TILECOL — function (no args)
000000r 2               XTK_TBUF           = $67              ; TBUF tile — fill column buffer
000000r 2               XTK_TBSET          = $68              ; TBSET row,tile — set buffer entry
000000r 2               XTK_TBFILL         = $69              ; TBFILL y1,y2,tile — fill buffer range
000000r 2               XTK_TBPUT          = $6A              ; TBPUT nt,x — write buffer to nametable
000000r 2               XTK_REVERSE        = $6B              ; REVERSE [fg,bg] — reverse text output
000000r 2               XTK_REVERSEOFF     = $6C              ; REVERSEOFF — normal text output
000000r 2               XTK_FLASH          = $6D              ; FLASH — flashing text output
000000r 2               XTK_FLASHOFF       = $6E              ; FLASHOFF — non-flashing text output
000000r 2               XTK_VPOKE          = $6F              ; VPOKE plane,addr,value — write VGC memory
000000r 2               XTK_VPEEK          = $70              ; VPEEK(plane,addr) — read VGC memory
000000r 2               XTK_DIROPEN        = $2B              ; DIROPEN "pattern"
000000r 2               XTK_DIRNEXT        = $2C              ; DIRNEXT — numeric function
000000r 2               XTK_DIRNAM         = $2D              ; DIRNAM$ — string function
000000r 2               XTK_DIRSIZ         = $2E              ; DIRSIZ — numeric function
000000r 2               XTK_DIRTYP         = $2F              ; DIRTYP — numeric function
000000r 2               XTK_META           = $30              ; META$(n) — string function
000000r 2               
000000r 2               ; offsets from a base of X or Y
000000r 2               
000000r 2               PLUS_0            = $00       ; X or Y plus 0
000000r 2               PLUS_1            = $01       ; X or Y plus 1
000000r 2               PLUS_2            = $02       ; X or Y plus 2
000000r 2               PLUS_3            = $03       ; X or Y plus 3
000000r 2               
000000r 2               LAB_STAK          = $0100     ; stack bottom, no offset
000000r 2               
000000r 2               LAB_SKFE          = LAB_STAK+$FE
000000r 2                                             ; flushed stack address
000000r 2               LAB_SKFF          = LAB_STAK+$FF
000000r 2                                             ; flushed stack address
000000r 2               
000000r 2               ; the following locations are bulk initialized from PG2_TABS at LAB_COLD
000000r 2               ccflag            = $0200     ; BASIC CTRL-C flag, 00 = enabled, 01 = dis
000000r 2               ccbyte            = ccflag+1  ; BASIC CTRL-C byte
000000r 2               ccnull            = ccbyte+1  ; BASIC CTRL-C byte timeout
000000r 2               
000000r 2               VEC_CC            = ccnull+1  ; ctrl c check vector
000000r 2               ; end bulk initialize from PG2_TABS at LAB_COLD
000000r 2               
000000r 2               ; the following locations are bulk initialized by min_mon.asm from LAB_vec at LAB_stlp
000000r 2               VEC_IN            = VEC_CC+2  ; input vector
000000r 2               VEC_OUT           = VEC_IN+2  ; output vector
000000r 2               VEC_LD            = VEC_OUT+2 ; load vector
000000r 2               VEC_SV            = VEC_LD+2  ; save vector
000000r 2               ; end bulk initialize by min_mon.asm from LAB_vec at LAB_stlp
000000r 2               
000000r 2               ; Ibuffs can now be anywhere in RAM, ensure that the max length is < $80,
000000r 2               ; the input buffer must not cross a page boundary and must not overlap with
000000r 2               ; program RAM pages!
000000r 2               
000000r 2               ;Ibuffs            = IRQ_vec+$14
000000r 2               EXT_vec           = VEC_SV+$16
000000r 2                                             ; extension ROM call trampoline in RAM ($0221)
000000r 2                                             ; Followed by EXT_RESET_CODE ($022E, 8 bytes) and
000000r 2                                             ; the Extension→BASIC bridge trampolines:
000000r 2                                             ;   EXT_GTBY  ($0236, 14 bytes) — parse byte expr
000000r 2                                             ;   EXT_GTWRD ($0244, 14 bytes) — parse 16-bit expr
000000r 2                                             ;   EXT_SNERR ($0252,  8 bytes) — syntax error
000000r 2               Ibuffs            = VEC_SV+$54
000000r 2                                             ; start of input buffer after IRQ/NMI/ext code
000000r 2               Ibuffe            = Ibuffs+$A0; end of input buffer (160 bytes, ends at $02FA)
000000r 2               
000000r 2               Ram_base          = $0300     ; start of user RAM (set as needed, should be page aligned)
000000r 2               Ram_top           = $A000     ; end of contiguous BASIC RAM+1 (before MMIO window)
000000r 2               
000000r 2               Stack_floor       = 16        ; bytes left free on stack for background interrupts
000000r 2               
000000r 2               ; This start can be changed to suit your system
000000r 2               
000000r 2                     .segment "CODE"
000000r 2                     .org    $C000
00C000  2               
00C000  2               ; BASIC cold start entry point
00C000  2               
00C000  2               ; new page 2 initialisation, copy block to ccflag on
00C000  2               
00C000  2               LAB_COLD
00C000  2  A0 04              LDY   #PG2_TABE-PG2_TABS-1
00C002  2                                             ; byte count-1
00C002  2               LAB_2D13
00C002  2  B9 E0 E8           LDA   PG2_TABS,Y        ; get byte
00C005  2  99 00 02           STA   ccflag,Y          ; store in page 2
00C008  2  88                 DEY                     ; decrement count
00C009  2  10 F7              BPL   LAB_2D13          ; loop if not done
00C00B  2               
00C00B  2  A2 FF              LDX   #$FF              ; set byte
00C00D  2  86 88              STX   Clineh            ; set current line high byte (set immediate mode)
00C00F  2  9A                 TXS                     ; reset stack pointer
00C010  2               
00C010  2  A9 4C              LDA   #$4C              ; code for JMP
00C012  2  85 A1              STA   Fnxjmp            ; save for jump vector for functions
00C014  2               
00C014  2               ; copy block from LAB_2CEE to $00BC - $00D7
00C014  2               
00C014  2  A2 1C              LDX   #StrTab-LAB_2CEE  ; set byte count
00C016  2               LAB_2D4E
00C016  2  BD 04 F7           LDA   LAB_2CEE-1,X      ; get byte from table
00C019  2  95 BB              STA   LAB_IGBY-1,X      ; save byte in page zero
00C01B  2  CA                 DEX                     ; decrement count
00C01C  2  D0 F8              BNE   LAB_2D4E          ; loop if not all done
00C01E  2               
00C01E  2               ; copy block from StrTab to $0000 - $0012
00C01E  2               
00C01E  2               LAB_GMEM
00C01E  2  A2 12              LDX   #EndTab-StrTab-1  ; set byte count-1
00C020  2               TabLoop
00C020  2  BD 21 F7           LDA   StrTab,X          ; get byte from table
00C023  2  95 00              STA   PLUS_0,X          ; save byte in page zero
00C025  2  CA                 DEX                     ; decrement count
00C026  2  10 F8              BPL   TabLoop           ; loop if not all done
00C028  2               
00C028  2               ; set-up start values
00C028  2               
00C028  2  64 DC              STZ   NmiBase           ; clear NMI handler enabled flag
00C02A  2  64 DF              STZ   IrqBase           ; clear IRQ handler enabled flag
00C02C  2  64 B2              STZ   FAC1_o            ; clear FAC1 overflow byte
00C02E  2  64 67              STZ   last_sh           ; clear descriptor stack top item pointer high byte
00C030  2               
00C030  2  A9 0E              LDA   #$0E              ; set default tab size
00C032  2  85 64              STA   TabSiz            ; save it
00C034  2  A9 03              LDA   #$03              ; set garbage collect step size for descriptor stack
00C036  2  85 A0              STA   g_step            ; save it
00C038  2  A2 68              LDX   #des_sk           ; descriptor stack start
00C03A  2  86 65              STX   next_s            ; set descriptor stack pointer
00C03C  2  20 7A CA           JSR   LAB_CRLF          ; print CR/LF
00C03F  2  A0 00              LDY   #$00              ; clear Y for indirect indexed writes
00C041  2  A9 00              LDA   #<Ram_base        ; always start from configured RAM base
00C043  2  85 11              STA   Itempl
00C045  2  A9 03              LDA   #>Ram_base
00C047  2  85 12              STA   Itemph
00C049  2                                             ; detect RAM limit by probing for writeable memory
00C049  2               LAB_2D93
00C049  2  E6 11              INC   Itempl            ; increment temporary integer low byte
00C04B  2  D0 08              BNE   LAB_2D99          ; branch if no overflow
00C04D  2               
00C04D  2  E6 12              INC   Itemph            ; increment temporary integer high byte
00C04F  2  A5 12              LDA   Itemph            ; get high byte
00C051  2  C9 A0              CMP   #>Ram_top         ; compare with top of RAM+1
00C053  2  F0 11              BEQ   LAB_2DB6          ; branch if match (end of user RAM)
00C055  2               
00C055  2               LAB_2D99
00C055  2  A9 55              LDA   #$55              ; set test byte
00C057  2  91 11              STA   (Itempl),Y        ; save via temporary integer
00C059  2  D1 11              CMP   (Itempl),Y        ; compare via temporary integer
00C05B  2  D0 09              BNE   LAB_2DB6          ; branch if fail
00C05D  2               
00C05D  2  0A                 ASL                     ; shift test byte left (now $AA)
00C05E  2  91 11              STA   (Itempl),Y        ; save via temporary integer
00C060  2  D1 11              CMP   (Itempl),Y        ; compare via temporary integer
00C062  2  F0 E5              BEQ   LAB_2D93          ; if ok go do next byte
00C064  2               
00C064  2  D0 00              BNE   LAB_2DB6          ; branch if fail
00C066  2               
00C066  2               LAB_2DB6
00C066  2  A5 11              LDA   Itempl            ; get temporary integer low byte
00C068  2  A4 12              LDY   Itemph            ; get temporary integer high byte
00C06A  2               ; uncomment these lines if you want to check on the high limit of memory.
00C06A  2               ; default is to trust the configured probe range.
00C06A  2               
00C06A  2               ;     CPY   #>Ram_top         ; compare with top of RAM high byte
00C06A  2               ;     BCC   MEM_OK            ; branch if < RAM top
00C06A  2               
00C06A  2               ;     BNE   LAB_GMEM          ; if too large go try again
00C06A  2                                             ; else was = so compare low bytes
00C06A  2               ;     CMP   #<Ram_top         ; compare with top of RAM low byte
00C06A  2               ;     BEQ   MEM_OK            ; branch if = RAM top
00C06A  2               
00C06A  2               ;     BCS   LAB_GMEM          ; if too large go try again
00C06A  2               
00C06A  2               ;MEM_OK
00C06A  2  85 85              STA   Ememl             ; set end of mem low byte
00C06C  2  84 86              STY   Ememh             ; set end of mem high byte
00C06E  2  85 81              STA   Sstorl            ; set bottom of string space low byte
00C070  2  84 82              STY   Sstorh            ; set bottom of string space high byte
00C072  2               
00C072  2  A0 00              LDY   #<Ram_base        ; set start addr low byte
00C074  2  A2 03              LDX   #>Ram_base        ; set start addr high byte
00C076  2  84 79              STY   Smeml             ; save start of mem low byte
00C078  2  86 7A              STX   Smemh             ; save start of mem high byte
00C07A  2               
00C07A  2               ; this line is only needed if Ram_base is not $xx00
00C07A  2                     .IF   Ram_base&$FF>0
00C07A  2                     LDY   #$00              ; clear Y
00C07A  2                     .ENDIF
00C07A  2               
00C07A  2  98                 TYA                     ; clear A
00C07B  2  91 79              STA   (Smeml),Y         ; clear first byte
00C07D  2  E6 79              INC   Smeml             ; increment start of mem low byte
00C07F  2               
00C07F  2               ; these two lines are only needed if Ram_base is $xxFF
00C07F  2                     .IF   Ram_base&$FF=$FF
00C07F  2                     BNE   LAB_2E05          ; branch if no rollover
00C07F  2                     INC   Smemh             ; increment start of mem high byte
00C07F  2               LAB_2E05
00C07F  2                     .ENDIF
00C07F  2               
00C07F  2  20 03 C4           JSR   LAB_1463          ; do "NEW" and "CLEAR"
00C082  2  20 E5 E8           JSR   LAB_SPLASH        ; draw centered text startup splash
00C085  2  A5 85              LDA   Ememl             ; get end of mem low byte
00C087  2  38                 SEC                     ; set carry for subtract
00C088  2  E5 79              SBC   Smeml             ; subtract start of mem low byte
00C08A  2  AA                 TAX                     ; copy to X
00C08B  2  A5 86              LDA   Ememh             ; get end of mem high byte
00C08D  2  E5 7A              SBC   Smemh             ; subtract start of mem high byte
00C08F  2  20 FD DE           JSR   LAB_295E          ; print XA as unsigned integer (bytes free)
00C092  2  A9 34              LDA   #<LAB_SMSG        ; point to sign-on message (low addr)
00C094  2  A0 F7              LDY   #>LAB_SMSG        ; point to sign-on message (high addr)
00C096  2  20 BB CA           JSR   LAB_18C3          ; print " BASIC bytes free  "
00C099  2               
00C099  2                     ; -- print expansion memory size if XMC present --
00C099  2  AD 0D BA           LDA   XMC_BANKS         ; read bank count register
00C09C  2  F0 19              BEQ   @no_xmc           ; skip if no expansion memory
00C09E  2               
00C09E  2                     ; banks * 64 = KB — shift left 6 bits to get A(hi):X(lo)
00C09E  2  AA                 TAX                     ; save bank count in X
00C09F  2  4A                 LSR   A
00C0A0  2  4A                 LSR   A                 ; A = banks >> 2 = high byte of KB
00C0A1  2  48                 PHA                     ; save high byte on stack
00C0A2  2  8A                 TXA                     ; A = bank count again
00C0A3  2  29 03              AND   #$03              ; keep only low 2 bits
00C0A5  2  0A                 ASL   A
00C0A6  2  0A                 ASL   A
00C0A7  2  0A                 ASL   A
00C0A8  2  0A                 ASL   A
00C0A9  2  0A                 ASL   A
00C0AA  2  0A                 ASL   A                 ; (low 2 bits) << 6 = low byte of KB
00C0AB  2  AA                 TAX                     ; X = low byte of KB
00C0AC  2  68                 PLA                     ; A = high byte of KB
