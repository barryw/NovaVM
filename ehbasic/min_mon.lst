00E843  2               ; system dependant i/o vectors
00E843  2               ; these are in RAM and are set by the monitor at start-up
00E843  2               
00E843  2               V_INPT
00E843  2  6C 05 02           JMP   (VEC_IN)          ; non halting scan input device
00E846  2               V_OUTP
00E846  2  6C 07 02           JMP   (VEC_OUT)         ; send byte to output device
00E849  2               V_LOAD
00E849  2  6C 09 02           JMP   (VEC_LD)          ; load BASIC program
00E84C  2               V_SAVE
00E84C  2  6C 0B 02           JMP   (VEC_SV)          ; save BASIC program
00E84F  2               
00E84F  2               ; The rest are tables messages and code for RAM
00E84F  2               
00E84F  2               ; the rest of the code is tables and BASIC start-up code
00E84F  2               
00E84F  2               PG2_TABS
00E84F  2  00                 .byte $00               ; ctrl-c flag           -     $00 = enabled
00E850  2  00                 .byte $00               ; ctrl-c byte           -     GET needs this
00E851  2  00                 .byte $00               ; ctrl-c byte timeout   -     GET needs this
00E852  2  CC E2              .word CTRLC             ; ctrl c check vector
00E854  2               ;     .word xxxx              ; non halting key input -     monitor to set this
00E854  2               ;     .word xxxx              ; output vector         -     monitor to set this
00E854  2               ;     .word xxxx              ; load vector           -     monitor to set this
00E854  2               ;     .word xxxx              ; save vector           -     monitor to set this
00E854  2               PG2_TABE
00E854  2               
00E854  2               ; --- VGC I/O register addresses ---
00E854  2               
00E854  2               VGC_MODE      = $A000
00E854  2               VGC_BGCOL     = $A001
00E854  2               VGC_FGCOL     = $A002
00E854  2               VGC_CURSX     = $A003
00E854  2               VGC_CURSY     = $A004
00E854  2               VGC_FONT      = $A007          ; font register
00E854  2               VGC_FRAME     = $A008          ; frame counter (read-only, incremented by host)
00E854  2               VGC_COLLST    = $A00B          ; sprite-sprite collision (read-only)
00E854  2               VGC_COLLBG    = $A00C          ; sprite-background collision (read-only)
00E854  2               VGC_BORDER    = $A00D          ; border color
00E854  2               VGC_CHAROUT   = $A00E
00E854  2               
00E854  2               ; --- VGC unified command register and parameters ---
00E854  2               
00E854  2               VGC_CMD       = $A010          ; command register (write triggers execution)
00E854  2               VGC_P0        = $A011          ; parameter 0
00E854  2               VGC_P1        = $A012          ; parameter 1
00E854  2               VGC_P2        = $A013          ; parameter 2
00E854  2               VGC_P3        = $A014          ; parameter 3
00E854  2               VGC_P4        = $A015          ; parameter 4
00E854  2               VGC_P5        = $A016          ; parameter 5
00E854  2               VGC_P6        = $A017          ; parameter 6
00E854  2               VGC_P7        = $A018          ; parameter 7
00E854  2               VGC_P8        = $A019          ; parameter 8
00E854  2               VGC_P9        = $A01A          ; parameter 9
00E854  2               
00E854  2               ; --- VGC graphics command codes ---
00E854  2               
00E854  2               VCMD_PLOT     = $01
00E854  2               VCMD_UNPLOT   = $02
00E854  2               VCMD_LINE     = $03
00E854  2               VCMD_CIRCLE   = $04
00E854  2               VCMD_RECT     = $05
00E854  2               VCMD_FILL     = $06
00E854  2               VCMD_GCLS     = $07
00E854  2               VCMD_GCOLOR   = $08
00E854  2               VCMD_PAINT    = $09
00E854  2               VCMD_GTEXT    = $0A
00E854  2               
00E854  2               ; --- VGC sprite command codes ---
00E854  2               
00E854  2               VCMD_SPRDEF   = $10            ; P0=sprite, P1=x, P2=y, P3=color
00E854  2               VCMD_SPRROW   = $11            ; P0=sprite, P1=row, P2-P9=8 bytes
00E854  2               VCMD_SPRCLR   = $12            ; P0=sprite (clears shape data)
00E854  2               VCMD_SPRCOPY  = $13            ; P0=src, P1=dest
00E854  2               VCMD_SPRPOS   = $14            ; P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00E854  2               VCMD_SPRENA   = $15            ; P0=sprite
00E854  2               VCMD_SPRDIS   = $16            ; P0=sprite
00E854  2               VCMD_SPRFLIP  = $17            ; P0=sprite, P1=flags
00E854  2               VCMD_SPRPRI   = $18            ; P0=sprite, P1=priority
00E854  2               
00E854  2               VCMD_COPPERADD = $1B           ; P0/P1=x, P2=y, P3=reg, P4=0, P5=value
00E854  2               VCMD_COPPERCLR = $1C           ; no params
00E854  2               VCMD_COPPERENA = $1D           ; no params
00E854  2               VCMD_COPPERDIS = $1E           ; no params
00E854  2               VCMD_SYSRESET  = $1F           ; full system reset (VGC+SID+music)
00E854  2               VCMD_COPPERLIST = $20          ; P0=list index (0-127)
00E854  2               VCMD_COPPERUSE = $21           ; P0=list index (0-127)
00E854  2               VCMD_COPPEREND = $22           ; reset target to active list
00E854  2               
00E854  2               ; --- File I/O coprocessor registers ---
00E854  2               
00E854  2               FIO_CMD       = $B9A0          ; command register (write triggers)
00E854  2               FIO_STATUS    = $B9A1          ; status: 0=idle, 2=ok, 3=error
00E854  2               FIO_ERRCODE   = $B9A2          ; error: 0=none, 1=not found, 2=io error
00E854  2               FIO_NAMELEN   = $B9A3          ; filename length (1-63)
00E854  2               FIO_SRCL      = $B9A4          ; source/dest addr low
00E854  2               FIO_SRCH      = $B9A5          ; source/dest addr high
00E854  2               FIO_ENDL      = $B9A6          ; end addr low (SAVE only)
00E854  2               FIO_ENDH      = $B9A7          ; end addr high (SAVE only)
00E854  2               FIO_SIZEL     = $B9A8          ; loaded size low (set by host after LOAD)
00E854  2               FIO_SIZEH     = $B9A9          ; loaded size high
00E854  2               FIO_GSPACE    = $B9AA          ; graphics space selector (0=screen,1=color,2=gfx,3=sprite)
00E854  2               FIO_GADDRL    = $B9AB          ; graphics offset low
00E854  2               FIO_GADDRH    = $B9AC          ; graphics offset high
