00E854  2               ; --- VGC command handlers ---
00E854  2               
00E854  2               ; draw a text-only cold-start splash screen
00E854  2               
00E854  2               LAB_SPLASH
00E854  2  A9 06              LDA   #$06              ; blue background
00E856  2  8D 01 A0           STA   VGC_BGCOL
00E859  2  A9 01              LDA   #$01              ; white text
00E85B  2  8D 02 A0           STA   VGC_FGCOL
00E85E  2  A9 06              LDA   #$06              ; blue border
00E860  2  8D 0D A0           STA   VGC_BORDER
00E863  2  A9 00              LDA   #$00              ; mode 0: text only
00E865  2  8D 00 A0           STA   VGC_MODE
00E868  2               
00E868  2  A9 0C              LDA   #$0C              ; clear text layer and home cursor
00E86A  2  20 46 E8           JSR   V_OUTP
00E86D  2  A9 21              LDA   #$21              ; centered x for "NovaBASIC v1.0"
00E86F  2  8D 03 A0           STA   VGC_CURSX
00E872  2  85 0E              STA   TPos
00E874  2  A9 00              LDA   #$00
00E876  2  8D 04 A0           STA   VGC_CURSY
00E879  2  A9 A0              LDA   #<LAB_BNR1
00E87B  2  A0 E8              LDY   #>LAB_BNR1
00E87D  2  20 7E CA           JSR   LAB_18C3
00E880  2               
00E880  2  A9 1A              LDA   #$1A              ; centered x for "Derived from EhBASIC 2.22p5"
00E882  2  8D 03 A0           STA   VGC_CURSX
00E885  2  85 0E              STA   TPos
00E887  2  A9 02              LDA   #$02              ; one empty row between lines
00E889  2  8D 04 A0           STA   VGC_CURSY
00E88C  2  A9 AF              LDA   #<LAB_BNR2
00E88E  2  A0 E8              LDY   #>LAB_BNR2
00E890  2  20 7E CA           JSR   LAB_18C3
00E893  2               
00E893  2  A9 11              LDA   #$11              ; centered x for "xxxxx BASIC bytes free  xxxK expansion memory"
00E895  2  8D 03 A0           STA   VGC_CURSX
00E898  2  85 0E              STA   TPos
00E89A  2  A9 04              LDA   #$04              ; one empty row between lines
00E89C  2  8D 04 A0           STA   VGC_CURSY
00E89F  2  60                 RTS
00E8A0  2               
00E8A0  2               LAB_BNR1
00E8A0  2  4E 6F 76 61        .byte "NovaBASIC v1.0",$00
00E8A4  2  42 41 53 49  
00E8A8  2  43 20 76 31  
00E8AF  2               LAB_BNR2
00E8AF  2  44 65 72 69        .byte "Derived from EhBASIC 2.22p5",$00
00E8B3  2  76 65 64 20  
00E8B7  2  66 72 6F 6D  
00E8CB  2               
00E8CB  2               ; perform CLS — clear screen, no arguments
00E8CB  2               
00E8CB  2               LAB_CLS
00E8CB  2  A9 0C              LDA   #$0C              ; form feed character
00E8CD  2  8D 0E A0           STA   VGC_CHAROUT       ; write to CHAROUT register
00E8D0  2  60                 RTS
00E8D1  2               
00E8D1  2               ; perform COLOR fg [,bg]
00E8D1  2               
00E8D1  2               LAB_COLOR
00E8D1  2  20 A9 D8           JSR   LAB_GTBY          ; get fg color byte in X
00E8D4  2  8E 02 A0           STX   VGC_FGCOL         ; store foreground color
00E8D7  2  20 C2 00           JSR   LAB_GBYT          ; peek at current byte
00E8DA  2  C9 2C              CMP   #','              ; comma follows?
00E8DC  2  D0 09              BNE   @done             ; no, just fg was given
00E8DE  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E8E1  2  20 A9 D8           JSR   LAB_GTBY          ; get bg color byte in X
00E8E4  2  8E 01 A0           STX   VGC_BGCOL         ; store background color
00E8E7  2               @done
00E8E7  2  60                 RTS
00E8E8  2               
00E8E8  2               ; perform LOCATE x, y
00E8E8  2               
00E8E8  2               LAB_LOCATE
00E8E8  2  20 A9 D8           JSR   LAB_GTBY          ; get x in X
00E8EB  2  8E 03 A0           STX   VGC_CURSX         ; store cursor X
00E8EE  2  20 A1 CD           JSR   LAB_1C01          ; require comma
00E8F1  2  20 A9 D8           JSR   LAB_GTBY          ; get y in X
00E8F4  2  8E 04 A0           STX   VGC_CURSY         ; store cursor Y
00E8F7  2  60                 RTS
00E8F8  2               
00E8F8  2               ; perform MODE n
00E8F8  2               
00E8F8  2               LAB_GMODE
00E8F8  2  20 A9 D8           JSR   LAB_GTBY          ; get mode byte in X
00E8FB  2  8E 00 A0           STX   VGC_MODE          ; store graphics mode
00E8FE  2  60                 RTS
00E8FF  2               
00E8FF  2               ; perform FONT n — select active font slot (0-7)
00E8FF  2               
00E8FF  2               LAB_FONT
00E8FF  2  20 A9 D8           JSR   LAB_GTBY          ; get font index byte (0-7) in X
00E902  2  8E 07 A0           STX   VGC_FONT          ; write to $A007
00E905  2  60                 RTS
00E906  2               
00E906  2               ; perform GCLS — clear the graphics bitmap layer
00E906  2               
00E906  2               LAB_GCLS
00E906  2  A9 07              LDA   #VCMD_GCLS        ; GCLS command
00E908  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E90B  2  60                 RTS
00E90C  2               
00E90C  2               ; perform GCOLOR c — set graphics draw color (0-15)
00E90C  2               
00E90C  2               LAB_GCOLOR
00E90C  2  20 A9 D8           JSR   LAB_GTBY          ; get color byte in X
00E90F  2  8E 11 A0           STX   VGC_P0             ; color in P0
00E912  2  A9 00              LDA   #$00
00E914  2  8D 12 A0           STA   VGC_P1             ; high byte = 0
00E917  2  A9 08              LDA   #VCMD_GCOLOR      ; GCOLOR command
00E919  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E91C  2  60                 RTS
00E91D  2               
00E91D  2               ; shared: load x(word),y(byte) into VGC_P0-P3
00E91D  2               
00E91D  2               LAB_VGC_XY
00E91D  2  20 97 D8           JSR   LAB_GTWRD         ; get x as 16-bit
00E920  2  A5 AF              LDA   FAC1_3
