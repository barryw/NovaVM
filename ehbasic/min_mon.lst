00FEFF  2  66 69 6E 65  
00FF03  2  64 20 66 75  
00FF0E  2  4C 4F 4F 50  ERR_LD      .byte "LOOP without DO",$00
00FF12  2  20 77 69 74  
00FF16  2  68 6F 75 74  
