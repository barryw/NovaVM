00E7AF  2               ; system dependant i/o vectors
00E7AF  2               ; these are in RAM and are set by the monitor at start-up
00E7AF  2               
00E7AF  2               V_INPT
00E7AF  2  6C 05 02           JMP   (VEC_IN)          ; non halting scan input device
00E7B2  2               V_OUTP
00E7B2  2  6C 07 02           JMP   (VEC_OUT)         ; send byte to output device
00E7B5  2               V_LOAD
00E7B5  2  6C 09 02           JMP   (VEC_LD)          ; load BASIC program
00E7B8  2               V_SAVE
00E7B8  2  6C 0B 02           JMP   (VEC_SV)          ; save BASIC program
00E7BB  2               
00E7BB  2               ; The rest are tables messages and code for RAM
00E7BB  2               
00E7BB  2               ; the rest of the code is tables and BASIC start-up code
