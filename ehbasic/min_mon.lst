00E82C  2               
00E82C  2               XMC_CMD       = $BA00          ; command register (write triggers)
00E82C  2               XMC_STATUS    = $BA01          ; status: 0=idle, 2=ok, 3=error
00E82C  2               XMC_ERRCODE   = $BA02          ; error: 0=none
00E82C  2               XMC_CFG       = $BA03          ; config flags (reserved)
00E82C  2               XMC_XAL       = $BA04          ; expansion addr low
00E82C  2               XMC_XAM       = $BA05          ; expansion addr mid
00E82C  2               XMC_XAH       = $BA06          ; expansion addr high
00E82C  2               XMC_RAML      = $BA07          ; cpu addr low
00E82C  2               XMC_RAMH      = $BA08          ; cpu addr high
00E82C  2               XMC_LENL      = $BA09          ; transfer length low
00E82C  2               XMC_LENH      = $BA0A          ; transfer length high
00E82C  2               XMC_DATA      = $BA0B          ; data port
00E82C  2               XMC_BANK      = $BA0C          ; current 64KB bank
00E82C  2               XMC_BANKS     = $BA0D          ; total banks
00E82C  2               XMC_USEDL     = $BA0E          ; used pages low (future allocator)
00E82C  2               XMC_USEDH     = $BA0F          ; used pages high
00E82C  2               XMC_FREEL     = $BA10          ; free pages low
00E82C  2               XMC_FREEH     = $BA11          ; free pages high
00E82C  2               XMC_NAMELEN   = $BA12          ; name length (0-27)
00E82C  2               XMC_HANDLE    = $BA13          ; block handle
00E82C  2               XMC_DIRCOUNTL = $BA14          ; named block count low
00E82C  2               XMC_DIRCOUNTH = $BA15          ; named block count high
00E82C  2               XMC_WINCTL    = $BA16          ; mapped window enable bits
00E82C  2               XMC_W0AL      = $BA18          ; window 0 xaddr low
00E82C  2               XMC_W0AM      = $BA19          ; window 0 xaddr mid
00E82C  2               XMC_W0AH      = $BA1A          ; window 0 xaddr high
00E82C  2               XMC_W1AL      = $BA1B          ; window 1 xaddr low
00E82C  2               XMC_W1AM      = $BA1C          ; window 1 xaddr mid
00E82C  2               XMC_W1AH      = $BA1D          ; window 1 xaddr high
00E82C  2               XMC_W2AL      = $BA1E          ; window 2 xaddr low
00E82C  2               XMC_W2AM      = $BA1F          ; window 2 xaddr mid
00E82C  2               XMC_W2AH      = $BA20          ; window 2 xaddr high
00E82C  2               XMC_W3AL      = $BA21          ; window 3 xaddr low
00E82C  2               XMC_W3AM      = $BA22          ; window 3 xaddr mid
00E82C  2               XMC_W3AH      = $BA23          ; window 3 xaddr high
00E82C  2               XMC_NAME      = $BA24          ; name buffer start
00E82C  2               XMC_NAME_MAX  = 28             ; bytes in name buffer
00E82C  2               
00E82C  2               XMC_CMD_GET   = $01            ; read byte at XADDR into XMC_DATA
00E82C  2               XMC_CMD_PUT   = $02            ; write XMC_DATA to XADDR
00E82C  2               XMC_CMD_STASH = $03            ; copy RAM -> XRAM
00E82C  2               XMC_CMD_FETCH = $04            ; copy XRAM -> RAM
00E82C  2               XMC_CMD_FILL  = $05            ; fill XRAM with XMC_DATA
00E82C  2               XMC_CMD_STATS = $07            ; refresh stats
00E82C  2               XMC_CMD_RSTUS = $08            ; clear usage tracking metadata
00E82C  2               XMC_CMD_REL   = $09            ; mark range as free in usage tracking
00E82C  2               XMC_CMD_ALLOC = $0A            ; allocate block (len -> xaddr/handle)
00E82C  2               XMC_CMD_NSTSH = $0B            ; named stash RAM->XRAM
00E82C  2               XMC_CMD_NFETC = $0C            ; named fetch XRAM->RAM
00E82C  2               XMC_CMD_NDEL  = $0D            ; named delete
00E82C  2               XMC_CMD_NDIRO = $0E            ; named dir open
00E82C  2               XMC_CMD_NDIRR = $0F            ; named dir read
00E82C  2               XMC_OK        = $02            ; command success status
00E82C  2               XMC_ERR_NF    = $03            ; not found
00E82C  2               XMC_ERR_EOD   = $06            ; end of directory
00E82C  2               
00E82C  2               ; --- NIC network interface controller registers ---
