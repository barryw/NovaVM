00E8E4  2               
00E8E4  2               ; system dependant i/o vectors
00E8E4  2               ; these are in RAM and are set by the monitor at start-up
00E8E4  2               
00E8E4  2               V_INPT
00E8E4  2  6C 05 02           JMP   (VEC_IN)          ; non halting scan input device
00E8E7  2               V_OUTP
00E8E7  2  6C 07 02           JMP   (VEC_OUT)         ; send byte to output device
00E8EA  2               V_LOAD
00E8EA  2  6C 09 02           JMP   (VEC_LD)          ; load BASIC program
00E8ED  2               V_SAVE
00E8ED  2  6C 0B 02           JMP   (VEC_SV)          ; save BASIC program
00E8F0  2               
00E8F0  2               ; The rest are tables messages and code for RAM
00E8F0  2               
00E8F0  2               ; the rest of the code is tables and BASIC start-up code
00E8F0  2               
00E8F0  2               PG2_TABS
00E8F0  2  00                 .byte $00               ; ctrl-c flag           -     $00 = enabled
00E8F1  2  00                 .byte $00               ; ctrl-c byte           -     GET needs this
00E8F2  2  00                 .byte $00               ; ctrl-c byte timeout   -     GET needs this
00E8F3  2  28 E3              .word CTRLC             ; ctrl c check vector
00E8F5  2               ;     .word xxxx              ; non halting key input -     monitor to set this
00E8F5  2               ;     .word xxxx              ; output vector         -     monitor to set this
00E8F5  2               ;     .word xxxx              ; load vector           -     monitor to set this
00E8F5  2               ;     .word xxxx              ; save vector           -     monitor to set this
00E8F5  2               PG2_TABE
00E8F5  2               
00E8F5  2               ; --- Nova hardware constants live in lib/nova.inc ---
00E8F5  2               
00E8F5  2               ; --- VGC command handlers ---
00E8F5  2               
00E8F5  2               ; draw a text-only cold-start splash screen
00E8F5  2               
00E8F5  2               LAB_SPLASH
00E8F5  2  9C 01 A0           STZ   VGC_BGCOL         ; black background
00E8F8  2  A9 0F              LDA   #$0F              ; light grey text
00E8FA  2  8D 02 A0           STA   VGC_FGCOL
00E8FD  2  A9 0B              LDA   #$0B              ; dark grey border
00E8FF  2  8D 0D A0           STA   VGC_BORDER
00E902  2  9C 00 A0           STZ   VGC_MODE          ; mode 0: text only
00E905  2               
00E905  2  A9 0C              LDA   #$0C              ; clear text layer and home cursor
00E907  2  20 E7 E8           JSR   V_OUTP
00E90A  2  A9 21              LDA   #$21              ; centered x for "NovaBASIC v1.0"
00E90C  2  8D 03 A0           STA   VGC_CURSX
00E90F  2  85 0E              STA   TPos
00E911  2  A9 01              LDA   #$01              ; leave breathing room on the first row
00E913  2  8D 04 A0           STA   VGC_CURSY
00E916  2  A9 3D              LDA   #<LAB_BNR1
00E918  2  A0 E9              LDY   #>LAB_BNR1
00E91A  2  20 D9 CA           JSR   LAB_18C3
00E91D  2               
00E91D  2  A9 1A              LDA   #$1A              ; centered x for "Derived from EhBASIC 2.22p5"
00E91F  2  8D 03 A0           STA   VGC_CURSX
00E922  2  85 0E              STA   TPos
00E924  2  A9 03              LDA   #$03              ; one empty row between lines
00E926  2  8D 04 A0           STA   VGC_CURSY
00E929  2  A9 4C              LDA   #<LAB_BNR2
00E92B  2  A0 E9              LDY   #>LAB_BNR2
00E92D  2  20 D9 CA           JSR   LAB_18C3
00E930  2               
00E930  2  A9 11              LDA   #$11              ; centered x for "xxxxx BASIC bytes free  xxxK expansion memory"
00E932  2  8D 03 A0           STA   VGC_CURSX
00E935  2  85 0E              STA   TPos
00E937  2  A9 05              LDA   #$05              ; one empty row between lines
00E939  2  8D 04 A0           STA   VGC_CURSY
00E93C  2  60                 RTS
00E93D  2               
00E93D  2               LAB_BNR1
00E93D  2  4E 6F 76 61        .byte "NovaBASIC v1.0",$00
00E941  2  42 41 53 49  
00E945  2  43 20 76 31  
00E94C  2               LAB_BNR2
00E94C  2  44 65 72 69        .byte "Derived from EhBASIC 2.22p5",$00
00E950  2  76 65 64 20  
00E954  2  66 72 6F 6D  
