00EE5B  2  20 BC 00           JSR   LAB_IGBY          ; consume R
00EE5E  2  20 C2 00           JSR   LAB_GBYT          ; peek field start: X, Y, S, F, P
00EE61  2  C9 58              CMP   #'X'
00EE63  2  F0 13              BEQ   @cs_x
00EE65  2  C9 59              CMP   #'Y'
00EE67  2  F0 26              BEQ   @cs_y
00EE69  2  C9 53              CMP   #'S'
00EE6B  2  F0 39              BEQ   @cs_shape
00EE6D  2  C9 46              CMP   #'F'
00EE6F  2  F0 3F              BEQ   @cs_flags
00EE71  2  C9 50              CMP   #'P'
00EE73  2  F0 45              BEQ   @cs_pri
00EE75  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EE78  2               
00EE78  2               @cs_x
00EE78  2  20 BC 00           JSR   LAB_IGBY          ; consume X
00EE7B  2  20 C2 00           JSR   LAB_GBYT          ; peek: H or (
00EE7E  2  C9 48              CMP   #'H'
