00E7D1  2               
00E7D1  2               ; system dependant i/o vectors
00E7D1  2               ; these are in RAM and are set by the monitor at start-up
00E7D1  2               
00E7D1  2               V_INPT
00E7D1  2  6C 05 02           JMP   (VEC_IN)          ; non halting scan input device
00E7D4  2               V_OUTP
00E7D4  2  6C 07 02           JMP   (VEC_OUT)         ; send byte to output device
00E7D7  2               V_LOAD
00E7D7  2  6C 09 02           JMP   (VEC_LD)          ; load BASIC program
00E7DA  2               V_SAVE
00E7DA  2  6C 0B 02           JMP   (VEC_SV)          ; save BASIC program
00E7DD  2               
00E7DD  2               ; The rest are tables messages and code for RAM
00E7DD  2               
00E7DD  2               ; the rest of the code is tables and BASIC start-up code
00E7DD  2               
00E7DD  2               PG2_TABS
00E7DD  2  00                 .byte $00               ; ctrl-c flag           -     $00 = enabled
00E7DE  2  00                 .byte $00               ; ctrl-c byte           -     GET needs this
00E7DF  2  00                 .byte $00               ; ctrl-c byte timeout   -     GET needs this
00E7E0  2  8E E2              .word CTRLC             ; ctrl c check vector
00E7E2  2               ;     .word xxxx              ; non halting key input -     monitor to set this
00E7E2  2               ;     .word xxxx              ; output vector         -     monitor to set this
00E7E2  2               ;     .word xxxx              ; load vector           -     monitor to set this
00E7E2  2               ;     .word xxxx              ; save vector           -     monitor to set this
00E7E2  2               PG2_TABE
00E7E2  2               
00E7E2  2               ; --- VGC I/O register addresses ---
00E7E2  2               
00E7E2  2               VGC_MODE      = $A000
00E7E2  2               VGC_BGCOL     = $A001
00E7E2  2               VGC_FGCOL     = $A002
00E7E2  2               VGC_CURSX     = $A003
00E7E2  2               VGC_CURSY     = $A004
00E7E2  2               VGC_FONT      = $A007          ; font register
00E7E2  2               VGC_FRAME     = $A008          ; frame counter (read-only, incremented by host)
00E7E2  2               VGC_COLLST    = $A00B          ; sprite-sprite collision (read-only)
00E7E2  2               VGC_COLLBG    = $A00C          ; sprite-background collision (read-only)
00E7E2  2               VGC_BORDER    = $A00D          ; border color
00E7E2  2               VGC_CHAROUT   = $A00E
00E7E2  2               
00E7E2  2               ; --- VGC unified command register and parameters ---
00E7E2  2               
00E7E2  2               VGC_CMD       = $A010          ; command register (write triggers execution)
00E7E2  2               VGC_P0        = $A011          ; parameter 0
00E7E2  2               VGC_P1        = $A012          ; parameter 1
00E7E2  2               VGC_P2        = $A013          ; parameter 2
00E7E2  2               VGC_P3        = $A014          ; parameter 3
00E7E2  2               VGC_P4        = $A015          ; parameter 4
00E7E2  2               VGC_P5        = $A016          ; parameter 5
00E7E2  2               VGC_P6        = $A017          ; parameter 6
00E7E2  2               VGC_P7        = $A018          ; parameter 7
00E7E2  2               VGC_P8        = $A019          ; parameter 8
00E7E2  2               VGC_P9        = $A01A          ; parameter 9
00E7E2  2               
00E7E2  2               ; --- VGC graphics command codes ---
00E7E2  2               
00E7E2  2               VCMD_PLOT     = $01
00E7E2  2               VCMD_UNPLOT   = $02
00E7E2  2               VCMD_LINE     = $03
00E7E2  2               VCMD_CIRCLE   = $04
00E7E2  2               VCMD_RECT     = $05
00E7E2  2               VCMD_FILL     = $06
00E7E2  2               VCMD_GCLS     = $07
00E7E2  2               VCMD_GCOLOR   = $08
00E7E2  2               VCMD_PAINT    = $09
00E7E2  2               VCMD_GTEXT    = $0A
00E7E2  2               
00E7E2  2               ; --- VGC sprite command codes ---
00E7E2  2               
00E7E2  2               VCMD_SPRDEF   = $10            ; P0=sprite, P1=x, P2=y, P3=color
00E7E2  2               VCMD_SPRROW   = $11            ; P0=sprite, P1=row, P2-P9=8 bytes
00E7E2  2               VCMD_SPRCLR   = $12            ; P0=sprite (clears shape data)
00E7E2  2               VCMD_SPRCOPY  = $13            ; P0=src, P1=dest
00E7E2  2               VCMD_SPRPOS   = $14            ; P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00E7E2  2               VCMD_SPRENA   = $15            ; P0=sprite
00E7E2  2               VCMD_SPRDIS   = $16            ; P0=sprite
00E7E2  2               VCMD_SPRFLIP  = $17            ; P0=sprite, P1=flags
00E7E2  2               VCMD_SPRPRI   = $18            ; P0=sprite, P1=priority
00E7E2  2               
00E7E2  2               VCMD_COPPERADD = $1B           ; P0/P1=x, P2=y, P3=reg, P4=0, P5=value
00E7E2  2               VCMD_COPPERCLR = $1C           ; no params
00E7E2  2               VCMD_COPPERENA = $1D           ; no params
00E7E2  2               VCMD_COPPERDIS = $1E           ; no params
00E7E2  2               VCMD_SYSRESET  = $1F           ; full system reset (VGC+SID+music)
00E7E2  2               VCMD_COPPERLIST = $20          ; P0=list index (0-127)
00E7E2  2               VCMD_COPPERUSE = $21           ; P0=list index (0-127)
00E7E2  2               VCMD_COPPEREND = $22           ; reset target to active list
00E7E2  2               
00E7E2  2               ; --- File I/O coprocessor registers ---
00E7E2  2               
00E7E2  2               FIO_CMD       = $B9A0          ; command register (write triggers)
00E7E2  2               FIO_STATUS    = $B9A1          ; status: 0=idle, 2=ok, 3=error
00E7E2  2               FIO_ERRCODE   = $B9A2          ; error: 0=none, 1=not found, 2=io error
00E7E2  2               FIO_NAMELEN   = $B9A3          ; filename length (1-63)
00E7E2  2               FIO_SRCL      = $B9A4          ; source/dest addr low
00E7E2  2               FIO_SRCH      = $B9A5          ; source/dest addr high
00E7E2  2               FIO_ENDL      = $B9A6          ; end addr low (SAVE only)
00E7E2  2               FIO_ENDH      = $B9A7          ; end addr high (SAVE only)
00E7E2  2               FIO_SIZEL     = $B9A8          ; loaded size low (set by host after LOAD)
00E7E2  2               FIO_SIZEH     = $B9A9          ; loaded size high
00E7E2  2               FIO_GSPACE    = $B9AA          ; graphics space selector (0=screen,1=color,2=gfx,3=sprite)
00E7E2  2               FIO_GADDRL    = $B9AB          ; graphics offset low
00E7E2  2               FIO_GADDRH    = $B9AC          ; graphics offset high
00E7E2  2               FIO_GLENL     = $B9AD          ; graphics transfer length low
00E7E2  2               FIO_GLENH     = $B9AE          ; graphics transfer length high
00E7E2  2               FIO_DIRTYPE   = $B9AF          ; dir entry type: 0=BAS, 1=SID, 2=BIN, 3=MID
00E7E2  2               FIO_NAME      = $B9B0          ; filename buffer (64 bytes)
00E7E2  2               
00E7E2  2               META_BASE       = $BAB0          ; metadata string buffer (80 bytes)
00E7E2  2               AUTOBOOT_SKIP = $B9F0          ; C# sets to $FF to skip autoboot
00E7E2  2               
00E7E2  2               FIO_CMD_SAVE  = $01            ; save program
00E7E2  2               FIO_CMD_LOAD  = $02            ; load program
00E7E2  2               FIO_OK        = $02            ; status: success
00E7E2  2               FIO_ERR       = $03            ; status: error
00E7E2  2               FIO_CMD_DIROPEN = $03          ; enumerate *.bas files, populate first entry
00E7E2  2               FIO_CMD_DIRREAD = $04          ; advance to next entry
00E7E2  2               FIO_CMD_DELETE = $05           ; delete a single *.bas file by name
00E7E2  2               FIO_CMD_GSAVE = $06            ; save VGC memory block to *.gfx
00E7E2  2               FIO_CMD_GLOAD = $07            ; load *.gfx into VGC memory block
00E7E2  2               FIO_CMD_SIDPLAY = $08          ; load .sid and start playback
00E7E2  2               FIO_CMD_SIDSTOP = $09          ; stop SID playback
00E7E2  2               FIO_CMD_INSTRUMENT = $0A       ; define instrument preset
00E7E2  2               FIO_CMD_SOUND  = $0B           ; play SFX (note, duration, instrument)
00E7E2  2               FIO_CMD_VOLUME = $0C           ; set master volume
00E7E2  2               FIO_CMD_MSEQ   = $0D           ; set voice MML sequence
00E7E2  2               FIO_CMD_MPLAY  = $0E           ; start music playback
00E7E2  2               FIO_CMD_MSTOP  = $0F           ; stop music playback
00E7E2  2               FIO_CMD_MTEMPO = $10           ; set music tempo (BPM)
00E7E2  2               FIO_CMD_MLOOP  = $11           ; set music loop on/off
00E7E2  2               FIO_CMD_MPRI   = $12           ; set SFX voice steal priority
00E7E2  2               FIO_CMD_MIDPLAY = $13          ; load .mid and start playback
00E7E2  2               FIO_CMD_MIDSTOP = $14          ; stop MIDI playback
00E7E2  2               FIO_CMD_SFLOAD  = $15          ; load soundfont (.sf2)
00E7E2  2               
00E7E2  2               ; --- Extension ROM command IDs (dispatched via EXT_vec trampoline) ---
00E7E2  2               EXT_CMD_NCC     = $00          ; NCC confirmation dialog
