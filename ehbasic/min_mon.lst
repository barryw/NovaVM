00E7E2  2               TileConfig     = $A0C0
00E7E2  2               TileTransColor = $A0C1
00E7E2  2               TileScrollXL   = $A0C2
00E7E2  2               TileScrollXH   = $A0C3
00E7E2  2               TileScrollYL   = $A0C4
00E7E2  2               TileScrollYH   = $A0C5
00E7E2  2               TileCmd        = $A0C7
00E7E2  2               TileP0         = $A0C8
00E7E2  2               TileP1         = $A0C9
00E7E2  2               TileP2         = $A0CA
00E7E2  2               TileP3         = $A0CB
00E7E2  2               TileAddrL      = $A0CC
00E7E2  2               TileAddrH      = $A0CD
00E7E2  2               TilePalP0      = $A0CE
00E7E2  2               TilePalP1      = $A0CF
00E7E2  2               TileColL       = $A0D0
00E7E2  2               TileColH       = $A0D1
00E7E2  2               TilePeekVal    = $A0D2
00E7E2  2               TilePeekAttr   = $A0D3
00E7E2  2               TileCfgSize16  = $01
00E7E2  2               TileCmdDef     = $01
00E7E2  2               TileCmdDefBulk = $02
00E7E2  2               TileCmdPut     = $03
00E7E2  2               TileCmdAttr    = $04
00E7E2  2               TileCmdFill    = $05
00E7E2  2               TileCmdRow     = $06
00E7E2  2               TileCmdCol     = $07
00E7E2  2               TileCmdLoad    = $08
00E7E2  2               TileCmdPal     = $0A
00E7E2  2               TileCmdPalC    = $0B
00E7E2  2               TileCmdPeek    = $0C
