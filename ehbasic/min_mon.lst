00EE08  3               
00EE08  3               .ifndef NIC_SERVER_COMMANDS
00EE08  3               NIC_SERVER_COMMANDS = 1
00EE08  3               .endif
00EE08  3               
00EE08  3                     .segment "CODE"
00EE08  3               
00EE08  3                     .export nic_command
00EE08  3                     .export nic_connect
00EE08  3                     .export nic_disconnect
00EE08  3               .if NIC_SERVER_COMMANDS
00EE08  3                     .export nic_listen
00EE08  3                     .export nic_accept
00EE08  3               .endif
00EE08  3                     .export nic_send
00EE08  3                     .export nic_recv
00EE08  3                     .export nic_status
00EE08  3                     .export nic_ready
00EE08  3                     .export nic_length
00EE08  3                     .export nic_copy_name
00EE08  3               
00EE08  3               ; Input: A = NIC command.
00EE08  3               ; @label NIC.COMMAND
00EE08  3               ; @kind routine
00EE08  3               ; @symbol nic_command
00EE08  3               ; @summary Issue a raw NIC command.
00EE08  3               ; @in A: NIC command byte.
00EE08  3               nic_command:
00EE08  3  8D 00 A1           STA   NIC_CMD
00EE0B  3  60                 RTS
00EE0C  3               
00EE0C  3               ; @label NIC.CONNECT
00EE0C  3               ; @kind routine
00EE0C  3               ; @symbol nic_connect
00EE0C  3               ; @summary Connect NIC_SLOT to NIC_NAMEBUF:NIC_RPORTL/H.
00EE0C  3               ; @requires NIC_SLOT NIC_NAMEBUF NIC_RPORTL NIC_RPORTH
00EE0C  3               nic_connect:
00EE0C  3  A9 01              LDA   #NIC_CMD_CONNECT
00EE0E  3  80 F8              BRA   nic_command
00EE10  3               
00EE10  3               ; @label NIC.DISCONNECT
00EE10  3               ; @kind routine
00EE10  3               ; @symbol nic_disconnect
00EE10  3               ; @summary Disconnect NIC_SLOT.
00EE10  3               ; @requires NIC_SLOT
00EE10  3               nic_disconnect:
00EE10  3  A9 02              LDA   #NIC_CMD_DISCONNECT
00EE12  3  80 F4              BRA   nic_command
00EE14  3               
00EE14  3               .if NIC_SERVER_COMMANDS
00EE14  3               ; @label NIC.LISTEN
00EE14  3               ; @kind routine
00EE14  3               ; @symbol nic_listen
00EE14  3               ; @summary Listen on NIC_SLOT using NIC_LPORTL/H.
00EE14  3               nic_listen:
00EE14  3                     LDA   #NIC_CMD_LISTEN
00EE14  3                     BRA   nic_command
00EE14  3               
00EE14  3               ; @label NIC.ACCEPT
00EE14  3               ; @kind routine
00EE14  3               ; @symbol nic_accept
00EE14  3               ; @summary Accept a pending connection for NIC_SLOT.
00EE14  3               nic_accept:
00EE14  3                     LDA   #NIC_CMD_ACCEPT
00EE14  3                     BRA   nic_command
00EE14  3               .endif
00EE14  3               
00EE14  3               ; @label NIC.SEND
00EE14  3               ; @kind routine
00EE14  3               ; @symbol nic_send
00EE14  3               ; @summary Send NIC_DMALEN bytes from NIC_DMAL/H on NIC_SLOT.
00EE14  3               ; @requires NIC_SLOT NIC_DMAL NIC_DMAH NIC_DMALEN
00EE14  3               nic_send:
00EE14  3  A9 03              LDA   #NIC_CMD_SEND
00EE16  3  80 F0              BRA   nic_command
00EE18  3               
00EE18  3               ; @label NIC.RECV
00EE18  3               ; @kind routine
00EE18  3               ; @symbol nic_recv
00EE18  3               ; @summary Receive data for NIC_SLOT into NIC_DMAL/H.
00EE18  3               ; @requires NIC_SLOT NIC_DMAL NIC_DMAH
00EE18  3               nic_recv:
00EE18  3  A9 04              LDA   #NIC_CMD_RECV
00EE1A  3  80 EC              BRA   nic_command
00EE1C  3               
00EE1C  3               ; Input: X = slot.  Returns A = clamped slot status.
00EE1C  3               ; @label NIC.STATUS
00EE1C  3               ; @kind routine
00EE1C  3               ; @symbol nic_status
00EE1C  3               ; @summary Read clamped NIC slot status.
00EE1C  3               ; @in X: Slot number.
00EE1C  3               ; @out A: Slot status byte.
00EE1C  3               nic_status:
00EE1C  3  8A                 TXA
00EE1D  3  29 03              AND   #$03
00EE1F  3  AA                 TAX
00EE20  3  BD 18 A1           LDA   NIC_SLOTST0,X
00EE23  3  60                 RTS
00EE24  3               
00EE24  3               ; Input: X = slot.  Returns A = 1 if data/accept is ready, otherwise 0.
00EE24  3               ; @label NIC.READY
00EE24  3               ; @kind routine
00EE24  3               ; @symbol nic_ready
00EE24  3               ; @summary Return 1 when NIC_SLOT has data/accept readiness, otherwise 0.
00EE24  3               ; @in X: Slot number.
00EE24  3               ; @out A: 1 when ready, 0 otherwise.
00EE24  3               nic_ready:
00EE24  3  20 1C EE           JSR   nic_status
00EE27  3  29 02              AND   #NIC_ST_DATAREADY
00EE29  3  F0 02              BEQ   @not_ready
00EE2B  3  A9 01              LDA   #$01
00EE2D  3               @not_ready:
00EE2D  3  60                 RTS
00EE2E  3               
00EE2E  3               ; @label NIC.LENGTH
00EE2E  3               ; @kind routine
00EE2E  3               ; @symbol nic_length
00EE2E  3               ; @summary Read the most recent NIC message length.
00EE2E  3               ; @out A: Message length byte.
00EE2E  3               nic_length:
00EE2E  3  AD 13 A1           LDA   NIC_MSGLEN
00EE31  3  60                 RTS
00EE32  3               
00EE32  3               ; Copy a host name from NIC_ARG_NAMEPTR_L/H into NIC_NAMEBUF and append NUL.
00EE32  3               ; Returns A=0 on success, A=1 on invalid length.
00EE32  3               ; @label NIC.COPY_NAME
00EE32  3               ; @kind routine
00EE32  3               ; @symbol nic_copy_name
00EE32  3               ; @summary Copy a pointer-based host name to NIC_NAMEBUF and append NUL.
00EE32  3               ; @requires NIC_ARG_NAMELEN NIC_ARG_NAMEPTR_L NIC_ARG_NAMEPTR_H
00EE32  3               ; @out A: 0 on success, 1 on invalid length.
00EE32  3               nic_copy_name:
00EE32  3  A5 20              LDA   NIC_ARG_NAMELEN
00EE34  3  F0 18              BEQ   @bad
00EE36  3  C9 20              CMP   #NIC_NAME_LIMIT + 1
00EE38  3  B0 14              BCS   @bad
00EE3A  3  AA                 TAX
00EE3B  3  A0 00              LDY   #$00
00EE3D  3               @copy:
00EE3D  3  B1 21              LDA   (NIC_ARG_NAMEPTR_L),Y
00EE3F  3  99 20 A1           STA   NIC_NAMEBUF,Y
00EE42  3  C8                 INY
00EE43  3  CA                 DEX
00EE44  3  D0 F7              BNE   @copy
00EE46  3  A9 00              LDA   #$00
00EE48  3  99 20 A1           STA   NIC_NAMEBUF,Y
00EE4B  3  A9 00              LDA   #NIC_RESULT_OK
00EE4D  3  60                 RTS
00EE4E  3               @bad:
00EE4E  3  A9 01              LDA   #NIC_RESULT_ERROR
00EE50  3  60                 RTS
00EE51  3               
00EE51  3               .endif
00EE51  3               
00EE51  2               
00EE51  2               LAB_FIO_CMD_RTS = fio_issue
00EE51  2               
