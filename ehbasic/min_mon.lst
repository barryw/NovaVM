00EDC6  2               
00EDC6  2               ; --- COPPER USE n ---
00EDC6  2               @c_use
00EDC6  2  A2 03              LDX   #3
00EDC8  2  20 92 EC           JSR   LAB_SKIPX          ; USE
00EDCB  2  20 A4 D7           JSR   LAB_GTBY          ; list index → X
00EDCE  2  8E 11 A0           STX   VGC_P0
00EDD1  2  A9 21              LDA   #VCMD_COPPERUSE
00EDD3  2  8D 10 A0           STA   VGC_CMD
