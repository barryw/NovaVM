00EF09  2               
00EF09  2               ; perform GLOAD "filename", space, offset [,length]
00EF09  2               
00EF09  2               LAB_GLOAD
00EF09  2  20 4B F3           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EF0C  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EF0F  2  20 1F D9           JSR   LAB_GTBY          ; graphics space id
00EF12  2  8E AA B9           STX   FIO_GSPACE
00EF15  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EF18  2  20 0D D9           JSR   LAB_GTWRD         ; graphics offset
00EF1B  2  A5 AF              LDA   FAC1_3
