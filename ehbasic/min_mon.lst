00E4BF  2  64 AF              STZ   FAC1_3            ; clear root
00E4C1  2  64 AE              STZ   FAC1_2            ; ..
00E4C3  2  64 AD              STZ   FAC1_1            ; ..
00E4C5  2               
00E4C5  2  A2 18              LDX   #$18              ; 24 pairs of bits to do
00E4C7  2  A5 B3              LDA   FAC2_e            ; get exponent
00E4C9  2  4A                 LSR                     ; check odd/even
00E4CA  2  B0 0E              BCS   LAB_SQE2          ; if odd only 1 shift first time
00E4CC  2               
00E4CC  2               LAB_SQE1
00E4CC  2  06 B6              ASL   FAC2_3            ; shift highest bit of number ..
00E4CE  2  26 B5              ROL   FAC2_2            ; ..
00E4D0  2  26 B4              ROL   FAC2_1            ; ..
00E4D2  2  26 77              ROL   FACt_3            ; .. into remainder
00E4D4  2  26 76              ROL   FACt_2            ; ..
00E4D6  2  26 75              ROL   FACt_1            ; ..
00E4D8  2  26 78              ROL   TempB             ; .. never overflows
00E4DA  2               LAB_SQE2
00E4DA  2  06 B6              ASL   FAC2_3            ; shift highest bit of number ..
00E4DC  2  26 B5              ROL   FAC2_2            ; ..
00E4DE  2  26 B4              ROL   FAC2_1            ; ..
00E4E0  2  26 77              ROL   FACt_3            ; .. into remainder
00E4E2  2  26 76              ROL   FACt_2            ; ..
00E4E4  2  26 75              ROL   FACt_1            ; ..
00E4E6  2  26 78              ROL   TempB             ; .. never overflows
00E4E8  2               
00E4E8  2  06 AF              ASL   FAC1_3            ; root = root * 2
00E4EA  2  26 AE              ROL   FAC1_2            ; ..
00E4EC  2  26 AD              ROL   FAC1_1            ; .. never overflows
00E4EE  2               
00E4EE  2  A5 AF              LDA   FAC1_3            ; get root low byte
00E4F0  2  2A                 ROL                     ; *2
00E4F1  2  85 5B              STA   Temp3             ; save partial low byte
00E4F3  2  A5 AE              LDA   FAC1_2            ; get root low mid byte
00E4F5  2  2A                 ROL                     ; *2
00E4F6  2  85 5C              STA   Temp3+1           ; save partial low mid byte
00E4F8  2  A5 AD              LDA   FAC1_1            ; get root high mid byte
00E4FA  2  2A                 ROL                     ; *2
00E4FB  2  85 5D              STA   Temp3+2           ; save partial high mid byte
00E4FD  2  A9 00              LDA   #$00              ; get root high byte (always $00)
00E4FF  2  2A                 ROL                     ; *2
00E500  2  85 5E              STA   Temp3+3           ; save partial high byte
00E502  2               
00E502  2                                             ; carry clear for subtract +1
00E502  2  A5 77              LDA   FACt_3            ; get remainder low byte
00E504  2  E5 5B              SBC   Temp3             ; subtract partial low byte
00E506  2  85 5B              STA   Temp3             ; save partial low byte
00E508  2               
00E508  2  A5 76              LDA   FACt_2            ; get remainder low mid byte
00E50A  2  E5 5C              SBC   Temp3+1           ; subtract partial low mid byte
00E50C  2  85 5C              STA   Temp3+1           ; save partial low mid byte
00E50E  2               
00E50E  2  A5 75              LDA   FACt_1            ; get remainder high mid byte
00E510  2  E5 5D              SBC   Temp3+2           ; subtract partial high mid byte
00E512  2  A8                 TAY                     ; copy partial high mid byte
00E513  2               
00E513  2  A5 78              LDA   TempB             ; get remainder high byte
00E515  2  E5 5E              SBC   Temp3+3           ; subtract partial high byte
00E517  2  90 0E              BCC   LAB_SQNS          ; skip sub if remainder smaller
00E519  2               
00E519  2  85 78              STA   TempB             ; save remainder high byte
00E51B  2               
00E51B  2  84 75              STY   FACt_1            ; save remainder high mid byte
00E51D  2               
00E51D  2  A5 5C              LDA   Temp3+1           ; get remainder low mid byte
00E51F  2  85 76              STA   FACt_2            ; save remainder low mid byte
00E521  2               
00E521  2  A5 5B              LDA   Temp3             ; get partial low byte
00E523  2  85 77              STA   FACt_3            ; save remainder low byte
00E525  2               
00E525  2  E6 AF              INC   FAC1_3            ; increment root low byte (never any rollover)
00E527  2               LAB_SQNS
00E527  2  CA                 DEX                     ; decrement bit pair count
00E528  2  D0 A2              BNE   LAB_SQE1          ; loop if not all done
00E52A  2               
00E52A  2  38                 SEC                     ; set carry for subtract
00E52B  2  A5 B3              LDA   FAC2_e            ; get exponent
00E52D  2  E9 80              SBC   #$80              ; normalise
00E52F  2  6A                 ROR                     ; /2 and re-bias to $80
00E530  2  69 00              ADC   #$00              ; add bit zero back in (allow for half shift)
00E532  2  85 AC              STA   FAC1_e            ; save it
00E534  2  4C BB DA           JMP   LAB_24D5          ; normalise FAC1 and return
00E537  2               
00E537  2               ; perform VARPTR()
00E537  2               
00E537  2               LAB_VARPTR
00E537  2  20 BC 00           JSR   LAB_IGBY          ; increment and scan memory
00E53A  2  20 10 D2           JSR   LAB_GVAR          ; get var address
00E53D  2  20 C9 CD           JSR   LAB_1BFB          ; scan for ")" , else do syntax error then warm start
00E540  2  A4 95              LDY   Cvaral            ; get var address low byte
00E542  2  A5 96              LDA   Cvarah            ; get var address high byte
00E544  2  4C C8 D4           JMP   LAB_AYFC          ; save and convert integer AY to FAC1 and return
00E547  2               
00E547  2               ; perform PI
00E547  2               
00E547  2               LAB_PI
00E547  2  A9 BF              LDA   #<LAB_2C7C        ; set (2*pi) pointer low byte
00E549  2  A0 F7              LDY   #>LAB_2C7C        ; set (2*pi) pointer high byte
00E54B  2  20 00 DD           JSR   LAB_UFAC          ; unpack memory (AY) into FAC1
00E54E  2  C6 AC              DEC   FAC1_e            ; make result = PI
00E550  2  60                 RTS
00E551  2               
00E551  2               ; perform TWOPI
00E551  2               
00E551  2               LAB_TWOPI
00E551  2  A9 BF              LDA   #<LAB_2C7C        ; set (2*pi) pointer low byte
00E553  2  A0 F7              LDY   #>LAB_2C7C        ; set (2*pi) pointer high byte
00E555  2  4C 00 DD           JMP   LAB_UFAC          ; unpack memory (AY) into FAC1 and return
00E558  2               
