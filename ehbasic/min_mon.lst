000000r 2               ; offsets from a base of X or Y
000000r 2               
000000r 2               PLUS_0            = $00       ; X or Y plus 0
000000r 2               PLUS_1            = $01       ; X or Y plus 1
000000r 2               PLUS_2            = $02       ; X or Y plus 2
000000r 2               PLUS_3            = $03       ; X or Y plus 3
000000r 2               
000000r 2               LAB_STAK          = $0100     ; stack bottom, no offset
000000r 2               
000000r 2               LAB_SKFE          = LAB_STAK+$FE
000000r 2                                             ; flushed stack address
000000r 2               LAB_SKFF          = LAB_STAK+$FF
000000r 2                                             ; flushed stack address
000000r 2               
000000r 2               ; the following locations are bulk initialized from PG2_TABS at LAB_COLD
000000r 2               ccflag            = $0200     ; BASIC CTRL-C flag, 00 = enabled, 01 = dis
000000r 2               ccbyte            = ccflag+1  ; BASIC CTRL-C byte
000000r 2               ccnull            = ccbyte+1  ; BASIC CTRL-C byte timeout
000000r 2               
000000r 2               VEC_CC            = ccnull+1  ; ctrl c check vector
000000r 2               ; end bulk initialize from PG2_TABS at LAB_COLD
000000r 2               
000000r 2               ; the following locations are bulk initialized by min_mon.asm from LAB_vec at LAB_stlp
000000r 2               VEC_IN            = VEC_CC+2  ; input vector
000000r 2               VEC_OUT           = VEC_IN+2  ; output vector
000000r 2               VEC_LD            = VEC_OUT+2 ; load vector
000000r 2               VEC_SV            = VEC_LD+2  ; save vector
000000r 2               ; end bulk initialize by min_mon.asm from LAB_vec at LAB_stlp
000000r 2               
000000r 2               ; Ibuffs can now be anywhere in RAM, ensure that the max length is < $80,
000000r 2               ; the input buffer must not cross a page boundary and must not overlap with
000000r 2               ; program RAM pages!
000000r 2               
000000r 2               ;Ibuffs            = IRQ_vec+$14
000000r 2               EXT_vec           = VEC_SV+$16
000000r 2                                             ; extension ROM call trampoline in RAM ($0221)
000000r 2                                             ; Followed by EXT_RESET_CODE ($022E, 8 bytes) and
000000r 2                                             ; the Extension→BASIC bridge trampolines:
000000r 2                                             ;   EXT_GTBY  ($023B, 14 bytes) — parse byte expr
000000r 2                                             ;   EXT_GTWRD ($0249, 14 bytes) — parse 16-bit expr
000000r 2                                             ;   EXT_SNERR ($0257,  8 bytes) — syntax error
000000r 2               Ibuffs            = VEC_SV+$54
000000r 2                                             ; start of input buffer after IRQ/NMI/ext code
000000r 2               Ibuffe            = Ibuffs+$A0; end of input buffer (160 bytes, ends at $02FA)
000000r 2               
000000r 2               Ram_base          = $0300     ; start of user RAM (set as needed, should be page aligned)
000000r 2               Ram_top           = $A000     ; end of contiguous BASIC RAM+1 (before MMIO window)
000000r 2               
000000r 2               Stack_floor       = 16        ; bytes left free on stack for background interrupts
000000r 2               
000000r 2               ; This start can be changed to suit your system
000000r 2               
000000r 2                     .segment "CODE"
000000r 2                     .org    $C000
00C000  2               
00C000  2               ; BASIC cold start entry point
00C000  2               
00C000  2               ; new page 2 initialisation, copy block to ccflag on
00C000  2               
00C000  2               LAB_COLD
00C000  2  A0 04              LDY   #PG2_TABE-PG2_TABS-1
00C002  2                                             ; byte count-1
00C002  2               LAB_2D13
00C002  2  B9 35 E8           LDA   PG2_TABS,Y        ; get byte
00C005  2  99 00 02           STA   ccflag,Y          ; store in page 2
00C008  2  88                 DEY                     ; decrement count
00C009  2  10 F7              BPL   LAB_2D13          ; loop if not done
00C00B  2               
00C00B  2  A2 FF              LDX   #$FF              ; set byte
00C00D  2  86 88              STX   Clineh            ; set current line high byte (set immediate mode)
00C00F  2  9A                 TXS                     ; reset stack pointer
00C010  2               
00C010  2  A9 4C              LDA   #$4C              ; code for JMP
00C012  2  85 A1              STA   Fnxjmp            ; save for jump vector for functions
00C014  2               
00C014  2               ; copy block from LAB_2CEE to $00BC - $00D7
00C014  2               
00C014  2  A2 1C              LDX   #StrTab-LAB_2CEE  ; set byte count
00C016  2               LAB_2D4E
00C016  2  BD D8 F3           LDA   LAB_2CEE-1,X      ; get byte from table
00C019  2  95 BB              STA   LAB_IGBY-1,X      ; save byte in page zero
00C01B  2  CA                 DEX                     ; decrement count
00C01C  2  D0 F8              BNE   LAB_2D4E          ; loop if not all done
00C01E  2               
00C01E  2               ; copy block from StrTab to $0000 - $0012
00C01E  2               
00C01E  2               LAB_GMEM
00C01E  2  A2 12              LDX   #EndTab-StrTab-1  ; set byte count-1
00C020  2               TabLoop
00C020  2  BD F5 F3           LDA   StrTab,X          ; get byte from table
00C023  2  95 00              STA   PLUS_0,X          ; save byte in page zero
00C025  2  CA                 DEX                     ; decrement count
00C026  2  10 F8              BPL   TabLoop           ; loop if not all done
00C028  2               
00C028  2               ; set-up start values
00C028  2               
00C028  2  64 DC              STZ   NmiBase           ; clear NMI handler enabled flag
00C02A  2  64 DF              STZ   IrqBase           ; clear IRQ handler enabled flag
00C02C  2  64 B2              STZ   FAC1_o            ; clear FAC1 overflow byte
00C02E  2  64 67              STZ   last_sh           ; clear descriptor stack top item pointer high byte
00C030  2               
00C030  2  A9 0E              LDA   #$0E              ; set default tab size
00C032  2  85 64              STA   TabSiz            ; save it
00C034  2  A9 03              LDA   #$03              ; set garbage collect step size for descriptor stack
00C036  2  85 A0              STA   g_step            ; save it
00C038  2  A2 68              LDX   #des_sk           ; descriptor stack start
00C03A  2  86 65              STX   next_s            ; set descriptor stack pointer
00C03C  2  20 9C CA           JSR   LAB_CRLF          ; print CR/LF
00C03F  2  A0 00              LDY   #$00              ; clear Y for indirect indexed writes
00C041  2  A9 00              LDA   #<Ram_base        ; always start from configured RAM base
00C043  2  85 11              STA   Itempl
00C045  2  A9 03              LDA   #>Ram_base
00C047  2  85 12              STA   Itemph
00C049  2                                             ; detect RAM limit by probing for writeable memory
00C049  2               LAB_2D93
00C049  2  E6 11              INC   Itempl            ; increment temporary integer low byte
00C04B  2  D0 08              BNE   LAB_2D99          ; branch if no overflow
00C04D  2               
00C04D  2  E6 12              INC   Itemph            ; increment temporary integer high byte
00C04F  2  A5 12              LDA   Itemph            ; get high byte
00C051  2  C9 A0              CMP   #>Ram_top         ; compare with top of RAM+1
00C053  2  F0 11              BEQ   LAB_2DB6          ; branch if match (end of user RAM)
00C055  2               
00C055  2               LAB_2D99
00C055  2  A9 55              LDA   #$55              ; set test byte
00C057  2  91 11              STA   (Itempl),Y        ; save via temporary integer
00C059  2  D1 11              CMP   (Itempl),Y        ; compare via temporary integer
00C05B  2  D0 09              BNE   LAB_2DB6          ; branch if fail
00C05D  2               
00C05D  2  0A                 ASL                     ; shift test byte left (now $AA)
00C05E  2  91 11              STA   (Itempl),Y        ; save via temporary integer
00C060  2  D1 11              CMP   (Itempl),Y        ; compare via temporary integer
00C062  2  F0 E5              BEQ   LAB_2D93          ; if ok go do next byte
00C064  2               
00C064  2  D0 00              BNE   LAB_2DB6          ; branch if fail
00C066  2               
00C066  2               LAB_2DB6
00C066  2  A5 11              LDA   Itempl            ; get temporary integer low byte
00C068  2  A4 12              LDY   Itemph            ; get temporary integer high byte
00C06A  2               ; uncomment these lines if you want to check on the high limit of memory.
00C06A  2               ; default is to trust the configured probe range.
00C06A  2               
00C06A  2               ;     CPY   #>Ram_top         ; compare with top of RAM high byte
00C06A  2               ;     BCC   MEM_OK            ; branch if < RAM top
00C06A  2               
00C06A  2               ;     BNE   LAB_GMEM          ; if too large go try again
00C06A  2                                             ; else was = so compare low bytes
00C06A  2               ;     CMP   #<Ram_top         ; compare with top of RAM low byte
00C06A  2               ;     BEQ   MEM_OK            ; branch if = RAM top
00C06A  2               
00C06A  2               ;     BCS   LAB_GMEM          ; if too large go try again
00C06A  2               
00C06A  2               ;MEM_OK
00C06A  2  85 85              STA   Ememl             ; set end of mem low byte
00C06C  2  84 86              STY   Ememh             ; set end of mem high byte
00C06E  2  85 81              STA   Sstorl            ; set bottom of string space low byte
00C070  2  84 82              STY   Sstorh            ; set bottom of string space high byte
00C072  2               
00C072  2  A0 00              LDY   #<Ram_base        ; set start addr low byte
00C074  2  A2 03              LDX   #>Ram_base        ; set start addr high byte
00C076  2  84 79              STY   Smeml             ; save start of mem low byte
00C078  2  86 7A              STX   Smemh             ; save start of mem high byte
00C07A  2               
00C07A  2               ; this line is only needed if Ram_base is not $xx00
00C07A  2                     .IF   Ram_base&$FF>0
00C07A  2                     LDY   #$00              ; clear Y
00C07A  2                     .ENDIF
00C07A  2               
00C07A  2  98                 TYA                     ; clear A
00C07B  2  91 79              STA   (Smeml),Y         ; clear first byte
00C07D  2  E6 79              INC   Smeml             ; increment start of mem low byte
00C07F  2               
00C07F  2               ; these two lines are only needed if Ram_base is $xxFF
00C07F  2                     .IF   Ram_base&$FF=$FF
00C07F  2                     BNE   LAB_2E05          ; branch if no rollover
00C07F  2                     INC   Smemh             ; increment start of mem high byte
00C07F  2               LAB_2E05
00C07F  2                     .ENDIF
00C07F  2               
00C07F  2  20 21 C4           JSR   LAB_1463          ; do "NEW" and "CLEAR"
00C082  2  20 3A E8           JSR   LAB_SPLASH        ; draw centered text startup splash
00C085  2  A5 85              LDA   Ememl             ; get end of mem low byte
00C087  2  38                 SEC                     ; set carry for subtract
00C088  2  E5 79              SBC   Smeml             ; subtract start of mem low byte
00C08A  2  AA                 TAX                     ; copy to X
00C08B  2  A5 86              LDA   Ememh             ; get end of mem high byte
00C08D  2  E5 7A              SBC   Smemh             ; subtract start of mem high byte
00C08F  2  20 D7 DE           JSR   LAB_295E          ; print XA as unsigned integer (bytes free)
00C092  2  A9 08              LDA   #<LAB_SMSG        ; point to sign-on message (low addr)
00C094  2  A0 F4              LDY   #>LAB_SMSG        ; point to sign-on message (high addr)
00C096  2  20 DD CA           JSR   LAB_18C3          ; print " BASIC bytes free  "
00C099  2               
00C099  2                     ; -- print expansion memory size if XMC present --
00C099  2  AD 0D BA           LDA   XMC_BANKS         ; read bank count register
00C09C  2  F0 19              BEQ   @no_xmc           ; skip if no expansion memory
00C09E  2               
00C09E  2                     ; banks * 64 = KB — shift left 6 bits to get A(hi):X(lo)
00C09E  2  AA                 TAX                     ; save bank count in X
00C09F  2  4A                 LSR   A
00C0A0  2  4A                 LSR   A                 ; A = banks >> 2 = high byte of KB
00C0A1  2  48                 PHA                     ; save high byte on stack
00C0A2  2  8A                 TXA                     ; A = bank count again
00C0A3  2  29 03              AND   #$03              ; keep only low 2 bits
00C0A5  2  0A                 ASL   A
00C0A6  2  0A                 ASL   A
00C0A7  2  0A                 ASL   A
00C0A8  2  0A                 ASL   A
00C0A9  2  0A                 ASL   A
00C0AA  2  0A                 ASL   A                 ; (low 2 bits) << 6 = low byte of KB
00C0AB  2  AA                 TAX                     ; X = low byte of KB
00C0AC  2  68                 PLA                     ; A = high byte of KB
00C0AD  2  20 D7 DE           JSR   LAB_295E          ; print KB as unsigned integer
00C0B0  2  A9 1C              LDA   #<LAB_XMSG
00C0B2  2  A0 F4              LDY   #>LAB_XMSG
00C0B4  2  20 DD CA           JSR   LAB_18C3          ; print "K expansion memory"
00C0B7  2               @no_xmc
00C0B7  2  A9 2F              LDA   #<LAB_NLNL
00C0B9  2  A0 F4              LDY   #>LAB_NLNL
00C0BB  2  20 DD CA           JSR   LAB_18C3          ; print CR/LF CR/LF
00C0BE  2               
00C0BE  2  A9 74              LDA   #<LAB_1274        ; warm start vector low byte
00C0C0  2  A0 C1              LDY   #>LAB_1274        ; warm start vector high byte
00C0C2  2  85 01              STA   Wrmjpl            ; save warm start vector low byte
00C0C4  2  84 02              STY   Wrmjph            ; save warm start vector high byte
00C0C6  2               
00C0C6  2  20 63 F3           JSR   LAB_AUTOBOOT      ; try autoboot before Ready prompt
00C0C9  2               
00C0C9  2  6C 01 00           JMP   (Wrmjpl)          ; go do warm start
00C0CC  2               
00C0CC  2               ; open up space in memory
00C0CC  2               ; move (Ostrtl)-(Obendl) to new block ending at (Nbendl)
00C0CC  2               
00C0CC  2               ; Nbendl,Nbendh - new block end address (A/Y)
00C0CC  2               ; Obendl,Obendh - old block end address
00C0CC  2               ; Ostrtl,Ostrth - old block start address
00C0CC  2               
00C0CC  2               ; returns with ..
00C0CC  2               
00C0CC  2               ; Nbendl,Nbendh - new block start address (high byte - $100)
00C0CC  2               ; Obendl,Obendh - old block start address (high byte - $100)
00C0CC  2               ; Ostrtl,Ostrth - old block start address (unchanged)
00C0CC  2               
00C0CC  2               LAB_11CF
00C0CC  2  20 19 C1           JSR   LAB_121F          ; check available memory, "Out of memory" error if no room
00C0CF  2                                             ; addr to check is in AY (low/high)
00C0CF  2  85 7F              STA   Earryl            ; save new array mem end low byte
00C0D1  2  84 80              STY   Earryh            ; save new array mem end high byte
00C0D3  2               
00C0D3  2               ; open up space in memory
00C0D3  2               ; move (Ostrtl)-(Obendl) to new block ending at (Nbendl)
00C0D3  2               ; don't set array end
00C0D3  2               
00C0D3  2               LAB_11D6
00C0D3  2  38                 SEC                     ; set carry for subtract
00C0D4  2  A5 A6              LDA   Obendl            ; get block end low byte
00C0D6  2  E5 AA              SBC   Ostrtl            ; subtract block start low byte
00C0D8  2  A8                 TAY                     ; copy MOD(block length/$100) byte to Y
00C0D9  2  A5 A7              LDA   Obendh            ; get block end high byte
00C0DB  2  E5 AB              SBC   Ostrth            ; subtract block start high byte
00C0DD  2  AA                 TAX                     ; copy block length high byte to X
00C0DE  2  E8                 INX                     ; +1 to allow for count=0 exit
00C0DF  2  98                 TYA                     ; copy block length low byte to A
00C0E0  2  F0 24              BEQ   LAB_120A          ; branch if length low byte=0
00C0E2  2               
00C0E2  2                                             ; block is (X-1)*256+Y bytes, do the Y bytes first
00C0E2  2               
00C0E2  2  38                 SEC                     ; set carry for add + 1, two's complement
00C0E3  2  49 FF              EOR   #$FF              ; invert low byte for subtract
