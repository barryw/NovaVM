00E125  2  26 DA              ROL   Rbyte2            ; shift PRNG middle byte
00E127  2  26 DB              ROL   Rbyte3            ; shift PRNG least significant byte
00E129  2  26 D8              ROL   Rbyte4            ; shift PRNG extra byte
00E12B  2  90 05              BCC   Ninc1             ; branch if bit 32 clear
00E12D  2               
00E12D  2  8A                 TXA                     ; set EOR byte
00E12E  2  45 D9              EOR   Rbyte1            ; EOR PRNG extra byte
00E130  2  85 D9              STA   Rbyte1            ; save new PRNG extra byte
00E132  2               Ninc1
00E132  2  88                 DEY                     ; decrement loop count
00E133  2  D0 EE              BNE   LoopPRN           ; loop if not all done
00E135  2               
