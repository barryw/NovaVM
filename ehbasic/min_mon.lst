00E82C  2               FIO_CMD_PWD     = $26              ; print working directory
00E82C  2               MUSIC_STATUS   = $BA50         ; bit 0=SFX playing, bit 1=music playing
00E82C  2               MUSIC_NOTE1    = $BA51         ; voice 1 current MIDI note (0=silent)
00E82C  2               MUSIC_NOTE2    = $BA52         ; voice 2 current MIDI note
00E82C  2               MUSIC_NOTE3    = $BA53         ; voice 3 current MIDI note
