00EFDE  2               ; common: issue FIO command in A, check status, error on fail
00EFDE  2               
00EFDE  2               LAB_FIO_EXEC
00EFDE  2  20 C4 ED           JSR   fio_exec
00EFE1  2  D0 01              BNE   @fio_chk_err
00EFE3  2  60                 RTS
00EFE4  2               @fio_chk_err
00EFE4  2  4C 79 F3           JMP   LAB_FIO_ERRHND
