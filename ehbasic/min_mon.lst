00EEB2  2  20 92 EC           JSR   LAB_SKIPX          ; FLAGS
00EEB5  2  A9 05              LDA   #$05              ; field offset 5 = Flags
00EEB7  2  4C C1 EE           JMP   @c_spr_idx
00EEBA  2               
00EEBA  2               @cs_pri
00EEBA  2  A2 03              LDX   #3
00EEBC  2  20 92 EC           JSR   LAB_SKIPX          ; PRI
00EEBF  2  A9 06              LDA   #$06              ; field offset 6 = Priority
00EEC1  2                     ; fall through to @c_spr_idx
00EEC1  2               
00EEC1  2                     ; A = field offset, now parse (n) and compute address $A040 + n*8 + A
00EEC1  2               @c_spr_idx
00EEC1  2  48                 PHA                     ; save field offset
00EEC2  2  20 BC 00           JSR   LAB_IGBY          ; consume '('
