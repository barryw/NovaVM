00DFCD  2  26 DA              ROL   Rbyte2            ; shift PRNG middle byte
00DFCF  2  26 DB              ROL   Rbyte3            ; shift PRNG least significant byte
00DFD1  2  26 D8              ROL   Rbyte4            ; shift PRNG extra byte
