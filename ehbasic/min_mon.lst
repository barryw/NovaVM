00EFAB  2               
00EFAB  2               LAB_SIDPLAY
00EFAB  2  20 4B F3           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EFAE  2  A9 01              LDA   #$01              ; default song = 1
00EFB0  2  8D A4 B9           STA   FIO_SRCL
00EFB3  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00EFB6  2  C9 2C              CMP   #','
00EFB8  2  D0 09              BNE   @sp_go
