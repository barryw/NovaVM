00EE1C  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00EE1F  2  C9 2C              CMP   #','
00EE21  2  F0 16              BEQ   @sv_raw
00EE23  2                     ; default: save BASIC program area
00EE23  2  A5 79              LDA   Smeml
00EE25  2  8D A4 B9           STA   FIO_SRCL
