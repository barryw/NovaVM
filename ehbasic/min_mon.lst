00E8E5  2               
00E8E5  2               BLT_CMD       = $BA83          ; write triggers blit
00E8E5  2               BLT_STATUS    = $BA84          ; 1=busy, 2=ok, 3=error
00E8E5  2               BLT_ERRCODE   = $BA85          ; blitter error code
00E8E5  2               BLT_SRCSPACE  = $BA86          ; source space id
00E8E5  2               BLT_DSTSPACE  = $BA87          ; destination space id
00E8E5  2               BLT_SRCL      = $BA88          ; source addr low
00E8E5  2               BLT_SRCM      = $BA89          ; source addr mid
00E8E5  2               BLT_SRCH      = $BA8A          ; source addr high
00E8E5  2               BLT_DSTL      = $BA8B          ; destination addr low
00E8E5  2               BLT_DSTM      = $BA8C          ; destination addr mid
00E8E5  2               BLT_DSTH      = $BA8D          ; destination addr high
00E8E5  2               BLT_WIDTHL    = $BA8E          ; width low
00E8E5  2               BLT_WIDTHH    = $BA8F          ; width high
00E8E5  2               BLT_HEIGHTL   = $BA90          ; height low
00E8E5  2               BLT_HEIGHTH   = $BA91          ; height high
00E8E5  2               BLT_SRCSTRL   = $BA92          ; source stride low
00E8E5  2               BLT_SRCSTRH   = $BA93          ; source stride high
00E8E5  2               BLT_DSTSTRL   = $BA94          ; destination stride low
00E8E5  2               BLT_DSTSTRH   = $BA95          ; destination stride high
00E8E5  2               BLT_MODE      = $BA96          ; mode flags
00E8E5  2               BLT_FILL      = $BA97          ; fill byte (when mode bit0 set)
00E8E5  2               BLT_CKEY      = $BA98          ; color key (when mode bit1 set)
00E8E5  2               BLT_CNTL      = $BA99          ; written count low
00E8E5  2               BLT_CNTM      = $BA9A          ; written count mid
00E8E5  2               BLT_CNTH      = $BA9B          ; written count high
00E8E5  2               
00E8E5  2               BLT_CMD_START = $01
00E8E5  2               BLT_BUSY      = $01
00E8E5  2               BLT_OK        = $02
00E8E5  2               BLT_MODE_FILL = $01
00E8E5  2               BLT_SPACE_XRAM = $05
00E8E5  2               
00E8E5  2               ; --- Tile engine registers ---
00E8E5  2               
00E8E5  2               TileConfig     = $A0C0
00E8E5  2               TileTransColor = $A0C1
00E8E5  2               TileScrollXL   = $A0C2
00E8E5  2               TileScrollXH   = $A0C3
00E8E5  2               TileScrollYL   = $A0C4
00E8E5  2               TileScrollYH   = $A0C5
00E8E5  2               TileCmd        = $A0C7
00E8E5  2               TileP0         = $A0C8
00E8E5  2               TileP1         = $A0C9
00E8E5  2               TileP2         = $A0CA
00E8E5  2               TileP3         = $A0CB
00E8E5  2               TileAddrL      = $A0CC
00E8E5  2               TileAddrH      = $A0CD
00E8E5  2               TilePalP0      = $A0CE
00E8E5  2               TilePalP1      = $A0CF
00E8E5  2               TileColL       = $A0D0
00E8E5  2               TileColH       = $A0D1
00E8E5  2               TilePeekVal    = $A0D2
00E8E5  2               TilePeekAttr   = $A0D3
00E8E5  2               TileCfgSize16  = $01
00E8E5  2               TileCmdDef     = $01
00E8E5  2               TileCmdDefBulk = $02
00E8E5  2               TileCmdPut     = $03
00E8E5  2               TileCmdAttr    = $04
00E8E5  2               TileCmdFill    = $05
00E8E5  2               TileCmdRow     = $06
00E8E5  2               TileCmdCol     = $07
00E8E5  2               TileCmdLoad    = $08
00E8E5  2               TileCmdPal     = $0A
00E8E5  2               TileCmdPalC    = $0B
00E8E5  2               TileCmdPeek    = $0C
00E8E5  2               TileCmdCls     = $0F
00E8E5  2               TileCmdBufFill = $10
00E8E5  2               TileCmdBufSet  = $11
00E8E5  2               TileCmdBufRange = $12
00E8E5  2               TileCmdBufPut  = $13
00E8E5  2               FioCmdTSave    = $16
00E8E5  2               FioCmdTLoad    = $17
00E8E5  2               
00E8E5  2               ; --- VGC command handlers ---
00E8E5  2               
00E8E5  2               ; draw a text-only cold-start splash screen
00E8E5  2               
00E8E5  2               LAB_SPLASH
00E8E5  2  9C 01 A0           STZ   VGC_BGCOL         ; black background
00E8E8  2  A9 0F              LDA   #$0F              ; light grey text
00E8EA  2  8D 02 A0           STA   VGC_FGCOL
00E8ED  2  A9 0B              LDA   #$0B              ; dark grey border
00E8EF  2  8D 0D A0           STA   VGC_BORDER
00E8F2  2  9C 00 A0           STZ   VGC_MODE          ; mode 0: text only
00E8F5  2               
00E8F5  2  A9 0C              LDA   #$0C              ; clear text layer and home cursor
00E8F7  2  20 D7 E8           JSR   V_OUTP
00E8FA  2  A9 21              LDA   #$21              ; centered x for "NovaBASIC v1.0"
00E8FC  2  8D 03 A0           STA   VGC_CURSX
00E8FF  2  85 0E              STA   TPos
00E901  2  A9 01              LDA   #$01              ; leave breathing room on the first row
00E903  2  8D 04 A0           STA   VGC_CURSY
00E906  2  A9 2D              LDA   #<LAB_BNR1
00E908  2  A0 E9              LDY   #>LAB_BNR1
00E90A  2  20 BB CA           JSR   LAB_18C3
00E90D  2               
00E90D  2  A9 1A              LDA   #$1A              ; centered x for "Derived from EhBASIC 2.22p5"
00E90F  2  8D 03 A0           STA   VGC_CURSX
00E912  2  85 0E              STA   TPos
00E914  2  A9 03              LDA   #$03              ; one empty row between lines
00E916  2  8D 04 A0           STA   VGC_CURSY
00E919  2  A9 3C              LDA   #<LAB_BNR2
00E91B  2  A0 E9              LDY   #>LAB_BNR2
00E91D  2  20 BB CA           JSR   LAB_18C3
00E920  2               
00E920  2  A9 11              LDA   #$11              ; centered x for "xxxxx BASIC bytes free  xxxK expansion memory"
00E922  2  8D 03 A0           STA   VGC_CURSX
00E925  2  85 0E              STA   TPos
00E927  2  A9 05              LDA   #$05              ; one empty row between lines
00E929  2  8D 04 A0           STA   VGC_CURSY
00E92C  2  60                 RTS
00E92D  2               
00E92D  2               LAB_BNR1
00E92D  2  4E 6F 76 61        .byte "NovaBASIC v1.0",$00
00E931  2  42 41 53 49  
00E935  2  43 20 76 31  
00E93C  2               LAB_BNR2
00E93C  2  44 65 72 69        .byte "Derived from EhBASIC 2.22p5",$00
00E940  2  76 65 64 20  
00E944  2  66 72 6F 6D  
00E958  2               
00E958  2               ; perform CLS — clear screen, no arguments
00E958  2               
00E958  2               LAB_CLS
00E958  2  A9 0C              LDA   #$0C              ; form feed character
00E95A  2  8D 0E A0           STA   VGC_CHAROUT       ; write to CHAROUT register
00E95D  2  60                 RTS
00E95E  2               
00E95E  2               ; perform COLOR fg [,bg [,border]]
00E95E  2               
00E95E  2               LAB_COLOR
00E95E  2  20 0F D9           JSR   LAB_GTBY          ; get fg color byte in X
00E961  2  8E 02 A0           STX   VGC_FGCOL         ; store foreground color
00E964  2  20 C2 00           JSR   LAB_GBYT          ; peek at current byte
00E967  2  C9 2C              CMP   #','              ; comma follows?
00E969  2  D0 19              BNE   @done             ; no, just fg was given
00E96B  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E96E  2  20 0F D9           JSR   LAB_GTBY          ; get bg color byte in X
00E971  2  8E 01 A0           STX   VGC_BGCOL         ; store background color
00E974  2  20 C2 00           JSR   LAB_GBYT          ; peek for optional border color
00E977  2  C9 2C              CMP   #','              ; second comma follows?
00E979  2  D0 09              BNE   @done             ; no, fg/bg only
00E97B  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E97E  2  20 0F D9           JSR   LAB_GTBY          ; get border color byte in X
00E981  2  8E 0D A0           STX   VGC_BORDER        ; store border color
00E984  2               @done
00E984  2  60                 RTS
00E985  2               
00E985  2               ; perform REVERSE [fg,bg]
00E985  2               
00E985  2               LAB_REVERSE
00E985  2  20 C2 00           JSR   LAB_GBYT          ; optional explicit reverse colours?
00E988  2  F0 2B              BEQ   @swap
00E98A  2  C9 3A              CMP   #':'              ; no args before next statement
00E98C  2  F0 27              BEQ   @swap
00E98E  2  20 0F D9           JSR   LAB_GTBY          ; reverse foreground in X
00E991  2  8A                 TXA
00E992  2  29 0F              AND   #$0F
00E994  2  48                 PHA
00E995  2  20 D8 CD           JSR   LAB_1C01          ; comma
00E998  2  20 0F D9           JSR   LAB_GTBY          ; reverse background in X
00E99B  2  8A                 TXA
00E99C  2  29 0F              AND   #$0F
00E99E  2  0A                 ASL
00E99F  2  0A                 ASL
00E9A0  2  0A                 ASL
00E9A1  2  0A                 ASL
00E9A2  2  85 78              STA   TempB
00E9A4  2  68                 PLA
00E9A5  2  05 78              ORA   TempB
00E9A7  2  8D E7 A0           STA   VGC_TXTREVATTR
00E9AA  2  AD E6 A0           LDA   VGC_TXTFLAGS
00E9AD  2  29 FC              AND   #$FC              ; clear reverse bits, preserve flash/future bits
00E9AF  2  09 03              ORA   #(VTXT_REV | VTXT_REVEX)
00E9B1  2  8D E6 A0           STA   VGC_TXTFLAGS
00E9B4  2  60                 RTS
00E9B5  2               @swap
00E9B5  2  AD E6 A0           LDA   VGC_TXTFLAGS
00E9B8  2  29 FC              AND   #$FC              ; clear explicit attr; default is fg/bg swap
00E9BA  2  09 01              ORA   #VTXT_REV
00E9BC  2  8D E6 A0           STA   VGC_TXTFLAGS
00E9BF  2  60                 RTS
00E9C0  2               
00E9C0  2               ; perform REVERSEOFF
00E9C0  2               
00E9C0  2               LAB_REVERSEOFF
00E9C0  2  AD E6 A0           LDA   VGC_TXTFLAGS
00E9C3  2  29 FC              AND   #$FC              ; clear reverse and explicit reverse bits
00E9C5  2  8D E6 A0           STA   VGC_TXTFLAGS
00E9C8  2  60                 RTS
00E9C9  2               
00E9C9  2               ; perform FLASH
00E9C9  2               
00E9C9  2               LAB_FLASH
00E9C9  2  AD E6 A0           LDA   VGC_TXTFLAGS
00E9CC  2  09 04              ORA   #VTXT_FLASH
00E9CE  2  8D E6 A0           STA   VGC_TXTFLAGS
00E9D1  2  60                 RTS
00E9D2  2               
00E9D2  2               ; perform FLASHOFF
00E9D2  2               
00E9D2  2               LAB_FLASHOFF
00E9D2  2  AD E6 A0           LDA   VGC_TXTFLAGS
00E9D5  2  29 FB              AND   #$FB              ; clear flash bit
00E9D7  2  8D E6 A0           STA   VGC_TXTFLAGS
00E9DA  2  60                 RTS
00E9DB  2               
00E9DB  2               ; perform VPOKE plane,addr,value — write a byte to VGC memory
00E9DB  2               
00E9DB  2               LAB_VPOKE
00E9DB  2  20 0F D9           JSR   LAB_GTBY
00E9DE  2  8E 11 A0           STX   VGC_P0
00E9E1  2  20 D8 CD           JSR   LAB_1C01
00E9E4  2  20 FD D8           JSR   LAB_GTWRD
00E9E7  2  A5 AF              LDA   FAC1_3
00E9E9  2  8D 12 A0           STA   VGC_P1
00E9EC  2  A5 AE              LDA   FAC1_2
00E9EE  2  8D 13 A0           STA   VGC_P2
00E9F1  2  20 D8 CD           JSR   LAB_1C01
00E9F4  2  20 0F D9           JSR   LAB_GTBY
00E9F7  2  8E 14 A0           STX   VGC_P3
00E9FA  2  9C 15 A0           STZ   VGC_P4
00E9FD  2  A9 1A              LDA   #VCMD_MEMWRITE
00E9FF  2  8D 10 A0           STA   VGC_CMD
00EA02  2               @vpoke_wait
00EA02  2  AD 10 A0           LDA   VGC_CMD
00EA05  2  29 01              AND   #$01
00EA07  2  D0 F9              BNE   @vpoke_wait
00EA09  2  60                 RTS
00EA0A  2               
00EA0A  2               ; perform LOCATE x, y
00EA0A  2               
00EA0A  2               LAB_LOCATE
00EA0A  2  20 0F D9           JSR   LAB_GTBY          ; get x in X
00EA0D  2  8E 03 A0           STX   VGC_CURSX         ; store cursor X
00EA10  2  20 D8 CD           JSR   LAB_1C01          ; require comma
00EA13  2  20 0F D9           JSR   LAB_GTBY          ; get y in X
00EA16  2  8E 04 A0           STX   VGC_CURSY         ; store cursor Y
00EA19  2  60                 RTS
00EA1A  2               
00EA1A  2               ; perform MODE n
00EA1A  2               
00EA1A  2               LAB_GMODE
00EA1A  2  20 0F D9           JSR   LAB_GTBY          ; get mode byte in X
00EA1D  2  8E 00 A0           STX   VGC_MODE          ; store graphics mode
00EA20  2  60                 RTS
00EA21  2               
00EA21  2               ; perform FONT n — select active font slot (0-7)
00EA21  2               
00EA21  2               LAB_FONT
00EA21  2  20 0F D9           JSR   LAB_GTBY          ; get font index byte (0-7) in X
00EA24  2  8E 07 A0           STX   VGC_FONT          ; write to $A007
00EA27  2  60                 RTS
00EA28  2               
00EA28  2               ; perform GCLS — clear the graphics bitmap layer
00EA28  2               
00EA28  2               LAB_VGC_CMD_RTS
00EA28  2  8D 10 A0           STA   VGC_CMD
00EA2B  2  60                 RTS
00EA2C  2               
00EA2C  2               LAB_GCLS
00EA2C  2  20 9D EE           JSR   LAB_VSYNC         ; BASIC hides visible VGC draw tearing
00EA2F  2  A9 07              LDA   #VCMD_GCLS        ; GCLS command
00EA31  2  80 F5              BRA   LAB_VGC_CMD_RTS   ; trigger and return
00EA33  2               
00EA33  2               ; perform GCOLOR c — set graphics draw color (0-15)
00EA33  2               
00EA33  2               LAB_GCOLOR
00EA33  2  20 0F D9           JSR   LAB_GTBY          ; get color byte in X
00EA36  2  8E 11 A0           STX   VGC_P0             ; color in P0
00EA39  2  9C 12 A0           STZ   VGC_P1             ; high byte = 0
00EA3C  2  A9 08              LDA   #VCMD_GCOLOR      ; GCOLOR command
00EA3E  2  80 E8              BRA   LAB_VGC_CMD_RTS   ; trigger and return
00EA40  2               
00EA40  2               ; shared: load x(word),y(byte) into VGC_P0-P3
00EA40  2               
00EA40  2               LAB_VGC_XY
00EA40  2  20 FD D8           JSR   LAB_GTWRD         ; get x as 16-bit
00EA43  2  A5 AF              LDA   FAC1_3
00EA45  2  8D 11 A0           STA   VGC_P0             ; x low
00EA48  2  A5 AE              LDA   FAC1_2
00EA4A  2  8D 12 A0           STA   VGC_P1             ; x high
00EA4D  2  20 D8 CD           JSR   LAB_1C01          ; require comma
00EA50  2  20 0F D9           JSR   LAB_GTBY          ; get y as byte
00EA53  2  8E 13 A0           STX   VGC_P2             ; y low
00EA56  2  9C 14 A0           STZ   VGC_P3             ; y high = 0
00EA59  2  60                 RTS
00EA5A  2               
00EA5A  2               ; shared: load x0,y0,x1,y1 into VGC_P0-P7
00EA5A  2               
00EA5A  2               LAB_VGC_XYXY
00EA5A  2  20 40 EA           JSR   LAB_VGC_XY        ; x0,y0 → P0-P3
00EA5D  2  20 D8 CD           JSR   LAB_1C01          ; comma
00EA60  2  20 FD D8           JSR   LAB_GTWRD         ; x1 as 16-bit
00EA63  2  A5 AF              LDA   FAC1_3
00EA65  2  8D 15 A0           STA   VGC_P4             ; x1 low
00EA68  2  A5 AE              LDA   FAC1_2
00EA6A  2  8D 16 A0           STA   VGC_P5             ; x1 high
00EA6D  2  20 D8 CD           JSR   LAB_1C01          ; comma
00EA70  2  20 0F D9           JSR   LAB_GTBY          ; y1
00EA73  2  8E 17 A0           STX   VGC_P6             ; y1 low
00EA76  2  9C 18 A0           STZ   VGC_P7             ; y1 high = 0
00EA79  2  60                 RTS
00EA7A  2               
00EA7A  2               ; perform PLOT x, y
00EA7A  2               
00EA7A  2               LAB_PLOT
00EA7A  2  20 40 EA           JSR   LAB_VGC_XY
00EA7D  2  20 9D EE           JSR   LAB_VSYNC         ; wait before visible graphics mutation
00EA80  2  A9 01              LDA   #VCMD_PLOT        ; PLOT command
00EA82  2  80 A4              BRA   LAB_VGC_CMD_RTS   ; trigger and return
00EA84  2               
00EA84  2               ; perform UNPLOT x, y
00EA84  2               
00EA84  2               LAB_UNPLOT
00EA84  2  20 40 EA           JSR   LAB_VGC_XY
00EA87  2  20 9D EE           JSR   LAB_VSYNC
00EA8A  2  A9 02              LDA   #VCMD_UNPLOT      ; UNPLOT command
00EA8C  2  80 9A              BRA   LAB_VGC_CMD_RTS
00EA8E  2               
00EA8E  2               ; perform LINE x0, y0, x1, y1
00EA8E  2               
00EA8E  2               LAB_GLINE
00EA8E  2  20 5A EA           JSR   LAB_VGC_XYXY
00EA91  2  20 9D EE           JSR   LAB_VSYNC
00EA94  2  A9 03              LDA   #VCMD_LINE        ; LINE command
00EA96  2  80 90              BRA   LAB_VGC_CMD_RTS
00EA98  2               
00EA98  2               ; perform CIRCLE cx, cy, rx [, ry]
00EA98  2               ; 3 args = circle (rx=ry), 4 args = ellipse
00EA98  2               
00EA98  2               LAB_CIRCLE
00EA98  2  20 40 EA           JSR   LAB_VGC_XY        ; cx,cy → P0-P3
00EA9B  2  20 D8 CD           JSR   LAB_1C01          ; comma
00EA9E  2  20 FD D8           JSR   LAB_GTWRD         ; rx as 16-bit
00EAA1  2  A5 AF              LDA   FAC1_3
00EAA3  2  8D 15 A0           STA   VGC_P4             ; rx low
00EAA6  2  A5 AE              LDA   FAC1_2
00EAA8  2  8D 16 A0           STA   VGC_P5             ; rx high
00EAAB  2  9C 17 A0           STZ   VGC_P6             ; ry low = 0 (circle)
00EAAE  2  9C 18 A0           STZ   VGC_P7             ; ry high = 0
00EAB1  2  20 C2 00           JSR   LAB_GBYT          ; peek next
00EAB4  2  C9 2C              CMP   #','
00EAB6  2  D0 10              BNE   @circ_go
00EAB8  2  20 D8 CD           JSR   LAB_1C01          ; consume comma
00EABB  2  20 FD D8           JSR   LAB_GTWRD         ; ry as 16-bit
00EABE  2  A5 AF              LDA   FAC1_3
00EAC0  2  8D 17 A0           STA   VGC_P6             ; ry low
00EAC3  2  A5 AE              LDA   FAC1_2
00EAC5  2  8D 18 A0           STA   VGC_P7             ; ry high
00EAC8  2               @circ_go
00EAC8  2  20 9D EE           JSR   LAB_VSYNC
00EACB  2  A9 04              LDA   #VCMD_CIRCLE      ; CIRCLE command
00EACD  2  4C 28 EA           JMP   LAB_VGC_CMD_RTS
00EAD0  2               
00EAD0  2               ; perform GTEXT x, y, font, scale, "string"
00EAD0  2               
00EAD0  2               LAB_GTEXT
00EAD0  2  20 40 EA           JSR   LAB_VGC_XY        ; x,y → P0-P3
00EAD3  2  20 D8 CD           JSR   LAB_1C01          ; comma
00EAD6  2  20 0F D9           JSR   LAB_GTBY          ; font (0-7) → X
00EAD9  2  8E 15 A0           STX   VGC_P4             ; P4 = font index
00EADC  2  20 D8 CD           JSR   LAB_1C01          ; comma
00EADF  2  20 0F D9           JSR   LAB_GTBY          ; scale (1-8) → X
00EAE2  2  8E 16 A0           STX   VGC_P5             ; P5 = scale
00EAE5  2  20 D8 CD           JSR   LAB_1C01          ; comma
00EAE8  2  20 39 F4           JSR   LAB_FIO_GETNAME   ; string → FIO_NAME/FIO_NAMELEN
00EAEB  2  20 9D EE           JSR   LAB_VSYNC
00EAEE  2  A9 0A              LDA   #VCMD_GTEXT
00EAF0  2  4C 28 EA           JMP   LAB_VGC_CMD_RTS
00EAF3  2               
00EAF3  2               ; ── Tile engine shared ────────────────────────────────────────
00EAF3  2               
00EAF3  2               LAB_TB0C
00EAF3  2  20 0F D9           JSR   LAB_GTBY          ; byte → TileP0, comma
00EAF6  2  8E C8 A0           STX   TileP0
00EAF9  2  4C D8 CD           JMP   LAB_1C01
00EAFC  2               LAB_TWAD
00EAFC  2  20 FD D8           JSR   LAB_GTWRD         ; word → TileAddrL/H
00EAFF  2  A5 AF              LDA   FAC1_3
00EB01  2  8D CC A0           STA   TileAddrL
00EB04  2  A5 AE              LDA   FAC1_2
00EB06  2  8D CD A0           STA   TileAddrH
00EB09  2  60                 RTS
00EB0A  2               
00EB0A  2               ; ── Tile engine BASIC commands ────────────────────────────────
00EB0A  2               
00EB0A  2               LAB_TILESIZE
00EB0A  2  20 0F D9           JSR   LAB_GTBY
00EB0D  2  AD C0 A0           LDA   TileConfig
00EB10  2  29 FE              AND   #$FE
00EB12  2  E0 10              CPX   #16
00EB14  2  D0 02              BNE   @ts_s
00EB16  2  09 01              ORA   #TileCfgSize16
00EB18  2  48           @ts_s PHA
00EB19  2  20 9D EE           JSR   LAB_VSYNC
00EB1C  2  68                 PLA
00EB1D  2  8D C0 A0           STA   TileConfig
00EB20  2  60                 RTS
00EB21  2               LAB_MIRROR
