00ED95  2  F0 1C              BEQ   @c_on
00ED97  2  C9 CB              CMP   #TK_OFF
00ED99  2  F0 21              BEQ   @c_off
00ED9B  2  C9 41              CMP   #'A'
00ED9D  2  F0 56              BEQ   @c_add
00ED9F  2  C9 A1              CMP   #TK_LIST
00EDA1  2  F0 22              BEQ   @c_list
