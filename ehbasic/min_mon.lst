00ED39  2  88                 DEY
00ED3A  2  10 FA              BPL   @m_pri_clr
00ED3C  2                     ; Parse up to 6 comma-separated voice values
00ED3C  2  A0 00              LDY   #$00              ; slot index
00ED3E  2               @m_pri_nxt
00ED3E  2  20 FE D7           JSR   LAB_GTBY          ; get voice number → X
00ED41  2  8A                 TXA
00ED42  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00ED45  2  C8                 INY
00ED46  2  C0 06              CPY   #$06
