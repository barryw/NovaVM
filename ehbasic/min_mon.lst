00E522  2  A5 B3              LDA   FAC2_e            ; get exponent
00E524  2  E9 80              SBC   #$80              ; normalise
00E526  2  6A                 ROR                     ; /2 and re-bias to $80
00E527  2  69 00              ADC   #$00              ; add bit zero back in (allow for half shift)
00E529  2  85 AC              STA   FAC1_e            ; save it
00E52B  2  4C AD D9           JMP   LAB_24D5          ; normalise FAC1 and return
00E52E  2               
00E52E  2               ; perform VARPTR()
00E52E  2               
00E52E  2               LAB_VARPTR
00E52E  2  20 BC 00           JSR   LAB_IGBY          ; increment and scan memory
00E531  2  20 04 D1           JSR   LAB_GVAR          ; get var address
00E534  2  20 55 CD           JSR   LAB_1BFB          ; scan for ")" , else do syntax error then warm start
00E537  2  A4 95              LDY   Cvaral            ; get var address low byte
00E539  2  A5 96              LDA   Cvarah            ; get var address high byte
00E53B  2  4C B3 D3           JMP   LAB_AYFC          ; save and convert integer AY to FAC1 and return
00E53E  2               
00E53E  2               ; perform PI
00E53E  2               
00E53E  2               LAB_PI
00E53E  2  A9 B8              LDA   #<LAB_2C7C        ; set (2*pi) pointer low byte
00E540  2  A0 F7              LDY   #>LAB_2C7C        ; set (2*pi) pointer high byte
00E542  2  20 F6 DB           JSR   LAB_UFAC          ; unpack memory (AY) into FAC1
00E545  2  C6 AC              DEC   FAC1_e            ; make result = PI
00E547  2  60                 RTS
00E548  2               
00E548  2               ; perform TWOPI
00E548  2               
00E548  2               LAB_TWOPI
00E548  2  A9 B8              LDA   #<LAB_2C7C        ; set (2*pi) pointer low byte
00E54A  2  A0 F7              LDY   #>LAB_2C7C        ; set (2*pi) pointer high byte
00E54C  2  4C F6 DB           JMP   LAB_UFAC          ; unpack memory (AY) into FAC1 and return
00E54F  2               
