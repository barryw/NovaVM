00EFCA  2               ; perform SIDSTOP
00EFCA  2               
00EFCA  2               LAB_SIDSTOP
00EFCA  2  A9 09              LDA   #FIO_CMD_SIDSTOP
00EFCC  2  4C B3 ED           JMP   LAB_FIO_CMD_RTS
00EFCF  2               
00EFCF  2               ; perform MIDPLAY "filename"
00EFCF  2               ; MIDPLAY "song"  — auto-select 6 busiest MIDI channels
00EFCF  2               
00EFCF  2               LAB_MIDPLAY
00EFCF  2  20 4B F3           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EFD2  2  9C A4 B9           STZ   FIO_SRCL            ; no explicit mapping (auto-select)
00EFD5  2  A9 13              LDA   #FIO_CMD_MIDPLAY
00EFD7  2  80 05              BRA   LAB_FIO_EXEC       ; issue command, check status, return
00EFD9  2               
00EFD9  2               ; perform MIDSTOP
00EFD9  2               
00EFD9  2               LAB_MIDSTOP
00EFD9  2  A9 14              LDA   #FIO_CMD_MIDSTOP
00EFDB  2  4C B3 ED           JMP   LAB_FIO_CMD_RTS
