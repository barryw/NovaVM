00E114  2               ; to get 19th next number in sequence after seed n. This version of the PRNG uses
00E114  2               ; the Galois method and a sample of 65536 bytes produced gives the following values.
00E114  2               
00E114  2               ; Entropy = 7.997442 bits per byte
00E114  2               ; Optimum compression would reduce these 65536 bytes by 0 percent
00E114  2               
00E114  2               ; Chi square distribution for 65536 samples is 232.01, and
00E114  2               ; randomly would exceed this value 75.00 percent of the time
00E114  2               
00E114  2               ; Arithmetic mean value of data bytes is 127.6724, 127.5 would be random
00E114  2               ; Monte Carlo value for Pi is 3.122871269, error 0.60 percent
00E114  2               ; Serial correlation coefficient is -0.000370, totally uncorrelated would be 0.0
00E114  2               
00E114  2               LAB_RND
00E114  2  A5 AC              LDA   FAC1_e            ; get FAC1 exponent
00E116  2  F0 07              BEQ   NextPRN           ; do next random # if zero
00E118  2               
00E118  2                                             ; else get seed into random number store
00E118  2  A2 D8              LDX   #Rbyte4           ; set PRNG pointer low byte
00E11A  2  A0 00              LDY   #$00              ; set PRNG pointer high byte
00E11C  2  20 2A DD           JSR   LAB_2778          ; pack FAC1 into (XY)
00E11F  2               NextPRN
00E11F  2  A2 AF              LDX   #$AF              ; set EOR byte
00E121  2  A0 13              LDY   #$13              ; do this nineteen times
00E123  2               LoopPRN
