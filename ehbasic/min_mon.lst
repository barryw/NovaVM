00E7BB  2  00                 .byte $00               ; ctrl-c flag           -     $00 = enabled
00E7BC  2  00                 .byte $00               ; ctrl-c byte           -     GET needs this
00E7BD  2  00                 .byte $00               ; ctrl-c byte timeout   -     GET needs this
00E7BE  2  0F E3              .word CTRLC             ; ctrl c check vector
00E7C0  2               ;     .word xxxx              ; non halting key input -     monitor to set this
00E7C0  2               ;     .word xxxx              ; output vector         -     monitor to set this
00E7C0  2               ;     .word xxxx              ; load vector           -     monitor to set this
00E7C0  2               ;     .word xxxx              ; save vector           -     monitor to set this
