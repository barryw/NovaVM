00EBEC  2  18                 CLC
00EBED  2  A5 79              LDA   Smeml
00EBEF  2  6D A8 B9           ADC   FIO_SIZEL
00EBF2  2  85 7B              STA   Svarl
00EBF4  2  A5 7A              LDA   Smemh
00EBF6  2  6D A9 B9           ADC   FIO_SIZEH
00EBF9  2  85 7C              STA   Svarh
