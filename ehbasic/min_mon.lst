00FE73  2               
00FE73  2               AA_end_basic
00FE73  2               
00FE73  1               
00FE73  1               ; put the IRQ and NMI code in RAM so that it can be changed
00FE73  1               
00FE73  1               IRQ_vec     = VEC_SV+2        ; IRQ code vector
00FE73  1               NMI_vec     = IRQ_vec+$0A     ; NMI code vector
00FE73  1               ; EXT_vec defined in basic.asm (= VEC_SV+$16 = $0221)
00FE73  1               EXT_RST     = EXT_vec+$12     ; extension ROM reset recovery in RAM
00FE73  1               EXT_GTBY    = EXT_RST+$08     ; bridge: extension → BASIC LAB_GTBY → extension
00FE73  1               EXT_GTWRD   = EXT_GTBY+$0E    ; bridge: extension → BASIC LAB_GTWRD → extension
00FE73  1               EXT_SNERR   = EXT_GTWRD+$0E   ; bridge: extension → BASIC LAB_15D9 (syntax error)
00FE73  1               
00FE73  1               ; setup for the 6502 simulator environment
00FE73  1               
00FE73  1               IO_AREA     = $F000           ; set I/O area for this monitor
00FE73  1               
00FE73  1               ACIAsimwr   = VGC_CHAROUT
00FE73  1               ACIAsimrd   = VGC_CHARIN
00FE73  1               
00FE73  1               ; --- Data block copied to RAM at boot (vectors + interrupt + extension code) ---
00FE73  1               ; This block is stored in ROM (CODE segment) and copied to VEC_IN at init.
00FE73  1               
00FE73  1               LAB_vec
00FE73  1  ED FF              .word ACIAin            ; byte in from simulated ACIA
00FE75  1  E9 FF              .word ACIAout           ; byte out to simulated ACIA
00FE77  1  6B EE              .word LAB_FLOAD         ; load vector for EhBASIC
00FE79  1  19 EE              .word LAB_FSAVE         ; save vector for EhBASIC
00FE7B  1               
00FE7B  1               ; EhBASIC IRQ support
00FE7B  1               
00FE7B  1               IRQ_CODE
00FE7B  1  48                 PHA                     ; save A
00FE7C  1  A5 DF              LDA   IrqBase           ; get the IRQ flag byte
00FE7E  1  4A                 LSR                     ; shift the set b7 to b6, and on down ...
00FE7F  1  05 DF              ORA   IrqBase           ; OR the original back in
00FE81  1  85 DF              STA   IrqBase           ; save the new IRQ flag byte
00FE83  1  68                 PLA                     ; restore A
00FE84  1  40                 RTI
00FE85  1               
00FE85  1               ; EhBASIC NMI support
00FE85  1               
00FE85  1               NMI_CODE
00FE85  1  48                 PHA                     ; save A
00FE86  1  A5 DC              LDA   NmiBase           ; get the NMI flag byte
00FE88  1  4A                 LSR                     ; shift the set b7 to b6, and on down ...
00FE89  1  05 DC              ORA   NmiBase           ; OR the original back in
00FE8B  1  85 DC              STA   NmiBase           ; save the new NMI flag byte
00FE8D  1  68                 PLA                     ; restore A
00FE8E  1  40                 RTI
00FE8F  1               
00FE8F  1               ; Extension ROM call trampoline (runs from RAM)
00FE8F  1               ; Called with command ID in A. Swaps to extension ROM, calls $C000,
00FE8F  1               ; swaps back to BASIC ROM, returns with handler result in A.
00FE8F  1               
00FE8F  1               EXT_CODE
00FE8F  1  85 E4              STA   ExtCmdId          ; save command ID to ZP
00FE91  1  A9 04              LDA   #ROMSWAP_EXTENSION
00FE93  1  8D 3F A0           STA   REG_ROMSWAP       ; swap to extension ROM
00FE96  1  20 00 C0           JSR   $C000             ; call extension entry point
00FE99  1  48                 PHA                     ; save handler return value
00FE9A  1  A9 02              LDA   #ROMSWAP_BASIC
00FE9C  1  8D 3F A0           STA   REG_ROMSWAP       ; swap back to BASIC ROM
00FE9F  1  68                 PLA                     ; restore handler return value
00FEA0  1  60                 RTS
00FEA1  1               
00FEA1  1               ; Extension ROM reset recovery (runs from RAM)
00FEA1  1               ; If RESET fires while extension ROM is active, extension ROM's reset
00FEA1  1               ; handler jumps here. Swaps back to BASIC ROM and continues reset.
00FEA1  1               
00FEA1  1               EXT_RESET_CODE
00FEA1  1  A9 02              LDA   #ROMSWAP_BASIC
00FEA3  1  8D 3F A0           STA   REG_ROMSWAP       ; swap to BASIC ROM
00FEA6  1  4C D7 FF           JMP   $FFD7             ; jump to BASIC reset handler (RES_vec)
00FEA9  1               
00FEA9  1               ; Extension → BASIC bridges (run from RAM at $023B, $0249, $0257).
00FEA9  1               ; Extension ROM handlers JSR these to invoke BASIC parser helpers
00FEA9  1               ; (numeric expression eval, syntax error) without losing access to
00FEA9  1               ; the active ROM bank. Each trampoline maps BASIC, calls the helper,
00FEA9  1               ; remaps extension, and returns. Result conventions match the wrapped
00FEA9  1               ; BASIC routines: GTBY → X, GTWRD → FAC1_3 (lo) / FAC1_2 (hi). SNERR
00FEA9  1               ; never returns — jumps into BASIC's standard syntax-error path.
00FEA9  1               
00FEA9  1               EXT_GTBY_CODE
00FEA9  1  A9 02              LDA   #ROMSWAP_BASIC
00FEAB  1  8D 3F A0           STA   REG_ROMSWAP       ; swap to BASIC ROM
00FEAE  1  20 1F D9           JSR   LAB_GTBY          ; parse byte expression → X
00FEB1  1  A9 04              LDA   #ROMSWAP_EXTENSION
00FEB3  1  8D 3F A0           STA   REG_ROMSWAP       ; swap back
00FEB6  1  60                 RTS                     ; X holds parsed byte
00FEB7  1               
00FEB7  1               EXT_GTWRD_CODE
00FEB7  1  A9 02              LDA   #ROMSWAP_BASIC
00FEB9  1  8D 3F A0           STA   REG_ROMSWAP
00FEBC  1  20 0D D9           JSR   LAB_GTWRD         ; parse 16-bit expression → FAC1_3 (lo), FAC1_2 (hi)
00FEBF  1  A9 04              LDA   #ROMSWAP_EXTENSION
00FEC1  1  8D 3F A0           STA   REG_ROMSWAP
00FEC4  1  60                 RTS
00FEC5  1               
00FEC5  1               EXT_SNERR_CODE
00FEC5  1  A9 02              LDA   #ROMSWAP_BASIC
00FEC7  1  8D 3F A0           STA   REG_ROMSWAP       ; swap to BASIC ROM
00FECA  1  4C DE C5           JMP   LAB_15D9          ; jump to BASIC syntax-error path (no return)
00FECD  1               
00FECD  1               END_CODE
00FECD  1               
00FECD  1               ; --- Monitor code (in MONITOR segment at $FFD7) ---
00FECD  1               
00FECD  1                     .segment "MONITOR"
00FECD  1                     .org    $FFD7
00FFD7  1               
00FFD7  1               ; reset vector points here
00FFD7  1               
00FFD7  1               RES_vec
00FFD7  1  D8                 CLD                     ; clear decimal mode
00FFD8  1  A2 FF              LDX   #$FF              ; empty stack
00FFDA  1  9A                 TXS                     ; set the stack
00FFDB  1               
00FFDB  1               ; set up vectors, interrupt code, and extension trampoline — copy to page 2
00FFDB  1               
00FFDB  1  A0 5A              LDY   #END_CODE-LAB_vec ; set index/count
00FFDD  1               LAB_stlp
00FFDD  1  B9 72 FE           LDA   LAB_vec-1,Y       ; get byte from ROM data block
00FFE0  1  99 04 02           STA   VEC_IN-1,Y        ; save to RAM
00FFE3  1  88                 DEY                     ; decrement index/count
00FFE4  1  D0 F7              BNE   LAB_stlp          ; loop if more to do
00FFE6  1               
00FFE6  1  4C 00 C0           JMP   LAB_COLD          ; always do EhBASIC cold start
00FFE9  1               
00FFE9  1               ; byte out to simulated ACIA
00FFE9  1               
00FFE9  1               ACIAout
00FFE9  1  8D 0E A0           STA   ACIAsimwr         ; save byte to simulated ACIA
00FFEC  1  60                 RTS
00FFED  1               
00FFED  1               ; byte in from simulated ACIA
00FFED  1               
00FFED  1               ACIAin
00FFED  1  AD 0F A0           LDA   ACIAsimrd         ; get byte from simulated ACIA
00FFF0  1  F0 02              BEQ   LAB_nobyw         ; branch if no byte waiting
00FFF2  1               
00FFF2  1  38                 SEC                     ; flag byte received
00FFF3  1  60                 RTS
00FFF4  1               
00FFF4  1               LAB_nobyw
00FFF4  1  18                 CLC                     ; flag no byte received
00FFF5  1  60                 RTS
00FFF6  1               
00FFF6  1               ; system vectors
00FFF6  1               
00FFF6  1                     .segment "VECTORS"
00FFF6  1                     .org    $FFFA
00FFFA  1               
00FFFA  1  17 02              .word NMI_vec           ; NMI vector
00FFFC  1  D7 FF              .word RES_vec           ; RESET vector
00FFFE  1  0D 02              .word IRQ_vec           ; IRQ vector
00FFFE  1               
