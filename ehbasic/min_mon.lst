00EE08  5               .endif
00EE08  5               .ifndef NOVA_SCREEN_ROWS
00EE08  5               NOVA_SCREEN_ROWS  = 50
00EE08  5               .endif
00EE08  5               .ifndef NOVA_SCREEN_SIZE
00EE08  5               NOVA_SCREEN_SIZE  = NOVA_SCREEN_COLS * NOVA_SCREEN_ROWS
00EE08  5               .endif
