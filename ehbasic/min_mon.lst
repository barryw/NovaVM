00FF1E  2               
00FF1E  2  0D 0A 42 72  LAB_BMSG    .byte $0D,$0A,"Break",$00
00FF22  2  65 61 6B 00  
00FF26  2  20 45 72 72  LAB_EMSG    .byte " Error",$00
00FF2A  2  6F 72 00     
00FF2D  2  20 69 6E 20  LAB_LMSG    .byte " in line ",$00
00FF31  2  6C 69 6E 65  
