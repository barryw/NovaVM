000000r 2               XTK_NCLOSE        = $1A              ; NCLOSE slot
000000r 2               XTK_NLISTEN       = $1B              ; NLISTEN slot,port
000000r 2               XTK_NACCEPT       = $1C              ; NACCEPT slot
000000r 2               XTK_NSEND         = $1D              ; NSEND slot,A$
000000r 2               XTK_NRECV         = $1E              ; NRECV$(slot) — string function
