00E969  2  A5 11              LDA   Itempl            ; get sprite number
00E96B  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00E96E  2  20 F7 D7           JSR   LAB_GTSW          ; get signed x as 16-bit
00E971  2  A5 AF              LDA   FAC1_3
00E973  2  8D 12 A0           STA   VGC_P1             ; P1 = x low
00E976  2  A5 AE              LDA   FAC1_2
00E978  2  8D 13 A0           STA   VGC_P2             ; P2 = x high
