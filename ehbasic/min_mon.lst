00E8AD  3               
00E8AD  3               ; Input: A = VGC command. Does not wait for completion.
00E8AD  3               ; @label VGC.COMMAND
00E8AD  3               ; @kind routine
00E8AD  3               ; @symbol vgc_cmd
00E8AD  3               ; @summary Issue a raw VGC command without waiting for completion.
00E8AD  3               ; @in A: VGC command byte.
00E8AD  3               vgc_cmd:
00E8AD  3  8D 10 A0           STA   VGC_CMD
00E8B0  3  60                 RTS
00E8B1  3               
00E8B1  3               ; Wait until the command busy bit clears.
00E8B1  3               ; @label VGC.WAIT_COMMAND
00E8B1  3               ; @kind routine
00E8B1  3               ; @symbol vgc_wait_cmd
00E8B1  3               ; @summary Wait for the active VGC command to complete.
00E8B1  3               vgc_wait_cmd:
00E8B1  3               @wait:
00E8B1  3  AD 10 A0           LDA   VGC_CMD
00E8B4  3  29 01              AND   #$01
00E8B6  3  D0 F9              BNE   @wait
00E8B8  3  60                 RTS
00E8B9  3               
00E8B9  3               ; Input: A = VGC command. Issue and wait for completion.
00E8B9  3               .ifndef VGC_NO_EXEC
00E8B9  3               ; @label VGC.EXEC
00E8B9  3               ; @kind routine
00E8B9  3               ; @symbol vgc_exec
00E8B9  3               ; @summary Issue a raw VGC command and wait for completion.
00E8B9  3               ; @in A: VGC command byte.
00E8B9  3               vgc_exec:
00E8B9  3                     JSR   vgc_cmd
00E8B9  3                     JMP   vgc_wait_cmd
00E8B9  3               .endif
00E8B9  3               
00E8B9  3               ; Wait for the next frame counter tick.
00E8B9  3               ; @label VGC.VSYNC
00E8B9  3               ; @kind routine
00E8B9  3               ; @symbol vgc_vsync
00E8B9  3               ; @summary Wait until the VGC frame counter advances.
00E8B9  3               ; @out A: Last observed frame counter value.
00E8B9  3               vgc_vsync:
00E8B9  3  AD 08 A0           LDA   VGC_FRAME
00E8BC  3               @wait:
00E8BC  3  CD 08 A0           CMP   VGC_FRAME
00E8BF  3  F0 FB              BEQ   @wait
00E8C1  3  60                 RTS
00E8C2  3               
00E8C2  3               ; @label VGC.CLS
00E8C2  3               ; @kind routine
00E8C2  3               ; @symbol vgc_cls
00E8C2  3               ; @summary Clear the text screen through the VGC character output register.
00E8C2  3               vgc_cls:
00E8C2  3  A9 0C              LDA   #$0C
00E8C4  3  8D 0E A0           STA   VGC_CHAROUT
00E8C7  3  60                 RTS
00E8C8  3               
00E8C8  3               ; @label VGC.SET_FG
00E8C8  3               ; @kind routine
00E8C8  3               ; @symbol vgc_set_fg
00E8C8  3               ; @summary Set the current text foreground colour.
00E8C8  3               ; @in X: Foreground colour byte.
00E8C8  3               vgc_set_fg:
00E8C8  3  8E 02 A0           STX   VGC_FGCOL
00E8CB  3  60                 RTS
00E8CC  3               
00E8CC  3               ; @label VGC.SET_BG
00E8CC  3               ; @kind routine
00E8CC  3               ; @symbol vgc_set_bg
00E8CC  3               ; @summary Set the current text background colour.
00E8CC  3               ; @in X: Background colour byte.
00E8CC  3               vgc_set_bg:
00E8CC  3  8E 01 A0           STX   VGC_BGCOL
00E8CF  3  60                 RTS
00E8D0  3               
00E8D0  3               ; @label VGC.SET_BORDER
00E8D0  3               ; @kind routine
00E8D0  3               ; @symbol vgc_set_border
00E8D0  3               ; @summary Set the VGC border colour.
00E8D0  3               ; @in X: Border colour byte.
00E8D0  3               vgc_set_border:
00E8D0  3  8E 0D A0           STX   VGC_BORDER
00E8D3  3  60                 RTS
00E8D4  3               
00E8D4  3               ; @label VGC.LOCATE
00E8D4  3               ; @kind routine
00E8D4  3               ; @symbol vgc_locate
00E8D4  3               ; @summary Set the text cursor position from VGC.P0/VGC.P1.
00E8D4  3               ; @in VGC_P0: Cursor X column.
00E8D4  3               ; @in VGC_P1: Cursor Y row.
00E8D4  3               vgc_locate:
00E8D4  3  AD 11 A0           LDA   VGC_P0
00E8D7  3  8D 03 A0           STA   VGC_CURSX
00E8DA  3  AD 12 A0           LDA   VGC_P1
00E8DD  3  8D 04 A0           STA   VGC_CURSY
00E8E0  3  60                 RTS
00E8E1  3               
00E8E1  3               ; @label VGC.SET_MODE
00E8E1  3               ; @kind routine
00E8E1  3               ; @symbol vgc_set_mode
00E8E1  3               ; @summary Set the active VGC graphics/text mode.
00E8E1  3               ; @in X: Mode byte.
00E8E1  3               vgc_set_mode:
00E8E1  3  8E 00 A0           STX   VGC_MODE
00E8E4  3  60                 RTS
00E8E5  3               
00E8E5  3               ; @label VGC.SET_FONT
00E8E5  3               ; @kind routine
00E8E5  3               ; @symbol vgc_set_font
00E8E5  3               ; @summary Select the active text font slot.
00E8E5  3               ; @in X: Font slot, 0..7.
00E8E5  3               vgc_set_font:
00E8E5  3  8E 07 A0           STX   VGC_FONT
00E8E8  3  60                 RTS
00E8E9  3               
00E8E9  3               ; @label VGC.MEM_READ
00E8E9  3               ; @kind routine
00E8E9  3               ; @symbol vgc_mem_read
00E8E9  3               ; @summary Read one byte from VGC memory using VGC.P0..VGC.P4.
00E8E9  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P4
00E8E9  3               ; @out VGC_P3: Read byte.
00E8E9  3               vgc_mem_read:
00E8E9  3  A9 19              LDA   #VCMD_MEMREAD
00E8EB  3  2C                 .byte $2C
00E8EC  3               
00E8EC  3               ; @label VGC.MEM_WRITE
00E8EC  3               ; @kind routine
00E8EC  3               ; @symbol vgc_mem_write
00E8EC  3               ; @summary Write one byte to VGC memory using VGC.P0..VGC.P4.
00E8EC  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3 VGC_P4
00E8EC  3               vgc_mem_write:
00E8EC  3  A9 1A              LDA   #VCMD_MEMWRITE
00E8EE  3  8D 10 A0           STA   VGC_CMD
00E8F1  3  4C B1 E8           JMP   vgc_wait_cmd
00E8F4  3               
00E8F4  3               ; Enable reverse text by swapping the current foreground/background colours.
00E8F4  3               ; @label VGC.REVERSE
00E8F4  3               ; @kind routine
00E8F4  3               ; @symbol vgc_reverse_default
00E8F4  3               ; @summary Enable reverse text using the current foreground/background colours.
00E8F4  3               vgc_reverse_default:
00E8F4  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E8F7  3  29 FC              AND   #$FC
00E8F9  3  09 01              ORA   #VTXT_REV
00E8FB  3  8D E6 A0           STA   VGC_TXTFLAGS
00E8FE  3  60                 RTS
00E8FF  3               
00E8FF  3               ; Input: A = packed reverse attribute, low nibble fg and high nibble bg.
00E8FF  3               ; @label VGC.REVERSE_EXPLICIT
00E8FF  3               ; @kind routine
00E8FF  3               ; @symbol vgc_reverse_explicit
00E8FF  3               ; @summary Enable reverse text with explicit packed foreground/background colours.
00E8FF  3               ; @in A: Packed reverse attribute, low nibble foreground and high nibble background.
00E8FF  3               vgc_reverse_explicit:
00E8FF  3  8D E7 A0           STA   VGC_TXTREVATTR
00E902  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E905  3  29 FC              AND   #$FC
00E907  3  09 03              ORA   #(VTXT_REV | VTXT_REVEX)
00E909  3  8D E6 A0           STA   VGC_TXTFLAGS
00E90C  3  60                 RTS
00E90D  3               
00E90D  3               ; @label VGC.REVERSE_OFF
00E90D  3               ; @kind routine
00E90D  3               ; @symbol vgc_reverse_off
00E90D  3               ; @summary Disable reverse text.
00E90D  3               vgc_reverse_off:
00E90D  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E910  3  29 FC              AND   #$FC
00E912  3  8D E6 A0           STA   VGC_TXTFLAGS
00E915  3  60                 RTS
00E916  3               
00E916  3               ; @label VGC.FLASH_ON
00E916  3               ; @kind routine
00E916  3               ; @symbol vgc_flash_on
00E916  3               ; @summary Enable flashing text.
00E916  3               vgc_flash_on:
00E916  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E919  3  09 04              ORA   #VTXT_FLASH
00E91B  3  8D E6 A0           STA   VGC_TXTFLAGS
00E91E  3  60                 RTS
00E91F  3               
00E91F  3               ; @label VGC.FLASH_OFF
00E91F  3               ; @kind routine
00E91F  3               ; @symbol vgc_flash_off
00E91F  3               ; @summary Disable flashing text.
00E91F  3               vgc_flash_off:
00E91F  3  AD E6 A0           LDA   VGC_TXTFLAGS
00E922  3  29 FB              AND   #$FB
00E924  3  8D E6 A0           STA   VGC_TXTFLAGS
00E927  3  60                 RTS
00E928  3               
00E928  3               .ifndef VGC_NO_PRIMITIVES
00E928  3               ; @label VGC.GCLS
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_gcls
00E928  3               ; @summary Issue the VGC graphics clear command.
00E928  3               vgc_gcls:
00E928  3                     LDA   #VCMD_GCLS
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.GCOLOR
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_gcolor
00E928  3               ; @summary Issue the VGC graphics colour command using VGC.P0/P1.
00E928  3               ; @requires VGC_P0 VGC_P1
00E928  3               vgc_gcolor:
00E928  3                     LDA   #VCMD_GCOLOR
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.PLOT
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_plot
00E928  3               ; @summary Issue the VGC plot command using VGC.P0..VGC.P3.
00E928  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3
00E928  3               vgc_plot:
00E928  3                     LDA   #VCMD_PLOT
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.UNPLOT
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_unplot
00E928  3               ; @summary Issue the VGC unplot command using VGC.P0..VGC.P3.
00E928  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3
00E928  3               vgc_unplot:
00E928  3                     LDA   #VCMD_UNPLOT
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.LINE
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_line
00E928  3               ; @summary Issue the VGC line command using VGC.P0..VGC.P7.
00E928  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3 VGC_P4 VGC_P5 VGC_P6 VGC_P7
00E928  3               vgc_line:
00E928  3                     LDA   #VCMD_LINE
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.CIRCLE
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_circle
00E928  3               ; @summary Issue the VGC circle/ellipse command using VGC.P0..VGC.P7.
00E928  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3 VGC_P4 VGC_P5 VGC_P6 VGC_P7
00E928  3               vgc_circle:
00E928  3                     LDA   #VCMD_CIRCLE
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.GTEXT
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_gtext
00E928  3               ; @summary Issue the VGC graphics text command using VGC.P0..VGC.P5 and FIO.NAME.
00E928  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3 VGC_P4 VGC_P5 FIO_NAME FIO_NAMELEN
00E928  3               vgc_gtext:
00E928  3                     LDA   #VCMD_GTEXT
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.RECT
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_rect
00E928  3               ; @summary Issue the VGC rectangle command using VGC.P0..VGC.P7.
00E928  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3 VGC_P4 VGC_P5 VGC_P6 VGC_P7
00E928  3               vgc_rect:
00E928  3                     LDA   #VCMD_RECT
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.FILL
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_fill
00E928  3               ; @summary Issue the VGC filled rectangle command using VGC.P0..VGC.P7.
00E928  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3 VGC_P4 VGC_P5 VGC_P6 VGC_P7
00E928  3               vgc_fill:
00E928  3                     LDA   #VCMD_FILL
00E928  3                     JMP   vgc_cmd
00E928  3               
00E928  3               ; @label VGC.PAINT
00E928  3               ; @kind routine
00E928  3               ; @symbol vgc_paint
00E928  3               ; @summary Issue the VGC paint command using VGC.P0..VGC.P3.
00E928  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3
00E928  3               vgc_paint:
00E928  3                     LDA   #VCMD_PAINT
00E928  3                     JMP   vgc_cmd
00E928  3               .endif
00E928  3               
00E928  3               .endif
00E928  3               
00E928  2                     .include "lib/sprite.s"
00E928  3               ; Shared Nova sprite helper routines.
00E928  3               ;
00E928  3               ; Assembly callers can load VGC_P* and call the command helpers, or use the
00E928  3               ; direct register helpers for the VGC sprite attribute block.
00E928  3               
00E928  3               .include "sprite.inc"
00E928  4               ; Shared Nova sprite helper declarations.
00E928  4               ;
00E928  4               ; Command helpers use VGC_P* registers directly. Direct sprite-register helpers
00E928  4               ; use the public sprite attribute register block at VGC_SPR_BASE.
00E928  4               
00E928  4               .ifndef SPRITE_INC_INCLUDED
00E928  4               SPRITE_INC_INCLUDED = 1
00E928  4               
00E928  4               .include "vgc.inc"
00E928  5               ; Shared Nova VGC helper declarations.
00E928  5               ;
00E928  5               ; The command helpers use the VGC hardware parameter registers directly:
00E928  5               ; callers load VGC_P0..VGC_P14 as needed, then call a vgc_* routine.
00E928  5               ; Routines return through the hardware status model; command completion can be
00E928  5               ; checked with vgc_wait_cmd when the caller needs a synchronous operation.
00E928  5               
00E928  5               .ifndef VGC_INC_INCLUDED
00E928  5               VGC_INC_INCLUDED = 1
00E928  5               
00E928  5               .include "nova.inc"
00E928  5               
00E928  5               VGC_RESULT_OK    = $00
00E928  5               VGC_RESULT_ERROR = $01
00E928  5               
00E928  5               .endif
00E928  5               
00E928  4               
00E928  4               SPRITE_RESULT_OK    = $00
00E928  4               SPRITE_RESULT_ERROR = $01
00E928  4               
00E928  4               .endif
00E928  4               
00E928  3               
00E928  3               .ifndef SPRITE_IMPLEMENTATION_INCLUDED
00E928  3               SPRITE_IMPLEMENTATION_INCLUDED = 1
00E928  3               
00E928  3                     .segment "CODE"
00E928  3               
00E928  3                     .export sprite_command
00E928  3                     .export sprite_pos
00E928  3                     .export sprite_enable
00E928  3                     .export sprite_disable
00E928  3                     .export sprite_row
00E928  3               .ifndef SPRITE_NO_EXTRA
00E928  3                     .export sprite_clear
00E928  3                     .export sprite_copy
00E928  3                     .export sprite_flip
00E928  3                     .export sprite_priority
00E928  3               .endif
00E928  3                     .export sprite_reg_offset
00E928  3                     .export sprite_set_shape
00E928  3                     .export sprite_set_reg8
00E928  3                     .export sprite_set_reg16
00E928  3                     .export sprite_get_x
00E928  3                     .export sprite_get_y
00E928  3                     .export sprite_collision_status
00E928  3                     .export sprite_background_collision_status
00E928  3               
00E928  3               ; Input: A = sprite VGC command. Does not wait for completion.
00E928  3               ; @label SPRITE.COMMAND
00E928  3               ; @kind routine
00E928  3               ; @symbol sprite_command
00E928  3               ; @summary Issue a raw sprite VGC command without waiting for completion.
00E928  3               ; @in A: VGC sprite command byte.
00E928  3               sprite_command:
00E928  3  8D 10 A0           STA   VGC_CMD
00E92B  3  60                 RTS
00E92C  3               
00E92C  3               ; Command wrappers. Callers load VGC_P* per the hardware command ABI.
00E92C  3               ; @label SPRITE.POS
00E92C  3               ; @kind routine
00E92C  3               ; @symbol sprite_pos
00E92C  3               ; @summary Move a sprite using VGC.P0=sprite, VGC.P1/P2=x, VGC.P3=y.
00E92C  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3
00E92C  3               sprite_pos:
00E92C  3  A9 14              LDA   #VCMD_SPRPOS
00E92E  3  4C 28 E9           JMP   sprite_command
00E931  3               
00E931  3               ; @label SPRITE.ENABLE
00E931  3               ; @kind routine
00E931  3               ; @symbol sprite_enable
00E931  3               ; @summary Enable the sprite in VGC.P0.
00E931  3               ; @requires VGC_P0
00E931  3               sprite_enable:
00E931  3  A9 15              LDA   #VCMD_SPRENA
00E933  3  4C 28 E9           JMP   sprite_command
00E936  3               
00E936  3               ; @label SPRITE.DISABLE
00E936  3               ; @kind routine
00E936  3               ; @symbol sprite_disable
00E936  3               ; @summary Disable the sprite in VGC.P0.
00E936  3               ; @requires VGC_P0
00E936  3               sprite_disable:
00E936  3  A9 16              LDA   #VCMD_SPRDIS
00E938  3  4C 28 E9           JMP   sprite_command
00E93B  3               
00E93B  3               ; @label SPRITE.ROW
00E93B  3               ; @kind routine
00E93B  3               ; @symbol sprite_row
00E93B  3               ; @summary Write one sprite bitmap row using VGC.P0..VGC.P9.
00E93B  3               ; @requires VGC_P0 VGC_P1 VGC_P2 VGC_P3 VGC_P4 VGC_P5 VGC_P6 VGC_P7 VGC_P8 VGC_P9
00E93B  3               sprite_row:
00E93B  3  A9 11              LDA   #VCMD_SPRROW
00E93D  3  4C 28 E9           JMP   sprite_command
00E940  3               
00E940  3               .ifndef SPRITE_NO_EXTRA
00E940  3               sprite_clear:
00E940  3                     LDA   #VCMD_SPRCLR
00E940  3                     JMP   sprite_command
00E940  3               
00E940  3               sprite_copy:
00E940  3                     LDA   #VCMD_SPRCOPY
00E940  3                     JMP   sprite_command
00E940  3               
00E940  3               sprite_flip:
00E940  3                     LDA   #VCMD_SPRFLIP
00E940  3                     JMP   sprite_command
00E940  3               
00E940  3               sprite_priority:
00E940  3                     LDA   #VCMD_SPRPRI
00E940  3                     JMP   sprite_command
00E940  3               .endif
00E940  3               
00E940  3               ; Input: X = sprite index, Y = sprite register field offset.
00E940  3               ; Output: Y = VGC_SPR_BASE-relative register offset.
00E940  3               ; Clobbers: A, NVR7L.
00E940  3               ; @label SPRITE.REG_OFFSET
00E940  3               ; @kind routine
00E940  3               ; @symbol sprite_reg_offset
00E940  3               ; @summary Compute the VGC sprite attribute block offset for a sprite field.
00E940  3               ; @in X: Sprite index.
00E940  3               ; @in Y: Sprite field offset.
00E940  3               ; @out Y: VGC_SPR_BASE-relative byte offset.
00E940  3               sprite_reg_offset:
00E940  3  84 2E              STY   NVR7L
00E942  3  8A                 TXA
00E943  3  0A                 ASL
00E944  3  0A                 ASL
00E945  3  0A                 ASL
00E946  3  18                 CLC
00E947  3  65 2E              ADC   NVR7L
00E949  3  A8                 TAY
00E94A  3  60                 RTS
00E94B  3               
00E94B  3               ; Input: X = sprite index, A = shape.
00E94B  3               ; @label SPRITE.SET_SHAPE
00E94B  3               ; @kind routine
00E94B  3               ; @symbol sprite_set_shape
00E94B  3               ; @summary Set a sprite's shape index.
00E94B  3               ; @in X: Sprite index.
00E94B  3               ; @in A: Shape index.
00E94B  3               sprite_set_shape:
00E94B  3  A0 04              LDY   #VGC_SPR_SHAPE_OFF
00E94D  3                     ; fall through
00E94D  3               
00E94D  3               ; Input: X = sprite index, Y = field offset, A = value.
00E94D  3               ; Clobbers: A, Y, NVR7L/NVR7H.
00E94D  3               ; @label SPRITE.SET_REG8
00E94D  3               ; @kind routine
00E94D  3               ; @symbol sprite_set_reg8
00E94D  3               ; @summary Write one 8-bit sprite attribute field.
00E94D  3               ; @in X: Sprite index.
00E94D  3               ; @in Y: Sprite field offset.
00E94D  3               ; @in A: Field value.
00E94D  3               sprite_set_reg8:
00E94D  3  85 2F              STA   NVR7H
00E94F  3  20 40 E9           JSR   sprite_reg_offset
00E952  3  A5 2F              LDA   NVR7H
00E954  3  99 40 A0           STA   VGC_SPR_BASE,Y
00E957  3  60                 RTS
00E958  3               
00E958  3               ; Input: X = sprite index, Y = field offset, NVR0L/NVR0H = little-endian value.
00E958  3               ; Clobbers: A, Y, NVR7L.
00E958  3               ; @label SPRITE.SET_REG16
00E958  3               ; @kind routine
00E958  3               ; @symbol sprite_set_reg16
00E958  3               ; @summary Write one 16-bit sprite attribute field.
00E958  3               ; @in X: Sprite index.
00E958  3               ; @in Y: Sprite field offset.
00E958  3               ; @in NVR0L: Low byte.
00E958  3               ; @in NVR0H: High byte.
00E958  3               sprite_set_reg16:
00E958  3  20 40 E9           JSR   sprite_reg_offset
00E95B  3  A5 20              LDA   NVR0L
00E95D  3  99 40 A0           STA   VGC_SPR_BASE,Y
00E960  3  C8                 INY
00E961  3  A5 21              LDA   NVR0H
00E963  3  99 40 A0           STA   VGC_SPR_BASE,Y
00E966  3  60                 RTS
00E967  3               
00E967  3               ; Input: X = sprite index. Output: A = X high byte, Y = X low byte.
00E967  3               ; @label SPRITE.GET_X
00E967  3               ; @kind routine
00E967  3               ; @symbol sprite_get_x
00E967  3               ; @summary Read a sprite's 16-bit X coordinate.
00E967  3               ; @in X: Sprite index.
00E967  3               ; @out A: X high byte.
00E967  3               ; @out Y: X low byte.
00E967  3               sprite_get_x:
00E967  3  A0 00              LDY   #VGC_SPR_XL_OFF
00E969  3  20 40 E9           JSR   sprite_reg_offset
00E96C  3  B9 40 A0           LDA   VGC_SPR_BASE,Y
00E96F  3  85 2E              STA   NVR7L
00E971  3  C8                 INY
00E972  3  B9 40 A0           LDA   VGC_SPR_BASE,Y
00E975  3  A4 2E              LDY   NVR7L
00E977  3  60                 RTS
00E978  3               
00E978  3               ; Input: X = sprite index. Output: Y = Y low byte.
00E978  3               ; @label SPRITE.GET_Y
00E978  3               ; @kind routine
00E978  3               ; @symbol sprite_get_y
00E978  3               ; @summary Read a sprite's Y coordinate.
00E978  3               ; @in X: Sprite index.
00E978  3               ; @out Y: Y coordinate byte.
00E978  3               sprite_get_y:
00E978  3  A0 02              LDY   #VGC_SPR_YL_OFF
00E97A  3  20 40 E9           JSR   sprite_reg_offset
00E97D  3  B9 40 A0           LDA   VGC_SPR_BASE,Y
00E980  3  A8                 TAY
00E981  3  60                 RTS
00E982  3               
00E982  3               ; @label SPRITE.COLLISION_STATUS
00E982  3               ; @kind routine
00E982  3               ; @symbol sprite_collision_status
00E982  3               ; @summary Read the sprite-sprite collision status register.
00E982  3               ; @out A: Collision status byte.
00E982  3               sprite_collision_status:
00E982  3  AD 0B A0           LDA   VGC_COLLST
00E985  3  60                 RTS
00E986  3               
00E986  3               ; @label SPRITE.BACKGROUND_STATUS
00E986  3               ; @kind routine
00E986  3               ; @symbol sprite_background_collision_status
00E986  3               ; @summary Read the sprite-background collision status register.
00E986  3               ; @out A: Background collision status byte.
00E986  3               sprite_background_collision_status:
00E986  3  AD 0C A0           LDA   VGC_COLLBG
00E989  3  60                 RTS
00E98A  3               
00E98A  3               .endif
00E98A  3               
00E98A  2               
00E98A  2               LAB_VGC_CMD_RTS = vgc_cmd
00E98A  2               LAB_VSYNC       = vgc_vsync
00E98A  2               
00E98A  2               ; perform CLS — clear screen, no arguments
00E98A  2               
00E98A  2               LAB_CLS
00E98A  2  4C C2 E8           JMP   vgc_cls
00E98D  2               
00E98D  2               ; perform COLOR fg [,bg [,border]]
00E98D  2               
00E98D  2               LAB_COLOR
00E98D  2  20 A2 D8           JSR   LAB_GTBY          ; get fg color byte in X
00E990  2  20 C8 E8           JSR   vgc_set_fg        ; store foreground color
00E993  2  20 C2 00           JSR   LAB_GBYT          ; peek at current byte
00E996  2  C9 2C              CMP   #','              ; comma follows?
00E998  2  D0 19              BNE   @done             ; no, just fg was given
00E99A  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E99D  2  20 A2 D8           JSR   LAB_GTBY          ; get bg color byte in X
00E9A0  2  20 CC E8           JSR   vgc_set_bg        ; store background color
00E9A3  2  20 C2 00           JSR   LAB_GBYT          ; peek for optional border color
00E9A6  2  C9 2C              CMP   #','              ; second comma follows?
00E9A8  2  D0 09              BNE   @done             ; no, fg/bg only
00E9AA  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E9AD  2  20 A2 D8           JSR   LAB_GTBY          ; get border color byte in X
00E9B0  2  20 D0 E8           JSR   vgc_set_border    ; store border color
00E9B3  2               @done
00E9B3  2  60                 RTS
00E9B4  2               
00E9B4  2               ; perform REVERSE [fg,bg]
00E9B4  2               
00E9B4  2               LAB_REVERSE
00E9B4  2  20 C2 00           JSR   LAB_GBYT          ; optional explicit reverse colours?
00E9B7  2  F0 20              BEQ   @swap
00E9B9  2  C9 3A              CMP   #':'              ; no args before next statement
00E9BB  2  F0 1C              BEQ   @swap
00E9BD  2  20 A2 D8           JSR   LAB_GTBY          ; reverse foreground in X
00E9C0  2  8A                 TXA
00E9C1  2  29 0F              AND   #$0F
00E9C3  2  48                 PHA
00E9C4  2  20 FA CD           JSR   LAB_1C01          ; comma
00E9C7  2  20 A2 D8           JSR   LAB_GTBY          ; reverse background in X
00E9CA  2  8A                 TXA
00E9CB  2  29 0F              AND   #$0F
00E9CD  2  0A                 ASL
00E9CE  2  0A                 ASL
00E9CF  2  0A                 ASL
00E9D0  2  0A                 ASL
00E9D1  2  85 78              STA   TempB
00E9D3  2  68                 PLA
00E9D4  2  05 78              ORA   TempB
00E9D6  2  4C FF E8           JMP   vgc_reverse_explicit
00E9D9  2               @swap
00E9D9  2  4C F4 E8           JMP   vgc_reverse_default
00E9DC  2               
00E9DC  2               ; perform REVERSEOFF
00E9DC  2               
00E9DC  2               LAB_REVERSEOFF
00E9DC  2  4C 0D E9           JMP   vgc_reverse_off
00E9DF  2               
00E9DF  2               ; perform FLASH
00E9DF  2               
00E9DF  2               LAB_FLASH
00E9DF  2  4C 16 E9           JMP   vgc_flash_on
00E9E2  2               
00E9E2  2               ; perform FLASHOFF
00E9E2  2               
00E9E2  2               LAB_FLASHOFF
00E9E2  2  4C 1F E9           JMP   vgc_flash_off
00E9E5  2               
00E9E5  2               ; perform VPOKE plane,addr,value — write a byte to VGC memory
00E9E5  2               
00E9E5  2               LAB_VPOKE
00E9E5  2  20 A2 D8           JSR   LAB_GTBY
00E9E8  2  8E 11 A0           STX   VGC_P0
00E9EB  2  20 FA CD           JSR   LAB_1C01
00E9EE  2  20 90 D8           JSR   LAB_GTWRD
00E9F1  2  A5 AF              LDA   FAC1_3
00E9F3  2  8D 12 A0           STA   VGC_P1
00E9F6  2  A5 AE              LDA   FAC1_2
00E9F8  2  8D 13 A0           STA   VGC_P2
00E9FB  2  20 FA CD           JSR   LAB_1C01
00E9FE  2  20 A2 D8           JSR   LAB_GTBY
00EA01  2  8E 14 A0           STX   VGC_P3
00EA04  2  9C 15 A0           STZ   VGC_P4
00EA07  2  4C EC E8           JMP   vgc_mem_write
00EA0A  2               
00EA0A  2               ; perform LOCATE x, y
00EA0A  2               
00EA0A  2               LAB_LOCATE
00EA0A  2  20 A2 D8           JSR   LAB_GTBY          ; get x in X
00EA0D  2  8E 11 A0           STX   VGC_P0            ; store cursor X
00EA10  2  20 FA CD           JSR   LAB_1C01          ; require comma
00EA13  2  20 A2 D8           JSR   LAB_GTBY          ; get y in X
00EA16  2  8E 12 A0           STX   VGC_P1            ; store cursor Y
00EA19  2  4C D4 E8           JMP   vgc_locate
00EA1C  2               
00EA1C  2               ; perform MODE n
00EA1C  2               
00EA1C  2               LAB_GMODE
00EA1C  2  20 A2 D8           JSR   LAB_GTBY          ; get mode byte in X
00EA1F  2  4C E1 E8           JMP   vgc_set_mode
00EA22  2               
00EA22  2               ; perform FONT n — select active font slot (0-7)
00EA22  2               
00EA22  2               LAB_FONT
00EA22  2  20 A2 D8           JSR   LAB_GTBY          ; get font index byte (0-7) in X
00EA25  2  4C E5 E8           JMP   vgc_set_font
00EA28  2               
00EA28  2               ; perform GCLS — clear the graphics bitmap layer
00EA28  2               
00EA28  2               LAB_GCLS
00EA28  2  20 B9 E8           JSR   LAB_VSYNC         ; BASIC hides visible VGC draw tearing
00EA2B  2  A9 07              LDA   #VCMD_GCLS        ; GCLS command
00EA2D  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EA30  2               
00EA30  2               ; perform GCOLOR c — set graphics draw color (0-15)
00EA30  2               
00EA30  2               LAB_GCOLOR
00EA30  2  20 A2 D8           JSR   LAB_GTBY          ; get color byte in X
00EA33  2  8E 11 A0           STX   VGC_P0             ; color in P0
00EA36  2  9C 12 A0           STZ   VGC_P1             ; high byte = 0
00EA39  2  A9 08              LDA   #VCMD_GCOLOR      ; GCOLOR command
00EA3B  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EA3E  2               
00EA3E  2               ; shared: load x(word),y(byte) into VGC_P0-P3
00EA3E  2               
00EA3E  2               LAB_VGC_XY
00EA3E  2  20 90 D8           JSR   LAB_GTWRD         ; get x as 16-bit
00EA41  2  A5 AF              LDA   FAC1_3
00EA43  2  8D 11 A0           STA   VGC_P0             ; x low
00EA46  2  A5 AE              LDA   FAC1_2
00EA48  2  8D 12 A0           STA   VGC_P1             ; x high
00EA4B  2  20 FA CD           JSR   LAB_1C01          ; require comma
00EA4E  2  20 A2 D8           JSR   LAB_GTBY          ; get y as byte
00EA51  2  8E 13 A0           STX   VGC_P2             ; y low
00EA54  2  9C 14 A0           STZ   VGC_P3             ; y high = 0
00EA57  2  60                 RTS
00EA58  2               
00EA58  2               ; shared: load x0,y0,x1,y1 into VGC_P0-P7
00EA58  2               
00EA58  2               LAB_VGC_XYXY
00EA58  2  20 3E EA           JSR   LAB_VGC_XY        ; x0,y0 → P0-P3
00EA5B  2  20 FA CD           JSR   LAB_1C01          ; comma
00EA5E  2  20 90 D8           JSR   LAB_GTWRD         ; x1 as 16-bit
00EA61  2  A5 AF              LDA   FAC1_3
00EA63  2  8D 15 A0           STA   VGC_P4             ; x1 low
00EA66  2  A5 AE              LDA   FAC1_2
00EA68  2  8D 16 A0           STA   VGC_P5             ; x1 high
00EA6B  2  20 FA CD           JSR   LAB_1C01          ; comma
00EA6E  2  20 A2 D8           JSR   LAB_GTBY          ; y1
00EA71  2  8E 17 A0           STX   VGC_P6             ; y1 low
00EA74  2  9C 18 A0           STZ   VGC_P7             ; y1 high = 0
00EA77  2  60                 RTS
00EA78  2               
00EA78  2               ; perform PLOT x, y
00EA78  2               
00EA78  2               LAB_PLOT
00EA78  2  20 3E EA           JSR   LAB_VGC_XY
00EA7B  2  20 B9 E8           JSR   LAB_VSYNC         ; wait before visible graphics mutation
00EA7E  2  A9 01              LDA   #VCMD_PLOT        ; PLOT command
00EA80  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EA83  2               
00EA83  2               ; perform UNPLOT x, y
00EA83  2               
00EA83  2               LAB_UNPLOT
00EA83  2  20 3E EA           JSR   LAB_VGC_XY
00EA86  2  20 B9 E8           JSR   LAB_VSYNC
00EA89  2  A9 02              LDA   #VCMD_UNPLOT      ; UNPLOT command
00EA8B  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EA8E  2               
00EA8E  2               ; perform LINE x0, y0, x1, y1
00EA8E  2               
00EA8E  2               LAB_GLINE
00EA8E  2  20 58 EA           JSR   LAB_VGC_XYXY
00EA91  2  20 B9 E8           JSR   LAB_VSYNC
00EA94  2  A9 03              LDA   #VCMD_LINE        ; LINE command
00EA96  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EA99  2               
00EA99  2               ; perform CIRCLE cx, cy, rx [, ry]
00EA99  2               ; 3 args = circle (rx=ry), 4 args = ellipse
00EA99  2               
00EA99  2               LAB_CIRCLE
00EA99  2  20 3E EA           JSR   LAB_VGC_XY        ; cx,cy → P0-P3
00EA9C  2  20 FA CD           JSR   LAB_1C01          ; comma
00EA9F  2  20 90 D8           JSR   LAB_GTWRD         ; rx as 16-bit
00EAA2  2  A5 AF              LDA   FAC1_3
00EAA4  2  8D 15 A0           STA   VGC_P4             ; rx low
00EAA7  2  A5 AE              LDA   FAC1_2
00EAA9  2  8D 16 A0           STA   VGC_P5             ; rx high
00EAAC  2  9C 17 A0           STZ   VGC_P6             ; ry low = 0 (circle)
00EAAF  2  9C 18 A0           STZ   VGC_P7             ; ry high = 0
00EAB2  2  20 C2 00           JSR   LAB_GBYT          ; peek next
00EAB5  2  C9 2C              CMP   #','
00EAB7  2  D0 10              BNE   @circ_go
00EAB9  2  20 FA CD           JSR   LAB_1C01          ; consume comma
00EABC  2  20 90 D8           JSR   LAB_GTWRD         ; ry as 16-bit
00EABF  2  A5 AF              LDA   FAC1_3
00EAC1  2  8D 17 A0           STA   VGC_P6             ; ry low
00EAC4  2  A5 AE              LDA   FAC1_2
00EAC6  2  8D 18 A0           STA   VGC_P7             ; ry high
00EAC9  2               @circ_go
00EAC9  2  20 B9 E8           JSR   LAB_VSYNC
00EACC  2  A9 04              LDA   #VCMD_CIRCLE      ; CIRCLE command
00EACE  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EAD1  2               
00EAD1  2               ; perform GTEXT x, y, font, scale, "string"
00EAD1  2               
00EAD1  2               LAB_GTEXT
00EAD1  2  20 3E EA           JSR   LAB_VGC_XY        ; x,y → P0-P3
00EAD4  2  20 FA CD           JSR   LAB_1C01          ; comma
00EAD7  2  20 A2 D8           JSR   LAB_GTBY          ; font (0-7) → X
00EADA  2  8E 15 A0           STX   VGC_P4             ; P4 = font index
00EADD  2  20 FA CD           JSR   LAB_1C01          ; comma
00EAE0  2  20 A2 D8           JSR   LAB_GTBY          ; scale (1-8) → X
00EAE3  2  8E 16 A0           STX   VGC_P5             ; P5 = scale
00EAE6  2  20 FA CD           JSR   LAB_1C01          ; comma
00EAE9  2  20 DD F1           JSR   LAB_FIO_GETNAME   ; string → FIO_NAME/FIO_NAMELEN
00EAEC  2  20 B9 E8           JSR   LAB_VSYNC
00EAEF  2  A9 0A              LDA   #VCMD_GTEXT
00EAF1  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EAF4  2               
00EAF4  2               ; ── Tile engine BASIC commands ────────────────────────────────
00EAF4  2               ; Full tile command parsing lives in the extension ROM and dispatches through
00EAF4  2               ; the shared tile library.
00EAF4  2               
00EAF4  2               LAB_TILESIZE
00EAF4  2  A9 11              LDA   #EXT_CMD_TILESIZE
00EAF6  2  4C 21 02           JMP   EXT_vec
00EAF9  2               LAB_MIRROR
00EAF9  2  A9 12              LDA   #EXT_CMD_TMIRROR
00EAFB  2  4C 21 02           JMP   EXT_vec
00EAFE  2               LAB_TTRANS
00EAFE  2  A9 13              LDA   #EXT_CMD_TTRANS
00EB00  2  4C 21 02           JMP   EXT_vec
00EB03  2               LAB_TDEF
00EB03  2  A9 14              LDA   #EXT_CMD_TDEF
00EB05  2  4C 21 02           JMP   EXT_vec
00EB08  2               LAB_TPUT
00EB08  2  A9 15              LDA   #EXT_CMD_TPUT
00EB0A  2  4C 21 02           JMP   EXT_vec
00EB0D  2               LAB_TATTR
00EB0D  2  A9 16              LDA   #EXT_CMD_TATTR
00EB0F  2  4C 21 02           JMP   EXT_vec
00EB12  2               LAB_TFILL
00EB12  2  A9 17              LDA   #EXT_CMD_TFILL
00EB14  2  4C 21 02           JMP   EXT_vec
00EB17  2               LAB_TCLS
00EB17  2  A9 1B              LDA   #EXT_CMD_TCLS
00EB19  2  4C 21 02           JMP   EXT_vec
00EB1C  2               LAB_TSCROLL
00EB1C  2  A9 20              LDA   #EXT_CMD_TSCROLL
00EB1E  2  4C 21 02           JMP   EXT_vec
00EB21  2               LAB_TPAL
00EB21  2  A9 21              LDA   #EXT_CMD_TPAL
00EB23  2  4C 21 02           JMP   EXT_vec
00EB26  2               LAB_TPALC
00EB26  2  A9 22              LDA   #EXT_CMD_TPALC
00EB28  2  4C 21 02           JMP   EXT_vec
00EB2B  2               
00EB2B  2               ; perform RECT x0, y0, x1, y1
00EB2B  2               
00EB2B  2               LAB_RECT
00EB2B  2  20 58 EA           JSR   LAB_VGC_XYXY
00EB2E  2  20 B9 E8           JSR   LAB_VSYNC
00EB31  2  A9 05              LDA   #VCMD_RECT        ; RECT command
00EB33  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EB36  2               
00EB36  2               ; perform FILL x0, y0, x1, y1
00EB36  2               
00EB36  2               LAB_FILLRECT
00EB36  2  20 58 EA           JSR   LAB_VGC_XYXY
00EB39  2  20 B9 E8           JSR   LAB_VSYNC
00EB3C  2  A9 06              LDA   #VCMD_FILL        ; FILL command
00EB3E  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EB41  2               
00EB41  2               ; perform PAINT x, y
00EB41  2               
00EB41  2               LAB_PAINT
00EB41  2  20 3E EA           JSR   LAB_VGC_XY
00EB44  2  20 B9 E8           JSR   LAB_VSYNC
00EB47  2  A9 09              LDA   #VCMD_PAINT       ; PAINT command
00EB49  2  4C AD E8           JMP   LAB_VGC_CMD_RTS
00EB4C  2               
00EB4C  2               ; perform SPRITE n, ON/OFF  or  SPRITE n, x, y
00EB4C  2               ; sprite number 0-15, ON/OFF enables/disables, x,y sets position
00EB4C  2               ; Uses command-driven VGC interface:
00EB4C  2               ;   SPRENA ($15): P0=sprite
00EB4C  2               ;   SPRDIS ($16): P0=sprite
00EB4C  2               ;   SPRPOS ($14): P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4 reserved
00EB4C  2               
00EB4C  2               LAB_SPRCMD
00EB4C  2  20 A2 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB4F  2  86 11              STX   Itempl            ; save sprite number
00EB51  2  20 FA CD           JSR   LAB_1C01          ; require comma
00EB54  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00EB57  2  C9 93              CMP   #TK_ON            ; is it ON?
00EB59  2  F0 25              BEQ   @spr_on
00EB5B  2  C9 CB              CMP   #TK_OFF           ; is it OFF?
00EB5D  2  F0 2C              BEQ   @spr_off
00EB5F  2                     ; not ON/OFF — parse x, y position
00EB5F  2  A5 11              LDA   Itempl            ; get sprite number
00EB61  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EB64  2  20 90 D8           JSR   LAB_GTWRD         ; get unsigned x as 16-bit
00EB67  2  A5 AF              LDA   FAC1_3
00EB69  2  8D 12 A0           STA   VGC_P1             ; P1 = x low
00EB6C  2  A5 AE              LDA   FAC1_2
00EB6E  2  8D 13 A0           STA   VGC_P2             ; P2 = x high
00EB71  2  20 FA CD           JSR   LAB_1C01          ; require comma
00EB74  2  20 A2 D8           JSR   LAB_GTBY          ; get unsigned y byte
00EB77  2  8E 14 A0           STX   VGC_P3             ; P3 = y
00EB7A  2  9C 15 A0           STZ   VGC_P4             ; P4 reserved
00EB7D  2  4C 2C E9           JMP   sprite_pos         ; trigger and return
00EB80  2               
00EB80  2               @spr_on
00EB80  2  20 BC 00           JSR   LAB_IGBY          ; consume the ON token
00EB83  2  A5 11              LDA   Itempl            ; get sprite number
00EB85  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EB88  2  4C 31 E9           JMP   sprite_enable      ; trigger and return
00EB8B  2               
00EB8B  2               @spr_off
00EB8B  2  20 BC 00           JSR   LAB_IGBY          ; consume the OFF token
00EB8E  2  A5 11              LDA   Itempl            ; get sprite number
00EB90  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EB93  2  4C 36 E9           JMP   sprite_disable     ; trigger and return
00EB96  2               
00EB96  2               ; perform SPRITESHAPE n, shape
00EB96  2               ; Writes shape index to sprite register VGC_SPR_SHAPE + n*8
00EB96  2               
00EB96  2               LAB_SPRSHAPE
00EB96  2  20 A2 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB99  2  86 11              STX   Itempl
00EB9B  2  20 FA CD           JSR   LAB_1C01          ; require comma
00EB9E  2  20 A2 D8           JSR   LAB_GTBY          ; get shape index in X
00EBA1  2  8A                 TXA
00EBA2  2  A6 11              LDX   Itempl
00EBA4  2  4C 4B E9           JMP   sprite_set_shape
00EBA7  2               
00EBA7  2               ; perform SPRITESET sprite, field, value — set sprite register
00EBA7  2               ; Field 0 (X) accepts an unsigned word and writes lo+hi bytes.
00EBA7  2               ; Field 2 (Y) and all other fields accept a byte value.
00EBA7  2               ; Hardware vblank-buffers sprite attribute writes; software writes immediately.
00EBA7  2               
00EBA7  2               LAB_SPRCOLOR
00EBA7  2  20 A2 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EBAA  2  86 11              STX   Itempl            ; save sprite number
00EBAC  2  20 FA CD           JSR   LAB_1C01          ; require comma
00EBAF  2  20 A2 D8           JSR   LAB_GTBY          ; get field (0-7) in X
00EBB2  2  86 12              STX   Itemph            ; save field number
00EBB4  2  20 FA CD           JSR   LAB_1C01          ; require comma
00EBB7  2  A5 12              LDA   Itemph            ; check field number
00EBB9  2  F0 0B              BEQ   @word_val
00EBBB  2                     ; --- byte field: parse byte value ---
00EBBB  2  20 A2 D8           JSR   LAB_GTBY          ; get value (0-255) in X
00EBBE  2  8A                 TXA                     ; A = value
00EBBF  2  A6 11              LDX   Itempl            ; X = sprite number
00EBC1  2  A4 12              LDY   Itemph            ; Y = field
00EBC3  2  4C 4D E9           JMP   sprite_set_reg8
00EBC6  2               @word_val
00EBC6  2                     ; --- word field: parse unsigned word, write lo+hi ---
00EBC6  2  20 90 D8           JSR   LAB_GTWRD         ; get unsigned 16-bit value, lo in FAC1_3, hi in FAC1_2
00EBC9  2  A5 AF              LDA   FAC1_3
00EBCB  2  85 20              STA   NVR0L
00EBCD  2  A5 AE              LDA   FAC1_2
00EBCF  2  85 21              STA   NVR0H
00EBD1  2  A6 11              LDX   Itempl            ; X = sprite number
00EBD3  2  A4 12              LDY   Itemph            ; Y = field
00EBD5  2  4C 58 E9           JMP   sprite_set_reg16
00EBD8  2               
00EBD8  2               ; perform SPRITEDATA sprite, row, b1, b2 [, b3 [, b4 [, b5 [, b6 [, b7 [, b8]]]]]]
00EBD8  2               ; Uses CmdSprRow ($11): P0=sprite, P1=row, P2-P9=8 bytes of row data.
00EBD8  2               ; Unprovided bytes are zeroed.
00EBD8  2               
00EBD8  2               LAB_SPRDATA
00EBD8  2  20 A2 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EBDB  2  8E 11 A0           STX   VGC_P0             ; P0 = sprite index
00EBDE  2  20 FA CD           JSR   LAB_1C01          ; comma
00EBE1  2  20 A2 D8           JSR   LAB_GTBY          ; get row (0-15) in X
00EBE4  2  8E 12 A0           STX   VGC_P1             ; P1 = row
00EBE7  2                     ; zero all 8 data bytes first
00EBE7  2  9C 13 A0           STZ   VGC_P2
00EBEA  2  9C 14 A0           STZ   VGC_P3
00EBED  2  9C 15 A0           STZ   VGC_P4
00EBF0  2  9C 16 A0           STZ   VGC_P5
00EBF3  2  9C 17 A0           STZ   VGC_P6
00EBF6  2  9C 18 A0           STZ   VGC_P7
00EBF9  2  9C 19 A0           STZ   VGC_P8
00EBFC  2  9C 1A A0           STZ   VGC_P9
00EBFF  2                     ; parse b1 (required)
00EBFF  2  20 FA CD           JSR   LAB_1C01          ; comma
00EC02  2  20 A2 D8           JSR   LAB_GTBY          ; b1 → X
00EC05  2  8E 13 A0           STX   VGC_P2
00EC08  2                     ; parse b2 (required)
00EC08  2  20 FA CD           JSR   LAB_1C01          ; comma
00EC0B  2  20 A2 D8           JSR   LAB_GTBY          ; b2 → X
00EC0E  2  8E 14 A0           STX   VGC_P3
00EC11  2                     ; parse optional b3-b8
00EC11  2  20 C2 00           JSR   LAB_GBYT
00EC14  2  C9 2C              CMP   #','
00EC16  2  D0 59              BNE   @sd_done
00EC18  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EC1B  2  20 A2 D8           JSR   LAB_GTBY          ; b3 → X
00EC1E  2  8E 15 A0           STX   VGC_P4
00EC21  2  20 C2 00           JSR   LAB_GBYT
00EC24  2  C9 2C              CMP   #','
00EC26  2  D0 49              BNE   @sd_done
00EC28  2  20 BC 00           JSR   LAB_IGBY
00EC2B  2  20 A2 D8           JSR   LAB_GTBY          ; b4 → X
00EC2E  2  8E 16 A0           STX   VGC_P5
00EC31  2  20 C2 00           JSR   LAB_GBYT
00EC34  2  C9 2C              CMP   #','
00EC36  2  D0 39              BNE   @sd_done
00EC38  2  20 BC 00           JSR   LAB_IGBY
00EC3B  2  20 A2 D8           JSR   LAB_GTBY          ; b5 → X
00EC3E  2  8E 17 A0           STX   VGC_P6
00EC41  2  20 C2 00           JSR   LAB_GBYT
00EC44  2  C9 2C              CMP   #','
00EC46  2  D0 29              BNE   @sd_done
00EC48  2  20 BC 00           JSR   LAB_IGBY
00EC4B  2  20 A2 D8           JSR   LAB_GTBY          ; b6 → X
00EC4E  2  8E 18 A0           STX   VGC_P7
00EC51  2  20 C2 00           JSR   LAB_GBYT
00EC54  2  C9 2C              CMP   #','
00EC56  2  D0 19              BNE   @sd_done
00EC58  2  20 BC 00           JSR   LAB_IGBY
00EC5B  2  20 A2 D8           JSR   LAB_GTBY          ; b7 → X
00EC5E  2  8E 19 A0           STX   VGC_P8
00EC61  2  20 C2 00           JSR   LAB_GBYT
00EC64  2  C9 2C              CMP   #','
00EC66  2  D0 09              BNE   @sd_done
00EC68  2  20 BC 00           JSR   LAB_IGBY
00EC6B  2  20 A2 D8           JSR   LAB_GTBY          ; b8 → X
00EC6E  2  8E 1A A0           STX   VGC_P9
00EC71  2               @sd_done
00EC71  2  4C 3B E9           JMP   sprite_row         ; trigger and return
00EC74  2               
00EC74  2               ; perform SOUND note, duration [, instrument]
00EC74  2               ; SOUND 60, 10          — MIDI note 60, 10 frames, default instrument 0
00EC74  2               ; SOUND 60, 10, 3       — MIDI note 60, 10 frames, instrument 3
00EC74  2               
00EC74  2               LAB_SOUND
00EC74  2  20 A2 D8           JSR   LAB_GTBY          ; midi note → X
00EC77  2  8E A4 B9           STX   AUDIO_NOTE
00EC7A  2  20 FA CD           JSR   LAB_1C01          ; comma
00EC7D  2  20 A2 D8           JSR   LAB_GTBY          ; duration → X
00EC80  2  8E A5 B9           STX   AUDIO_DURATION
00EC83  2  9C A6 B9           STZ   AUDIO_INSTRUMENT  ; default instrument = 0
00EC86  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00EC89  2  C9 2C              CMP   #','
00EC8B  2  D0 09              BNE   @snd_go
00EC8D  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EC90  2  20 A2 D8           JSR   LAB_GTBY          ; instrument id → X
00EC93  2  8E A6 B9           STX   AUDIO_INSTRUMENT
00EC96  2               @snd_go
00EC96  2  4C 9A ED           JMP   audio_sound
00EC99  2               
00EC99  2               ; perform VOLUME level (0-15)               — set master volume
00EC99  2               ; perform VOLUME level, voice (0-255, 1-6)  — set per-voice volume
00EC99  2               
00EC99  2               LAB_VOLUME
00EC99  2  20 A2 D8           JSR   LAB_GTBY          ; level → X
00EC9C  2  8E A4 B9           STX   AUDIO_VOLUME
00EC9F  2  9C A5 B9           STZ   AUDIO_VOICE       ; default voice = 0 (master)
00ECA2  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00ECA5  2  C9 2C              CMP   #','
00ECA7  2  D0 09              BNE   @vol_go
00ECA9  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00ECAC  2  20 A2 D8           JSR   LAB_GTBY          ; voice → X
00ECAF  2  8E A5 B9           STX   AUDIO_VOICE
00ECB2  2               @vol_go
00ECB2  2  4C 9F ED           JMP   audio_volume
00ECB5  2               
00ECB5  2               ; perform INSTRUMENT id, waveform, a, d, s, r
00ECB5  2               ; Waveform: $10=TRI, $20=SAW, $40=PULSE, $80=NOISE
00ECB5  2               ; INSTRUMENT 1, $40, 0, 9, 0, 0
00ECB5  2               
00ECB5  2               LAB_ENVELOPE
00ECB5  2  20 A2 D8           JSR   LAB_GTBY          ; id → X
00ECB8  2  8E A4 B9           STX   AUDIO_INST_ID
00ECBB  2  20 FA CD           JSR   LAB_1C01          ; comma
00ECBE  2  20 A2 D8           JSR   LAB_GTBY          ; waveform → X
00ECC1  2  8E A5 B9           STX   AUDIO_WAVEFORM
00ECC4  2  20 FA CD           JSR   LAB_1C01          ; comma
00ECC7  2  20 A2 D8           JSR   LAB_GTBY          ; attack → X
00ECCA  2  8E A6 B9           STX   AUDIO_ATTACK
00ECCD  2  20 FA CD           JSR   LAB_1C01          ; comma
00ECD0  2  20 A2 D8           JSR   LAB_GTBY          ; decay → X
00ECD3  2  8E A7 B9           STX   AUDIO_DECAY
00ECD6  2  20 FA CD           JSR   LAB_1C01          ; comma
00ECD9  2  20 A2 D8           JSR   LAB_GTBY          ; sustain → X
00ECDC  2  8E A8 B9           STX   AUDIO_SUSTAIN
00ECDF  2  20 FA CD           JSR   LAB_1C01          ; comma
00ECE2  2  20 A2 D8           JSR   LAB_GTBY          ; release → X
00ECE5  2  8E A9 B9           STX   AUDIO_RELEASE
00ECE8  2  4C A4 ED           JMP   audio_instrument
00ECEB  2               
00ECEB  2               FIO_NO_STREAMING = 1
00ECEB  2               ; Primary ROM is tight. NIC server entry points are library concerns, so omit
00ECEB  2               ; those helper shims from the BASIC ROM build.
00ECEB  2               NIC_SERVER_COMMANDS = 0
00ECEB  2                     .include "lib/audio.s"
00ECEB  3               ; Shared Nova audio/music helper routines.
00ECEB  3               ;
00ECEB  3               ; These routines are BASIC-agnostic.  They wrap the FIO audio commands behind
00ECEB  3               ; named entry points so BASIC, assembly programs, and future runtimes share one
00ECEB  3               ; audio ABI.
00ECEB  3               
00ECEB  3               .include "audio.inc"
00ECEB  4               ; Shared Nova audio/music runtime interface.
00ECEB  4               ;
00ECEB  4               ; BASIC parses language syntax and loads the argument registers; assembly
00ECEB  4               ; callers can use the same register layout directly.
00ECEB  4               ;
00ECEB  4               ; Sound effect:
00ECEB  4               ;   AUDIO_NOTE       MIDI note
00ECEB  4               ;   AUDIO_DURATION   duration in 60 Hz frames
00ECEB  4               ;   AUDIO_INSTRUMENT instrument slot
00ECEB  4               ;
00ECEB  4               ; Volume:
00ECEB  4               ;   AUDIO_VOLUME     volume level
00ECEB  4               ;   AUDIO_VOICE      0=master, 1..14=voice volume
00ECEB  4               ;
00ECEB  4               ; Instrument:
00ECEB  4               ;   AUDIO_INST_ID    instrument slot
00ECEB  4               ;   AUDIO_WAVEFORM   SID waveform/control byte
00ECEB  4               ;   AUDIO_ATTACK     attack
00ECEB  4               ;   AUDIO_DECAY      decay
00ECEB  4               ;   AUDIO_SUSTAIN    sustain
00ECEB  4               ;   AUDIO_RELEASE    release
00ECEB  4               ;
00ECEB  4               ; Music sequence:
00ECEB  4               ;   AUDIO_VOICE      voice number, 1..14
00ECEB  4               ;   AUDIO_STRLEN     MML byte length
00ECEB  4               ;   AUDIO_STRL/H     pointer to MML bytes
00ECEB  4               ;
00ECEB  4               ; File-backed commands:
00ECEB  4               ;   FIO_NAME/FIO_NAMELEN hold the filename.  Call fio_copy_name first when
00ECEB  4               ;   using a pointer-based filename.
00ECEB  4               ;
00ECEB  4               ; Routines return A=0 on success and A=1 on error unless documented as a raw
00ECEB  4               ; status query.
00ECEB  4               
00ECEB  4               .ifndef AUDIO_INC_INCLUDED
00ECEB  4               AUDIO_INC_INCLUDED = 1
00ECEB  4               
00ECEB  4               .include "fio.inc"
00ECEB  5               ; Shared Nova File I/O helper declarations.
00ECEB  5               ;
00ECEB  5               ; Calling convention for pointer-based filename helpers:
00ECEB  5               ;   FIO_ARG_NAMELEN      filename length, 1..63
00ECEB  5               ;   FIO_ARG_NAMEPTR_L/H  CPU pointer to filename bytes
00ECEB  5               ;
00ECEB  5               ; Calling convention for XRAM streaming setup:
00ECEB  5               ;   FIO_ARG_ADDRL/M/H    flat 24-bit XRAM address
00ECEB  5               ;   FIO_ARG_LENL/H       transfer length; zero means full file for XLOAD
00ECEB  5               ;
00ECEB  5               ; Routines return A=0 on success and A=1 on error. Detailed status remains
00ECEB  5               ; in the FIO_STATUS/FIO_ERRCODE hardware registers.
00ECEB  5               
00ECEB  5               .ifndef FIO_INC_INCLUDED
00ECEB  5               FIO_INC_INCLUDED = 1
00ECEB  5               
00ECEB  5               .include "nova.inc"
00ECEB  6               ; Shared Nova hardware constants for BASIC, assembly, and runtime libraries.
00ECEB  6               ;
00ECEB  6               ; This include is deliberately guarded per symbol so it can coexist with older
00ECEB  6               ; source files that still define a subset of these names locally.
00ECEB  6               
00ECEB  6               .ifndef NOVA_INC_INCLUDED
00ECEB  6               NOVA_INC_INCLUDED = 1
00ECEB  6               
00ECEB  6               ; Nova pseudo-register mailbox. These bytes are available to callers and
00ECEB  6               ; runtime helpers as ephemeral argument/scratch storage only. A routine may
00ECEB  6               ; clobber them unless its documentation explicitly says otherwise; persistent
00ECEB  6               ; library state must be allocated in a linker segment such as BSS/ZEROPAGE.
