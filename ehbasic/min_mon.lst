00E7E2  2               XMC_CMD_PUT   = $02            ; write XMC_DATA to XADDR
00E7E2  2               XMC_CMD_STASH = $03            ; copy RAM -> XRAM
00E7E2  2               XMC_CMD_FETCH = $04            ; copy XRAM -> RAM
00E7E2  2               XMC_CMD_FILL  = $05            ; fill XRAM with XMC_DATA
00E7E2  2               XMC_CMD_STATS = $07            ; refresh stats
00E7E2  2               XMC_CMD_RSTUS = $08            ; clear usage tracking metadata
00E7E2  2               XMC_CMD_REL   = $09            ; mark range as free in usage tracking
00E7E2  2               XMC_CMD_ALLOC = $0A            ; allocate block (len -> xaddr/handle)
00E7E2  2               XMC_CMD_NSTSH = $0B            ; named stash RAM->XRAM
00E7E2  2               XMC_CMD_NFETC = $0C            ; named fetch XRAM->RAM
00E7E2  2               XMC_CMD_NDEL  = $0D            ; named delete
00E7E2  2               XMC_CMD_NDIRO = $0E            ; named dir open
00E7E2  2               XMC_CMD_NDIRR = $0F            ; named dir read
00E7E2  2               XMC_OK        = $02            ; command success status
00E7E2  2               XMC_ERR_NF    = $03            ; not found
00E7E2  2               XMC_ERR_EOD   = $06            ; end of directory
