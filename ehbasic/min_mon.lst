00EEE1  2  20 0D D9           JSR   LAB_GTWRD         ; graphics offset
00EEE4  2  A5 AF              LDA   FAC1_3
00EEE6  2  8D AB B9           STA   FIO_GADDRL
00EEE9  2  A5 AE              LDA   FAC1_2
00EEEB  2  8D AC B9           STA   FIO_GADDRH
00EEEE  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EEF1  2  20 0D D9           JSR   LAB_GTWRD         ; graphics length
00EEF4  2  A5 AF              LDA   FAC1_3
00EEF6  2  8D AD B9           STA   FIO_GLENL
00EEF9  2  A5 AE              LDA   FAC1_2
00EEFB  2  8D AE B9           STA   FIO_GLENH
