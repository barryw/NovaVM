00ED01  2               
00ED01  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00ED01  2               @m_loop_tok
00ED01  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00ED04  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00ED07  2  C9 93              CMP   #TK_ON
00ED09  2  F0 07              BEQ   @m_loop_on
00ED0B  2  C9 CB              CMP   #TK_OFF
00ED0D  2  F0 0E              BEQ   @m_loop_off
