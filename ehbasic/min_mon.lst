00F1CC  2  A9 01              LDA   #EXT_CMD_SFLOAD
00F1CE  2  20 21 02           JSR   EXT_vec            ; call extension ROM handler
00F1D1  2  D0 01              BNE   @sf_err            ; nonzero A = error
00F1D3  2  60                 RTS
00F1D4  2               @sf_err
00F1D4  2  4C 0B F2           JMP   LAB_FIO_ERRHND
