000000r 3               
000000r 3               ; BASIC SYS register bridge. SYS addr[,A[,X[,Y]]] loads A/X/Y from these
000000r 3               ; bytes before jumping and stores A/X/Y back here when the routine returns.
000000r 3               ; @label SYS.REGA
000000r 3               ; @kind u8
000000r 3               ; @symbol SYS_REGA
000000r 3               ; @summary Returned A register from the most recent SYS call.
000000r 3               .ifndef SYS_REGA
000000r 3               SYS_REGA          = $E7
000000r 3               .endif
000000r 3               ; @label SYS.REGX
000000r 3               ; @kind u8
000000r 3               ; @symbol SYS_REGX
000000r 3               ; @summary Returned X register from the most recent SYS call.
000000r 3               .ifndef SYS_REGX
000000r 3               SYS_REGX          = $E8
000000r 3               .endif
000000r 3               ; @label SYS.REGY
000000r 3               ; @kind u8
000000r 3               ; @symbol SYS_REGY
000000r 3               ; @summary Returned Y register from the most recent SYS call.
000000r 3               .ifndef SYS_REGY
000000r 3               SYS_REGY          = $E9
000000r 3               .endif
