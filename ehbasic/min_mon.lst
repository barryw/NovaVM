00ED6E  2               ; perform COPPER subcommand
00ED6E  2               ; COPPER ADD x, y, reg, value
00ED6E  2               ; COPPER CLEAR | ON | OFF
00ED6E  2               
00ED6E  2               LAB_COPPER
00ED6E  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte
00ED71  2  C9 A2              CMP   #TK_CLEAR
00ED73  2  F0 17              BEQ   @c_clear
00ED75  2  C9 93              CMP   #TK_ON
00ED77  2  F0 1C              BEQ   @c_on
00ED79  2  C9 CB              CMP   #TK_OFF
00ED7B  2  F0 21              BEQ   @c_off
00ED7D  2  C9 41              CMP   #'A'
00ED7F  2  F0 56              BEQ   @c_add
00ED81  2  C9 A1              CMP   #TK_LIST
00ED83  2  F0 22              BEQ   @c_list
00ED85  2  C9 55              CMP   #'U'
00ED87  2  F0 3D              BEQ   @c_use
00ED89  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00ED8C  2               
00ED8C  2               ; --- COPPER CLEAR ---
00ED8C  2               @c_clear
00ED8C  2  20 BC 00           JSR   LAB_IGBY          ; consume CLEAR token
00ED8F  2  A9 1C              LDA   #VCMD_COPPERCLR
00ED91  2  8D 10 A0           STA   VGC_CMD
00ED94  2  60                 RTS
00ED95  2               
00ED95  2               ; --- COPPER ON ---
00ED95  2               @c_on
00ED95  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00ED98  2  A9 1D              LDA   #VCMD_COPPERENA
00ED9A  2  8D 10 A0           STA   VGC_CMD
00ED9D  2  60                 RTS
00ED9E  2               
00ED9E  2               ; --- COPPER OFF ---
00ED9E  2               @c_off
00ED9E  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00EDA1  2  A9 1E              LDA   #VCMD_COPPERDIS
00EDA3  2  8D 10 A0           STA   VGC_CMD
00EDA6  2  60                 RTS
00EDA7  2               
00EDA7  2               ; --- COPPER LIST n / COPPER LIST END ---
00EDA7  2               @c_list
