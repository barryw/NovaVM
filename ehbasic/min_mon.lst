00EC4C  2  20 75 F2           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EC4F  2  A9 01              LDA   #$01              ; default song = 1
00EC51  2  8D A4 B9           STA   FIO_SRCL
00EC54  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00EC57  2  C9 2C              CMP   #','
00EC59  2  D0 09              BNE   @sp_go
00EC5B  2  20 62 CD           JSR   LAB_1C01          ; consume comma
00EC5E  2  20 A4 D7           JSR   LAB_GTBY          ; evaluate song number → X
00EC61  2  8E A4 B9           STX   FIO_SRCL
00EC64  2               @sp_go
00EC64  2  A9 08              LDA   #FIO_CMD_SIDPLAY
00EC66  2  20 84 EC           JSR   LAB_FIO_EXEC      ; issue command and check status
00EC69  2  58                 CLI                     ; enable interrupts so timer IRQ can fire
00EC6A  2  60                 RTS
00EC6B  2               
00EC6B  2               ; perform SIDSTOP
00EC6B  2               
00EC6B  2               LAB_SIDSTOP
00EC6B  2  A9 09              LDA   #FIO_CMD_SIDSTOP
00EC6D  2  8D A0 B9           STA   FIO_CMD
00EC70  2  60                 RTS
00EC71  2               
00EC71  2               ; perform MIDPLAY "filename"
00EC71  2               ; MIDPLAY "song"  — auto-select 6 busiest MIDI channels
00EC71  2               
00EC71  2               LAB_MIDPLAY
00EC71  2  20 75 F2           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EC74  2  A9 00              LDA   #$00
00EC76  2  8D A4 B9           STA   FIO_SRCL            ; no explicit mapping (auto-select)
00EC79  2  A9 13              LDA   #FIO_CMD_MIDPLAY
00EC7B  2  4C 84 EC           JMP   LAB_FIO_EXEC       ; issue command, check status, return
00EC7E  2               
00EC7E  2               ; perform MIDSTOP
00EC7E  2               
00EC7E  2               LAB_MIDSTOP
00EC7E  2  A9 14              LDA   #FIO_CMD_MIDSTOP
00EC80  2  8D A0 B9           STA   FIO_CMD
00EC83  2  60                 RTS
00EC84  2               
00EC84  2               ; common: issue FIO command in A, check status, error on fail
00EC84  2               
00EC84  2               LAB_FIO_EXEC
00EC84  2  8D A0 B9           STA   FIO_CMD
00EC87  2  AD A1 B9           LDA   FIO_STATUS
00EC8A  2  C9 02              CMP   #FIO_OK
00EC8C  2  D0 01              BNE   @fio_chk_err
00EC8E  2  60                 RTS
00EC8F  2               @fio_chk_err
00EC8F  2  4C AA F2           JMP   LAB_FIO_ERRHND
00EC92  2               
00EC92  2               ; Skip X characters from BASIC input
00EC92  2               LAB_SKIPX
00EC92  2  20 BC 00           JSR   LAB_IGBY
00EC95  2  CA                 DEX
00EC96  2  D0 FA              BNE   LAB_SKIPX
00EC98  2  60                 RTS
00EC99  2               
00EC99  2               ; perform MUSIC subcommand
00EC99  2               ; MUSIC voice, "mml"
00EC99  2               ; MUSIC PLAY | STOP | TEMPO bpm | LOOP ON|OFF | PRIORITY v1[,v2[,v3]]
00EC99  2               
00EC99  2               LAB_MUSIC
00EC99  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte (after MUSIC token consumed)
00EC9C  2  C9 50              CMP   #'P'
00EC9E  2  F0 0F              BEQ   @m_chk_p
00ECA0  2  C9 92              CMP   #TK_STOP           ; STOP is tokenized by BASIC
00ECA2  2  F0 1E              BEQ   @m_stop_tok
00ECA4  2  C9 54              CMP   #'T'
00ECA6  2  F0 23              BEQ   @m_tempo
00ECA8  2  C9 9E              CMP   #TK_LOOP           ; LOOP is tokenized by BASIC
00ECAA  2  F0 37              BEQ   @m_loop_tok
00ECAC  2                     ; Not a subcommand — must be a number (voice 1-6)
00ECAC  2  4C 3F ED           JMP   @m_seq
00ECAF  2               
00ECAF  2               ; --- MUSIC PLAY or PRIORITY ---
00ECAF  2               @m_chk_p
00ECAF  2                     ; Consume P, then check next char to distinguish PLAY vs PRIORITY
00ECAF  2  20 BC 00           JSR   LAB_IGBY          ; consume P, A = next char
00ECB2  2  C9 52              CMP   #'R'              ; PRIORITY has R after P
00ECB4  2  F0 57              BEQ   @m_priority
00ECB6  2                     ; else PLAY — consume remaining "LAY" (3 chars, P already consumed)
00ECB6  2  A2 03              LDX   #3
00ECB8  2  20 92 EC           JSR   LAB_SKIPX          ; LAY
00ECBB  2  A9 0E              LDA   #FIO_CMD_MPLAY
00ECBD  2  8D A0 B9           STA   FIO_CMD
00ECC0  2  58                 CLI                     ; enable interrupts for music
00ECC1  2  60                 RTS
00ECC2  2               
00ECC2  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00ECC2  2               @m_stop_tok
00ECC2  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00ECC5  2  A9 0F              LDA   #FIO_CMD_MSTOP
00ECC7  2  8D A0 B9           STA   FIO_CMD
00ECCA  2  60                 RTS
00ECCB  2               
00ECCB  2               ; --- MUSIC TEMPO bpm ---
00ECCB  2               @m_tempo
00ECCB  2  A2 05              LDX   #5
00ECCD  2  20 92 EC           JSR   LAB_SKIPX          ; TEMPO
00ECD0  2  20 92 D7           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00ECD3  2  A5 AF              LDA   FAC1_3
00ECD5  2  8D A4 B9           STA   FIO_SRCL
00ECD8  2  A5 AE              LDA   FAC1_2
00ECDA  2  8D A5 B9           STA   FIO_SRCH
00ECDD  2  A9 10              LDA   #FIO_CMD_MTEMPO
00ECDF  2  8D A0 B9           STA   FIO_CMD
00ECE2  2  60                 RTS
00ECE3  2               
00ECE3  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00ECE3  2               @m_loop_tok
00ECE3  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00ECE6  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00ECE9  2  C9 93              CMP   #TK_ON
00ECEB  2  F0 07              BEQ   @m_loop_on
00ECED  2  C9 CB              CMP   #TK_OFF
00ECEF  2  F0 0E              BEQ   @m_loop_off
00ECF1  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00ECF4  2               @m_loop_on
00ECF4  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00ECF7  2  A9 01              LDA   #$01
00ECF9  2  8D A4 B9           STA   FIO_SRCL
00ECFC  2  4C 07 ED           JMP   @m_loop_go
00ECFF  2               @m_loop_off
00ECFF  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00ED02  2  A9 00              LDA   #$00
00ED04  2  8D A4 B9           STA   FIO_SRCL
00ED07  2               @m_loop_go
00ED07  2  A9 11              LDA   #FIO_CMD_MLOOP
00ED09  2  8D A0 B9           STA   FIO_CMD
00ED0C  2  60                 RTS
00ED0D  2               
00ED0D  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00ED0D  2               @m_priority
00ED0D  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00ED0D  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00ED0D  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00ED0D  2               @m_pri_skip
00ED0D  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00ED10  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00ED12  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00ED14  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00ED14  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00ED14  2                     ; Clear all 6 voice slots
00ED14  2  A9 00              LDA   #$00
00ED16  2  A0 05              LDY   #$05
00ED18  2               @m_pri_clr
00ED18  2  99 A4 B9           STA   FIO_SRCL,Y
00ED1B  2  88                 DEY
00ED1C  2  10 FA              BPL   @m_pri_clr
00ED1E  2                     ; Parse up to 6 comma-separated voice values
00ED1E  2  A0 00              LDY   #$00              ; slot index
00ED20  2               @m_pri_nxt
00ED20  2  20 A4 D7           JSR   LAB_GTBY          ; get voice number → X
00ED23  2  8A                 TXA
00ED24  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00ED27  2  C8                 INY
00ED28  2  C0 06              CPY   #$06
00ED2A  2  B0 0D              BCS   @m_pri_go         ; all 6 parsed
00ED2C  2  20 C2 00           JSR   LAB_GBYT          ; peek next char
00ED2F  2  C9 2C              CMP   #','
00ED31  2  D0 06              BNE   @m_pri_go         ; no more commas
00ED33  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00ED36  2  4C 20 ED           JMP   @m_pri_nxt
00ED39  2               @m_pri_go
00ED39  2  A9 12              LDA   #FIO_CMD_MPRI
00ED3B  2  8D A0 B9           STA   FIO_CMD
00ED3E  2  60                 RTS
00ED3F  2               
00ED3F  2               ; --- MUSIC voice, "mml" ---
00ED3F  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00ED3F  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
00ED3F  2               @m_seq
00ED3F  2  20 A4 D7           JSR   LAB_GTBY          ; voice number (1-6) → X
00ED42  2  8E A4 B9           STX   FIO_SRCL          ; store voice
00ED45  2  20 62 CD           JSR   LAB_1C01          ; comma
00ED48  2  20 3E CC           JSR   LAB_EVEX          ; evaluate expression
00ED4B  2  20 41 D6           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00ED4E  2  AA                 TAX
00ED4F  2  F0 1A              BEQ   @m_seq_err        ; empty string = error
00ED51  2  8E A3 B9           STX   FIO_NAMELEN       ; string length (1-255)
00ED54  2  A5 71              LDA   ut1_pl
00ED56  2  8D A6 B9           STA   FIO_ENDL          ; string pointer low
00ED59  2  A5 72              LDA   ut1_ph
00ED5B  2  8D A7 B9           STA   FIO_ENDH          ; string pointer high
00ED5E  2  A9 0D              LDA   #FIO_CMD_MSEQ
00ED60  2  8D A0 B9           STA   FIO_CMD
00ED63  2  AD A1 B9           LDA   FIO_STATUS
00ED66  2  C9 02              CMP   #FIO_OK
00ED68  2  D0 01              BNE   @m_seq_err
00ED6A  2  60                 RTS
00ED6B  2               @m_seq_err
00ED6B  2  4C B1 F2           JMP   LAB_FIO_ERRIO
