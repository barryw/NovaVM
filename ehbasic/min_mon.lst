00E7B1  2  00                 .byte $00               ; ctrl-c flag           -     $00 = enabled
00E7B2  2  00                 .byte $00               ; ctrl-c byte           -     GET needs this
00E7B3  2  00                 .byte $00               ; ctrl-c byte timeout   -     GET needs this
00E7B4  2  0D E3              .word CTRLC             ; ctrl c check vector
00E7B6  2               ;     .word xxxx              ; non halting key input -     monitor to set this
00E7B6  2               ;     .word xxxx              ; output vector         -     monitor to set this
