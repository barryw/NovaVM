00F200  2  C9 0A              CMP   #$0A
00F202  2  90 02              BCC   @pr_dig
00F204  2  69 06              ADC   #$06              ; adjust for A-F (carry is set)
00F206  2               @pr_dig
00F206  2  69 30              ADC   #'0'              ; convert to ASCII
00F208  2  4C F7 CA           JMP   LAB_PRNA
