00EBD4  2               ; perform SPRITEDATA sprite, row, b1, b2 [, b3 [, b4 [, b5 [, b6 [, b7 [, b8]]]]]]
00EBD4  2               ; Uses CmdSprRow ($11): P0=sprite, P1=row, P2-P9=8 bytes of row data.
00EBD4  2               ; Unprovided bytes are zeroed.
00EBD4  2               
00EBD4  2               LAB_SPRDATA
00EBD4  2  20 A1 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EBD7  2  8E 11 A0           STX   VGC_P0             ; P0 = sprite index
00EBDA  2  20 99 CD           JSR   LAB_1C01          ; comma
00EBDD  2  20 A1 D8           JSR   LAB_GTBY          ; get row (0-15) in X
00EBE0  2  8E 12 A0           STX   VGC_P1             ; P1 = row
00EBE3  2                     ; zero all 8 data bytes first
00EBE3  2  A9 00              LDA   #$00
00EBE5  2  8D 13 A0           STA   VGC_P2
00EBE8  2  8D 14 A0           STA   VGC_P3
00EBEB  2  8D 15 A0           STA   VGC_P4
00EBEE  2  8D 16 A0           STA   VGC_P5
00EBF1  2  8D 17 A0           STA   VGC_P6
