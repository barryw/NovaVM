00EAD1  2               
00EAD1  2               ; perform SPRITE n, ON/OFF  or  SPRITE n, x, y
00EAD1  2               ; sprite number 0-15, ON/OFF enables/disables, x,y sets position
00EAD1  2               ; Uses command-driven VGC interface:
00EAD1  2               ;   SPRENA ($15): P0=sprite
00EAD1  2               ;   SPRDIS ($16): P0=sprite
00EAD1  2               ;   SPRPOS ($14): P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00EAD1  2               
00EAD1  2               LAB_SPRCMD
00EAD1  2  20 6B D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EAD4  2  86 11              STX   Itempl            ; save sprite number
00EAD6  2  20 90 CD           JSR   LAB_1C01          ; require comma
00EAD9  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00EADC  2  C9 93              CMP   #TK_ON            ; is it ON?
00EADE  2  F0 2C              BEQ   @spr_on
00EAE0  2  C9 CB              CMP   #TK_OFF           ; is it OFF?
00EAE2  2  F0 36              BEQ   @spr_off
00EAE4  2                     ; not ON/OFF — parse x, y position
00EAE4  2  A5 11              LDA   Itempl            ; get sprite number
00EAE6  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EAE9  2  20 62 D8           JSR   LAB_GTSW          ; get signed x as 16-bit
00EAEC  2  A5 AF              LDA   FAC1_3
00EAEE  2  8D 12 A0           STA   VGC_P1             ; P1 = x low
00EAF1  2  A5 AE              LDA   FAC1_2
00EAF3  2  8D 13 A0           STA   VGC_P2             ; P2 = x high
00EAF6  2  20 90 CD           JSR   LAB_1C01          ; require comma
00EAF9  2  20 62 D8           JSR   LAB_GTSW          ; get signed y as 16-bit
00EAFC  2  A5 AF              LDA   FAC1_3
00EAFE  2  8D 14 A0           STA   VGC_P3             ; P3 = y low
00EB01  2  A5 AE              LDA   FAC1_2
00EB03  2  8D 15 A0           STA   VGC_P4             ; P4 = y high
00EB06  2  A9 14              LDA   #VCMD_SPRPOS      ; SPRPOS command
00EB08  2  8D 10 A0           STA   VGC_CMD            ; trigger
00EB0B  2  60                 RTS
00EB0C  2               
00EB0C  2               @spr_on
00EB0C  2  20 BC 00           JSR   LAB_IGBY          ; consume the ON token
00EB0F  2  A5 11              LDA   Itempl            ; get sprite number
00EB11  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EB14  2  A9 15              LDA   #VCMD_SPRENA      ; SPRENA command
00EB16  2  8D 10 A0           STA   VGC_CMD            ; trigger
00EB19  2  60                 RTS
00EB1A  2               
00EB1A  2               @spr_off
00EB1A  2  20 BC 00           JSR   LAB_IGBY          ; consume the OFF token
00EB1D  2  A5 11              LDA   Itempl            ; get sprite number
00EB1F  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EB22  2  A9 16              LDA   #VCMD_SPRDIS      ; SPRDIS command
00EB24  2  8D 10 A0           STA   VGC_CMD            ; trigger
00EB27  2  60                 RTS
00EB28  2               
00EB28  2               ; perform SPRITESHAPE n, shape
00EB28  2               ; Writes shape index to sprite register $A044 + n*8
00EB28  2               
00EB28  2               LAB_SPRSHAPE
00EB28  2  20 6B D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB2B  2  8A                 TXA
00EB2C  2  0A                 ASL                     ; *2
00EB2D  2  0A                 ASL                     ; *4
00EB2E  2  0A                 ASL                     ; *8
00EB2F  2  A8                 TAY                     ; Y = sprite * 8
00EB30  2  20 90 CD           JSR   LAB_1C01          ; require comma
00EB33  2  20 6B D8           JSR   LAB_GTBY          ; get shape index in X
00EB36  2  8A                 TXA
00EB37  2  99 44 A0           STA   $A044,Y           ; write to shape register ($A044 + n*8)
00EB3A  2  60                 RTS
00EB3B  2               
00EB3B  2               ; perform SPRITESET sprite, field, value — set sprite register with vblank sync
00EB3B  2               ; Fields 0 (X) and 2 (Y) accept a signed word and write both lo/hi bytes.
00EB3B  2               ; All other fields accept a byte value.
00EB3B  2               ; Waits for vblank before writing to avoid visual glitching.
00EB3B  2               
00EB3B  2               LAB_SPRCOLOR
00EB3B  2  20 6B D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB3E  2  8A                 TXA
00EB3F  2  0A                 ASL                     ; *2
00EB40  2  0A                 ASL                     ; *4
00EB41  2  0A                 ASL                     ; *8
00EB42  2  85 11              STA   Itempl            ; save base offset (sprite * 8)
00EB44  2  20 90 CD           JSR   LAB_1C01          ; require comma
00EB47  2  20 6B D8           JSR   LAB_GTBY          ; get field (0-7) in X
00EB4A  2  86 12              STX   Itemph            ; save field number
00EB4C  2  8A                 TXA
00EB4D  2  18                 CLC
00EB4E  2  65 11              ADC   Itempl            ; base + field = register offset
00EB50  2  85 11              STA   Itempl            ; save register offset
00EB52  2  20 90 CD           JSR   LAB_1C01          ; require comma
00EB55  2  A5 12              LDA   Itemph            ; check field number
00EB57  2  C9 00              CMP   #$00              ; field 0 = X position?
00EB59  2  F0 16              BEQ   @word_val
00EB5B  2  C9 02              CMP   #$02              ; field 2 = Y position?
00EB5D  2  F0 12              BEQ   @word_val
00EB5F  2                     ; --- byte field: parse byte value ---
00EB5F  2  20 6B D8           JSR   LAB_GTBY          ; get value (0-255) in X
00EB62  2  AD 08 A0           LDA   VGC_FRAME         ; wait for vblank
00EB65  2               @bwait
00EB65  2  CD 08 A0           CMP   VGC_FRAME
00EB68  2  F0 FB              BEQ   @bwait
00EB6A  2  A4 11              LDY   Itempl            ; Y = register offset
00EB6C  2  8A                 TXA                     ; A = value
00EB6D  2  99 40 A0           STA   $A040,Y           ; write to sprite register
00EB70  2  60                 RTS
00EB71  2               @word_val
00EB71  2                     ; --- word field (X or Y): parse signed word, write lo+hi ---
00EB71  2  20 62 D8           JSR   LAB_GTSW          ; get signed 16-bit value, lo in FAC1_3, hi in FAC1_2
00EB74  2  AD 08 A0           LDA   VGC_FRAME         ; wait for vblank
00EB77  2               @wwait
00EB77  2  CD 08 A0           CMP   VGC_FRAME
00EB7A  2  F0 FB              BEQ   @wwait
00EB7C  2  A4 11              LDY   Itempl            ; Y = register offset (points to lo byte)
00EB7E  2  A5 AF              LDA   FAC1_3            ; low byte
00EB80  2  99 40 A0           STA   $A040,Y           ; write lo
00EB83  2  C8                 INY
00EB84  2  A5 AE              LDA   FAC1_2            ; high byte
00EB86  2  99 40 A0           STA   $A040,Y           ; write hi
00EB89  2  60                 RTS
00EB8A  2               
00EB8A  2               ; perform SPRITEDATA sprite, row, b1, b2 [, b3 [, b4 [, b5 [, b6 [, b7 [, b8]]]]]]
00EB8A  2               ; Uses CmdSprRow ($11): P0=sprite, P1=row, P2-P9=8 bytes of row data.
00EB8A  2               ; Unprovided bytes are zeroed.
00EB8A  2               
00EB8A  2               LAB_SPRDATA
00EB8A  2  20 6B D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB8D  2  8E 11 A0           STX   VGC_P0             ; P0 = sprite index
00EB90  2  20 90 CD           JSR   LAB_1C01          ; comma
00EB93  2  20 6B D8           JSR   LAB_GTBY          ; get row (0-15) in X
00EB96  2  8E 12 A0           STX   VGC_P1             ; P1 = row
00EB99  2                     ; zero all 8 data bytes first
00EB99  2  A9 00              LDA   #$00
00EB9B  2  8D 13 A0           STA   VGC_P2
00EB9E  2  8D 14 A0           STA   VGC_P3
00EBA1  2  8D 15 A0           STA   VGC_P4
00EBA4  2  8D 16 A0           STA   VGC_P5
00EBA7  2  8D 17 A0           STA   VGC_P6
00EBAA  2  8D 18 A0           STA   VGC_P7
00EBAD  2  8D 19 A0           STA   VGC_P8
00EBB0  2  8D 1A A0           STA   VGC_P9
00EBB3  2                     ; parse b1 (required)
00EBB3  2  20 90 CD           JSR   LAB_1C01          ; comma
00EBB6  2  20 6B D8           JSR   LAB_GTBY          ; b1 → X
00EBB9  2  8E 13 A0           STX   VGC_P2
00EBBC  2                     ; parse b2 (required)
00EBBC  2  20 90 CD           JSR   LAB_1C01          ; comma
00EBBF  2  20 6B D8           JSR   LAB_GTBY          ; b2 → X
00EBC2  2  8E 14 A0           STX   VGC_P3
00EBC5  2                     ; parse optional b3-b8
00EBC5  2  20 C2 00           JSR   LAB_GBYT
00EBC8  2  C9 2C              CMP   #','
00EBCA  2  D0 59              BNE   @sd_done
00EBCC  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EBCF  2  20 6B D8           JSR   LAB_GTBY          ; b3 → X
00EBD2  2  8E 15 A0           STX   VGC_P4
00EBD5  2  20 C2 00           JSR   LAB_GBYT
00EBD8  2  C9 2C              CMP   #','
00EBDA  2  D0 49              BNE   @sd_done
00EBDC  2  20 BC 00           JSR   LAB_IGBY
00EBDF  2  20 6B D8           JSR   LAB_GTBY          ; b4 → X
00EBE2  2  8E 16 A0           STX   VGC_P5
00EBE5  2  20 C2 00           JSR   LAB_GBYT
