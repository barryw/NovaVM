00EDB3  5               .ifndef NVR0H
00EDB3  5               NVR0H             = $21
00EDB3  5               .endif
00EDB3  5               .ifndef NVR1L
00EDB3  5               NVR1L             = $22
00EDB3  5               .endif
00EDB3  5               .ifndef NVR1H
00EDB3  5               NVR1H             = $23
00EDB3  5               .endif
00EDB3  5               .ifndef NVR2L
00EDB3  5               NVR2L             = $24
00EDB3  5               .endif
00EDB3  5               .ifndef NVR2H
00EDB3  5               NVR2H             = $25
00EDB3  5               .endif
00EDB3  5               .ifndef NVR3L
00EDB3  5               NVR3L             = $26
00EDB3  5               .endif
00EDB3  5               .ifndef NVR3H
00EDB3  5               NVR3H             = $27
00EDB3  5               .endif
00EDB3  5               .ifndef NVR4L
00EDB3  5               NVR4L             = $28
00EDB3  5               .endif
00EDB3  5               .ifndef NVR4H
00EDB3  5               NVR4H             = $29
00EDB3  5               .endif
00EDB3  5               .ifndef NVR5L
00EDB3  5               NVR5L             = $2A
00EDB3  5               .endif
00EDB3  5               .ifndef NVR5H
00EDB3  5               NVR5H             = $2B
00EDB3  5               .endif
00EDB3  5               .ifndef NVR6L
00EDB3  5               NVR6L             = $2C
00EDB3  5               .endif
00EDB3  5               .ifndef NVR6H
00EDB3  5               NVR6H             = $2D
00EDB3  5               .endif
00EDB3  5               .ifndef NVR7L
00EDB3  5               NVR7L             = $2E
00EDB3  5               .endif
00EDB3  5               .ifndef NVR7H
00EDB3  5               NVR7H             = $2F
00EDB3  5               .endif
00EDB3  5               
00EDB3  5               .ifndef NOVA_SCREEN_COLS
00EDB3  5               NOVA_SCREEN_COLS  = 80
00EDB3  5               .endif
00EDB3  5               .ifndef NOVA_SCREEN_ROWS
00EDB3  5               NOVA_SCREEN_ROWS  = 50
