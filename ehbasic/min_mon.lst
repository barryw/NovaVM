00E968  3               ; Shared Nova VGC helper routines.
00E968  3               ;
00E968  3               ; BASIC should parse language syntax and load VGC registers; assembly callers
00E968  3               ; can use the same routines directly after setting VGC_P* arguments.
00E968  3               
00E968  3               .include "vgc.inc"
00E968  4               ; Shared Nova VGC helper declarations.
00E968  4               ;
00E968  4               ; The command helpers use the VGC hardware parameter registers directly:
00E968  4               ; callers load VGC_P0..VGC_P14 as needed, then call a vgc_* routine.
00E968  4               ; Routines return through the hardware status model; command completion can be
00E968  4               ; checked with vgc_wait_cmd when the caller needs a synchronous operation.
00E968  4               
00E968  4               .ifndef VGC_INC_INCLUDED
00E968  4               VGC_INC_INCLUDED = 1
00E968  4               
00E968  4               .include "nova.inc"
