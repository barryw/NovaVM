00EFA2  2               
00EFA2  2               LAB_XFIO_EXEC
00EFA2  2  20 21 02           JSR   EXT_vec
00EFA5  2  D0 01              BNE   @xerr
00EFA7  2  60                 RTS
00EFA8  2               @xerr
00EFA8  2  4C 79 F3           JMP   LAB_FIO_ERRHND
