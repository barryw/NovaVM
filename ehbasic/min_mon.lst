00EE78  2               
00EE78  2               LAB_FSAVE
00EE78  2  20 DD F1           JSR   LAB_FIO_GETNAME   ; parse filename into FIO_NAME (errors internally)
00EE7B  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00EE7E  2  C9 2C              CMP   #','
00EE80  2  F0 16              BEQ   @sv_raw
00EE82  2                     ; default: save BASIC program area
00EE82  2  A5 79              LDA   Smeml
00EE84  2  8D A4 B9           STA   FIO_SRCL
00EE87  2  A5 7A              LDA   Smemh
00EE89  2  8D A5 B9           STA   FIO_SRCH
00EE8C  2  A5 7B              LDA   Svarl
00EE8E  2  8D A6 B9           STA   FIO_ENDL
00EE91  2  A5 7C              LDA   Svarh
00EE93  2  8D A7 B9           STA   FIO_ENDH
00EE96  2  80 27              BRA   @sv_go
00EE98  2               @sv_raw
00EE98  2  20 FA CD           JSR   LAB_1C01          ; comma
00EE9B  2  20 90 D8           JSR   LAB_GTWRD         ; source address
00EE9E  2  A5 AF              LDA   FAC1_3
00EEA0  2  8D A4 B9           STA   FIO_SRCL
00EEA3  2  A5 AE              LDA   FAC1_2
00EEA5  2  8D A5 B9           STA   FIO_SRCH
00EEA8  2  20 FA CD           JSR   LAB_1C01          ; comma
00EEAB  2  20 90 D8           JSR   LAB_GTWRD         ; length
00EEAE  2  18                 CLC
00EEAF  2  AD A4 B9           LDA   FIO_SRCL
00EEB2  2  65 AF              ADC   FAC1_3
00EEB4  2  8D A6 B9           STA   FIO_ENDL
00EEB7  2  AD A5 B9           LDA   FIO_SRCH
00EEBA  2  65 AE              ADC   FAC1_2
00EEBC  2  8D A7 B9           STA   FIO_ENDH
00EEBF  2               @sv_go
00EEBF  2  20 4B ED           JSR   fio_save
00EEC2  2  F0 03              BEQ   @sv_ok
00EEC4  2  4C 12 F2           JMP   LAB_FIO_ERRIO
00EEC7  2               @sv_ok
00EEC7  2  60                 RTS
00EEC8  2               
00EEC8  2               ; perform LOAD "filename"
00EEC8  2               ; File type is auto-detected by extension:
00EEC8  2               ;   .bas — loaded into BASIC program space, pointers updated
00EEC8  2               ;   .bin — loaded at embedded address (from 2-byte file header)
00EEC8  2               
00EEC8  2               LAB_FLOAD
00EEC8  2  20 DD F1           JSR   LAB_FIO_GETNAME   ; parse filename into FIO_NAME (errors internally)
00EECB  2                     ; set default load address to BASIC program start
00EECB  2  A5 79              LDA   Smeml
00EECD  2  8D A4 B9           STA   FIO_SRCL
00EED0  2  A5 7A              LDA   Smemh
00EED2  2  8D A5 B9           STA   FIO_SRCH
00EED5  2  20 50 ED           JSR   fio_load
00EED8  2  D0 42              BNE   @ld_chk_err
00EEDA  2                     ; check file type — host sets FIO_DIRTYPE after load
00EEDA  2  AD AF B9           LDA   FIO_DIRTYPE
00EEDD  2  C9 02              CMP   #$02              ; .bin file?
00EEDF  2  F0 1E              BEQ   @ld_bin_ok
00EEE1  2                     ; .bas file — update Svarl/Svarh = Smeml + FIO_SIZE
00EEE1  2  18                 CLC
00EEE2  2  A5 79              LDA   Smeml
00EEE4  2  6D A8 B9           ADC   FIO_SIZEL
00EEE7  2  85 7B              STA   Svarl
00EEE9  2  A5 7A              LDA   Smemh
00EEEB  2  6D A9 B9           ADC   FIO_SIZEH
00EEEE  2  85 7C              STA   Svarh
00EEF0  2                     ; reset array/var pointers so LIST works correctly
00EEF0  2  A5 7B              LDA   Svarl
00EEF2  2  85 7D              STA   Sarryl
00EEF4  2  85 7F              STA   Earryl
00EEF6  2  A5 7C              LDA   Svarh
00EEF8  2  85 7E              STA   Sarryh
00EEFA  2  85 80              STA   Earryh
00EEFC  2  4C 74 C1           JMP   LAB_1274          ; print Ready, return to command loop
00EEFF  2               @ld_bin_ok
00EEFF  2                     ; In program mode, silently continue; in immediate mode, print address
00EEFF  2  A5 88              LDA   Clineh
00EF01  2  C9 FF              CMP   #$FF
00EF03  2  D0 16              BNE   @ld_bin_done      ; running from a program — just return
00EF05  2  A9 1F              LDA   #<@s_loaded
00EF07  2  A0 EF              LDY   #>@s_loaded
00EF09  2  20 DD CA           JSR   LAB_18C3          ; print string
00EF0C  2  AD A5 B9           LDA   FIO_SRCH          ; high byte of load address
00EF0F  2  20 F5 F1           JSR   LAB_PRHEX
00EF12  2  AD A4 B9           LDA   FIO_SRCL          ; low byte
00EF15  2  20 F5 F1           JSR   LAB_PRHEX
00EF18  2  4C 74 C1           JMP   LAB_1274          ; print Ready, return to command loop
00EF1B  2               @ld_bin_done
00EF1B  2  60                 RTS
00EF1C  2               @ld_chk_err
00EF1C  2  4C 0B F2           JMP   LAB_FIO_ERRHND
00EF1F  2  0D 0A 4C 6F  @s_loaded .byte $0D,$0A,"Loaded at $",0
00EF23  2  61 64 65 64  
00EF27  2  20 61 74 20  
00EF2D  2               
00EF2D  2               ; perform GSAVE "filename", space, offset, length
00EF2D  2               
00EF2D  2               LAB_GSAVE
00EF2D  2  20 DD F1           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EF30  2  20 FA CD           JSR   LAB_1C01          ; comma
00EF33  2  20 A2 D8           JSR   LAB_GTBY          ; graphics space id
00EF36  2  8E AA B9           STX   FIO_GSPACE
00EF39  2  20 FA CD           JSR   LAB_1C01          ; comma
00EF3C  2  20 90 D8           JSR   LAB_GTWRD         ; graphics offset
00EF3F  2  A5 AF              LDA   FAC1_3
00EF41  2  8D AB B9           STA   FIO_GADDRL
00EF44  2  A5 AE              LDA   FAC1_2
00EF46  2  8D AC B9           STA   FIO_GADDRH
00EF49  2  20 FA CD           JSR   LAB_1C01          ; comma
00EF4C  2  20 90 D8           JSR   LAB_GTWRD         ; graphics length
00EF4F  2  A5 AF              LDA   FAC1_3
00EF51  2  8D AD B9           STA   FIO_GLENL
00EF54  2  A5 AE              LDA   FAC1_2
