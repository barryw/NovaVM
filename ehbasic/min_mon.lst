00EC6F  2  8D A4 B9           STA   FIO_SRCL
00EC72  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00EC75  2  C9 2C              CMP   #','
00EC77  2  D0 09              BNE   @sp_go
