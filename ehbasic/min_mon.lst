00E7A5  2               ; system dependant i/o vectors
00E7A5  2               ; these are in RAM and are set by the monitor at start-up
00E7A5  2               
00E7A5  2               V_INPT
00E7A5  2  6C 05 02           JMP   (VEC_IN)          ; non halting scan input device
00E7A8  2               V_OUTP
00E7A8  2  6C 07 02           JMP   (VEC_OUT)         ; send byte to output device
00E7AB  2               V_LOAD
00E7AB  2  6C 09 02           JMP   (VEC_LD)          ; load BASIC program
00E7AE  2               V_SAVE
00E7AE  2  6C 0B 02           JMP   (VEC_SV)          ; save BASIC program
00E7B1  2               
00E7B1  2               ; The rest are tables messages and code for RAM
00E7B1  2               
00E7B1  2               ; the rest of the code is tables and BASIC start-up code
00E7B1  2               
