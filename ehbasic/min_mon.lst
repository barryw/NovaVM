00E82C  2               ; --- VGC command handlers ---
00E82C  2               
00E82C  2               ; draw a text-only cold-start splash screen
00E82C  2               
00E82C  2               LAB_SPLASH
00E82C  2  A9 06              LDA   #$06              ; blue background
00E82E  2  8D 01 A0           STA   VGC_BGCOL
00E831  2  A9 01              LDA   #$01              ; white text
00E833  2  8D 02 A0           STA   VGC_FGCOL
00E836  2  A9 06              LDA   #$06              ; blue border
00E838  2  8D 0D A0           STA   VGC_BORDER
00E83B  2  A9 00              LDA   #$00              ; mode 0: text only
00E83D  2  8D 00 A0           STA   VGC_MODE
00E840  2               
00E840  2  A9 0C              LDA   #$0C              ; clear text layer and home cursor
00E842  2  20 1E E8           JSR   V_OUTP
00E845  2  A9 21              LDA   #$21              ; centered x for "NovaBASIC v1.0"
00E847  2  8D 03 A0           STA   VGC_CURSX
00E84A  2  85 0E              STA   TPos
00E84C  2  A9 00              LDA   #$00
00E84E  2  8D 04 A0           STA   VGC_CURSY
00E851  2  A9 78              LDA   #<LAB_BNR1
00E853  2  A0 E8              LDY   #>LAB_BNR1
00E855  2  20 76 CA           JSR   LAB_18C3
00E858  2               
00E858  2  A9 1A              LDA   #$1A              ; centered x for "Derived from EhBASIC 2.22p5"
00E85A  2  8D 03 A0           STA   VGC_CURSX
00E85D  2  85 0E              STA   TPos
00E85F  2  A9 02              LDA   #$02              ; one empty row between lines
00E861  2  8D 04 A0           STA   VGC_CURSY
00E864  2  A9 87              LDA   #<LAB_BNR2
00E866  2  A0 E8              LDY   #>LAB_BNR2
00E868  2  20 76 CA           JSR   LAB_18C3
00E86B  2               
00E86B  2  A9 11              LDA   #$11              ; centered x for "xxxxx BASIC bytes free  xxxK expansion memory"
00E86D  2  8D 03 A0           STA   VGC_CURSX
00E870  2  85 0E              STA   TPos
00E872  2  A9 04              LDA   #$04              ; one empty row between lines
00E874  2  8D 04 A0           STA   VGC_CURSY
00E877  2  60                 RTS
00E878  2               
00E878  2               LAB_BNR1
00E878  2  4E 6F 76 61        .byte "NovaBASIC v1.0",$00
00E87C  2  42 41 53 49  
00E880  2  43 20 76 31  
00E887  2               LAB_BNR2
00E887  2  44 65 72 69        .byte "Derived from EhBASIC 2.22p5",$00
00E88B  2  76 65 64 20  
00E88F  2  66 72 6F 6D  
00E8A3  2               
00E8A3  2               ; perform CLS — clear screen, no arguments
00E8A3  2               
00E8A3  2               LAB_CLS
00E8A3  2  A9 0C              LDA   #$0C              ; form feed character
00E8A5  2  8D 0E A0           STA   VGC_CHAROUT       ; write to CHAROUT register
00E8A8  2  60                 RTS
00E8A9  2               
00E8A9  2               ; perform COLOR fg [,bg]
00E8A9  2               
00E8A9  2               LAB_COLOR
00E8A9  2  20 A1 D8           JSR   LAB_GTBY          ; get fg color byte in X
00E8AC  2  8E 02 A0           STX   VGC_FGCOL         ; store foreground color
00E8AF  2  20 C2 00           JSR   LAB_GBYT          ; peek at current byte
00E8B2  2  C9 2C              CMP   #','              ; comma follows?
00E8B4  2  D0 09              BNE   @done             ; no, just fg was given
00E8B6  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E8B9  2  20 A1 D8           JSR   LAB_GTBY          ; get bg color byte in X
00E8BC  2  8E 01 A0           STX   VGC_BGCOL         ; store background color
00E8BF  2               @done
00E8BF  2  60                 RTS
00E8C0  2               
00E8C0  2               ; perform LOCATE x, y
00E8C0  2               
00E8C0  2               LAB_LOCATE
00E8C0  2  20 A1 D8           JSR   LAB_GTBY          ; get x in X
00E8C3  2  8E 03 A0           STX   VGC_CURSX         ; store cursor X
00E8C6  2  20 99 CD           JSR   LAB_1C01          ; require comma
00E8C9  2  20 A1 D8           JSR   LAB_GTBY          ; get y in X
00E8CC  2  8E 04 A0           STX   VGC_CURSY         ; store cursor Y
00E8CF  2  60                 RTS
00E8D0  2               
00E8D0  2               ; perform MODE n
00E8D0  2               
00E8D0  2               LAB_GMODE
00E8D0  2  20 A1 D8           JSR   LAB_GTBY          ; get mode byte in X
00E8D3  2  8E 00 A0           STX   VGC_MODE          ; store graphics mode
00E8D6  2  60                 RTS
00E8D7  2               
00E8D7  2               ; perform FONT n — select active font slot (0-7)
00E8D7  2               
00E8D7  2               LAB_FONT
00E8D7  2  20 A1 D8           JSR   LAB_GTBY          ; get font index byte (0-7) in X
00E8DA  2  8E 07 A0           STX   VGC_FONT          ; write to $A007
00E8DD  2  60                 RTS
00E8DE  2               
00E8DE  2               ; perform GCLS — clear the graphics bitmap layer
00E8DE  2               
00E8DE  2               LAB_GCLS
00E8DE  2  A9 07              LDA   #VCMD_GCLS        ; GCLS command
00E8E0  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E8E3  2  60                 RTS
00E8E4  2               
00E8E4  2               ; perform GCOLOR c — set graphics draw color (0-15)
00E8E4  2               
00E8E4  2               LAB_GCOLOR
00E8E4  2  20 A1 D8           JSR   LAB_GTBY          ; get color byte in X
00E8E7  2  8E 11 A0           STX   VGC_P0             ; color in P0
00E8EA  2  A9 00              LDA   #$00
00E8EC  2  8D 12 A0           STA   VGC_P1             ; high byte = 0
00E8EF  2  A9 08              LDA   #VCMD_GCOLOR      ; GCOLOR command
00E8F1  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E8F4  2  60                 RTS
00E8F5  2               
00E8F5  2               ; shared: load x(word),y(byte) into VGC_P0-P3
00E8F5  2               
00E8F5  2               LAB_VGC_XY
00E8F5  2  20 8F D8           JSR   LAB_GTWRD         ; get x as 16-bit
00E8F8  2  A5 AF              LDA   FAC1_3
00E8FA  2  8D 11 A0           STA   VGC_P0             ; x low
00E8FD  2  A5 AE              LDA   FAC1_2
00E8FF  2  8D 12 A0           STA   VGC_P1             ; x high
00E902  2  20 99 CD           JSR   LAB_1C01          ; require comma
00E905  2  20 A1 D8           JSR   LAB_GTBY          ; get y as byte
00E908  2  8E 13 A0           STX   VGC_P2             ; y low
00E90B  2  A9 00              LDA   #$00
00E90D  2  8D 14 A0           STA   VGC_P3             ; y high = 0
00E910  2  60                 RTS
00E911  2               
00E911  2               ; shared: load x0,y0,x1,y1 into VGC_P0-P7
00E911  2               
00E911  2               LAB_VGC_XYXY
00E911  2  20 F5 E8           JSR   LAB_VGC_XY        ; x0,y0 → P0-P3
00E914  2  20 99 CD           JSR   LAB_1C01          ; comma
00E917  2  20 8F D8           JSR   LAB_GTWRD         ; x1 as 16-bit
00E91A  2  A5 AF              LDA   FAC1_3
00E91C  2  8D 15 A0           STA   VGC_P4             ; x1 low
00E91F  2  A5 AE              LDA   FAC1_2
