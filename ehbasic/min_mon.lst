00EB1B  2               ; perform SPRITE n, ON/OFF  or  SPRITE n, x, y
00EB1B  2               ; sprite number 0-15, ON/OFF enables/disables, x,y sets position
00EB1B  2               ; Uses command-driven VGC interface:
00EB1B  2               ;   SPRENA ($15): P0=sprite
00EB1B  2               ;   SPRDIS ($16): P0=sprite
00EB1B  2               ;   SPRPOS ($14): P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00EB1B  2               
00EB1B  2               LAB_SPRCMD
00EB1B  2  20 A1 D8           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00EB1E  2  86 11              STX   Itempl            ; save sprite number
00EB20  2  20 99 CD           JSR   LAB_1C01          ; require comma
00EB23  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00EB26  2  C9 93              CMP   #TK_ON            ; is it ON?
00EB28  2  F0 2C              BEQ   @spr_on
00EB2A  2  C9 CB              CMP   #TK_OFF           ; is it OFF?
00EB2C  2  F0 36              BEQ   @spr_off
00EB2E  2                     ; not ON/OFF — parse x, y position
00EB2E  2  A5 11              LDA   Itempl            ; get sprite number
00EB30  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EB33  2  20 98 D8           JSR   LAB_GTSW          ; get signed x as 16-bit
00EB36  2  A5 AF              LDA   FAC1_3
00EB38  2  8D 12 A0           STA   VGC_P1             ; P1 = x low
00EB3B  2  A5 AE              LDA   FAC1_2
00EB3D  2  8D 13 A0           STA   VGC_P2             ; P2 = x high
00EB40  2  20 99 CD           JSR   LAB_1C01          ; require comma
00EB43  2  20 98 D8           JSR   LAB_GTSW          ; get signed y as 16-bit
00EB46  2  A5 AF              LDA   FAC1_3
00EB48  2  8D 14 A0           STA   VGC_P3             ; P3 = y low
00EB4B  2  A5 AE              LDA   FAC1_2
00EB4D  2  8D 15 A0           STA   VGC_P4             ; P4 = y high
00EB50  2  A9 14              LDA   #VCMD_SPRPOS      ; SPRPOS command
00EB52  2  8D 10 A0           STA   VGC_CMD            ; trigger
00EB55  2  60                 RTS
00EB56  2               
00EB56  2               @spr_on
00EB56  2  20 BC 00           JSR   LAB_IGBY          ; consume the ON token
00EB59  2  A5 11              LDA   Itempl            ; get sprite number
00EB5B  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00EB5E  2  A9 15              LDA   #VCMD_SPRENA      ; SPRENA command
00EB60  2  8D 10 A0           STA   VGC_CMD            ; trigger
00EB63  2  60                 RTS
00EB64  2               
00EB64  2               @spr_off
