000000r 2               XTK_MIDSTOP       = $2A              ; MIDSTOP — stop MIDI playback
000000r 2                                                     ; $2B-$30 directory/metadata tokens
000000r 2               XTK_XLOAD         = $31              ; XLOAD "filename",offset[,length]
000000r 2               XTK_XSAVE         = $32              ; XSAVE "filename",offset,length
000000r 2                                                     ; $33-$3F reserved
