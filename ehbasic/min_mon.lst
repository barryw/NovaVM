00E798  2               XMC_CMD_STATS = $07            ; refresh stats
00E798  2               XMC_CMD_RSTUS = $08            ; clear usage tracking metadata
00E798  2               XMC_CMD_REL   = $09            ; mark range as free in usage tracking
00E798  2               XMC_CMD_ALLOC = $0A            ; allocate block (len -> xaddr/handle)
00E798  2               XMC_CMD_NSTSH = $0B            ; named stash RAM->XRAM
00E798  2               XMC_CMD_NFETC = $0C            ; named fetch XRAM->RAM
00E798  2               XMC_CMD_NDEL  = $0D            ; named delete
00E798  2               XMC_CMD_NDIRO = $0E            ; named dir open
00E798  2               XMC_CMD_NDIRR = $0F            ; named dir read
00E798  2               XMC_OK        = $02            ; command success status
00E798  2               XMC_ERR_NF    = $03            ; not found
00E798  2               XMC_ERR_EOD   = $06            ; end of directory
00E798  2               
00E798  2               ; --- NIC network interface controller registers ---
00E798  2               
00E798  2               NIC_CMD        = $A100          ; command register (write triggers)
00E798  2               NIC_STATUS     = $A101          ; global status
00E798  2               NIC_SLOT       = $A102          ; active slot ID (0-3)
00E798  2               NIC_RPORTL     = $A108          ; remote port low
00E798  2               NIC_RPORTH     = $A109          ; remote port high
00E798  2               NIC_LPORTL     = $A10A          ; local port low (for listen)
00E798  2               NIC_LPORTH     = $A10B          ; local port high
00E798  2               NIC_DMAL       = $A110          ; DMA RAM address low
00E798  2               NIC_DMAH       = $A111          ; DMA RAM address high
00E798  2               NIC_DMALEN     = $A112          ; DMA length
00E798  2               NIC_MSGLEN     = $A113          ; received message length (read-only)
00E798  2               NIC_SLOTST0    = $A118          ; slot 0 status
00E798  2               NIC_NAMEBUF    = $A120          ; hostname buffer (32 bytes, null-terminated)
00E798  2               
00E798  2               NIC_CMD_CONNECT    = $01
00E798  2               NIC_CMD_DISCONNECT = $02
00E798  2               NIC_CMD_SEND       = $03
00E798  2               NIC_CMD_RECV       = $04
00E798  2               NIC_CMD_LISTEN     = $05
00E798  2               NIC_CMD_ACCEPT     = $06
00E798  2               
00E798  2               NIC_ST_CONNECTED   = $01
00E798  2               NIC_ST_DATAREADY   = $02
00E798  2               NIC_ST_ERROR       = $08
00E798  2               
00E798  2               ; --- Unified DMA controller registers ---
00E798  2               
00E798  2               DMA_CMD       = $BA60          ; write triggers transfer
00E798  2               DMA_STATUS    = $BA61          ; 1=busy, 2=ok, 3=error
00E798  2               DMA_ERRCODE   = $BA62          ; DMA error code
00E798  2               DMA_SRCSPACE  = $BA63          ; source space id
00E798  2               DMA_DSTSPACE  = $BA64          ; destination space id
00E798  2               DMA_SRCL      = $BA65          ; source addr low
00E798  2               DMA_SRCM      = $BA66          ; source addr mid
00E798  2               DMA_SRCH      = $BA67          ; source addr high
00E798  2               DMA_DSTL      = $BA68          ; destination addr low
00E798  2               DMA_DSTM      = $BA69          ; destination addr mid
00E798  2               DMA_DSTH      = $BA6A          ; destination addr high
00E798  2               DMA_LENL      = $BA6B          ; length low
00E798  2               DMA_LENM      = $BA6C          ; length mid
00E798  2               DMA_LENH      = $BA6D          ; length high
00E798  2               DMA_MODE      = $BA6E          ; mode flags
00E798  2               DMA_FILL      = $BA6F          ; fill byte (when mode bit0 set)
00E798  2               DMA_CNTL      = $BA70          ; transferred count low
00E798  2               DMA_CNTM      = $BA71          ; transferred count mid
00E798  2               DMA_CNTH      = $BA72          ; transferred count high
00E798  2               
00E798  2               DMA_CMD_START = $01
00E798  2               DMA_BUSY      = $01
00E798  2               DMA_OK        = $02
00E798  2               DMA_MODE_FILL = $01
00E798  2               DMA_SPACE_XRAM = $05
00E798  2               
00E798  2               ; --- Blitter controller registers ---
00E798  2               
00E798  2               BLT_CMD       = $BA80          ; write triggers blit
00E798  2               BLT_STATUS    = $BA81          ; 1=busy, 2=ok, 3=error
00E798  2               BLT_ERRCODE   = $BA82          ; blitter error code
00E798  2               BLT_SRCSPACE  = $BA83          ; source space id
00E798  2               BLT_DSTSPACE  = $BA84          ; destination space id
00E798  2               BLT_SRCL      = $BA85          ; source addr low
00E798  2               BLT_SRCM      = $BA86          ; source addr mid
00E798  2               BLT_SRCH      = $BA87          ; source addr high
00E798  2               BLT_DSTL      = $BA88          ; destination addr low
00E798  2               BLT_DSTM      = $BA89          ; destination addr mid
00E798  2               BLT_DSTH      = $BA8A          ; destination addr high
00E798  2               BLT_WIDTHL    = $BA8B          ; width low
00E798  2               BLT_WIDTHH    = $BA8C          ; width high
00E798  2               BLT_HEIGHTL   = $BA8D          ; height low
00E798  2               BLT_HEIGHTH   = $BA8E          ; height high
00E798  2               BLT_SRCSTRL   = $BA8F          ; source stride low
00E798  2               BLT_SRCSTRH   = $BA90          ; source stride high
00E798  2               BLT_DSTSTRL   = $BA91          ; destination stride low
00E798  2               BLT_DSTSTRH   = $BA92          ; destination stride high
00E798  2               BLT_MODE      = $BA93          ; mode flags
00E798  2               BLT_FILL      = $BA94          ; fill byte (when mode bit0 set)
00E798  2               BLT_CKEY      = $BA95          ; color key (when mode bit1 set)
00E798  2               BLT_CNTL      = $BA96          ; written count low
00E798  2               BLT_CNTM      = $BA97          ; written count mid
00E798  2               BLT_CNTH      = $BA98          ; written count high
00E798  2               
00E798  2               BLT_CMD_START = $01
00E798  2               BLT_BUSY      = $01
00E798  2               BLT_OK        = $02
00E798  2               BLT_MODE_FILL = $01
00E798  2               BLT_SPACE_XRAM = $05
00E798  2               
00E798  2               ; --- VGC command handlers ---
00E798  2               
00E798  2               ; draw a text-only cold-start splash screen
00E798  2               
00E798  2               LAB_SPLASH
00E798  2  A9 06              LDA   #$06              ; blue background
00E79A  2  8D 01 A0           STA   VGC_BGCOL
00E79D  2  A9 01              LDA   #$01              ; white text
00E79F  2  8D 02 A0           STA   VGC_FGCOL
00E7A2  2  A9 06              LDA   #$06              ; blue border
00E7A4  2  8D 0D A0           STA   VGC_BORDER
00E7A7  2  A9 00              LDA   #$00              ; mode 0: text only
00E7A9  2  8D 00 A0           STA   VGC_MODE
00E7AC  2               
00E7AC  2  A9 0C              LDA   #$0C              ; clear text layer and home cursor
00E7AE  2  20 8A E7           JSR   V_OUTP
00E7B1  2  A9 21              LDA   #$21              ; centered x for "NovaBASIC v1.0"
00E7B3  2  8D 03 A0           STA   VGC_CURSX
00E7B6  2  85 0E              STA   TPos
00E7B8  2  A9 00              LDA   #$00
00E7BA  2  8D 04 A0           STA   VGC_CURSY
00E7BD  2  A9 E4              LDA   #<LAB_BNR1
00E7BF  2  A0 E7              LDY   #>LAB_BNR1
00E7C1  2  20 3F CA           JSR   LAB_18C3
00E7C4  2               
00E7C4  2  A9 1A              LDA   #$1A              ; centered x for "Derived from EhBASIC 2.22p5"
00E7C6  2  8D 03 A0           STA   VGC_CURSX
00E7C9  2  85 0E              STA   TPos
00E7CB  2  A9 02              LDA   #$02              ; one empty row between lines
00E7CD  2  8D 04 A0           STA   VGC_CURSY
00E7D0  2  A9 F3              LDA   #<LAB_BNR2
00E7D2  2  A0 E7              LDY   #>LAB_BNR2
00E7D4  2  20 3F CA           JSR   LAB_18C3
00E7D7  2               
00E7D7  2  A9 11              LDA   #$11              ; centered x for "xxxxx BASIC bytes free  xxxK expansion memory"
00E7D9  2  8D 03 A0           STA   VGC_CURSX
00E7DC  2  85 0E              STA   TPos
00E7DE  2  A9 04              LDA   #$04              ; one empty row between lines
00E7E0  2  8D 04 A0           STA   VGC_CURSY
00E7E3  2  60                 RTS
00E7E4  2               
00E7E4  2               LAB_BNR1
00E7E4  2  4E 6F 76 61        .byte "NovaBASIC v1.0",$00
00E7E8  2  42 41 53 49  
00E7EC  2  43 20 76 31  
00E7F3  2               LAB_BNR2
00E7F3  2  44 65 72 69        .byte "Derived from EhBASIC 2.22p5",$00
00E7F7  2  76 65 64 20  
00E7FB  2  66 72 6F 6D  
00E80F  2               
00E80F  2               ; perform CLS — clear screen, no arguments
00E80F  2               
00E80F  2               LAB_CLS
00E80F  2  A9 0C              LDA   #$0C              ; form feed character
00E811  2  8D 0E A0           STA   VGC_CHAROUT       ; write to CHAROUT register
00E814  2  60                 RTS
00E815  2               
00E815  2               ; perform COLOR fg [,bg]
00E815  2               
00E815  2               LAB_COLOR
00E815  2  20 A4 D7           JSR   LAB_GTBY          ; get fg color byte in X
00E818  2  8E 02 A0           STX   VGC_FGCOL         ; store foreground color
00E81B  2  20 C2 00           JSR   LAB_GBYT          ; peek at current byte
00E81E  2  C9 2C              CMP   #','              ; comma follows?
00E820  2  D0 09              BNE   @done             ; no, just fg was given
00E822  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E825  2  20 A4 D7           JSR   LAB_GTBY          ; get bg color byte in X
00E828  2  8E 01 A0           STX   VGC_BGCOL         ; store background color
00E82B  2               @done
00E82B  2  60                 RTS
00E82C  2               
00E82C  2               ; perform LOCATE x, y
00E82C  2               
00E82C  2               LAB_LOCATE
00E82C  2  20 A4 D7           JSR   LAB_GTBY          ; get x in X
00E82F  2  8E 03 A0           STX   VGC_CURSX         ; store cursor X
00E832  2  20 62 CD           JSR   LAB_1C01          ; require comma
00E835  2  20 A4 D7           JSR   LAB_GTBY          ; get y in X
00E838  2  8E 04 A0           STX   VGC_CURSY         ; store cursor Y
00E83B  2  60                 RTS
00E83C  2               
00E83C  2               ; perform MODE n
00E83C  2               
00E83C  2               LAB_GMODE
00E83C  2  20 A4 D7           JSR   LAB_GTBY          ; get mode byte in X
00E83F  2  8E 00 A0           STX   VGC_MODE          ; store graphics mode
00E842  2  60                 RTS
00E843  2               
00E843  2               ; perform FONT n — select active font slot (0-7)
00E843  2               
00E843  2               LAB_FONT
00E843  2  20 A4 D7           JSR   LAB_GTBY          ; get font index byte (0-7) in X
00E846  2  8E 07 A0           STX   VGC_FONT          ; write to $A007
00E849  2  60                 RTS
00E84A  2               
00E84A  2               ; perform GCLS — clear the graphics bitmap layer
00E84A  2               
00E84A  2               LAB_GCLS
00E84A  2  A9 07              LDA   #VCMD_GCLS        ; GCLS command
00E84C  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E84F  2  60                 RTS
00E850  2               
00E850  2               ; perform GCOLOR c — set graphics draw color (0-15)
00E850  2               
00E850  2               LAB_GCOLOR
00E850  2  20 A4 D7           JSR   LAB_GTBY          ; get color byte in X
00E853  2  8E 11 A0           STX   VGC_P0             ; color in P0
00E856  2  A9 00              LDA   #$00
00E858  2  8D 12 A0           STA   VGC_P1             ; high byte = 0
00E85B  2  A9 08              LDA   #VCMD_GCOLOR      ; GCOLOR command
00E85D  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E860  2  60                 RTS
00E861  2               
00E861  2               ; shared: load x(word),y(byte) into VGC_P0-P3
00E861  2               
00E861  2               LAB_VGC_XY
00E861  2  20 92 D7           JSR   LAB_GTWRD         ; get x as 16-bit
00E864  2  A5 AF              LDA   FAC1_3
00E866  2  8D 11 A0           STA   VGC_P0             ; x low
00E869  2  A5 AE              LDA   FAC1_2
00E86B  2  8D 12 A0           STA   VGC_P1             ; x high
00E86E  2  20 62 CD           JSR   LAB_1C01          ; require comma
00E871  2  20 A4 D7           JSR   LAB_GTBY          ; get y as byte
00E874  2  8E 13 A0           STX   VGC_P2             ; y low
00E877  2  A9 00              LDA   #$00
00E879  2  8D 14 A0           STA   VGC_P3             ; y high = 0
00E87C  2  60                 RTS
00E87D  2               
00E87D  2               ; shared: load x0,y0,x1,y1 into VGC_P0-P7
00E87D  2               
00E87D  2               LAB_VGC_XYXY
00E87D  2  20 61 E8           JSR   LAB_VGC_XY        ; x0,y0 → P0-P3
00E880  2  20 62 CD           JSR   LAB_1C01          ; comma
00E883  2  20 92 D7           JSR   LAB_GTWRD         ; x1 as 16-bit
00E886  2  A5 AF              LDA   FAC1_3
00E888  2  8D 15 A0           STA   VGC_P4             ; x1 low
00E88B  2  A5 AE              LDA   FAC1_2
00E88D  2  8D 16 A0           STA   VGC_P5             ; x1 high
00E890  2  20 62 CD           JSR   LAB_1C01          ; comma
00E893  2  20 A4 D7           JSR   LAB_GTBY          ; y1
00E896  2  8E 17 A0           STX   VGC_P6             ; y1 low
00E899  2  A9 00              LDA   #$00
00E89B  2  8D 18 A0           STA   VGC_P7             ; y1 high = 0
00E89E  2  60                 RTS
00E89F  2               
00E89F  2               ; perform PLOT x, y
00E89F  2               
00E89F  2               LAB_PLOT
00E89F  2  20 61 E8           JSR   LAB_VGC_XY
00E8A2  2  A9 01              LDA   #VCMD_PLOT        ; PLOT command
00E8A4  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E8A7  2  60                 RTS
00E8A8  2               
00E8A8  2               ; perform UNPLOT x, y
00E8A8  2               
00E8A8  2               LAB_UNPLOT
00E8A8  2  20 61 E8           JSR   LAB_VGC_XY
00E8AB  2  A9 02              LDA   #VCMD_UNPLOT      ; UNPLOT command
00E8AD  2  8D 10 A0           STA   VGC_CMD
00E8B0  2  60                 RTS
00E8B1  2               
00E8B1  2               ; perform LINE x0, y0, x1, y1
00E8B1  2               
00E8B1  2               LAB_GLINE
00E8B1  2  20 7D E8           JSR   LAB_VGC_XYXY
00E8B4  2  A9 03              LDA   #VCMD_LINE        ; LINE command
00E8B6  2  8D 10 A0           STA   VGC_CMD
00E8B9  2  60                 RTS
00E8BA  2               
00E8BA  2               ; perform CIRCLE cx, cy, r
00E8BA  2               
00E8BA  2               LAB_CIRCLE
00E8BA  2  20 61 E8           JSR   LAB_VGC_XY        ; cx,cy → P0-P3
00E8BD  2  20 62 CD           JSR   LAB_1C01          ; comma
00E8C0  2  20 92 D7           JSR   LAB_GTWRD         ; r as 16-bit
00E8C3  2  A5 AF              LDA   FAC1_3
00E8C5  2  8D 15 A0           STA   VGC_P4             ; r low
00E8C8  2  A5 AE              LDA   FAC1_2
00E8CA  2  8D 16 A0           STA   VGC_P5             ; r high
00E8CD  2  A9 04              LDA   #VCMD_CIRCLE      ; CIRCLE command
00E8CF  2  8D 10 A0           STA   VGC_CMD
00E8D2  2  60                 RTS
00E8D3  2               
00E8D3  2               ; perform RECT x0, y0, x1, y1
00E8D3  2               
00E8D3  2               LAB_RECT
00E8D3  2  20 7D E8           JSR   LAB_VGC_XYXY
00E8D6  2  A9 05              LDA   #VCMD_RECT        ; RECT command
00E8D8  2  8D 10 A0           STA   VGC_CMD
00E8DB  2  60                 RTS
00E8DC  2               
00E8DC  2               ; perform FILL x0, y0, x1, y1
00E8DC  2               
00E8DC  2               LAB_FILLRECT
00E8DC  2  20 7D E8           JSR   LAB_VGC_XYXY
00E8DF  2  A9 06              LDA   #VCMD_FILL        ; FILL command
00E8E1  2  8D 10 A0           STA   VGC_CMD
00E8E4  2  60                 RTS
00E8E5  2               
00E8E5  2               ; perform PAINT x, y
00E8E5  2               
00E8E5  2               LAB_PAINT
00E8E5  2  20 61 E8           JSR   LAB_VGC_XY
00E8E8  2  A9 09              LDA   #VCMD_PAINT       ; PAINT command
00E8EA  2  8D 10 A0           STA   VGC_CMD
00E8ED  2  60                 RTS
00E8EE  2               
00E8EE  2               ; perform SPRITE n, ON/OFF  or  SPRITE n, x, y
00E8EE  2               ; sprite number 0-15, ON/OFF enables/disables, x,y sets position
00E8EE  2               ; Uses command-driven VGC interface:
00E8EE  2               ;   SPRENA ($15): P0=sprite
00E8EE  2               ;   SPRDIS ($16): P0=sprite
00E8EE  2               ;   SPRPOS ($14): P0=sprite, P1=x_low, P2=x_high, P3=y_low, P4=y_high
00E8EE  2               
00E8EE  2               LAB_SPRCMD
00E8EE  2  20 A4 D7           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00E8F1  2  86 11              STX   Itempl            ; save sprite number
00E8F3  2  20 62 CD           JSR   LAB_1C01          ; require comma
00E8F6  2  20 C2 00           JSR   LAB_GBYT          ; peek at next token
00E8F9  2  C9 93              CMP   #TK_ON            ; is it ON?
00E8FB  2  F0 2C              BEQ   @spr_on
00E8FD  2  C9 CB              CMP   #TK_OFF           ; is it OFF?
00E8FF  2  F0 36              BEQ   @spr_off
00E901  2                     ; not ON/OFF — parse x, y position
00E901  2  A5 11              LDA   Itempl            ; get sprite number
00E903  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00E906  2  20 9B D7           JSR   LAB_GTSW          ; get signed x as 16-bit
00E909  2  A5 AF              LDA   FAC1_3
00E90B  2  8D 12 A0           STA   VGC_P1             ; P1 = x low
00E90E  2  A5 AE              LDA   FAC1_2
00E910  2  8D 13 A0           STA   VGC_P2             ; P2 = x high
00E913  2  20 62 CD           JSR   LAB_1C01          ; require comma
00E916  2  20 9B D7           JSR   LAB_GTSW          ; get signed y as 16-bit
00E919  2  A5 AF              LDA   FAC1_3
00E91B  2  8D 14 A0           STA   VGC_P3             ; P3 = y low
00E91E  2  A5 AE              LDA   FAC1_2
00E920  2  8D 15 A0           STA   VGC_P4             ; P4 = y high
00E923  2  A9 14              LDA   #VCMD_SPRPOS      ; SPRPOS command
00E925  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E928  2  60                 RTS
00E929  2               
00E929  2               @spr_on
00E929  2  20 BC 00           JSR   LAB_IGBY          ; consume the ON token
00E92C  2  A5 11              LDA   Itempl            ; get sprite number
00E92E  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00E931  2  A9 15              LDA   #VCMD_SPRENA      ; SPRENA command
00E933  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E936  2  60                 RTS
00E937  2               
00E937  2               @spr_off
00E937  2  20 BC 00           JSR   LAB_IGBY          ; consume the OFF token
00E93A  2  A5 11              LDA   Itempl            ; get sprite number
00E93C  2  8D 11 A0           STA   VGC_P0             ; P0 = sprite index
00E93F  2  A9 16              LDA   #VCMD_SPRDIS      ; SPRDIS command
00E941  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E944  2  60                 RTS
00E945  2               
00E945  2               ; perform SPRITESHAPE n, shape
00E945  2               ; Writes shape index to sprite register $A044 + n*8
00E945  2               
00E945  2               LAB_SPRSHAPE
00E945  2  20 A4 D7           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00E948  2  8A                 TXA
00E949  2  0A                 ASL                     ; *2
00E94A  2  0A                 ASL                     ; *4
00E94B  2  0A                 ASL                     ; *8
00E94C  2  A8                 TAY                     ; Y = sprite * 8
00E94D  2  20 62 CD           JSR   LAB_1C01          ; require comma
00E950  2  20 A4 D7           JSR   LAB_GTBY          ; get shape index in X
00E953  2  8A                 TXA
00E954  2  99 44 A0           STA   $A044,Y           ; write to shape register ($A044 + n*8)
00E957  2  60                 RTS
00E958  2               
00E958  2               ; perform SPRITESET sprite, field, value — set sprite register with vblank sync
00E958  2               ; Fields 0 (X) and 2 (Y) accept a signed word and write both lo/hi bytes.
00E958  2               ; All other fields accept a byte value.
00E958  2               ; Waits for vblank before writing to avoid visual glitching.
00E958  2               
00E958  2               LAB_SPRCOLOR
00E958  2  20 A4 D7           JSR   LAB_GTBY          ; get sprite number (0-15) in X
00E95B  2  8A                 TXA
00E95C  2  0A                 ASL                     ; *2
00E95D  2  0A                 ASL                     ; *4
00E95E  2  0A                 ASL                     ; *8
00E95F  2  85 11              STA   Itempl            ; save base offset (sprite * 8)
00E961  2  20 62 CD           JSR   LAB_1C01          ; require comma
00E964  2  20 A4 D7           JSR   LAB_GTBY          ; get field (0-7) in X
00E967  2  86 12              STX   Itemph            ; save field number
00E969  2  8A                 TXA
00E96A  2  18                 CLC
00E96B  2  65 11              ADC   Itempl            ; base + field = register offset
00E96D  2  85 11              STA   Itempl            ; save register offset
00E96F  2  20 62 CD           JSR   LAB_1C01          ; require comma
00E972  2  A5 12              LDA   Itemph            ; check field number
00E974  2  C9 00              CMP   #$00              ; field 0 = X position?
00E976  2  F0 16              BEQ   @word_val
