00E854  2               FIO_NAME      = $B9B0          ; filename buffer (64 bytes)
00E854  2               
00E854  2               META_BASE       = $BAB0          ; metadata string buffer (80 bytes)
00E854  2               AUTOBOOT_SKIP = $B9F0          ; C# sets to $FF to skip autoboot
00E854  2               
00E854  2               FIO_CMD_SAVE  = $01            ; save program
00E854  2               FIO_CMD_LOAD  = $02            ; load program
00E854  2               FIO_OK        = $02            ; status: success
00E854  2               FIO_ERR       = $03            ; status: error
00E854  2               FIO_CMD_DIROPEN = $03          ; enumerate *.bas files, populate first entry
00E854  2               FIO_CMD_DIRREAD = $04          ; advance to next entry
00E854  2               FIO_CMD_DELETE = $05           ; delete a single *.bas file by name
