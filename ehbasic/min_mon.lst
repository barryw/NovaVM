00F705  2               ; character get subroutine for zero page
00F705  2               
00F705  2               ; For a 1.8432MHz 6502 including the JSR and RTS
00F705  2               ; fastest (>=":") =  29 cycles =  15.7uS
00F705  2               ; slowest (<":")  =  40 cycles =  21.7uS
00F705  2               ; space skip      = +21 cycles = +11.4uS
00F705  2               ; inc across page =  +4 cycles =  +2.2uS
00F705  2               
00F705  2               ; the target address for the LDA at LAB_2CF4 becomes the BASIC execute pointer once the
00F705  2               ; block is copied to it's destination, any non zero page address will do at assembly
00F705  2               ; time, to assemble a three byte instruction.
00F705  2               
00F705  2               ; page 0 initialisation table from $BC
00F705  2               ; increment and scan memory
00F705  2               
00F705  2               LAB_2CEE
00F705  2  E6 C3              INC   Bpntrl            ; increment BASIC execute pointer low byte
00F707  2  D0 02              BNE   LAB_2CF4          ; branch if no carry
00F709  2                                             ; else
00F709  2  E6 C4              INC   Bpntrh            ; increment BASIC execute pointer high byte
00F70B  2               
00F70B  2               ; page 0 initialisation table from $C2
00F70B  2               ; scan memory
00F70B  2               
00F70B  2               LAB_2CF4
00F70B  2  AD FF FF           LDA   $FFFF             ; get byte to scan (addr set by call routine)
00F70E  2  C9 C2              CMP   #TK_ELSE          ; compare with the token for ELSE
00F710  2  F0 0E              BEQ   LAB_2D05          ; exit if ELSE, not numeric, carry set
00F712  2               
00F712  2  C9 3A              CMP   #':'              ; compare with ":"
00F714  2  B0 0A              BCS   LAB_2D05          ; exit if >= ":", not numeric, carry set
00F716  2               
00F716  2  C9 20              CMP   #' '              ; compare with " "
00F718  2  F0 EB              BEQ   LAB_2CEE          ; if " " go do next
00F71A  2               
00F71A  2  38                 SEC                     ; set carry for SBC
00F71B  2  E9 30              SBC   #'0'              ; subtract "0"
00F71D  2  38                 SEC                     ; set carry for SBC
00F71E  2  E9 D0              SBC   #$D0              ; subtract -"0"
00F720  2                                             ; clear carry if byte = "0"-"9"
00F720  2               LAB_2D05
00F720  2  60                 RTS
