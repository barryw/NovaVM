00EE07  2  20 64 CD           JSR   LAB_1C01          ; comma
00EE0A  2  20 FE D7           JSR   LAB_GTBY          ; y (8-bit) → X
00EE0D  2  8E 13 A0           STX   VGC_P2             ; y
00EE10  2  20 64 CD           JSR   LAB_1C01          ; comma
00EE13  2                     ; parse register name: BGCOL, MODE, SCROLLX, SCROLLY,
00EE13  2                     ; SPRX(n), SPRXH(n), SPRY(n), SPRYH(n), SPRSHAPE(n), SPRFLAGS(n), SPRPRI(n)
00EE13  2  20 C2 00           JSR   LAB_GBYT          ; peek
00EE16  2  C9 42              CMP   #'B'
00EE18  2  F0 0B              BEQ   @c_bgcol
00EE1A  2  C9 B5              CMP   #TK_GMODE
00EE1C  2  F0 11              BEQ   @c_mode
00EE1E  2  C9 53              CMP   #'S'
00EE20  2  F0 15              BEQ   @c_s_dispatch
00EE22  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EE25  2               
00EE25  2               @c_bgcol
00EE25  2  A2 05              LDX   #5
00EE27  2  20 B0 EC           JSR   LAB_SKIPX          ; BGCOL
00EE2A  2  A9 01              LDA   #$01              ; reg index 1 = BGCOL
00EE2C  2  4C 6B EE           JMP   @c_store_idx
00EE2F  2               
00EE2F  2               @c_mode
