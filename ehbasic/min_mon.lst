00ECEB  3               .include "fio.s"
00ECEB  4               ; Shared Nova File I/O helper routines.
00ECEB  4               ;
00ECEB  4               ; This file is BASIC-agnostic. BASIC is still responsible for parsing language
00ECEB  4               ; expressions; assembly callers can load the FIO_ARG_* pseudo-registers and use
00ECEB  4               ; these helpers directly.
00ECEB  4               
00ECEB  4               .include "fio.inc"
00ECEB  5               ; Shared Nova File I/O helper declarations.
00ECEB  5               ;
00ECEB  5               ; Calling convention for pointer-based filename helpers:
00ECEB  5               ;   FIO_ARG_NAMELEN      filename length, 1..63
00ECEB  5               ;   FIO_ARG_NAMEPTR_L/H  CPU pointer to filename bytes
00ECEB  5               ;
00ECEB  5               ; Calling convention for XRAM streaming setup:
00ECEB  5               ;   FIO_ARG_ADDRL/M/H    flat 24-bit XRAM address
00ECEB  5               ;   FIO_ARG_LENL/H       transfer length; zero means full file for XLOAD
00ECEB  5               ;
00ECEB  5               ; Routines return A=0 on success and A=1 on error. Detailed status remains
00ECEB  5               ; in the FIO_STATUS/FIO_ERRCODE hardware registers.
00ECEB  5               
00ECEB  5               .ifndef FIO_INC_INCLUDED
00ECEB  5               FIO_INC_INCLUDED = 1
00ECEB  5               
00ECEB  5               .include "nova.inc"
00ECEB  5               
00ECEB  5               FIO_RESULT_OK    = $00
00ECEB  5               FIO_RESULT_ERROR = $01
00ECEB  5               FIO_NAME_LIMIT   = $3F
00ECEB  5               
00ECEB  5               ; Match the XRAM streaming ABI so xram_xload/xram_xsave can call directly.
00ECEB  5               ; @label FIO.ARG_ADDRL
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_ADDRL
00ECEB  5               ; @summary Low byte of XRAM address argument for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_ADDRL     = NVR0L
00ECEB  5               ; @label FIO.ARG_ADDRM
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_ADDRM
00ECEB  5               ; @summary Middle byte of XRAM address argument for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_ADDRM     = NVR0H
00ECEB  5               ; @label FIO.ARG_ADDRH
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_ADDRH
00ECEB  5               ; @summary High byte of XRAM address argument for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_ADDRH     = NVR1L
00ECEB  5               ; @label FIO.ARG_LENL
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_LENL
00ECEB  5               ; @summary Low byte of transfer length for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_LENL      = NVR3L
00ECEB  5               ; @label FIO.ARG_LENH
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_LENH
00ECEB  5               ; @summary High byte of transfer length for FIO.PREPARE_XRAM_TRANSFER.
00ECEB  5               FIO_ARG_LENH      = NVR3H
00ECEB  5               ; @label FIO.ARG_NAMELEN
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_NAMELEN
00ECEB  5               ; @summary Filename length for FIO.COPY_NAME.
00ECEB  5               FIO_ARG_NAMELEN   = NVR4L
00ECEB  5               ; @label FIO.ARG_NAMEPTR_L
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_NAMEPTR_L
00ECEB  5               ; @summary Low byte of filename pointer for FIO.COPY_NAME.
00ECEB  5               FIO_ARG_NAMEPTR_L = NVR4H
00ECEB  5               ; @label FIO.ARG_NAMEPTR_H
00ECEB  5               ; @kind zp
00ECEB  5               ; @symbol FIO_ARG_NAMEPTR_H
00ECEB  5               ; @summary High byte of filename pointer for FIO.COPY_NAME.
00ECEB  5               FIO_ARG_NAMEPTR_H = NVR5L
00ECEB  5               
00ECEB  5               .endif
00ECEB  5               
00ECEB  4               
00ECEB  4               .ifndef FIO_IMPLEMENTATION_INCLUDED
00ECEB  4               FIO_IMPLEMENTATION_INCLUDED = 1
00ECEB  4               
00ECEB  4                     .segment "CODE"
00ECEB  4               
00ECEB  4                     .export fio_issue
00ECEB  4                     .export fio_check
00ECEB  4                     .export fio_exec
00ECEB  4                     .export fio_copy_name
00ECEB  4                     .export fio_clear_error
00ECEB  4                     .export fio_set_io_error
00ECEB  4                     .export fio_save
00ECEB  4                     .export fio_load
00ECEB  4                     .export fio_dir_open
00ECEB  4                     .export fio_dir_read
00ECEB  4                     .export fio_delete
00ECEB  4                     .export fio_gsave
00ECEB  4                     .export fio_gload
00ECEB  4                     .export fio_cd
00ECEB  4                     .export fio_mkdir
00ECEB  4                     .export fio_rmdir
00ECEB  4                     .export fio_pwd
00ECEB  4                     .export fio_load_runtime
00ECEB  4               .ifndef FIO_NO_STREAMING
00ECEB  4                     .export fio_run
00ECEB  4                     .export fio_prepare_xram_transfer
00ECEB  4               .endif
00ECEB  4               
00ECEB  4               ; Input: A = FIO command. Does not check completion/status.
00ECEB  4               ; @label FIO.ISSUE
00ECEB  4               ; @kind routine
00ECEB  4               ; @symbol fio_issue
00ECEB  4               ; @summary Issue a raw FIO command without waiting for completion.
00ECEB  4               ; @in A: FIO command byte.
00ECEB  4               fio_issue:
00ECEB  4  8D A0 B9           STA   FIO_CMD
00ECEE  4  60                 RTS
00ECEF  4               
00ECEF  4               ; Check current FIO_STATUS.
00ECEF  4               ; @label FIO.CHECK
00ECEF  4               ; @kind routine
00ECEF  4               ; @symbol fio_check
00ECEF  4               ; @summary Convert the current FIO status register to the shared A=0/1 result.
00ECEF  4               ; @out A: 0 on success, 1 on error.
00ECEF  4               fio_check:
00ECEF  4  AD A1 B9           LDA   FIO_STATUS
00ECF2  4  C9 02              CMP   #FIO_OK
00ECF4  4  F0 03              BEQ   @ok
00ECF6  4  A9 01              LDA   #FIO_RESULT_ERROR
00ECF8  4  60                 RTS
00ECF9  4               @ok:
00ECF9  4  A9 00              LDA   #FIO_RESULT_OK
00ECFB  4  60                 RTS
00ECFC  4               
00ECFC  4               ; Input: A = FIO command. Issue, wait for completion, and check status.
00ECFC  4               ; @label FIO.EXEC
00ECFC  4               ; @kind routine
00ECFC  4               ; @symbol fio_exec
00ECFC  4               ; @summary Issue an FIO command, wait for completion, and return A=0/1 status.
00ECFC  4               ; @in A: FIO command byte.
00ECFC  4               ; @out A: 0 on success, 1 on error.
00ECFC  4               fio_exec:
00ECFC  4  48                 PHA
00ECFD  4  9C A1 B9           STZ   FIO_STATUS
00ED00  4  9C A2 B9           STZ   FIO_ERRCODE
00ED03  4  68                 PLA
00ED04  4  8D A0 B9           STA   FIO_CMD
00ED07  4               @wait:
00ED07  4  AD A1 B9           LDA   FIO_STATUS
00ED0A  4  F0 FB              BEQ   @wait
00ED0C  4  4C EF EC           JMP   fio_check
00ED0F  4               
00ED0F  4               ; Clear the host-visible FIO error/status latch.
00ED0F  4               ; @label FIO.CLEAR_ERROR
00ED0F  4               ; @kind routine
00ED0F  4               ; @symbol fio_clear_error
00ED0F  4               ; @summary Clear the host-visible FIO status and error latch.
00ED0F  4               ; @out A: 0 on success.
00ED0F  4               fio_clear_error:
00ED0F  4  A9 00              LDA   #FIO_ERR_NONE
00ED11  4  8D A2 B9           STA   FIO_ERRCODE
00ED14  4  A9 02              LDA   #FIO_STATUS_OK
00ED16  4  8D A1 B9           STA   FIO_STATUS
00ED19  4  A9 27              LDA   #FIO_CMD_CLEARERR
00ED1B  4  8D A0 B9           STA   FIO_CMD
00ED1E  4  A9 00              LDA   #FIO_RESULT_OK
00ED20  4  60                 RTS
00ED21  4               
00ED21  4               ; Mark an argument/host I/O error in the hardware status registers.
00ED21  4               ; @label FIO.SET_IO_ERROR
00ED21  4               ; @kind routine
00ED21  4               ; @symbol fio_set_io_error
00ED21  4               ; @summary Set FIO_STATUS/FIO_ERRCODE to the shared I/O error state.
00ED21  4               ; @out A: 1 on error.
00ED21  4               fio_set_io_error:
00ED21  4  A9 03              LDA   #FIO_STATUS_ERROR
00ED23  4  8D A1 B9           STA   FIO_STATUS
00ED26  4  A9 02              LDA   #FIO_ERR_IO
00ED28  4  8D A2 B9           STA   FIO_ERRCODE
00ED2B  4  A9 01              LDA   #FIO_RESULT_ERROR
00ED2D  4  60                 RTS
00ED2E  4               
00ED2E  4               ; Copy filename from FIO_ARG_NAMEPTR_L/H into FIO_NAME.
00ED2E  4               ; @label FIO.COPY_NAME
00ED2E  4               ; @kind routine
00ED2E  4               ; @symbol fio_copy_name
00ED2E  4               ; @summary Copy a pointer-based filename into FIO.NAME/FIO.NAMELEN.
00ED2E  4               ; @requires FIO_ARG_NAMELEN FIO_ARG_NAMEPTR_L FIO_ARG_NAMEPTR_H
00ED2E  4               ; @out A: 0 on success, 1 on invalid name.
00ED2E  4               fio_copy_name:
00ED2E  4  A5 28              LDA   FIO_ARG_NAMELEN
00ED30  4  F0 16              BEQ   @bad
00ED32  4  C9 40              CMP   #FIO_NAME_LIMIT + 1
00ED34  4  B0 12              BCS   @bad
00ED36  4  8D A3 B9           STA   FIO_NAMELEN
00ED39  4  AA                 TAX
00ED3A  4  A0 00              LDY   #$00
00ED3C  4               @copy:
00ED3C  4  B1 29              LDA   (FIO_ARG_NAMEPTR_L),Y
00ED3E  4  99 B0 B9           STA   FIO_NAME,Y
00ED41  4  C8                 INY
00ED42  4  CA                 DEX
00ED43  4  D0 F7              BNE   @copy
00ED45  4  A9 00              LDA   #FIO_RESULT_OK
00ED47  4  60                 RTS
00ED48  4               @bad:
00ED48  4  4C 21 ED           JMP   fio_set_io_error
00ED4B  4               
00ED4B  4               ; @label FIO.SAVE
00ED4B  4               ; @kind routine
00ED4B  4               ; @symbol fio_save
00ED4B  4               ; @summary Save RAM using FIO.NAME plus FIO_SRCL/H and FIO_ENDL/H.
00ED4B  4               ; @requires FIO_NAME FIO_NAMELEN FIO_SRCL FIO_SRCH FIO_ENDL FIO_ENDH
00ED4B  4               fio_save:
00ED4B  4  A9 01              LDA   #FIO_CMD_SAVE
00ED4D  4  4C FC EC           JMP   fio_exec
00ED50  4               
00ED50  4               ; @label FIO.LOAD
00ED50  4               ; @kind routine
00ED50  4               ; @symbol fio_load
00ED50  4               ; @summary Load a BASIC or binary file using FIO.NAME and FIO_SRCL/H.
00ED50  4               ; @requires FIO_NAME FIO_NAMELEN FIO_SRCL FIO_SRCH
00ED50  4               fio_load:
00ED50  4  A9 02              LDA   #FIO_CMD_LOAD
00ED52  4  4C FC EC           JMP   fio_exec
00ED55  4               
00ED55  4               ; @label FIO.DIR_OPEN
00ED55  4               ; @kind routine
00ED55  4               ; @symbol fio_dir_open
00ED55  4               ; @summary Open a directory listing using optional FIO.NAME/FIO.NAMELEN filter.
00ED55  4               fio_dir_open:
00ED55  4  A9 03              LDA   #FIO_CMD_DIROPEN
00ED57  4  4C FC EC           JMP   fio_exec
00ED5A  4               
00ED5A  4               ; @label FIO.DIR_READ
00ED5A  4               ; @kind routine
00ED5A  4               ; @symbol fio_dir_read
00ED5A  4               ; @summary Read the next directory entry into the FIO directory result registers.
00ED5A  4               fio_dir_read:
00ED5A  4  A9 04              LDA   #FIO_CMD_DIRREAD
00ED5C  4  4C FC EC           JMP   fio_exec
00ED5F  4               
00ED5F  4               ; @label FIO.DELETE
00ED5F  4               ; @kind routine
00ED5F  4               ; @symbol fio_delete
00ED5F  4               ; @summary Delete the file named by FIO.NAME/FIO.NAMELEN.
00ED5F  4               ; @requires FIO_NAME FIO_NAMELEN
00ED5F  4               fio_delete:
00ED5F  4  A9 05              LDA   #FIO_CMD_DELETE
00ED61  4  4C FC EC           JMP   fio_exec
00ED64  4               
00ED64  4               ; @label FIO.GSAVE
00ED64  4               ; @kind routine
00ED64  4               ; @symbol fio_gsave
00ED64  4               ; @summary Save VGC/graphics memory using FIO graphics registers.
00ED64  4               ; @requires FIO_NAME FIO_NAMELEN FIO_GSPACE FIO_GADDRL FIO_GADDRH FIO_GLENL FIO_GLENH
00ED64  4               fio_gsave:
00ED64  4  A9 06              LDA   #FIO_CMD_GSAVE
00ED66  4  4C FC EC           JMP   fio_exec
00ED69  4               
00ED69  4               ; @label FIO.GLOAD
00ED69  4               ; @kind routine
00ED69  4               ; @symbol fio_gload
00ED69  4               ; @summary Load VGC/graphics memory using FIO graphics registers.
00ED69  4               ; @requires FIO_NAME FIO_NAMELEN FIO_GSPACE FIO_GADDRL FIO_GADDRH FIO_GLENL FIO_GLENH
00ED69  4               fio_gload:
00ED69  4  A9 07              LDA   #FIO_CMD_GLOAD
00ED6B  4  4C FC EC           JMP   fio_exec
00ED6E  4               
00ED6E  4               ; @label FIO.CD
00ED6E  4               ; @kind routine
00ED6E  4               ; @symbol fio_cd
00ED6E  4               ; @summary Change directory to FIO.NAME/FIO.NAMELEN.
00ED6E  4               ; @requires FIO_NAME FIO_NAMELEN
00ED6E  4               fio_cd:
00ED6E  4  A9 20              LDA   #FIO_CMD_CD
00ED70  4  4C FC EC           JMP   fio_exec
00ED73  4               
00ED73  4               ; @label FIO.MKDIR
00ED73  4               ; @kind routine
00ED73  4               ; @symbol fio_mkdir
00ED73  4               ; @summary Create the directory named by FIO.NAME/FIO.NAMELEN.
00ED73  4               ; @requires FIO_NAME FIO_NAMELEN
00ED73  4               fio_mkdir:
00ED73  4  A9 21              LDA   #FIO_CMD_MKDIR
00ED75  4  4C FC EC           JMP   fio_exec
00ED78  4               
00ED78  4               ; @label FIO.RMDIR
00ED78  4               ; @kind routine
00ED78  4               ; @symbol fio_rmdir
00ED78  4               ; @summary Remove the directory named by FIO.NAME/FIO_NAMELEN.
00ED78  4               ; @requires FIO_NAME FIO_NAMELEN
00ED78  4               fio_rmdir:
00ED78  4  A9 22              LDA   #FIO_CMD_RMDIR
00ED7A  4  4C FC EC           JMP   fio_exec
00ED7D  4               
00ED7D  4               ; @label FIO.PWD
00ED7D  4               ; @kind routine
00ED7D  4               ; @symbol fio_pwd
00ED7D  4               ; @summary Read the current directory into FIO.NAME/FIO.NAMELEN.
00ED7D  4               fio_pwd:
00ED7D  4  A9 26              LDA   #FIO_CMD_PWD
00ED7F  4  4C FC EC           JMP   fio_exec
00ED82  4               
00ED82  4               ; Load a 16K runtime ROM image into the primary $C000 bank.
00ED82  4               ; This routine is meant for RAM-resident launchers. The host overwrites the
00ED82  4               ; primary ROM bank while the command is in progress.
00ED82  4               ; @label FIO.LOAD_RUNTIME
00ED82  4               ; @kind routine
00ED82  4               ; @symbol fio_load_runtime
00ED82  4               ; @summary Load a 16K runtime ROM image named by FIO.NAME/FIO.NAMELEN into the primary runtime ROM bank.
00ED82  4               ; @requires FIO_NAME FIO_NAMELEN
00ED82  4               fio_load_runtime:
00ED82  4  A9 28              LDA   #FIO_CMD_LOADRUNTIME
00ED84  4  4C FC EC           JMP   fio_exec
00ED87  4               
00ED87  4               .ifndef FIO_NO_STREAMING
00ED87  4               ; Compatibility alias for assembly callers that used the streaming name.
00ED87  4               ; @label FIO.RUN
00ED87  4               ; @kind routine
00ED87  4               ; @symbol fio_run
00ED87  4               ; @summary Compatibility alias for FIO.EXEC.
00ED87  4               fio_run:
00ED87  4                     JMP   fio_exec
00ED87  4               
00ED87  4               ; Prepare the FIO hardware registers for XLOAD/XSAVE-style direct XRAM I/O.
00ED87  4               ; @label FIO.PREPARE_XRAM_TRANSFER
00ED87  4               ; @kind routine
00ED87  4               ; @symbol fio_prepare_xram_transfer
00ED87  4               ; @summary Copy pointer filename and XRAM transfer arguments into FIO registers.
00ED87  4               ; @requires FIO_ARG_NAMELEN FIO_ARG_NAMEPTR_L FIO_ARG_NAMEPTR_H FIO_ARG_ADDRL FIO_ARG_ADDRM FIO_ARG_ADDRH FIO_ARG_LENL FIO_ARG_LENH
00ED87  4               fio_prepare_xram_transfer:
00ED87  4                     JSR   fio_copy_name
00ED87  4                     BNE   @done
00ED87  4                     LDA   FIO_ARG_ADDRL
00ED87  4                     STA   FIO_GADDRL
00ED87  4                     LDA   FIO_ARG_ADDRM
00ED87  4                     STA   FIO_GADDRH
00ED87  4                     LDA   FIO_ARG_ADDRH
00ED87  4                     STA   FIO_GSPACE
00ED87  4                     LDA   FIO_ARG_LENL
00ED87  4                     STA   FIO_GLENL
00ED87  4                     LDA   FIO_ARG_LENH
00ED87  4                     STA   FIO_GLENH
00ED87  4                     LDA   #FIO_RESULT_OK
00ED87  4               @done:
00ED87  4                     RTS
00ED87  4               .endif
00ED87  4               
00ED87  4               .endif
00ED87  4               
00ED87  3               
00ED87  3               ; @label AUDIO.PLAY_SOUND
00ED87  3               ; @kind routine
00ED87  3               ; @symbol audio_play_sound
00ED87  3               ; @abi register
00ED87  3               ; @summary Play a one-shot note using A/X/Y register arguments.
00ED87  3               ; @in A: MIDI note
00ED87  3               ; @in X: Duration in 60 Hz frames
00ED87  3               ; @in Y: Instrument slot
00ED87  3               ; @out A: 0 on success, nonzero on error
00ED87  3               audio_play_sound:
00ED87  3  8D A4 B9           STA   AUDIO_NOTE
00ED8A  3  8E A5 B9           STX   AUDIO_DURATION
00ED8D  3  8C A6 B9           STY   AUDIO_INSTRUMENT
00ED90  3  80 08              BRA   audio_sound
00ED92  3               
00ED92  3               ; @label AUDIO.SET_VOLUME
00ED92  3               ; @kind routine
00ED92  3               ; @symbol audio_set_volume
00ED92  3               ; @abi register
00ED92  3               ; @summary Set master or per-voice volume using A/X register arguments.
00ED92  3               ; @in A: Volume level
00ED92  3               ; @in X: Voice selector, 0=master
00ED92  3               ; @out A: 0 on success, nonzero on error
00ED92  3               audio_set_volume:
00ED92  3  8D A4 B9           STA   AUDIO_VOLUME
00ED95  3  8E A5 B9           STX   AUDIO_VOICE
00ED98  3  80 05              BRA   audio_volume
00ED9A  3               
00ED9A  3               ; @label AUDIO.SOUND
00ED9A  3               ; @kind routine
00ED9A  3               ; @symbol audio_sound
00ED9A  3               ; @abi pseudo-register
00ED9A  3               ; @summary Play a one-shot note from AUDIO.NOTE, AUDIO.DURATION, and AUDIO.INSTRUMENT.
00ED9A  3               ; @requires AUDIO.NOTE AUDIO.DURATION AUDIO.INSTRUMENT
00ED9A  3               ; @out A: 0 on success, nonzero on error
00ED9A  3               audio_sound:
00ED9A  3  A9 0B              LDA   #FIO_CMD_SOUND
00ED9C  3  4C FC EC           JMP   fio_exec
00ED9F  3               
00ED9F  3               ; @label AUDIO.VOLUME
00ED9F  3               ; @kind routine
00ED9F  3               ; @symbol audio_volume
00ED9F  3               ; @abi pseudo-register
00ED9F  3               ; @summary Set volume from AUDIO.VOLUME_LEVEL and AUDIO.VOICE.
00ED9F  3               ; @requires AUDIO.VOLUME_LEVEL AUDIO.VOICE
00ED9F  3               ; @out A: 0 on success, nonzero on error
00ED9F  3               audio_volume:
00ED9F  3  A9 0C              LDA   #FIO_CMD_VOLUME
00EDA1  3  4C FC EC           JMP   fio_exec
00EDA4  3               
00EDA4  3               ; @label AUDIO.INSTRUMENT_SET
00EDA4  3               ; @kind routine
00EDA4  3               ; @symbol audio_instrument
00EDA4  3               ; @abi pseudo-register
00EDA4  3               ; @summary Define an instrument envelope and waveform.
00EDA4  3               ; @requires AUDIO.INST_ID AUDIO.WAVEFORM AUDIO.ATTACK AUDIO.DECAY AUDIO.SUSTAIN AUDIO.RELEASE
00EDA4  3               ; @out A: 0 on success, nonzero on error
00EDA4  3               audio_instrument:
00EDA4  3  A9 0A              LDA   #FIO_CMD_INSTRUMENT
00EDA6  3  4C FC EC           JMP   fio_exec
00EDA9  3               
00EDA9  3               .if AUDIO_FILE_COMMANDS
00EDA9  3               ; @label AUDIO.SIDPLAY
00EDA9  3               ; @kind routine
00EDA9  3               ; @symbol audio_sidplay
00EDA9  3               ; @abi pseudo-register
00EDA9  3               ; @summary Play the SID file named by FIO.NAME/FIO.NAMELEN. AUDIO.NOTE is reused as the 1-based song number.
00EDA9  3               ; @requires FIO.NAME FIO.NAMELEN AUDIO.NOTE
00EDA9  3               ; @out A: 0 on success, nonzero on error
00EDA9  3               audio_sidplay:
00EDA9  3  A9 08              LDA   #FIO_CMD_SIDPLAY
00EDAB  3  20 FC EC           JSR   fio_exec
00EDAE  3  D0 01              BNE   @done
00EDB0  3  58                 CLI                     ; playback needs timer IRQs active
00EDB1  3               @done:
00EDB1  3  60                 RTS
00EDB2  3               
00EDB2  3               ; @label AUDIO.SIDSTOP
00EDB2  3               ; @kind routine
00EDB2  3               ; @symbol audio_sidstop
00EDB2  3               ; @abi none
00EDB2  3               ; @summary Stop SID file playback.
00EDB2  3               ; @out A: 0 on success, nonzero on error
00EDB2  3               audio_sidstop:
00EDB2  3  A9 09              LDA   #FIO_CMD_SIDSTOP
00EDB4  3  4C FC EC           JMP   fio_exec
00EDB7  3               
00EDB7  3               ; @label AUDIO.MIDPLAY
00EDB7  3               ; @kind routine
00EDB7  3               ; @symbol audio_midplay
00EDB7  3               ; @abi pseudo-register
00EDB7  3               ; @summary Play the MIDI file named by FIO.NAME/FIO.NAMELEN.
00EDB7  3               ; @requires FIO.NAME FIO.NAMELEN
00EDB7  3               ; @out A: 0 on success, nonzero on error
00EDB7  3               audio_midplay:
00EDB7  3  A9 13              LDA   #FIO_CMD_MIDPLAY
00EDB9  3  4C FC EC           JMP   fio_exec
00EDBC  3               
00EDBC  3               ; @label AUDIO.MIDSTOP
00EDBC  3               ; @kind routine
00EDBC  3               ; @symbol audio_midstop
00EDBC  3               ; @abi none
00EDBC  3               ; @summary Stop MIDI file playback.
00EDBC  3               ; @out A: 0 on success, nonzero on error
00EDBC  3               audio_midstop:
00EDBC  3  A9 14              LDA   #FIO_CMD_MIDSTOP
00EDBE  3  4C FC EC           JMP   fio_exec
00EDC1  3               
00EDC1  3               ; @label AUDIO.SFLOAD
00EDC1  3               ; @kind routine
00EDC1  3               ; @symbol audio_sfload
00EDC1  3               ; @abi pseudo-register
00EDC1  3               ; @summary Load the soundfont named by FIO.NAME/FIO.NAMELEN.
00EDC1  3               ; @requires FIO.NAME FIO.NAMELEN
00EDC1  3               ; @out A: 0 on success, nonzero on error
00EDC1  3               audio_sfload:
00EDC1  3  A9 15              LDA   #FIO_CMD_SFLOAD
00EDC3  3  4C FC EC           JMP   fio_exec
00EDC6  3               .endif
00EDC6  3               
00EDC6  3               ; @label AUDIO.MUSIC_SEQUENCE
00EDC6  3               ; @kind routine
00EDC6  3               ; @symbol audio_music_sequence
00EDC6  3               ; @abi pseudo-register
00EDC6  3               ; @summary Queue an MML sequence for AUDIO.VOICE using AUDIO.STRL/H and AUDIO.STRLEN.
00EDC6  3               ; @requires AUDIO.VOICE AUDIO.STRL AUDIO.STRH AUDIO.STRLEN
00EDC6  3               ; @out A: 0 on success, nonzero on error
00EDC6  3               audio_music_sequence:
00EDC6  3  A9 0D              LDA   #FIO_CMD_MSEQ
00EDC8  3  4C FC EC           JMP   fio_exec
00EDCB  3               
00EDCB  3               ; @label AUDIO.MUSIC_PLAY
00EDCB  3               ; @kind routine
00EDCB  3               ; @symbol audio_music_play
00EDCB  3               ; @abi none
00EDCB  3               ; @summary Start queued music playback.
00EDCB  3               ; @out A: 0 on success, nonzero on error
00EDCB  3               audio_music_play:
00EDCB  3  A9 0E              LDA   #FIO_CMD_MPLAY
00EDCD  3  20 FC EC           JSR   fio_exec
00EDD0  3  D0 01              BNE   @done
00EDD2  3  58                 CLI                     ; playback needs timer IRQs active
00EDD3  3               @done:
00EDD3  3  60                 RTS
00EDD4  3               
00EDD4  3               ; @label AUDIO.MUSIC_STOP
00EDD4  3               ; @kind routine
00EDD4  3               ; @symbol audio_music_stop
00EDD4  3               ; @abi none
00EDD4  3               ; @summary Stop music playback.
00EDD4  3               ; @out A: 0 on success, nonzero on error
00EDD4  3               audio_music_stop:
00EDD4  3  A9 0F              LDA   #FIO_CMD_MSTOP
00EDD6  3  4C FC EC           JMP   fio_exec
00EDD9  3               
00EDD9  3               ; @label AUDIO.MUSIC_TEMPO
00EDD9  3               ; @kind routine
00EDD9  3               ; @symbol audio_music_tempo
00EDD9  3               ; @abi pseudo-register
00EDD9  3               ; @summary Set music tempo from AUDIO.NOTE/AUDIO.DURATION as a 16-bit BPM value.
00EDD9  3               ; @requires AUDIO.NOTE AUDIO.DURATION
00EDD9  3               ; @out A: 0 on success, nonzero on error
00EDD9  3               audio_music_tempo:
00EDD9  3  A9 10              LDA   #FIO_CMD_MTEMPO
00EDDB  3  4C FC EC           JMP   fio_exec
00EDDE  3               
00EDDE  3               ; @label AUDIO.MUSIC_LOOP
00EDDE  3               ; @kind routine
00EDDE  3               ; @symbol audio_music_loop
00EDDE  3               ; @abi pseudo-register
00EDDE  3               ; @summary Enable or disable music looping. AUDIO.NOTE is 0=off, nonzero=on.
00EDDE  3               ; @requires AUDIO.NOTE
00EDDE  3               ; @out A: 0 on success, nonzero on error
00EDDE  3               audio_music_loop:
00EDDE  3  A9 11              LDA   #FIO_CMD_MLOOP
00EDE0  3  4C FC EC           JMP   fio_exec
00EDE3  3               
00EDE3  3               ; @label AUDIO.MUSIC_PRIORITY
00EDE3  3               ; @kind routine
00EDE3  3               ; @symbol audio_music_priority
00EDE3  3               ; @abi pseudo-register
00EDE3  3               ; @summary Set voice-stealing priority from AUDIO.NOTE and following pseudo-register bytes.
00EDE3  3               ; @requires AUDIO.NOTE
00EDE3  3               ; @out A: 0 on success, nonzero on error
00EDE3  3               audio_music_priority:
00EDE3  3  A9 12              LDA   #FIO_CMD_MPRI
00EDE5  3  4C FC EC           JMP   fio_exec
00EDE8  3               
00EDE8  3               ; @label AUDIO.STATUS
00EDE8  3               ; @kind routine
00EDE8  3               ; @symbol audio_status
00EDE8  3               ; @abi none
00EDE8  3               ; @summary Return raw music status bits.
00EDE8  3               ; @out A: Raw MUSIC_STATUS byte
00EDE8  3               audio_status:
00EDE8  3  AD 50 BA           LDA   MUSIC_STATUS
00EDEB  3  60                 RTS
00EDEC  3               
00EDEC  3               ; @label AUDIO.SFX_PLAYING
00EDEC  3               ; @kind routine
00EDEC  3               ; @symbol audio_sfx_playing
00EDEC  3               ; @abi none
00EDEC  3               ; @summary Return nonzero if a sound effect is playing.
00EDEC  3               ; @out A: 1 if playing, 0 if idle
00EDEC  3               audio_sfx_playing:
00EDEC  3  AD 50 BA           LDA   MUSIC_STATUS
00EDEF  3  29 01              AND   #$01
00EDF1  3  60                 RTS
00EDF2  3               
00EDF2  3               ; @label AUDIO.MUSIC_PLAYING
00EDF2  3               ; @kind routine
00EDF2  3               ; @symbol audio_music_playing
00EDF2  3               ; @abi none
00EDF2  3               ; @summary Return nonzero if music is playing.
00EDF2  3               ; @out A: 1 if playing, 0 if idle
00EDF2  3               audio_music_playing:
00EDF2  3  AD 50 BA           LDA   MUSIC_STATUS
00EDF5  3  29 02              AND   #$02
00EDF7  3  F0 02              BEQ   @off
00EDF9  3  A9 01              LDA   #$01
00EDFB  3               @off:
00EDFB  3  60                 RTS
00EDFC  3               
00EDFC  3               ; @label AUDIO.MUSIC_NOTE
00EDFC  3               ; @kind routine
00EDFC  3               ; @symbol audio_music_note
00EDFC  3               ; @abi register
00EDFC  3               ; @summary Return the current MIDI note for a music voice.
00EDFC  3               ; @in X: Voice number, 1..14
00EDFC  3               ; @out A: Current MIDI note, or 0 if out of range or silent
00EDFC  3               audio_music_note:
00EDFC  3  CA                 DEX
00EDFD  3  E0 0E              CPX   #$0E
00EDFF  3  B0 04              BCS   @bad
00EE01  3  BD 51 BA           LDA   MUSIC_NOTE1,X
00EE04  3  60                 RTS
00EE05  3               @bad:
00EE05  3  A9 00              LDA   #$00
00EE07  3  60                 RTS
00EE08  3               
00EE08  3               .endif
00EE08  3               
00EE08  2                     .include "lib/nic.s"
00EE08  3               ; Shared Nova NIC helper routines.
00EE08  3               
00EE08  3               .include "nic.inc"
00EE08  4               ; Shared Nova NIC runtime interface.
00EE08  4               ;
00EE08  4               ; BASIC handles string allocation/parsing.  Assembly callers can use these
00EE08  4               ; routines by loading the NIC MMIO registers directly.
00EE08  4               ;
00EE08  4               ; Connect:
00EE08  4               ;   NIC_SLOT      slot number
00EE08  4               ;   NIC_NAMEBUF   zero-terminated host name
00EE08  4               ;   NIC_RPORTL/H  remote port
00EE08  4               ;
00EE08  4               ; Listen:
00EE08  4               ;   NIC_SLOT      slot number
00EE08  4               ;   NIC_LPORTL/H  local port
00EE08  4               ;
00EE08  4               ; Send:
00EE08  4               ;   NIC_SLOT      slot number
00EE08  4               ;   NIC_DMAL/H    CPU pointer to bytes
00EE08  4               ;   NIC_DMALEN    byte count
00EE08  4               ;
00EE08  4               ; Receive:
00EE08  4               ;   NIC_SLOT      slot number
00EE08  4               ;   NIC_DMAL/H    CPU destination pointer
00EE08  4               ;   NIC_MSGLEN    byte count returned by hardware
00EE08  4               
00EE08  4               .ifndef NIC_INC_INCLUDED
00EE08  4               NIC_INC_INCLUDED = 1
00EE08  4               
00EE08  4               .include "nova.inc"
00EE08  5               ; Shared Nova hardware constants for BASIC, assembly, and runtime libraries.
00EE08  5               ;
00EE08  5               ; This include is deliberately guarded per symbol so it can coexist with older
00EE08  5               ; source files that still define a subset of these names locally.
00EE08  5               
00EE08  5               .ifndef NOVA_INC_INCLUDED
00EE08  5               NOVA_INC_INCLUDED = 1
00EE08  5               
00EE08  5               ; Nova pseudo-register mailbox. These bytes are available to callers and
00EE08  5               ; runtime helpers as ephemeral argument/scratch storage only. A routine may
00EE08  5               ; clobber them unless its documentation explicitly says otherwise; persistent
00EE08  5               ; library state must be allocated in a linker segment such as BSS/ZEROPAGE.
00EE08  5               .ifndef NVR0L
00EE08  5               NVR0L             = $20
00EE08  5               .endif
00EE08  5               .ifndef NVR0H
00EE08  5               NVR0H             = $21
00EE08  5               .endif
00EE08  5               .ifndef NVR1L
00EE08  5               NVR1L             = $22
00EE08  5               .endif
00EE08  5               .ifndef NVR1H
00EE08  5               NVR1H             = $23
00EE08  5               .endif
00EE08  5               .ifndef NVR2L
00EE08  5               NVR2L             = $24
00EE08  5               .endif
00EE08  5               .ifndef NVR2H
00EE08  5               NVR2H             = $25
00EE08  5               .endif
00EE08  5               .ifndef NVR3L
00EE08  5               NVR3L             = $26
00EE08  5               .endif
00EE08  5               .ifndef NVR3H
00EE08  5               NVR3H             = $27
00EE08  5               .endif
00EE08  5               .ifndef NVR4L
00EE08  5               NVR4L             = $28
00EE08  5               .endif
00EE08  5               .ifndef NVR4H
00EE08  5               NVR4H             = $29
00EE08  5               .endif
00EE08  5               .ifndef NVR5L
00EE08  5               NVR5L             = $2A
00EE08  5               .endif
00EE08  5               .ifndef NVR5H
00EE08  5               NVR5H             = $2B
00EE08  5               .endif
00EE08  5               .ifndef NVR6L
00EE08  5               NVR6L             = $2C
00EE08  5               .endif
00EE08  5               .ifndef NVR6H
00EE08  5               NVR6H             = $2D
00EE08  5               .endif
00EE08  5               .ifndef NVR7L
00EE08  5               NVR7L             = $2E
00EE08  5               .endif
00EE08  5               .ifndef NVR7H
00EE08  5               NVR7H             = $2F
00EE08  5               .endif
00EE08  5               
00EE08  5               ; BASIC SYS register bridge. SYS addr[,A[,X[,Y]]] loads A/X/Y from these
00EE08  5               ; bytes before jumping and stores A/X/Y back here when the routine returns.
00EE08  5               ; @label SYS.REGA
00EE08  5               ; @kind u8
00EE08  5               ; @symbol SYS_REGA
00EE08  5               ; @summary Returned A register from the most recent SYS call.
00EE08  5               .ifndef SYS_REGA
00EE08  5               SYS_REGA          = $E7
00EE08  5               .endif
00EE08  5               ; @label SYS.REGX
00EE08  5               ; @kind u8
00EE08  5               ; @symbol SYS_REGX
00EE08  5               ; @summary Returned X register from the most recent SYS call.
00EE08  5               .ifndef SYS_REGX
00EE08  5               SYS_REGX          = $E8
00EE08  5               .endif
00EE08  5               ; @label SYS.REGY
00EE08  5               ; @kind u8
00EE08  5               ; @symbol SYS_REGY
00EE08  5               ; @summary Returned Y register from the most recent SYS call.
00EE08  5               .ifndef SYS_REGY
00EE08  5               SYS_REGY          = $E9
00EE08  5               .endif
00EE08  5               
00EE08  5               ; Extension ROM argument mailbox used by small BASIC stubs that parse
00EE08  5               ; BASIC-owned data before calling an extension handler.
00EE08  5               .ifndef EXT_ARG_LEN
00EE08  5               EXT_ARG_LEN       = $EA
00EE08  5               .endif
00EE08  5               .ifndef EXT_ARG_PTRL
00EE08  5               EXT_ARG_PTRL      = $EB
00EE08  5               .endif
00EE08  5               .ifndef EXT_ARG_PTRH
00EE08  5               EXT_ARG_PTRH      = $EC
00EE08  5               .endif
00EE08  5               
