00E7E2  2               ; --- VGC command handlers ---
00E7E2  2               
00E7E2  2               ; draw a text-only cold-start splash screen
00E7E2  2               
00E7E2  2               LAB_SPLASH
00E7E2  2  A9 06              LDA   #$06              ; blue background
00E7E4  2  8D 01 A0           STA   VGC_BGCOL
00E7E7  2  A9 01              LDA   #$01              ; white text
00E7E9  2  8D 02 A0           STA   VGC_FGCOL
00E7EC  2  A9 06              LDA   #$06              ; blue border
00E7EE  2  8D 0D A0           STA   VGC_BORDER
00E7F1  2  A9 00              LDA   #$00              ; mode 0: text only
00E7F3  2  8D 00 A0           STA   VGC_MODE
00E7F6  2               
00E7F6  2  A9 0C              LDA   #$0C              ; clear text layer and home cursor
00E7F8  2  20 D4 E7           JSR   V_OUTP
00E7FB  2  A9 21              LDA   #$21              ; centered x for "NovaBASIC v1.0"
00E7FD  2  8D 03 A0           STA   VGC_CURSX
00E800  2  85 0E              STA   TPos
00E802  2  A9 00              LDA   #$00
00E804  2  8D 04 A0           STA   VGC_CURSY
00E807  2  A9 2E              LDA   #<LAB_BNR1
00E809  2  A0 E8              LDY   #>LAB_BNR1
00E80B  2  20 6D CA           JSR   LAB_18C3
00E80E  2               
00E80E  2  A9 1A              LDA   #$1A              ; centered x for "Derived from EhBASIC 2.22p5"
00E810  2  8D 03 A0           STA   VGC_CURSX
00E813  2  85 0E              STA   TPos
00E815  2  A9 02              LDA   #$02              ; one empty row between lines
00E817  2  8D 04 A0           STA   VGC_CURSY
00E81A  2  A9 3D              LDA   #<LAB_BNR2
00E81C  2  A0 E8              LDY   #>LAB_BNR2
00E81E  2  20 6D CA           JSR   LAB_18C3
00E821  2               
00E821  2  A9 11              LDA   #$11              ; centered x for "xxxxx BASIC bytes free  xxxK expansion memory"
00E823  2  8D 03 A0           STA   VGC_CURSX
00E826  2  85 0E              STA   TPos
00E828  2  A9 04              LDA   #$04              ; one empty row between lines
00E82A  2  8D 04 A0           STA   VGC_CURSY
00E82D  2  60                 RTS
00E82E  2               
00E82E  2               LAB_BNR1
00E82E  2  4E 6F 76 61        .byte "NovaBASIC v1.0",$00
00E832  2  42 41 53 49  
00E836  2  43 20 76 31  
00E83D  2               LAB_BNR2
00E83D  2  44 65 72 69        .byte "Derived from EhBASIC 2.22p5",$00
00E841  2  76 65 64 20  
00E845  2  66 72 6F 6D  
00E859  2               
00E859  2               ; perform CLS — clear screen, no arguments
00E859  2               
00E859  2               LAB_CLS
00E859  2  A9 0C              LDA   #$0C              ; form feed character
00E85B  2  8D 0E A0           STA   VGC_CHAROUT       ; write to CHAROUT register
00E85E  2  60                 RTS
00E85F  2               
00E85F  2               ; perform COLOR fg [,bg]
00E85F  2               
00E85F  2               LAB_COLOR
00E85F  2  20 6B D8           JSR   LAB_GTBY          ; get fg color byte in X
00E862  2  8E 02 A0           STX   VGC_FGCOL         ; store foreground color
00E865  2  20 C2 00           JSR   LAB_GBYT          ; peek at current byte
00E868  2  C9 2C              CMP   #','              ; comma follows?
00E86A  2  D0 09              BNE   @done             ; no, just fg was given
00E86C  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00E86F  2  20 6B D8           JSR   LAB_GTBY          ; get bg color byte in X
00E872  2  8E 01 A0           STX   VGC_BGCOL         ; store background color
00E875  2               @done
00E875  2  60                 RTS
00E876  2               
00E876  2               ; perform LOCATE x, y
00E876  2               
00E876  2               LAB_LOCATE
00E876  2  20 6B D8           JSR   LAB_GTBY          ; get x in X
00E879  2  8E 03 A0           STX   VGC_CURSX         ; store cursor X
00E87C  2  20 90 CD           JSR   LAB_1C01          ; require comma
00E87F  2  20 6B D8           JSR   LAB_GTBY          ; get y in X
00E882  2  8E 04 A0           STX   VGC_CURSY         ; store cursor Y
00E885  2  60                 RTS
00E886  2               
00E886  2               ; perform MODE n
00E886  2               
00E886  2               LAB_GMODE
00E886  2  20 6B D8           JSR   LAB_GTBY          ; get mode byte in X
00E889  2  8E 00 A0           STX   VGC_MODE          ; store graphics mode
00E88C  2  60                 RTS
00E88D  2               
00E88D  2               ; perform FONT n — select active font slot (0-7)
00E88D  2               
00E88D  2               LAB_FONT
00E88D  2  20 6B D8           JSR   LAB_GTBY          ; get font index byte (0-7) in X
00E890  2  8E 07 A0           STX   VGC_FONT          ; write to $A007
00E893  2  60                 RTS
00E894  2               
00E894  2               ; perform GCLS — clear the graphics bitmap layer
00E894  2               
00E894  2               LAB_GCLS
00E894  2  A9 07              LDA   #VCMD_GCLS        ; GCLS command
00E896  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E899  2  60                 RTS
00E89A  2               
00E89A  2               ; perform GCOLOR c — set graphics draw color (0-15)
00E89A  2               
00E89A  2               LAB_GCOLOR
00E89A  2  20 6B D8           JSR   LAB_GTBY          ; get color byte in X
00E89D  2  8E 11 A0           STX   VGC_P0             ; color in P0
00E8A0  2  A9 00              LDA   #$00
00E8A2  2  8D 12 A0           STA   VGC_P1             ; high byte = 0
00E8A5  2  A9 08              LDA   #VCMD_GCOLOR      ; GCOLOR command
00E8A7  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E8AA  2  60                 RTS
00E8AB  2               
00E8AB  2               ; shared: load x(word),y(byte) into VGC_P0-P3
00E8AB  2               
00E8AB  2               LAB_VGC_XY
00E8AB  2  20 59 D8           JSR   LAB_GTWRD         ; get x as 16-bit
00E8AE  2  A5 AF              LDA   FAC1_3
00E8B0  2  8D 11 A0           STA   VGC_P0             ; x low
00E8B3  2  A5 AE              LDA   FAC1_2
00E8B5  2  8D 12 A0           STA   VGC_P1             ; x high
00E8B8  2  20 90 CD           JSR   LAB_1C01          ; require comma
00E8BB  2  20 6B D8           JSR   LAB_GTBY          ; get y as byte
00E8BE  2  8E 13 A0           STX   VGC_P2             ; y low
00E8C1  2  A9 00              LDA   #$00
00E8C3  2  8D 14 A0           STA   VGC_P3             ; y high = 0
00E8C6  2  60                 RTS
00E8C7  2               
00E8C7  2               ; shared: load x0,y0,x1,y1 into VGC_P0-P7
00E8C7  2               
00E8C7  2               LAB_VGC_XYXY
00E8C7  2  20 AB E8           JSR   LAB_VGC_XY        ; x0,y0 → P0-P3
00E8CA  2  20 90 CD           JSR   LAB_1C01          ; comma
00E8CD  2  20 59 D8           JSR   LAB_GTWRD         ; x1 as 16-bit
00E8D0  2  A5 AF              LDA   FAC1_3
00E8D2  2  8D 15 A0           STA   VGC_P4             ; x1 low
00E8D5  2  A5 AE              LDA   FAC1_2
00E8D7  2  8D 16 A0           STA   VGC_P5             ; x1 high
00E8DA  2  20 90 CD           JSR   LAB_1C01          ; comma
00E8DD  2  20 6B D8           JSR   LAB_GTBY          ; y1
00E8E0  2  8E 17 A0           STX   VGC_P6             ; y1 low
00E8E3  2  A9 00              LDA   #$00
00E8E5  2  8D 18 A0           STA   VGC_P7             ; y1 high = 0
00E8E8  2  60                 RTS
00E8E9  2               
00E8E9  2               ; perform PLOT x, y
00E8E9  2               
00E8E9  2               LAB_PLOT
00E8E9  2  20 AB E8           JSR   LAB_VGC_XY
00E8EC  2  A9 01              LDA   #VCMD_PLOT        ; PLOT command
00E8EE  2  8D 10 A0           STA   VGC_CMD            ; trigger
00E8F1  2  60                 RTS
00E8F2  2               
00E8F2  2               ; perform UNPLOT x, y
00E8F2  2               
00E8F2  2               LAB_UNPLOT
00E8F2  2  20 AB E8           JSR   LAB_VGC_XY
00E8F5  2  A9 02              LDA   #VCMD_UNPLOT      ; UNPLOT command
00E8F7  2  8D 10 A0           STA   VGC_CMD
00E8FA  2  60                 RTS
00E8FB  2               
00E8FB  2               ; perform LINE x0, y0, x1, y1
00E8FB  2               
00E8FB  2               LAB_GLINE
