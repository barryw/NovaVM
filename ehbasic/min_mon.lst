00EFEE  2               
00EFEE  2               ; perform MUSIC subcommand
00EFEE  2               ; MUSIC voice, "mml"
00EFEE  2               ; MUSIC PLAY | STOP | TEMPO bpm | LOOP ON|OFF | PRIORITY v1[,v2[,v3]]
00EFEE  2               
00EFEE  2               LAB_MUSIC
00EFEE  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte (after MUSIC token consumed)
00EFF1  2  C9 50              CMP   #'P'
00EFF3  2  F0 0F              BEQ   @m_chk_p
00EFF5  2  C9 92              CMP   #TK_STOP           ; STOP is tokenized by BASIC
00EFF7  2  F0 1E              BEQ   @m_stop_tok
00EFF9  2  C9 54              CMP   #'T'
00EFFB  2  F0 22              BEQ   @m_tempo
00EFFD  2  C9 9E              CMP   #TK_LOOP           ; LOOP is tokenized by BASIC
00EFFF  2  F0 35              BEQ   @m_loop_tok
00F001  2                     ; Not a subcommand — must be a number (voice 1-6)
00F001  2  4C 8C F0           JMP   @m_seq
00F004  2               
00F004  2               ; --- MUSIC PLAY or PRIORITY ---
00F004  2               @m_chk_p
00F004  2                     ; Consume P, then check next char to distinguish PLAY vs PRIORITY
00F004  2  20 BC 00           JSR   LAB_IGBY          ; consume P, A = next char
00F007  2  C9 52              CMP   #'R'              ; PRIORITY has R after P
00F009  2  F0 51              BEQ   @m_priority
00F00B  2                     ; else PLAY — consume remaining "LAY" (3 chars, P already consumed)
00F00B  2  A2 03              LDX   #3
00F00D  2  20 E7 EF           JSR   LAB_SKIPX          ; LAY
00F010  2  A9 0E              LDA   #FIO_CMD_MPLAY
00F012  2  20 B3 ED           JSR   fio_issue
00F015  2  58                 CLI                     ; enable interrupts for music
00F016  2  60                 RTS
00F017  2               
00F017  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00F017  2               @m_stop_tok
00F017  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00F01A  2  A9 0F              LDA   #FIO_CMD_MSTOP
00F01C  2  4C B3 ED           JMP   LAB_FIO_CMD_RTS
00F01F  2               
00F01F  2               ; --- MUSIC TEMPO bpm ---
00F01F  2               @m_tempo
00F01F  2  A2 05              LDX   #5
00F021  2  20 E7 EF           JSR   LAB_SKIPX          ; TEMPO
00F024  2  20 0D D9           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00F027  2  A5 AF              LDA   FAC1_3
00F029  2  8D A4 B9           STA   FIO_SRCL
00F02C  2  A5 AE              LDA   FAC1_2
00F02E  2  8D A5 B9           STA   FIO_SRCH
00F031  2  A9 10              LDA   #FIO_CMD_MTEMPO
00F033  2  4C B3 ED           JMP   LAB_FIO_CMD_RTS
00F036  2               
00F036  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00F036  2               @m_loop_tok
00F036  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00F039  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00F03C  2  C9 93              CMP   #TK_ON
00F03E  2  F0 07              BEQ   @m_loop_on
00F040  2  C9 CB              CMP   #TK_OFF
00F042  2  F0 0D              BEQ   @m_loop_off
00F044  2  4C DE C5           JMP   LAB_15D9          ; syntax error
00F047  2               @m_loop_on
00F047  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00F04A  2  A9 01              LDA   #$01
00F04C  2  8D A4 B9           STA   FIO_SRCL
00F04F  2  80 06              BRA   @m_loop_go
00F051  2               @m_loop_off
00F051  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00F054  2  9C A4 B9           STZ   FIO_SRCL
00F057  2               @m_loop_go
00F057  2  A9 11              LDA   #FIO_CMD_MLOOP
00F059  2  4C B3 ED           JMP   LAB_FIO_CMD_RTS
00F05C  2               
00F05C  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00F05C  2               @m_priority
00F05C  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00F05C  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00F05C  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00F05C  2               @m_pri_skip
00F05C  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00F05F  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00F061  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00F063  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00F063  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00F063  2                     ; Clear all 6 voice slots
00F063  2  A9 00              LDA   #$00
00F065  2  A0 05              LDY   #$05
00F067  2               @m_pri_clr
00F067  2  99 A4 B9           STA   FIO_SRCL,Y
00F06A  2  88                 DEY
00F06B  2  10 FA              BPL   @m_pri_clr
00F06D  2                     ; Parse up to 6 comma-separated voice values
00F06D  2  A0 00              LDY   #$00              ; slot index
00F06F  2               @m_pri_nxt
00F06F  2  20 1F D9           JSR   LAB_GTBY          ; get voice number → X
00F072  2  8A                 TXA
00F073  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00F076  2  C8                 INY
00F077  2  C0 06              CPY   #$06
00F079  2  B0 0C              BCS   @m_pri_go         ; all 6 parsed
00F07B  2  20 C2 00           JSR   LAB_GBYT          ; peek next char
00F07E  2  C9 2C              CMP   #','
00F080  2  D0 05              BNE   @m_pri_go         ; no more commas
00F082  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00F085  2  80 E8              BRA   @m_pri_nxt
00F087  2               @m_pri_go
00F087  2  A9 12              LDA   #FIO_CMD_MPRI
00F089  2  4C B3 ED           JMP   LAB_FIO_CMD_RTS
00F08C  2               
00F08C  2               ; --- MUSIC voice, "mml" ---
00F08C  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00F08C  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
00F08C  2               @m_seq
00F08C  2  20 1F D9           JSR   LAB_GTBY          ; voice number (1-14) → X
00F08F  2  8E A4 B9           STX   FIO_SRCL          ; store voice
00F092  2  20 F6 CD           JSR   LAB_1C01          ; comma
