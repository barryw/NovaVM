00F008  2               LAB_EXT_FCER
00F008  2  20 21 02           JSR   EXT_vec
00F00B  2  D0 01              BNE   @ext_bad
00F00D  2  60                 RTS
00F00E  2               @ext_bad
00F00E  2  4C 2B D3           JMP   LAB_FCER
00F011  2               
00F011  2               ; perform SIDPLAY "filename" [, song]
00F011  2               
00F011  2               LAB_SIDPLAY
00F011  2  20 DD F1           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00F014  2  A9 01              LDA   #$01              ; default song = 1
00F016  2  8D A4 B9           STA   FIO_SRCL
00F019  2  20 C2 00           JSR   LAB_GBYT          ; peek next token
00F01C  2  C9 2C              CMP   #','
00F01E  2  D0 09              BNE   @sp_go
00F020  2  20 FA CD           JSR   LAB_1C01          ; consume comma
00F023  2  20 A2 D8           JSR   LAB_GTBY          ; evaluate song number -> X
00F026  2  8E A4 B9           STX   FIO_SRCL
00F029  2               @sp_go
00F029  2  20 A9 ED           JSR   audio_sidplay
00F02C  2  D0 01              BNE   @sp_err
00F02E  2  60                 RTS
