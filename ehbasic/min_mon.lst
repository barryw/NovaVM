00EC0A  2               @ld_bin_ok
00EC0A  2                     ; In program mode, silently continue; in immediate mode, print address
00EC0A  2  A5 88              LDA   Clineh
00EC0C  2  C9 FF              CMP   #$FF
00EC0E  2  D0 16              BNE   @ld_bin_done      ; running from a program — just return
00EC10  2  A9 2A              LDA   #<@s_loaded
00EC12  2  A0 EC              LDY   #>@s_loaded
00EC14  2  20 43 CA           JSR   LAB_18C3          ; print string
00EC17  2  AD A5 B9           LDA   FIO_SRCH          ; high byte of load address
00EC1A  2  20 F5 F2           JSR   LAB_PRHEX
00EC1D  2  AD A4 B9           LDA   FIO_SRCL          ; low byte
00EC20  2  20 F5 F2           JSR   LAB_PRHEX
00EC23  2  4C 6A C1           JMP   LAB_1274          ; print Ready, return to command loop
00EC26  2               @ld_bin_done
00EC26  2  60                 RTS
00EC27  2               @ld_chk_err
00EC27  2  4C 0B F3           JMP   LAB_FIO_ERRHND
00EC2A  2  0D 0A 4C 6F  @s_loaded .byte $0D,$0A,"Loaded at $",0
00EC2E  2  61 64 65 64  
00EC32  2  20 61 74 20  
