00EC9C  2               
00EC9C  2               LAB_MIDSTOP
00EC9C  2  A9 14              LDA   #FIO_CMD_MIDSTOP
00EC9E  2  8D A0 B9           STA   FIO_CMD
00ECA1  2  60                 RTS
00ECA2  2               
00ECA2  2               ; common: issue FIO command in A, check status, error on fail
00ECA2  2               
00ECA2  2               LAB_FIO_EXEC
00ECA2  2  8D A0 B9           STA   FIO_CMD
00ECA5  2  AD A1 B9           LDA   FIO_STATUS
00ECA8  2  C9 02              CMP   #FIO_OK
