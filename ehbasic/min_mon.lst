00ECBB  2               ; --- VGC function handlers ---
00ECBB  2               
00ECBB  2               ; perform SPRITEX(n) — return X position of sprite n as signed word
00ECBB  2               
00ECBB  2               LAB_SPRITEX
00ECBB  2  20 C9 D8           JSR   LAB_F2FX          ; convert FAC1 to integer, low byte in Itempl
00ECBE  2  A5 11              LDA   Itempl            ; get sprite number
00ECC0  2  0A                 ASL                     ; *2
00ECC1  2  0A                 ASL                     ; *4
00ECC2  2  0A                 ASL                     ; *8
00ECC3  2  AA                 TAX                     ; X = sprite * 8
00ECC4  2  BC 40 A0           LDY   $A040,X           ; Y = X position low byte
00ECC7  2  BD 41 A0           LDA   $A041,X           ; A = X position high byte
00ECCA  2  4C 20 D4           JMP   LAB_AYFC          ; return AY as signed integer
00ECCD  2               
00ECCD  2               ; perform SPRITEY(n) — return Y position of sprite n as signed word
00ECCD  2               
00ECCD  2               LAB_SPRITEY
00ECCD  2  20 C9 D8           JSR   LAB_F2FX          ; convert FAC1 to integer, low byte in Itempl
00ECD0  2  A5 11              LDA   Itempl            ; get sprite number
