00EE7C  2               ; perform MUSIC subcommand
00EE7C  2               ; MUSIC voice, "mml"
00EE7C  2               ; MUSIC PLAY | STOP | TEMPO bpm | LOOP ON|OFF | PRIORITY v1[,v2[,v3]]
00EE7C  2               
00EE7C  2               LAB_MUSIC
00EE7C  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte (after MUSIC token consumed)
00EE7F  2  C9 50              CMP   #'P'
00EE81  2  F0 0F              BEQ   @m_chk_p
