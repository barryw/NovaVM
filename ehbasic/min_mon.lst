00DFBE  2  F0 07              BEQ   NextPRN           ; do next random # if zero
00DFC0  2               
00DFC0  2                                             ; else get seed into random number store
00DFC0  2  A2 D8              LDX   #Rbyte4           ; set PRNG pointer low byte
00DFC2  2  A0 00              LDY   #$00              ; set PRNG pointer high byte
00DFC4  2  20 C6 DB           JSR   LAB_2778          ; pack FAC1 into (XY)
00DFC7  2               NextPRN
00DFC7  2  A2 AF              LDX   #$AF              ; set EOR byte
00DFC9  2  A0 13              LDY   #$13              ; do this nineteen times
00DFCB  2               LoopPRN
