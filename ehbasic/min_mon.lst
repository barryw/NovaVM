00EDD7  2               
00EDD7  2               ; --- COPPER ADD x, y, reg, value ---
00EDD7  2               @c_add
00EDD7  2  A2 03              LDX   #3
00EDD9  2  20 92 EC           JSR   LAB_SKIPX          ; ADD
00EDDC  2  20 92 D7           JSR   LAB_GTWRD         ; x (16-bit) → FAC1_3(lo), FAC1_2(hi)
00EDDF  2  A5 AF              LDA   FAC1_3
00EDE1  2  8D 11 A0           STA   VGC_P0             ; x low
00EDE4  2  A5 AE              LDA   FAC1_2
00EDE6  2  8D 12 A0           STA   VGC_P1             ; x high
00EDE9  2  20 62 CD           JSR   LAB_1C01          ; comma
00EDEC  2  20 A4 D7           JSR   LAB_GTBY          ; y (8-bit) → X
00EDEF  2  8E 13 A0           STX   VGC_P2             ; y
00EDF2  2  20 62 CD           JSR   LAB_1C01          ; comma
00EDF5  2                     ; parse register name: BGCOL, MODE, SCROLLX, SCROLLY,
00EDF5  2                     ; SPRX(n), SPRXH(n), SPRY(n), SPRYH(n), SPRSHAPE(n), SPRFLAGS(n), SPRPRI(n)
00EDF5  2  20 C2 00           JSR   LAB_GBYT          ; peek
00EDF8  2  C9 42              CMP   #'B'
00EDFA  2  F0 0B              BEQ   @c_bgcol
00EDFC  2  C9 B5              CMP   #TK_GMODE
00EDFE  2  F0 11              BEQ   @c_mode
00EE00  2  C9 53              CMP   #'S'
00EE02  2  F0 15              BEQ   @c_s_dispatch
00EE04  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EE07  2               
00EE07  2               @c_bgcol
00EE07  2  A2 05              LDX   #5
00EE09  2  20 92 EC           JSR   LAB_SKIPX          ; BGCOL
00EE0C  2  A9 01              LDA   #$01              ; reg index 1 = BGCOL
00EE0E  2  4C 4D EE           JMP   @c_store_idx
00EE11  2               
00EE11  2               @c_mode
00EE11  2  20 BC 00           JSR   LAB_IGBY          ; consume MODE token
00EE14  2  A9 00              LDA   #$00              ; reg index 0 = MODE
00EE16  2  4C 4D EE           JMP   @c_store_idx
00EE19  2               
00EE19  2               @c_s_dispatch
00EE19  2  20 BC 00           JSR   LAB_IGBY          ; consume S
00EE1C  2  20 C2 00           JSR   LAB_GBYT          ; peek next: C=scroll, P=sprite
00EE1F  2  C9 43              CMP   #'C'
00EE21  2  F0 07              BEQ   @c_scroll
00EE23  2  C9 50              CMP   #'P'
00EE25  2  F0 31              BEQ   @c_spr
00EE27  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EE2A  2               
00EE2A  2               @c_scroll
00EE2A  2  A2 05              LDX   #5
00EE2C  2  20 92 EC           JSR   LAB_SKIPX          ; CROLL
00EE2F  2  20 C2 00           JSR   LAB_GBYT          ; peek X or Y
00EE32  2  C9 58              CMP   #'X'
00EE34  2  F0 07              BEQ   @c_scrollx
00EE36  2  C9 59              CMP   #'Y'
00EE38  2  F0 0B              BEQ   @c_scrolly
00EE3A  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EE3D  2               
00EE3D  2               @c_scrollx
00EE3D  2  20 BC 00           JSR   LAB_IGBY          ; consume X
00EE40  2  A9 05              LDA   #$05              ; reg index 5 = SCROLLX
00EE42  2  4C 4D EE           JMP   @c_store_idx
00EE45  2               
00EE45  2               @c_scrolly
00EE45  2  20 BC 00           JSR   LAB_IGBY          ; consume Y
00EE48  2  A9 06              LDA   #$06              ; reg index 6 = SCROLLY
00EE4A  2  4C 4D EE           JMP   @c_store_idx
00EE4D  2               
00EE4D  2               @c_store_idx
00EE4D  2  8D 14 A0           STA   VGC_P3             ; register index (low byte)
00EE50  2  A9 00              LDA   #$00
00EE52  2  8D 15 A0           STA   VGC_P4             ; high byte = 0
00EE55  2  4C EA EE           JMP   @c_store_val
00EE58  2               
00EE58  2                     ; --- Sprite register names: SPR + field + (n) ---
00EE58  2                     ; SPRX(n)=$A040+n*8+0, SPRXH(n)=+1, SPRY(n)=+2, SPRYH(n)=+3,
00EE58  2                     ; SPRSHAPE(n)=+4, SPRFLAGS(n)=+5, SPRPRI(n)=+6
00EE58  2               @c_spr
