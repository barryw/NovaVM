00EF20  2  A5 AE              LDA   FAC1_2
00EF22  2  8D AC B9           STA   FIO_GADDRH
00EF25  2  9C AD B9           STZ   FIO_GLENL         ; default: load full file
00EF28  2  9C AE B9           STZ   FIO_GLENH
00EF2B  2  20 C2 00           JSR   LAB_GBYT          ; optional comma,length
00EF2E  2  C9 2C              CMP   #','
00EF30  2  D0 10              BNE   @gl_go
00EF32  2  20 F6 CD           JSR   LAB_1C01
00EF35  2  20 0D D9           JSR   LAB_GTWRD
00EF38  2  A5 AF              LDA   FAC1_3
00EF3A  2  8D AD B9           STA   FIO_GLENL
00EF3D  2  A5 AE              LDA   FAC1_2
00EF3F  2  8D AE B9           STA   FIO_GLENH
00EF42  2               @gl_go
00EF42  2  A9 07              LDA   #FIO_CMD_GLOAD
00EF44  2  4C DE EF           JMP   LAB_FIO_EXEC      ; issue command, check status, return
00EF47  2               
00EF47  2               ; parse 16-bit XRAM offset into FIO flat-address registers
00EF47  2               ; BASIC supplies the high byte through current XBANK.
00EF47  2               
00EF47  2               LAB_XFIO_SETOFF
00EF47  2  20 0D D9           JSR   LAB_GTWRD
