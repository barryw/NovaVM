00EC3C  2  A5 AF              LDA   FAC1_3
00EC3E  2  8D AB B9           STA   FIO_GADDRL
00EC41  2  A5 AE              LDA   FAC1_2
00EC43  2  8D AC B9           STA   FIO_GADDRH
00EC46  2  A9 00              LDA   #$00              ; default: load full file
00EC48  2  8D AD B9           STA   FIO_GLENL
00EC4B  2  8D AE B9           STA   FIO_GLENH
00EC4E  2  20 C2 00           JSR   LAB_GBYT          ; optional comma,length
00EC51  2  C9 2C              CMP   #','
00EC53  2  D0 10              BNE   @gl_go
00EC55  2  20 64 CD           JSR   LAB_1C01
00EC58  2  20 EC D7           JSR   LAB_GTWRD
