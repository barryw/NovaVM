00EF81  2  A9 0D              LDA   #EXT_CMD_XLOAD
00EF83  2  80 1D              BRA   LAB_XFIO_EXEC     ; issue command through shared XRAM runtime
00EF85  2               
00EF85  2               ; perform XSAVE "filename", offset, length
00EF85  2               
00EF85  2               LAB_XSAVE
00EF85  2  20 4B F3           JSR   LAB_FIO_GETNAME   ; parse filename (errors internally)
00EF88  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EF8B  2  20 47 EF           JSR   LAB_XFIO_SETOFF   ; XRAM source offset + bank
00EF8E  2  20 F6 CD           JSR   LAB_1C01          ; comma
00EF91  2  20 0D D9           JSR   LAB_GTWRD
00EF94  2  A5 AF              LDA   FAC1_3
00EF96  2  8D AD B9           STA   FIO_GLENL
00EF99  2  A5 AE              LDA   FAC1_2
00EF9B  2  8D AE B9           STA   FIO_GLENH
00EF9E  2  A9 0E              LDA   #EXT_CMD_XSAVE
