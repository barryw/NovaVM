00EE25  2               
00EE25  2               @c_list_end
00EE25  2  20 BC 00           JSR   LAB_IGBY          ; consume END token
00EE28  2  A9 22              LDA   #VCMD_COPPEREND
00EE2A  2  8D 10 A0           STA   VGC_CMD
00EE2D  2  60                 RTS
00EE2E  2               
00EE2E  2               ; --- COPPER USE n ---
00EE2E  2               @c_use
00EE2E  2  A2 03              LDX   #3
00EE30  2  20 FA EC           JSR   LAB_SKIPX          ; USE
00EE33  2  20 00 D8           JSR   LAB_GTBY          ; list index → X
00EE36  2  8E 11 A0           STX   VGC_P0
00EE39  2  A9 21              LDA   #VCMD_COPPERUSE
00EE3B  2  8D 10 A0           STA   VGC_CMD
00EE3E  2  60                 RTS
00EE3F  2               
00EE3F  2               ; --- COPPER ADD x, y, reg, value ---
00EE3F  2               @c_add
00EE3F  2  A2 03              LDX   #3
00EE41  2  20 FA EC           JSR   LAB_SKIPX          ; ADD
00EE44  2  20 EE D7           JSR   LAB_GTWRD         ; x (16-bit) → FAC1_3(lo), FAC1_2(hi)
00EE47  2  A5 AF              LDA   FAC1_3
00EE49  2  8D 11 A0           STA   VGC_P0             ; x low
