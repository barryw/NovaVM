00F04D  2               @fio_chk_err
00F04D  2  4C 0B F2           JMP   LAB_FIO_ERRHND
00F050  2               
00F050  2               ; Skip X characters from BASIC input
00F050  2               LAB_SKIPX
00F050  2  20 BC 00           JSR   LAB_IGBY
00F053  2  CA                 DEX
00F054  2  D0 FA              BNE   LAB_SKIPX
