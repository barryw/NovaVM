00ECB7  2               
00ECB7  2               ; perform MUSIC subcommand
00ECB7  2               ; MUSIC voice, "mml"
00ECB7  2               ; MUSIC PLAY | STOP | TEMPO bpm | LOOP ON|OFF | PRIORITY v1[,v2[,v3]]
00ECB7  2               
00ECB7  2               LAB_MUSIC
00ECB7  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte (after MUSIC token consumed)
00ECBA  2  C9 50              CMP   #'P'
00ECBC  2  F0 0F              BEQ   @m_chk_p
00ECBE  2  C9 92              CMP   #TK_STOP           ; STOP is tokenized by BASIC
00ECC0  2  F0 1E              BEQ   @m_stop_tok
00ECC2  2  C9 54              CMP   #'T'
00ECC4  2  F0 23              BEQ   @m_tempo
00ECC6  2  C9 9E              CMP   #TK_LOOP           ; LOOP is tokenized by BASIC
00ECC8  2  F0 37              BEQ   @m_loop_tok
00ECCA  2                     ; Not a subcommand — must be a number (voice 1-6)
00ECCA  2  4C 5D ED           JMP   @m_seq
00ECCD  2               
00ECCD  2               ; --- MUSIC PLAY or PRIORITY ---
00ECCD  2               @m_chk_p
00ECCD  2                     ; Consume P, then check next char to distinguish PLAY vs PRIORITY
00ECCD  2  20 BC 00           JSR   LAB_IGBY          ; consume P, A = next char
00ECD0  2  C9 52              CMP   #'R'              ; PRIORITY has R after P
00ECD2  2  F0 57              BEQ   @m_priority
00ECD4  2                     ; else PLAY — consume remaining "LAY" (3 chars, P already consumed)
00ECD4  2  A2 03              LDX   #3
00ECD6  2  20 B0 EC           JSR   LAB_SKIPX          ; LAY
00ECD9  2  A9 0E              LDA   #FIO_CMD_MPLAY
00ECDB  2  8D A0 B9           STA   FIO_CMD
00ECDE  2  58                 CLI                     ; enable interrupts for music
00ECDF  2  60                 RTS
00ECE0  2               
00ECE0  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00ECE0  2               @m_stop_tok
00ECE0  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00ECE3  2  A9 0F              LDA   #FIO_CMD_MSTOP
00ECE5  2  8D A0 B9           STA   FIO_CMD
00ECE8  2  60                 RTS
00ECE9  2               
00ECE9  2               ; --- MUSIC TEMPO bpm ---
00ECE9  2               @m_tempo
00ECE9  2  A2 05              LDX   #5
00ECEB  2  20 B0 EC           JSR   LAB_SKIPX          ; TEMPO
00ECEE  2  20 EC D7           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00ECF1  2  A5 AF              LDA   FAC1_3
00ECF3  2  8D A4 B9           STA   FIO_SRCL
00ECF6  2  A5 AE              LDA   FAC1_2
