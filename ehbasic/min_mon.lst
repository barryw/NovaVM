00EE99  2  A2 03              LDX   #3
00EE9B  2  20 75 EE           JSR   LAB_SKIPX          ; LAY
00EE9E  2  A9 0E              LDA   #FIO_CMD_MPLAY
00EEA0  2  8D A0 B9           STA   FIO_CMD
00EEA3  2  58                 CLI                     ; enable interrupts for music
00EEA4  2  60                 RTS
00EEA5  2               
00EEA5  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00EEA5  2               @m_stop_tok
00EEA5  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00EEA8  2  A9 0F              LDA   #FIO_CMD_MSTOP
00EEAA  2  8D A0 B9           STA   FIO_CMD
00EEAD  2  60                 RTS
00EEAE  2               
00EEAE  2               ; --- MUSIC TEMPO bpm ---
00EEAE  2               @m_tempo
00EEAE  2  A2 05              LDX   #5
00EEB0  2  20 75 EE           JSR   LAB_SKIPX          ; TEMPO
00EEB3  2  20 59 D8           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00EEB6  2  A5 AF              LDA   FAC1_3
00EEB8  2  8D A4 B9           STA   FIO_SRCL
00EEBB  2  A5 AE              LDA   FAC1_2
00EEBD  2  8D A5 B9           STA   FIO_SRCH
00EEC0  2  A9 10              LDA   #FIO_CMD_MTEMPO
00EEC2  2  8D A0 B9           STA   FIO_CMD
00EEC5  2  60                 RTS
00EEC6  2               
00EEC6  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00EEC6  2               @m_loop_tok
00EEC6  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00EEC9  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00EECC  2  C9 93              CMP   #TK_ON
00EECE  2  F0 07              BEQ   @m_loop_on
00EED0  2  C9 CB              CMP   #TK_OFF
00EED2  2  F0 0E              BEQ   @m_loop_off
00EED4  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EED7  2               @m_loop_on
00EED7  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00EEDA  2  A9 01              LDA   #$01
00EEDC  2  8D A4 B9           STA   FIO_SRCL
00EEDF  2  4C EA EE           JMP   @m_loop_go
00EEE2  2               @m_loop_off
00EEE2  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00EEE5  2  A9 00              LDA   #$00
00EEE7  2  8D A4 B9           STA   FIO_SRCL
00EEEA  2               @m_loop_go
00EEEA  2  A9 11              LDA   #FIO_CMD_MLOOP
00EEEC  2  8D A0 B9           STA   FIO_CMD
00EEEF  2  60                 RTS
00EEF0  2               
00EEF0  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00EEF0  2               @m_priority
00EEF0  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00EEF0  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00EEF0  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00EEF0  2               @m_pri_skip
00EEF0  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00EEF3  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00EEF5  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00EEF7  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00EEF7  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00EEF7  2                     ; Clear all 6 voice slots
00EEF7  2  A9 00              LDA   #$00
00EEF9  2  A0 05              LDY   #$05
00EEFB  2               @m_pri_clr
00EEFB  2  99 A4 B9           STA   FIO_SRCL,Y
00EEFE  2  88                 DEY
00EEFF  2  10 FA              BPL   @m_pri_clr
00EF01  2                     ; Parse up to 6 comma-separated voice values
00EF01  2  A0 00              LDY   #$00              ; slot index
00EF03  2               @m_pri_nxt
00EF03  2  20 6B D8           JSR   LAB_GTBY          ; get voice number → X
00EF06  2  8A                 TXA
00EF07  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00EF0A  2  C8                 INY
00EF0B  2  C0 06              CPY   #$06
00EF0D  2  B0 0D              BCS   @m_pri_go         ; all 6 parsed
00EF0F  2  20 C2 00           JSR   LAB_GBYT          ; peek next char
00EF12  2  C9 2C              CMP   #','
00EF14  2  D0 06              BNE   @m_pri_go         ; no more commas
00EF16  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00EF19  2  4C 03 EF           JMP   @m_pri_nxt
00EF1C  2               @m_pri_go
00EF1C  2  A9 12              LDA   #FIO_CMD_MPRI
00EF1E  2  8D A0 B9           STA   FIO_CMD
00EF21  2  60                 RTS
00EF22  2               
00EF22  2               ; --- MUSIC voice, "mml" ---
00EF22  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00EF22  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
00EF22  2               @m_seq
00EF22  2  20 6B D8           JSR   LAB_GTBY          ; voice number (1-14) → X
00EF25  2  8E A4 B9           STX   FIO_SRCL          ; store voice
00EF28  2  20 90 CD           JSR   LAB_1C01          ; comma
00EF2B  2  20 6C CC           JSR   LAB_EVEX          ; evaluate expression
00EF2E  2  20 08 D7           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00EF31  2  AA                 TAX
00EF32  2  F0 1A              BEQ   @m_seq_err        ; empty string = error
00EF34  2  8E A3 B9           STX   FIO_NAMELEN       ; string length (1-255)
00EF37  2  A5 71              LDA   ut1_pl
00EF39  2  8D A6 B9           STA   FIO_ENDL          ; string pointer low
00EF3C  2  A5 72              LDA   ut1_ph
00EF3E  2  8D A7 B9           STA   FIO_ENDH          ; string pointer high
00EF41  2  A9 0D              LDA   #FIO_CMD_MSEQ
00EF43  2  8D A0 B9           STA   FIO_CMD
00EF46  2  AD A1 B9           LDA   FIO_STATUS
00EF49  2  C9 02              CMP   #FIO_OK
00EF4B  2  D0 01              BNE   @m_seq_err
00EF4D  2  60                 RTS
00EF4E  2               @m_seq_err
00EF4E  2  4C 8D F4           JMP   LAB_FIO_ERRIO
00EF51  2               
00EF51  2               ; perform COPPER subcommand
00EF51  2               ; COPPER ADD x, y, reg, value
00EF51  2               ; COPPER CLEAR | ON | OFF
00EF51  2               
00EF51  2               LAB_COPPER
00EF51  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte
00EF54  2  C9 A2              CMP   #TK_CLEAR
00EF56  2  F0 17              BEQ   @c_clear
00EF58  2  C9 93              CMP   #TK_ON
00EF5A  2  F0 1C              BEQ   @c_on
00EF5C  2  C9 CB              CMP   #TK_OFF
00EF5E  2  F0 21              BEQ   @c_off
00EF60  2  C9 41              CMP   #'A'
00EF62  2  F0 56              BEQ   @c_add
00EF64  2  C9 A1              CMP   #TK_LIST
00EF66  2  F0 22              BEQ   @c_list
00EF68  2  C9 55              CMP   #'U'
00EF6A  2  F0 3D              BEQ   @c_use
00EF6C  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EF6F  2               
00EF6F  2               ; --- COPPER CLEAR ---
00EF6F  2               @c_clear
00EF6F  2  20 BC 00           JSR   LAB_IGBY          ; consume CLEAR token
00EF72  2  A9 1C              LDA   #VCMD_COPPERCLR
00EF74  2  8D 10 A0           STA   VGC_CMD
00EF77  2  60                 RTS
00EF78  2               
00EF78  2               ; --- COPPER ON ---
00EF78  2               @c_on
00EF78  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00EF7B  2  A9 1D              LDA   #VCMD_COPPERENA
00EF7D  2  8D 10 A0           STA   VGC_CMD
00EF80  2  60                 RTS
00EF81  2               
00EF81  2               ; --- COPPER OFF ---
00EF81  2               @c_off
00EF81  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00EF84  2  A9 1E              LDA   #VCMD_COPPERDIS
00EF86  2  8D 10 A0           STA   VGC_CMD
00EF89  2  60                 RTS
00EF8A  2               
00EF8A  2               ; --- COPPER LIST n / COPPER LIST END ---
00EF8A  2               @c_list
00EF8A  2  20 BC 00           JSR   LAB_IGBY          ; consume LIST token
00EF8D  2  20 C2 00           JSR   LAB_GBYT          ; peek next
00EF90  2  C9 80              CMP   #TK_END
00EF92  2  F0 0C              BEQ   @c_list_end
00EF94  2                     ; LIST n — parse list index
00EF94  2  20 6B D8           JSR   LAB_GTBY          ; 8-bit → X
00EF97  2  8E 11 A0           STX   VGC_P0             ; list index
00EF9A  2  A9 20              LDA   #VCMD_COPPERLIST
00EF9C  2  8D 10 A0           STA   VGC_CMD
00EF9F  2  60                 RTS
00EFA0  2               
00EFA0  2               @c_list_end
00EFA0  2  20 BC 00           JSR   LAB_IGBY          ; consume END token
00EFA3  2  A9 22              LDA   #VCMD_COPPEREND
00EFA5  2  8D 10 A0           STA   VGC_CMD
00EFA8  2  60                 RTS
00EFA9  2               
00EFA9  2               ; --- COPPER USE n ---
00EFA9  2               @c_use
00EFA9  2  A2 03              LDX   #3
00EFAB  2  20 75 EE           JSR   LAB_SKIPX          ; USE
00EFAE  2  20 6B D8           JSR   LAB_GTBY          ; list index → X
00EFB1  2  8E 11 A0           STX   VGC_P0
00EFB4  2  A9 21              LDA   #VCMD_COPPERUSE
00EFB6  2  8D 10 A0           STA   VGC_CMD
00EFB9  2  60                 RTS
00EFBA  2               
00EFBA  2               ; --- COPPER ADD x, y, reg, value ---
00EFBA  2               @c_add
00EFBA  2  A2 03              LDX   #3
00EFBC  2  20 75 EE           JSR   LAB_SKIPX          ; ADD
00EFBF  2  20 59 D8           JSR   LAB_GTWRD         ; x (16-bit) → FAC1_3(lo), FAC1_2(hi)
00EFC2  2  A5 AF              LDA   FAC1_3
00EFC4  2  8D 11 A0           STA   VGC_P0             ; x low
00EFC7  2  A5 AE              LDA   FAC1_2
00EFC9  2  8D 12 A0           STA   VGC_P1             ; x high
00EFCC  2  20 90 CD           JSR   LAB_1C01          ; comma
00EFCF  2  20 6B D8           JSR   LAB_GTBY          ; y (8-bit) → X
00EFD2  2  8E 13 A0           STX   VGC_P2             ; y
00EFD5  2  20 90 CD           JSR   LAB_1C01          ; comma
00EFD8  2                     ; parse register name: BGCOL, MODE, SCROLLX, SCROLLY,
00EFD8  2                     ; SPRX(n), SPRXH(n), SPRY(n), SPRYH(n), SPRSHAPE(n), SPRFLAGS(n), SPRPRI(n)
00EFD8  2  20 C2 00           JSR   LAB_GBYT          ; peek
00EFDB  2  C9 42              CMP   #'B'
00EFDD  2  F0 0B              BEQ   @c_bgcol
00EFDF  2  C9 B5              CMP   #TK_GMODE
00EFE1  2  F0 11              BEQ   @c_mode
00EFE3  2  C9 53              CMP   #'S'
00EFE5  2  F0 15              BEQ   @c_s_dispatch
00EFE7  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00EFEA  2               
00EFEA  2               @c_bgcol
00EFEA  2  A2 05              LDX   #5
00EFEC  2  20 75 EE           JSR   LAB_SKIPX          ; BGCOL
00EFEF  2  A9 01              LDA   #$01              ; reg index 1 = BGCOL
00EFF1  2  4C 30 F0           JMP   @c_store_idx
00EFF4  2               
00EFF4  2               @c_mode
00EFF4  2  20 BC 00           JSR   LAB_IGBY          ; consume MODE token
00EFF7  2  A9 00              LDA   #$00              ; reg index 0 = MODE
00EFF9  2  4C 30 F0           JMP   @c_store_idx
00EFFC  2               
00EFFC  2               @c_s_dispatch
00EFFC  2  20 BC 00           JSR   LAB_IGBY          ; consume S
00EFFF  2  20 C2 00           JSR   LAB_GBYT          ; peek next: C=scroll, P=sprite
00F002  2  C9 43              CMP   #'C'
00F004  2  F0 07              BEQ   @c_scroll
00F006  2  C9 50              CMP   #'P'
00F008  2  F0 31              BEQ   @c_spr
00F00A  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00F00D  2               
00F00D  2               @c_scroll
00F00D  2  A2 05              LDX   #5
00F00F  2  20 75 EE           JSR   LAB_SKIPX          ; CROLL
00F012  2  20 C2 00           JSR   LAB_GBYT          ; peek X or Y
00F015  2  C9 58              CMP   #'X'
00F017  2  F0 07              BEQ   @c_scrollx
00F019  2  C9 59              CMP   #'Y'
00F01B  2  F0 0B              BEQ   @c_scrolly
00F01D  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00F020  2               
00F020  2               @c_scrollx
00F020  2  20 BC 00           JSR   LAB_IGBY          ; consume X
00F023  2  A9 05              LDA   #$05              ; reg index 5 = SCROLLX
00F025  2  4C 30 F0           JMP   @c_store_idx
00F028  2               
00F028  2               @c_scrolly
00F028  2  20 BC 00           JSR   LAB_IGBY          ; consume Y
00F02B  2  A9 06              LDA   #$06              ; reg index 6 = SCROLLY
00F02D  2  4C 30 F0           JMP   @c_store_idx
00F030  2               
00F030  2               @c_store_idx
00F030  2  8D 14 A0           STA   VGC_P3             ; register index (low byte)
00F033  2  A9 00              LDA   #$00
00F035  2  8D 15 A0           STA   VGC_P4             ; high byte = 0
00F038  2  4C CD F0           JMP   @c_store_val
00F03B  2               
00F03B  2                     ; --- Sprite register names: SPR + field + (n) ---
00F03B  2                     ; SPRX(n)=$A040+n*8+0, SPRXH(n)=+1, SPRY(n)=+2, SPRYH(n)=+3,
00F03B  2                     ; SPRSHAPE(n)=+4, SPRFLAGS(n)=+5, SPRPRI(n)=+6
00F03B  2               @c_spr
00F03B  2  20 BC 00           JSR   LAB_IGBY          ; consume P
00F03E  2  20 BC 00           JSR   LAB_IGBY          ; consume R
00F041  2  20 C2 00           JSR   LAB_GBYT          ; peek field start: X, Y, S, F, P
00F044  2  C9 58              CMP   #'X'
00F046  2  F0 13              BEQ   @cs_x
00F048  2  C9 59              CMP   #'Y'
00F04A  2  F0 26              BEQ   @cs_y
00F04C  2  C9 53              CMP   #'S'
00F04E  2  F0 39              BEQ   @cs_shape
00F050  2  C9 46              CMP   #'F'
00F052  2  F0 3F              BEQ   @cs_flags
00F054  2  C9 50              CMP   #'P'
00F056  2  F0 45              BEQ   @cs_pri
00F058  2  4C 7B C5           JMP   LAB_15D9          ; syntax error
00F05B  2               
00F05B  2               @cs_x
00F05B  2  20 BC 00           JSR   LAB_IGBY          ; consume X
00F05E  2  20 C2 00           JSR   LAB_GBYT          ; peek: H or (
00F061  2  C9 48              CMP   #'H'
00F063  2  F0 05              BEQ   @cs_xh
00F065  2  A9 00              LDA   #$00              ; field offset 0 = X low
00F067  2  4C A4 F0           JMP   @c_spr_idx
00F06A  2               
00F06A  2               @cs_xh
00F06A  2  20 BC 00           JSR   LAB_IGBY          ; consume H
00F06D  2  A9 01              LDA   #$01              ; field offset 1 = X high
00F06F  2  4C A4 F0           JMP   @c_spr_idx
00F072  2               
00F072  2               @cs_y
00F072  2  20 BC 00           JSR   LAB_IGBY          ; consume Y
00F075  2  20 C2 00           JSR   LAB_GBYT          ; peek: H or (
00F078  2  C9 48              CMP   #'H'
00F07A  2  F0 05              BEQ   @cs_yh
00F07C  2  A9 02              LDA   #$02              ; field offset 2 = Y low
00F07E  2  4C A4 F0           JMP   @c_spr_idx
00F081  2               
00F081  2               @cs_yh
00F081  2  20 BC 00           JSR   LAB_IGBY          ; consume H
00F084  2  A9 03              LDA   #$03              ; field offset 3 = Y high
00F086  2  4C A4 F0           JMP   @c_spr_idx
00F089  2               
00F089  2               @cs_shape
00F089  2  A2 05              LDX   #5
00F08B  2  20 75 EE           JSR   LAB_SKIPX          ; SHAPE
00F08E  2  A9 04              LDA   #$04              ; field offset 4 = Shape
00F090  2  4C A4 F0           JMP   @c_spr_idx
00F093  2               
00F093  2               @cs_flags
00F093  2  A2 05              LDX   #5
00F095  2  20 75 EE           JSR   LAB_SKIPX          ; FLAGS
00F098  2  A9 05              LDA   #$05              ; field offset 5 = Flags
00F09A  2  4C A4 F0           JMP   @c_spr_idx
00F09D  2               
00F09D  2               @cs_pri
00F09D  2  A2 03              LDX   #3
00F09F  2  20 75 EE           JSR   LAB_SKIPX          ; PRI
00F0A2  2  A9 06              LDA   #$06              ; field offset 6 = Priority
00F0A4  2                     ; fall through to @c_spr_idx
00F0A4  2               
00F0A4  2                     ; A = field offset, now parse (n) and compute address $A040 + n*8 + A
00F0A4  2               @c_spr_idx
00F0A4  2  48                 PHA                     ; save field offset
00F0A5  2  20 BC 00           JSR   LAB_IGBY          ; consume '('
00F0A8  2  20 6B D8           JSR   LAB_GTBY          ; sprite index (0-15) → X
00F0AB  2  E0 10              CPX   #$10
00F0AD  2  90 03              BCC   @cs_idx_ok
00F0AF  2  4C 7B C5           JMP   LAB_15D9          ; syntax error if n > 15
00F0B2  2               @cs_idx_ok
00F0B2  2  20 BC 00           JSR   LAB_IGBY          ; consume ')'
00F0B5  2                     ; compute address: $A040 + X*8 + field
00F0B5  2  8A                 TXA                     ; A = sprite index
00F0B6  2  0A                 ASL                     ; *2
00F0B7  2  0A                 ASL                     ; *4
00F0B8  2  0A                 ASL                     ; *8
00F0B9  2  8D 14 A0           STA   VGC_P3             ; temp = n*8
00F0BC  2  68                 PLA                     ; A = field offset
00F0BD  2  18                 CLC
00F0BE  2  6D 14 A0           ADC   VGC_P3             ; A = n*8 + field
00F0C1  2  69 40              ADC   #$40              ; A = n*8 + field + $40 (low byte of $A040)
00F0C3  2  8D 14 A0           STA   VGC_P3             ; P3 = address low byte
00F0C6  2  A9 A0              LDA   #$A0              ; high byte of $A040
00F0C8  2  69 00              ADC   #$00              ; add carry if low byte wrapped
00F0CA  2  8D 15 A0           STA   VGC_P4             ; P4 = address high byte
00F0CD  2               
00F0CD  2               @c_store_val
00F0CD  2  20 90 CD           JSR   LAB_1C01          ; comma
00F0D0  2  20 6B D8           JSR   LAB_GTBY          ; value (8-bit) → X
00F0D3  2  8E 16 A0           STX   VGC_P5             ; value
00F0D6  2  A9 1B              LDA   #VCMD_COPPERADD
00F0D8  2  8D 10 A0           STA   VGC_CMD            ; trigger
00F0DB  2  60                 RTS
00F0DC  2               
00F0DC  2               ; perform RESET — full system reset (VGC, SID, music) + cold start BASIC
00F0DC  2               
00F0DC  2               LAB_RESET
00F0DC  2  A9 1F              LDA   #VCMD_SYSRESET
00F0DE  2  8D 10 A0           STA   VGC_CMD            ; trigger hardware reset
00F0E1  2  6C FC FF           JMP   ($FFFC)            ; jump through reset vector
00F0E4  2               
00F0E4  2               ; --- NIC BASIC keyword handlers ---
00F0E4  2               
00F0E4  2               ; NOPEN slot,"host",port — connect slot to remote host
00F0E4  2               LAB_NOPEN
00F0E4  2  20 6B D8           JSR   LAB_GTBY          ; slot → X
00F0E7  2  8E 02 A1           STX   NIC_SLOT
00F0EA  2  20 90 CD           JSR   LAB_1C01          ; comma
00F0ED  2  20 6C CC           JSR   LAB_EVEX          ; evaluate string expression
00F0F0  2  20 08 D7           JSR   LAB_EVST          ; pop: A=len, ut1_pl/ph=ptr
00F0F3  2  AA                 TAX                     ; len → X
00F0F4  2  F0 2A              BEQ   @nopen_err        ; empty hostname = error
00F0F6  2  E0 20              CPX   #32
00F0F8  2  B0 26              BCS   @nopen_err        ; too long
00F0FA  2  A0 00              LDY   #$00
00F0FC  2               @nopen_cp
00F0FC  2  B1 71              LDA   (ut1_pl),Y
00F0FE  2  99 20 A1           STA   NIC_NAMEBUF,Y
00F101  2  C8                 INY
00F102  2  CA                 DEX
00F103  2  D0 F7              BNE   @nopen_cp
00F105  2  A9 00              LDA   #$00
00F107  2  99 20 A1           STA   NIC_NAMEBUF,Y     ; null-terminate
00F10A  2  20 90 CD           JSR   LAB_1C01          ; comma
00F10D  2  20 59 D8           JSR   LAB_GTWRD         ; port → FAC1_3/FAC1_2
00F110  2  A5 AF              LDA   FAC1_3
00F112  2  8D 08 A1           STA   NIC_RPORTL
00F115  2  A5 AE              LDA   FAC1_2
00F117  2  8D 09 A1           STA   NIC_RPORTH
00F11A  2  A9 01              LDA   #NIC_CMD_CONNECT
00F11C  2  8D 00 A1           STA   NIC_CMD
00F11F  2  60                 RTS
00F120  2               @nopen_err
00F120  2  4C F0 D2           JMP   LAB_FCER          ; function call error
00F123  2               
00F123  2               ; NCLOSE slot — disconnect slot
00F123  2               LAB_NCLOSE
