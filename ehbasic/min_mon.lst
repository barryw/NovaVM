00F057  2               
00F057  2               ; perform MUSIC subcommand
00F057  2               ; MUSIC voice, "mml"
00F057  2               ; MUSIC PLAY | STOP | TEMPO bpm | LOOP ON|OFF | PRIORITY v1[,v2[,v3]]
00F057  2               
00F057  2               LAB_MUSIC
00F057  2  20 C2 00           JSR   LAB_GBYT          ; peek next byte (after MUSIC token consumed)
00F05A  2  C9 50              CMP   #'P'
00F05C  2  F0 0F              BEQ   @m_chk_p
00F05E  2  C9 92              CMP   #TK_STOP           ; STOP is tokenized by BASIC
00F060  2  F0 1A              BEQ   @m_stop_tok
00F062  2  C9 54              CMP   #'T'
00F064  2  F0 1C              BEQ   @m_tempo
00F066  2  C9 9E              CMP   #TK_LOOP           ; LOOP is tokenized by BASIC
00F068  2  F0 2D              BEQ   @m_loop_tok
00F06A  2                     ; Not a subcommand — must be a number (voice 1-6)
00F06A  2  4C E9 F0           JMP   @m_seq
00F06D  2               
00F06D  2               ; --- MUSIC PLAY or PRIORITY ---
00F06D  2               @m_chk_p
00F06D  2                     ; Consume P, then check next char to distinguish PLAY vs PRIORITY
00F06D  2  20 BC 00           JSR   LAB_IGBY          ; consume P, A = next char
00F070  2  C9 52              CMP   #'R'              ; PRIORITY has R after P
00F072  2  F0 47              BEQ   @m_priority
00F074  2                     ; else PLAY — consume remaining "LAY" (3 chars, P already consumed)
00F074  2  A2 03              LDX   #3
00F076  2  20 50 F0           JSR   LAB_SKIPX          ; LAY
00F079  2  4C CB ED           JMP   audio_music_play
00F07C  2               
00F07C  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00F07C  2               @m_stop_tok
00F07C  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00F07F  2  4C D4 ED           JMP   audio_music_stop
00F082  2               
00F082  2               ; --- MUSIC TEMPO bpm ---
00F082  2               @m_tempo
00F082  2  A2 05              LDX   #5
00F084  2  20 50 F0           JSR   LAB_SKIPX          ; TEMPO
00F087  2  20 90 D8           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00F08A  2  A5 AF              LDA   FAC1_3
00F08C  2  8D A4 B9           STA   FIO_SRCL
00F08F  2  A5 AE              LDA   FAC1_2
00F091  2  8D A5 B9           STA   FIO_SRCH
00F094  2  4C D9 ED           JMP   audio_music_tempo
00F097  2               
00F097  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00F097  2               @m_loop_tok
00F097  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00F09A  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00F09D  2  C9 93              CMP   #TK_ON
00F09F  2  F0 07              BEQ   @m_loop_on
00F0A1  2  C9 CB              CMP   #TK_OFF
00F0A3  2  F0 0D              BEQ   @m_loop_off
00F0A5  2  4C DE C5           JMP   LAB_15D9          ; syntax error
00F0A8  2               @m_loop_on
00F0A8  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00F0AB  2  A9 01              LDA   #$01
00F0AD  2  8D A4 B9           STA   FIO_SRCL
00F0B0  2  80 06              BRA   @m_loop_go
00F0B2  2               @m_loop_off
00F0B2  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00F0B5  2  9C A4 B9           STZ   FIO_SRCL
00F0B8  2               @m_loop_go
00F0B8  2  4C DE ED           JMP   audio_music_loop
00F0BB  2               
00F0BB  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00F0BB  2               @m_priority
00F0BB  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00F0BB  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00F0BB  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00F0BB  2               @m_pri_skip
00F0BB  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00F0BE  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00F0C0  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00F0C2  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00F0C2  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00F0C2  2                     ; Clear all 6 voice slots
00F0C2  2  A9 00              LDA   #$00
00F0C4  2  A0 05              LDY   #$05
00F0C6  2               @m_pri_clr
00F0C6  2  99 A4 B9           STA   FIO_SRCL,Y
00F0C9  2  88                 DEY
00F0CA  2  10 FA              BPL   @m_pri_clr
00F0CC  2                     ; Parse up to 6 comma-separated voice values
00F0CC  2  A0 00              LDY   #$00              ; slot index
00F0CE  2               @m_pri_nxt
00F0CE  2  20 A2 D8           JSR   LAB_GTBY          ; get voice number → X
00F0D1  2  8A                 TXA
00F0D2  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00F0D5  2  C8                 INY
00F0D6  2  C0 06              CPY   #$06
00F0D8  2  B0 0C              BCS   @m_pri_go         ; all 6 parsed
00F0DA  2  20 C2 00           JSR   LAB_GBYT          ; peek next char
00F0DD  2  C9 2C              CMP   #','
00F0DF  2  D0 05              BNE   @m_pri_go         ; no more commas
00F0E1  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00F0E4  2  80 E8              BRA   @m_pri_nxt
00F0E6  2               @m_pri_go
00F0E6  2  4C E3 ED           JMP   audio_music_priority
00F0E9  2               
00F0E9  2               ; --- MUSIC voice, "mml" ---
00F0E9  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00F0E9  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
00F0E9  2               @m_seq
00F0E9  2  20 A2 D8           JSR   LAB_GTBY          ; voice number (1-14) → X
00F0EC  2  8E A5 B9           STX   AUDIO_VOICE       ; store voice
00F0EF  2  20 FA CD           JSR   LAB_1C01          ; comma
00F0F2  2  20 D9 CC           JSR   LAB_EVEX          ; evaluate expression
00F0F5  2  20 41 D7           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00F0F8  2  AA                 TAX
00F0F9  2  F0 13              BEQ   @m_seq_err        ; empty string = error
00F0FB  2  8E A3 B9           STX   AUDIO_STRLEN      ; string length (1-255)
00F0FE  2  A5 71              LDA   ut1_pl
00F100  2  8D A6 B9           STA   AUDIO_STRL        ; string pointer low
00F103  2  A5 72              LDA   ut1_ph
00F105  2  8D A7 B9           STA   AUDIO_STRH        ; string pointer high
00F108  2  20 C6 ED           JSR   audio_music_sequence
00F10B  2  D0 01              BNE   @m_seq_err
00F10D  2  60                 RTS
00F10E  2               @m_seq_err
00F10E  2  4C 12 F2           JMP   LAB_FIO_ERRIO
00F111  2               
00F111  2               ; perform COPPER subcommand — full handler relocated to extension ROM.
00F111  2               ; Saves ~390 bytes in BASIC ROM. EXT_COPPER in extension.s parses raw
00F111  2               ; BASIC text via (Bpntrl),Y and uses RAM bridges (EXT_GTBY, EXT_GTWRD,
00F111  2               ; EXT_SNERR) to reach BASIC's numeric expression evaluator and syntax
00F111  2               ; error path.
00F111  2               
00F111  2               LAB_COPPER
00F111  2  A9 0C              LDA   #EXT_CMD_COPPER
00F113  2  4C 21 02           JMP   EXT_vec
00F116  2               
00F116  2               ; perform RESET — full system reset (VGC, SID, music) + cold start BASIC
00F116  2               
00F116  2               LAB_RESET
00F116  2  A9 1F              LDA   #VCMD_SYSRESET
00F118  2  8D 10 A0           STA   VGC_CMD            ; trigger hardware reset
00F11B  2  6C FC FF           JMP   ($FFFC)            ; jump through reset vector
00F11E  2               
00F11E  2               ; --- NIC BASIC keyword handlers ---
00F11E  2               
00F11E  2               ; NOPEN slot,"host",port — connect slot to remote host
00F11E  2               LAB_NOPEN
00F11E  2  20 A2 D8           JSR   LAB_GTBY          ; slot → X
00F121  2  8E 02 A1           STX   NIC_SLOT
00F124  2  20 FA CD           JSR   LAB_1C01          ; comma
00F127  2  20 D9 CC           JSR   LAB_EVEX          ; evaluate string expression
00F12A  2  20 41 D7           JSR   LAB_EVST          ; pop: A=len, ut1_pl/ph=ptr
00F12D  2  85 20              STA   NIC_ARG_NAMELEN
00F12F  2  A5 71              LDA   ut1_pl
00F131  2  85 21              STA   NIC_ARG_NAMEPTR_L
00F133  2  A5 72              LDA   ut1_ph
00F135  2  85 22              STA   NIC_ARG_NAMEPTR_H
00F137  2  20 32 EE           JSR   nic_copy_name
00F13A  2  D0 13              BNE   @nopen_err
00F13C  2  20 FA CD           JSR   LAB_1C01          ; comma
00F13F  2  20 90 D8           JSR   LAB_GTWRD         ; port → FAC1_3/FAC1_2
00F142  2  A5 AF              LDA   FAC1_3
00F144  2  8D 08 A1           STA   NIC_RPORTL
00F147  2  A5 AE              LDA   FAC1_2
00F149  2  8D 09 A1           STA   NIC_RPORTH
00F14C  2  4C 0C EE           JMP   nic_connect
00F14F  2               @nopen_err
00F14F  2  4C 2B D3           JMP   LAB_FCER          ; function call error
00F152  2               
00F152  2               ; NCLOSE slot — disconnect slot
00F152  2               LAB_NCLOSE
00F152  2  20 A2 D8           JSR   LAB_GTBY          ; slot → X
00F155  2  8E 02 A1           STX   NIC_SLOT
00F158  2  4C 10 EE           JMP   nic_disconnect
00F15B  2               
00F15B  2               ; NSEND slot,A$ — send string via NIC
00F15B  2               LAB_NSEND
00F15B  2  20 A2 D8           JSR   LAB_GTBY          ; slot → X
00F15E  2  8E 02 A1           STX   NIC_SLOT
00F161  2  20 FA CD           JSR   LAB_1C01          ; comma
00F164  2  20 D9 CC           JSR   LAB_EVEX          ; evaluate expression
00F167  2  20 41 D7           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00F16A  2  AA                 TAX
00F16B  2  F0 10              BEQ   @nsend_err        ; empty string
00F16D  2                     ; Point DMA at string in BASIC memory
00F16D  2  A5 71              LDA   ut1_pl
00F16F  2  8D 10 A1           STA   NIC_DMAL
00F172  2  A5 72              LDA   ut1_ph
00F174  2  8D 11 A1           STA   NIC_DMAH
00F177  2  8E 12 A1           STX   NIC_DMALEN        ; length
00F17A  2  4C 14 EE           JMP   nic_send
00F17D  2               @nsend_err
00F17D  2  4C 2B D3           JMP   LAB_FCER
00F180  2               
00F180  2               ; DMACOPY srcSpace,srcAddr,dstSpace,dstAddr,len
00F180  2               ; Address arguments are 16-bit offsets. For XRAM space (5), current XBANK
00F180  2               ; is used as the high address byte.
00F180  2               LAB_DMACOPY
00F180  2  A9 0F              LDA   #EXT_CMD_DMACOPY
00F182  2  4C 08 F0           JMP   LAB_EXT_FCER
00F185  2               
00F185  2               ; DMAFILL dstSpace,dstAddr,len,value
00F185  2               ; Address argument is a 16-bit offset. For XRAM space (5), current XBANK
00F185  2               ; is used as the high address byte.
00F185  2               LAB_DMAFILL
00F185  2  A9 09              LDA   #EXT_CMD_DMAFILL
00F187  2  4C 08 F0           JMP   LAB_EXT_FCER
00F18A  2               
00F18A  2               ; BLITCOPY srcSpace,srcAddr,srcStride,dstSpace,dstAddr,dstStride,width,height
00F18A  2               ; Address arguments are 16-bit offsets. For XRAM space (5), current XBANK
00F18A  2               ; is used as the high address byte.
00F18A  2               LAB_BLITCOPY
