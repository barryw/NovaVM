00EB0E  2  0A                 ASL                     ; *4
00EB0F  2  0A                 ASL                     ; *8
00EB10  2  AA                 TAX                     ; X = sprite * 8
00EB11  2  BC 42 A0           LDY   $A042,X           ; Y = Y position low byte
00EB14  2  BD 43 A0           LDA   $A043,X           ; A = Y position high byte
00EB17  2  4C B3 D3           JMP   LAB_AYFC          ; return AY as signed integer
00EB1A  2               
00EB1A  2               ; perform COLLISION(n) — return sprite-sprite collision register
00EB1A  2               ; argument already consumed by preprocessor
