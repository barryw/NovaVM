00EDAA  2  20 C2 00           JSR   LAB_GBYT          ; peek next
00EDAD  2  C9 80              CMP   #TK_END
00EDAF  2  F0 0C              BEQ   @c_list_end
00EDB1  2                     ; LIST n — parse list index
