00F0D2  2  20 BC 00           JSR   LAB_IGBY          ; consume P, A = next char
00F0D5  2  C9 52              CMP   #'R'              ; PRIORITY has R after P
00F0D7  2  F0 51              BEQ   @m_priority
00F0D9  2                     ; else PLAY — consume remaining "LAY" (3 chars, P already consumed)
00F0D9  2  A2 03              LDX   #3
00F0DB  2  20 B5 F0           JSR   LAB_SKIPX          ; LAY
00F0DE  2  A9 0E              LDA   #FIO_CMD_MPLAY
00F0E0  2  8D A0 B9           STA   FIO_CMD
00F0E3  2  58                 CLI                     ; enable interrupts for music
00F0E4  2  60                 RTS
00F0E5  2               
00F0E5  2               ; --- MUSIC STOP (TK_STOP is a single token byte) ---
00F0E5  2               @m_stop_tok
00F0E5  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_STOP token
00F0E8  2  A9 0F              LDA   #FIO_CMD_MSTOP
00F0EA  2  4C 1C EE           JMP   LAB_FIO_CMD_RTS
00F0ED  2               
00F0ED  2               ; --- MUSIC TEMPO bpm ---
00F0ED  2               @m_tempo
00F0ED  2  A2 05              LDX   #5
00F0EF  2  20 B5 F0           JSR   LAB_SKIPX          ; TEMPO
00F0F2  2  20 FD D8           JSR   LAB_GTWRD         ; bpm as 16-bit → FAC1_3(lo), FAC1_2(hi)
00F0F5  2  A5 AF              LDA   FAC1_3
00F0F7  2  8D A4 B9           STA   FIO_SRCL
00F0FA  2  A5 AE              LDA   FAC1_2
00F0FC  2  8D A5 B9           STA   FIO_SRCH
00F0FF  2  A9 10              LDA   #FIO_CMD_MTEMPO
00F101  2  4C 1C EE           JMP   LAB_FIO_CMD_RTS
00F104  2               
00F104  2               ; --- MUSIC LOOP ON|OFF (TK_LOOP is a single token byte) ---
00F104  2               @m_loop_tok
00F104  2  20 BC 00           JSR   LAB_IGBY          ; consume TK_LOOP token
00F107  2  20 C2 00           JSR   LAB_GBYT          ; skip spaces, get TK_ON or TK_OFF
00F10A  2  C9 93              CMP   #TK_ON
00F10C  2  F0 07              BEQ   @m_loop_on
00F10E  2  C9 CB              CMP   #TK_OFF
00F110  2  F0 0D              BEQ   @m_loop_off
00F112  2  4C C0 C5           JMP   LAB_15D9          ; syntax error
00F115  2               @m_loop_on
00F115  2  20 BC 00           JSR   LAB_IGBY          ; consume ON token
00F118  2  A9 01              LDA   #$01
00F11A  2  8D A4 B9           STA   FIO_SRCL
00F11D  2  80 06              BRA   @m_loop_go
00F11F  2               @m_loop_off
00F11F  2  20 BC 00           JSR   LAB_IGBY          ; consume OFF token
00F122  2  9C A4 B9           STZ   FIO_SRCL
00F125  2               @m_loop_go
00F125  2  A9 11              LDA   #FIO_CMD_MLOOP
00F127  2  4C 1C EE           JMP   LAB_FIO_CMD_RTS
00F12A  2               
00F12A  2               ; --- MUSIC PRIORITY v1[,v2[,v3[,v4[,v5[,v6]]]]] ---
00F12A  2               @m_priority
00F12A  2                     ; P already consumed by @m_chk_p.  Skip remaining keyword bytes.
00F12A  2                     ; "RIORITY" is tokenized as R,I,TK_OR,I,T,Y (OR becomes a token),
00F12A  2                     ; so we scan dynamically instead of using a fixed IGBY count.
00F12A  2               @m_pri_skip
00F12A  2  20 BC 00           JSR   LAB_IGBY          ; advance past current byte
00F12D  2  C9 41              CMP   #'A'              ; letters ($41-$5A) and tokens ($80+) are >= 'A'
00F12F  2  B0 F9              BCS   @m_pri_skip       ; keep skipping keyword chars and tokens
00F131  2                     ; A < 'A': hit a space or digit — keyword is consumed.
00F131  2                     ; pointer is at the space/digit; LAB_GTBY calls GBYT which skips spaces.
00F131  2                     ; Clear all 6 voice slots
00F131  2  A9 00              LDA   #$00
00F133  2  A0 05              LDY   #$05
00F135  2               @m_pri_clr
00F135  2  99 A4 B9           STA   FIO_SRCL,Y
00F138  2  88                 DEY
00F139  2  10 FA              BPL   @m_pri_clr
00F13B  2                     ; Parse up to 6 comma-separated voice values
00F13B  2  A0 00              LDY   #$00              ; slot index
00F13D  2               @m_pri_nxt
00F13D  2  20 0F D9           JSR   LAB_GTBY          ; get voice number → X
00F140  2  8A                 TXA
00F141  2  99 A4 B9           STA   FIO_SRCL,Y        ; store to slot
00F144  2  C8                 INY
00F145  2  C0 06              CPY   #$06
00F147  2  B0 0C              BCS   @m_pri_go         ; all 6 parsed
00F149  2  20 C2 00           JSR   LAB_GBYT          ; peek next char
00F14C  2  C9 2C              CMP   #','
00F14E  2  D0 05              BNE   @m_pri_go         ; no more commas
00F150  2  20 BC 00           JSR   LAB_IGBY          ; skip comma
00F153  2  80 E8              BRA   @m_pri_nxt
00F155  2               @m_pri_go
00F155  2  A9 12              LDA   #FIO_CMD_MPRI
00F157  2  4C 1C EE           JMP   LAB_FIO_CMD_RTS
00F15A  2               
00F15A  2               ; --- MUSIC voice, "mml" ---
00F15A  2               ; Pass string via pointer (ut1_pl/ph) so MML strings can exceed 63 bytes.
00F15A  2               ; FIO_SRCL = voice, FIO_ENDL/ENDH = string pointer, FIO_NAMELEN = length.
00F15A  2               @m_seq
00F15A  2  20 0F D9           JSR   LAB_GTBY          ; voice number (1-14) → X
00F15D  2  8E A4 B9           STX   FIO_SRCL          ; store voice
00F160  2  20 D8 CD           JSR   LAB_1C01          ; comma
00F163  2  20 B7 CC           JSR   LAB_EVEX          ; evaluate expression
00F166  2  20 AE D7           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00F169  2  AA                 TAX
00F16A  2  F0 1A              BEQ   @m_seq_err        ; empty string = error
00F16C  2  8E A3 B9           STX   FIO_NAMELEN       ; string length (1-255)
00F16F  2  A5 71              LDA   ut1_pl
00F171  2  8D A6 B9           STA   FIO_ENDL          ; string pointer low
00F174  2  A5 72              LDA   ut1_ph
00F176  2  8D A7 B9           STA   FIO_ENDH          ; string pointer high
00F179  2  A9 0D              LDA   #FIO_CMD_MSEQ
00F17B  2  8D A0 B9           STA   FIO_CMD
00F17E  2  AD A1 B9           LDA   FIO_STATUS
00F181  2  C9 02              CMP   #FIO_OK
00F183  2  D0 01              BNE   @m_seq_err
00F185  2  60                 RTS
00F186  2               @m_seq_err
00F186  2  4C 74 F4           JMP   LAB_FIO_ERRIO
00F189  2               
00F189  2               ; perform COPPER subcommand — full handler relocated to extension ROM.
00F189  2               ; Saves ~390 bytes in BASIC ROM. EXT_COPPER in extension.s parses raw
00F189  2               ; BASIC text via (Bpntrl),Y and uses RAM bridges (EXT_GTBY, EXT_GTWRD,
00F189  2               ; EXT_SNERR) to reach BASIC's numeric expression evaluator and syntax
00F189  2               ; error path.
00F189  2               
00F189  2               LAB_COPPER
00F189  2  A9 0C              LDA   #EXT_CMD_COPPER
00F18B  2  4C 21 02           JMP   EXT_vec
00F18E  2               
00F18E  2               ; perform RESET — full system reset (VGC, SID, music) + cold start BASIC
00F18E  2               
00F18E  2               LAB_RESET
00F18E  2  A9 1F              LDA   #VCMD_SYSRESET
00F190  2  8D 10 A0           STA   VGC_CMD            ; trigger hardware reset
00F193  2  6C FC FF           JMP   ($FFFC)            ; jump through reset vector
00F196  2               
00F196  2               ; --- NIC BASIC keyword handlers ---
00F196  2               
00F196  2               ; NOPEN slot,"host",port — connect slot to remote host
00F196  2               LAB_NOPEN
00F196  2  20 0F D9           JSR   LAB_GTBY          ; slot → X
00F199  2  8E 02 A1           STX   NIC_SLOT
00F19C  2  20 D8 CD           JSR   LAB_1C01          ; comma
00F19F  2  20 B7 CC           JSR   LAB_EVEX          ; evaluate string expression
00F1A2  2  20 AE D7           JSR   LAB_EVST          ; pop: A=len, ut1_pl/ph=ptr
00F1A5  2  AA                 TAX                     ; len → X
00F1A6  2  F0 2A              BEQ   @nopen_err        ; empty hostname = error
00F1A8  2  E0 20              CPX   #32
00F1AA  2  B0 26              BCS   @nopen_err        ; too long
00F1AC  2  A0 00              LDY   #$00
00F1AE  2               @nopen_cp
00F1AE  2  B1 71              LDA   (ut1_pl),Y
00F1B0  2  99 20 A1           STA   NIC_NAMEBUF,Y
00F1B3  2  C8                 INY
00F1B4  2  CA                 DEX
00F1B5  2  D0 F7              BNE   @nopen_cp
00F1B7  2  A9 00              LDA   #$00
00F1B9  2  99 20 A1           STA   NIC_NAMEBUF,Y     ; null-terminate
00F1BC  2  20 D8 CD           JSR   LAB_1C01          ; comma
00F1BF  2  20 FD D8           JSR   LAB_GTWRD         ; port → FAC1_3/FAC1_2
00F1C2  2  A5 AF              LDA   FAC1_3
00F1C4  2  8D 08 A1           STA   NIC_RPORTL
00F1C7  2  A5 AE              LDA   FAC1_2
00F1C9  2  8D 09 A1           STA   NIC_RPORTH
00F1CC  2  A9 01              LDA   #NIC_CMD_CONNECT
00F1CE  2  8D 00 A1           STA   NIC_CMD
00F1D1  2  60                 RTS
00F1D2  2               @nopen_err
00F1D2  2  4C 98 D3           JMP   LAB_FCER          ; function call error
00F1D5  2               
00F1D5  2               ; NCLOSE slot — disconnect slot
00F1D5  2               LAB_NCLOSE
00F1D5  2  20 0F D9           JSR   LAB_GTBY          ; slot → X
00F1D8  2  8E 02 A1           STX   NIC_SLOT
00F1DB  2  A9 02              LDA   #NIC_CMD_DISCONNECT
00F1DD  2  8D 00 A1           STA   NIC_CMD
00F1E0  2  60                 RTS
00F1E1  2               
00F1E1  2               ; NLISTEN slot,port — listen for incoming connections
00F1E1  2               LAB_NLISTEN
00F1E1  2  20 0F D9           JSR   LAB_GTBY          ; slot → X
00F1E4  2  8E 02 A1           STX   NIC_SLOT
00F1E7  2  20 D8 CD           JSR   LAB_1C01          ; comma
00F1EA  2  20 FD D8           JSR   LAB_GTWRD         ; port → FAC1_3/FAC1_2
00F1ED  2  A5 AF              LDA   FAC1_3
00F1EF  2  8D 0A A1           STA   NIC_LPORTL
00F1F2  2  A5 AE              LDA   FAC1_2
00F1F4  2  8D 0B A1           STA   NIC_LPORTH
00F1F7  2  A9 05              LDA   #NIC_CMD_LISTEN
00F1F9  2  8D 00 A1           STA   NIC_CMD
00F1FC  2  60                 RTS
00F1FD  2               
00F1FD  2               ; NACCEPT slot — accept pending connection
00F1FD  2               LAB_NACCEPT
00F1FD  2  20 0F D9           JSR   LAB_GTBY          ; slot → X
00F200  2  8E 02 A1           STX   NIC_SLOT
00F203  2  A9 06              LDA   #NIC_CMD_ACCEPT
00F205  2  8D 00 A1           STA   NIC_CMD
00F208  2  60                 RTS
00F209  2               
00F209  2               ; NSEND slot,A$ — send string via NIC
00F209  2               LAB_NSEND
00F209  2  20 0F D9           JSR   LAB_GTBY          ; slot → X
00F20C  2  8E 02 A1           STX   NIC_SLOT
00F20F  2  20 D8 CD           JSR   LAB_1C01          ; comma
00F212  2  20 B7 CC           JSR   LAB_EVEX          ; evaluate expression
00F215  2  20 AE D7           JSR   LAB_EVST          ; pop string: A=len, ut1_pl/ph=ptr
00F218  2  AA                 TAX
00F219  2  F0 13              BEQ   @nsend_err        ; empty string
00F21B  2                     ; Point DMA at string in BASIC memory
00F21B  2  A5 71              LDA   ut1_pl
00F21D  2  8D 10 A1           STA   NIC_DMAL
00F220  2  A5 72              LDA   ut1_ph
00F222  2  8D 11 A1           STA   NIC_DMAH
00F225  2  8E 12 A1           STX   NIC_DMALEN        ; length
00F228  2  A9 03              LDA   #NIC_CMD_SEND
00F22A  2  8D 00 A1           STA   NIC_CMD
00F22D  2  60                 RTS
00F22E  2               @nsend_err
00F22E  2  4C 98 D3           JMP   LAB_FCER
00F231  2               
00F231  2               ; LAB_CWRD: parse comma + 16-bit word, store L/H to address in X:A
00F231  2               ; Entry: X = target address low, A = target address high
00F231  2               ; Stores parsed low byte at (ptr), high byte at (ptr)+1
00F231  2               LAB_CWRD
00F231  2  86 2E              STX   CwrdPtr
00F233  2  85 2F              STA   CwrdPtr+1
00F235  2  20 D8 CD           JSR   LAB_1C01
00F238  2  20 FD D8           JSR   LAB_GTWRD
00F23B  2  A0 00              LDY   #$00
00F23D  2  A5 AF              LDA   FAC1_3
00F23F  2  91 2E              STA   (CwrdPtr),Y
00F241  2  C8                 INY
00F242  2  A5 AE              LDA   FAC1_2
00F244  2  91 2E              STA   (CwrdPtr),Y
00F246  2  60                 RTS
00F247  2               
00F247  2               ; DMACOPY srcSpace,srcAddr,dstSpace,dstAddr,len
00F247  2               ; Address arguments are 16-bit offsets. For XRAM space (5), current XBANK
00F247  2               ; is used as the high address byte.
00F247  2               LAB_DMACOPY
00F247  2                     ; src space
00F247  2  20 0F D9           JSR   LAB_GTBY
00F24A  2  8E 66 BA           STX   DMA_SRCSPACE
00F24D  2  86 11              STX   Itempl
00F24F  2                     ; src addr
00F24F  2  A2 68              LDX   #<DMA_SRCL
00F251  2  A9 BA              LDA   #>DMA_SRCL
00F253  2  20 31 F2           JSR   LAB_CWRD
00F256  2  9C 6A BA           STZ   DMA_SRCH
00F259  2  A4 11              LDY   Itempl
00F25B  2  C0 05              CPY   #DMA_SPACE_XRAM
00F25D  2  D0 06              BNE   @dmac_srcok
00F25F  2  AD 0C BA           LDA   XMC_BANK
00F262  2  8D 6A BA           STA   DMA_SRCH
00F265  2               @dmac_srcok
00F265  2                     ; dst space
00F265  2  20 D8 CD           JSR   LAB_1C01
00F268  2  20 0F D9           JSR   LAB_GTBY
00F26B  2  8E 67 BA           STX   DMA_DSTSPACE
00F26E  2  86 11              STX   Itempl
00F270  2                     ; dst addr
00F270  2  A2 6B              LDX   #<DMA_DSTL
00F272  2  A9 BA              LDA   #>DMA_DSTL
00F274  2  20 31 F2           JSR   LAB_CWRD
00F277  2  9C 6D BA           STZ   DMA_DSTH
00F27A  2  A4 11              LDY   Itempl
00F27C  2  C0 05              CPY   #DMA_SPACE_XRAM
00F27E  2  D0 06              BNE   @dmac_dstok
00F280  2  AD 0C BA           LDA   XMC_BANK
00F283  2  8D 6D BA           STA   DMA_DSTH
00F286  2               @dmac_dstok
00F286  2                     ; len
00F286  2  A2 6E              LDX   #<DMA_LENL
00F288  2  A9 BA              LDA   #>DMA_LENL
00F28A  2  20 31 F2           JSR   LAB_CWRD
00F28D  2  9C 70 BA           STZ   DMA_LENH
00F290  2                     ; mode = copy
00F290  2  9C 71 BA           STZ   DMA_MODE
00F293  2                     ; start
00F293  2  A9 01              LDA   #DMA_CMD_START
00F295  2  8D 63 BA           STA   DMA_CMD
00F298  2  AD 64 BA           LDA   DMA_STATUS
00F29B  2  C9 01              CMP   #DMA_BUSY
00F29D  2  F0 07              BEQ   @dmac_ok
00F29F  2  C9 02              CMP   #DMA_OK
00F2A1  2  F0 03              BEQ   @dmac_ok
00F2A3  2  4C 98 D3           JMP   LAB_FCER
00F2A6  2               @dmac_ok
00F2A6  2  60                 RTS
00F2A7  2               
00F2A7  2               ; DMAFILL dstSpace,dstAddr,len,value
00F2A7  2               ; Address argument is a 16-bit offset. For XRAM space (5), current XBANK
00F2A7  2               ; is used as the high address byte.
00F2A7  2               LAB_DMAFILL
00F2A7  2                     ; dst space
00F2A7  2  20 0F D9           JSR   LAB_GTBY
00F2AA  2  8E 67 BA           STX   DMA_DSTSPACE
00F2AD  2  86 11              STX   Itempl
00F2AF  2                     ; dst addr
00F2AF  2  A2 6B              LDX   #<DMA_DSTL
00F2B1  2  A9 BA              LDA   #>DMA_DSTL
00F2B3  2  20 31 F2           JSR   LAB_CWRD
00F2B6  2  9C 6D BA           STZ   DMA_DSTH
00F2B9  2  A4 11              LDY   Itempl
00F2BB  2  C0 05              CPY   #DMA_SPACE_XRAM
00F2BD  2  D0 06              BNE   @dmaf_dstok
00F2BF  2  AD 0C BA           LDA   XMC_BANK
00F2C2  2  8D 6D BA           STA   DMA_DSTH
00F2C5  2               @dmaf_dstok
00F2C5  2                     ; len
00F2C5  2  A2 6E              LDX   #<DMA_LENL
00F2C7  2  A9 BA              LDA   #>DMA_LENL
00F2C9  2  20 31 F2           JSR   LAB_CWRD
00F2CC  2  9C 70 BA           STZ   DMA_LENH
00F2CF  2                     ; fill value
00F2CF  2  20 D8 CD           JSR   LAB_1C01
00F2D2  2  20 0F D9           JSR   LAB_GTBY
00F2D5  2  8E 72 BA           STX   DMA_FILL
00F2D8  2  A9 09              LDA   #EXT_CMD_DMAFILL
00F2DA  2  20 21 02           JSR   EXT_vec
00F2DD  2  F0 03              BEQ   @dmaf_ok
00F2DF  2  4C 98 D3           JMP   LAB_FCER
00F2E2  2               @dmaf_ok
00F2E2  2  60                 RTS
00F2E3  2               
00F2E3  2               ; BLITCOPY srcSpace,srcAddr,srcStride,dstSpace,dstAddr,dstStride,width,height
00F2E3  2               ; Address arguments are 16-bit offsets. For XRAM space (5), current XBANK
00F2E3  2               ; is used as the high address byte.
00F2E3  2               LAB_BLITCOPY
00F2E3  2                     ; src space
00F2E3  2  20 0F D9           JSR   LAB_GTBY
00F2E6  2  8E 86 BA           STX   BLT_SRCSPACE
00F2E9  2  86 11              STX   Itempl
00F2EB  2                     ; src addr
00F2EB  2  A2 88              LDX   #<BLT_SRCL
00F2ED  2  A9 BA              LDA   #>BLT_SRCL
00F2EF  2  20 31 F2           JSR   LAB_CWRD
00F2F2  2  9C 8A BA           STZ   BLT_SRCH
00F2F5  2  A4 11              LDY   Itempl
00F2F7  2  C0 05              CPY   #BLT_SPACE_XRAM
00F2F9  2  D0 06              BNE   @bltc_srcok
00F2FB  2  AD 0C BA           LDA   XMC_BANK
00F2FE  2  8D 8A BA           STA   BLT_SRCH
00F301  2               @bltc_srcok
00F301  2                     ; src stride
00F301  2  A2 92              LDX   #<BLT_SRCSTRL
00F303  2  A9 BA              LDA   #>BLT_SRCSTRL
00F305  2  20 31 F2           JSR   LAB_CWRD
00F308  2                     ; dst space
00F308  2  20 D8 CD           JSR   LAB_1C01
00F30B  2  20 0F D9           JSR   LAB_GTBY
00F30E  2  8E 87 BA           STX   BLT_DSTSPACE
00F311  2  86 11              STX   Itempl
00F313  2                     ; dst addr
00F313  2  A2 8B              LDX   #<BLT_DSTL
00F315  2  A9 BA              LDA   #>BLT_DSTL
00F317  2  20 31 F2           JSR   LAB_CWRD
00F31A  2  9C 8D BA           STZ   BLT_DSTH
00F31D  2  A4 11              LDY   Itempl
00F31F  2  C0 05              CPY   #BLT_SPACE_XRAM
00F321  2  D0 06              BNE   @bltc_dstok
00F323  2  AD 0C BA           LDA   XMC_BANK
00F326  2  8D 8D BA           STA   BLT_DSTH
00F329  2               @bltc_dstok
00F329  2                     ; dst stride
00F329  2  A2 94              LDX   #<BLT_DSTSTRL
00F32B  2  A9 BA              LDA   #>BLT_DSTSTRL
00F32D  2  20 31 F2           JSR   LAB_CWRD
00F330  2                     ; width
00F330  2  A2 8E              LDX   #<BLT_WIDTHL
00F332  2  A9 BA              LDA   #>BLT_WIDTHL
00F334  2  20 31 F2           JSR   LAB_CWRD
00F337  2                     ; height
00F337  2  A2 90              LDX   #<BLT_HEIGHTL
00F339  2  A9 BA              LDA   #>BLT_HEIGHTL
00F33B  2  20 31 F2           JSR   LAB_CWRD
00F33E  2                     ; mode = copy
00F33E  2  9C 96 BA           STZ   BLT_MODE
00F341  2  9C 97 BA           STZ   BLT_FILL
00F344  2  9C 98 BA           STZ   BLT_CKEY
00F347  2                     ; start
00F347  2  A9 01              LDA   #BLT_CMD_START
00F349  2  8D 83 BA           STA   BLT_CMD
00F34C  2  AD 84 BA           LDA   BLT_STATUS
00F34F  2  C9 01              CMP   #BLT_BUSY
00F351  2  F0 07              BEQ   @bltc_ok
