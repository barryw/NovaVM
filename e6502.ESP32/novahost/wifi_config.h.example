// Copy this file to wifi_config.h and fill in your credentials
// wifi_config.h is gitignored and will not be checked in
const char* WIFI_SSID     = "your_ssid";
const char* WIFI_PASSWORD = "your_password";

// Static IP — removes mDNS flakiness from the deploy loop. Comment out
// all four to fall back to DHCP. The gateway/subnet should match your
// router's LAN. If WIFI_STATIC_IP is not defined, DHCP is used.
#define WIFI_STATIC_IP       "192.168.1.65"
#define WIFI_GATEWAY         "192.168.1.1"
#define WIFI_SUBNET          "255.255.255.0"
#define WIFI_DNS             "192.168.1.1"
