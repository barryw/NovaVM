740 REM -- MUSIC FINISHED --
750 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
760 END
770 REM == HIGHLIGHT KEY ==
780 S=S-MB:IF S<0 OR S>95 THEN RETURN
790 OC=INT(S/12):PC=S-OC*12
800 T=KT(PC):W=KI(PC)
810 IF OC>3 THEN GOTO 880
820 REM UPPER ROW
830 IF T=1 THEN GOTO 860
840 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
850 RETURN
860 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
870 RETURN
880 REM LOWER ROW
890 OC=OC-4
900 IF T=1 THEN GOTO 930
910 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
920 RETURN
930 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
940 RETURN
