740 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=8:GOSUB 860
750 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 860
760 P1=N1
770 REM -- UPDATE V2 --
780 IF N2=P2 THEN GOTO 820
