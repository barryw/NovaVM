920 RETURN
930 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
940 RETURN
950 REM LOWER ROW
960 OC=OC-4
970 IF T=1 THEN GOTO 1000
980 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
990 RETURN
1000 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1010 RETURN
