550 GCOLOR 0
560 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
570 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
580 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
590 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
