360 COLOR 14,0:PRINT "           ELITE SYNCOPATIONS"
370 REM -- KEY LOOKUP TABLES --
380 DIM KT(11),KI(11)
390 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
400 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
410 REM -- KEYBOARD CONSTANTS --
420 KW=11:BW=7:KH=40:BH=24:SH=8
430 KX=6:Y1=36:Y2=90
440 MB=12:REM BASE MIDI C0
450 N1K=28:N2K=28
460 REM -- DRAW KEYBOARDS --
470 GCOLOR 1
480 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
490 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
500 GCOLOR 11
510 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
520 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
530 REM -- BLACK KEYS --
