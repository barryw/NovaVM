790 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 900
800 P1=N1
810 REM -- UPDATE V2 --
820 IF N2=P2 THEN GOTO 860
830 IF P2>0 THEN S=P2:KC=1:BC=0:YO=33:BO=16:GOSUB 900
840 IF N2>0 THEN S=N2:KC=12:BC=4:YO=33:BO=16:GOSUB 900
850 P2=N2
