10 REM SPRITE BOUNCE - NO VSYNC IN MOTION LOOP
20 REM USES PUBLIC SPRITE COMMANDS TO TEST HARDWARE BUFFERING
30 MODE 3
40 FOR R=0 TO 15
50 SPRITEDATA 0,R,$EE,$EE,$EE,$EE,$EE,$EE,$EE,$EE
60 NEXT R
70 SPRITESHAPE 0,0
80 SPRITESET 0,6,2
90 SPRITESET 0,7,0
100 X=0
110 Y=0
120 DX=1
130 DY=1
140 SPRITE 0,ON
150 SPRITE 0,X,Y
160 X=X+DX
170 Y=Y+DY
180 IF X<0 THEN X=0:DX=-DX
190 IF X>304 THEN X=304:DX=-DX
200 IF Y<0 THEN Y=0:DY=-DY
210 IF Y>224 THEN Y=224:DY=-DY
220 FOR T=1 TO 120
230 NEXT T
240 GOTO 150
