10 REM ====================================
20 REM  BACH - INVENTION No. 8 IN F
30 REM  BWV 779 - UNIFIED VOICE DEMO
40 REM  SID RIGHT HAND + WTS LEFT HAND
50 REM ====================================
60 PRINT CHR$(12)
70 MODE 1:COLOR 1,0:GCLS
80 REM -- SID INSTRUMENT FOR VOICE 1 --
90 INSTRUMENT 1,64,0,6,5,4:REM PULSE HARPSICHORD
100 REM -- VOICE 1: SID RIGHT HAND --
110 MUSIC 1,"T90I1O4L8FAF>C<F>FL16EDCDC<B-AB-AGL8FA>C<A>FCL16A>C<B->C<A>C<B->C<A>C<B->C<FAGAFAGAFAGADFEFDFEFDFEF<L8BG>D<B>FDL16GAGFEFEDCDC<B-L8A>L16DC<B>C<BAGAGFEFEDL8C>L16C<B>L8C<EF>C<E>C<DB>L4CL8CECGC>C<L16BAGAG"
120 MUSIC 1,"O5L16FEFEDC<B->CACA<B->ACA<A>A<L8B-GB-G>D<G>GL16FE-DE-DC<B->C<B-AL8GB->D<B->GDB-D-B-D-B-D-D<A>FDAFL16GFGB-CB-DB-EB-CB-FEFA<B>AD-ADA<B>AEDEG<A>G<B>GD-G<A>GL8FD<B->D<G>FEC<A>C<F>E-L16DFE-FDFE-FDFE-"
130 MUSIC 1,"O5L16F<B->DCD<B->DCD<B->DCD<GB-AB-GB-AB-GB-AB-L8ECGEB-G>L16CDC<B-AB-AGFGFE-L8DL16GFEFEDCDC<B-AB-AGL8F>L16FEL8F<AB->F<A>F<G>EL4F"
140 REM -- VOICE 7: WTS LEFT HAND (CELLO) --
150 MUSIC 7,"T90@I42V14R2.O3L8FAF>C<F>FL16EDCDC<B-AB-AGL8FA>C<A>FCL16A>C<B->C<A>C<B->C<A>C<B->C<FAGAFAGAFAGADFEFDFEFDFEF<L8BG>C<G>ECL16FGFEDEDC<B>C<BAL8G>L16C<BABAGFGFEDEDCGFEFL8G<GR>CECGC>C<L16BAGAGFEFEDL8CEGE>C<G>E-"
160 MUSIC 7,"O3L8<G->E-<G->E-<G-GL16FE-DE-DC<B->C<B-AL8G>GB-G>D<G>GL16FE-DE-DC<B->C<B-AGFG>E<G>E<F>E<G>E<E>E<FEF>D<F>D<E>D<F>D<D>D<L8B-GEGCEAFDF<B>DGED-E<A>D-<L16D>DCD<G>D<A>D<B->D<G>D<C>C<B->C<F>C<G>C<A>C<F"
170 MUSIC 7,"O3L16>C<L8B->DFDB-F>L16DFE-FDFE-FDFE-F<B->DCD<B->DCD<B->DCD<GB-AB-GB-AB-GB-AB-L8ECFCAFL16B->C<B-AGAGFEFEDL8CL16FEDEDC<B->C<B-AGAGF>C<B-AB->L8C<CL4F"
180 VOLUME 15
190 MUSIC PLAY
200 REM -- TITLE --
210 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
220 COLOR 15,0:PRINT "  BACH - INVENTION No.8 IN F"
230 COLOR 14,0:PRINT "          BWV 779"
240 PRINT
250 COLOR 7,0:PRINT " UNIFIED VOICE ROUTING DEMO"
260 COLOR 10,0:PRINT " V1 SID HARPSICHORD (RIGHT)"
270 COLOR 9,0:PRINT " V7 WTS CELLO (LEFT)"
280 REM -- KEY LOOKUP TABLES --
290 DIM KT(11),KI(11)
300 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
310 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
320 REM -- KEYBOARD CONSTANTS --
330 KW=11:BW=7:KH=44:BH=26
340 KX=6:Y1=56:Y2=136
350 M1=48:M7=36:REM BASE MIDI: V1=C3, V7=C2
360 NK=28:REM 4 OCTAVES = 28 WHITE KEYS
370 REM -- DRAW KEYBOARDS --
380 GCOLOR 1
390 FOR I=0 TO NK-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
400 GCOLOR 11
410 FOR I=0 TO NK:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:LINE X,Y2,X,Y2+KH:NEXT I
420 REM -- BLACK KEYS --
430 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
440 GCOLOR 0
450 FOR O=0 TO 3:FOR I=0 TO 4
460 X=KX+(O*7+BK(I))*KW+KW-BW/2
470 FILL X,Y1,X+BW-1,Y1+BH:FILL X,Y2,X+BW-1,Y2+BH
480 NEXT I:NEXT O
490 REM -- LABELS --
500 GCOLOR 10:LINE KX-1,Y1+KH+1,KX+NK*KW,Y1+KH+1
510 GCOLOR 9:LINE KX-1,Y2+KH+1,KX+NK*KW,Y2+KH+1
520 COLOR 10,0:LOCATE 1,13:PRINT " V1 SID Right Hand";
530 COLOR 9,0:LOCATE 1,23:PRINT " V7 WTS Left Hand";
540 REM -- MAIN LOOP --
550 P1=0:P7=0
560 VSYNC
570 N1=MNOTE(1):N7=MNOTE(7)
580 REM -- UPDATE VOICE 1 (SID) --
590 IF N1=P1 THEN GOTO 650
600 IF P1>0 THEN S=P1-M1:KY=Y1:KC=1:BC=0:GOSUB 740
610 IF N1>0 THEN S=N1-M1:KY=Y1:KC=10:BC=2:GOSUB 740
620 P1=N1
650 REM -- UPDATE VOICE 7 (WTS) --
660 IF N7=P7 THEN GOTO 710
670 IF P7>0 THEN S=P7-M7:KY=Y2:KC=1:BC=0:GOSUB 740
680 IF N7>0 THEN S=N7-M7:KY=Y2:KC=9:BC=3:GOSUB 740
690 P7=N7
710 IF PLAYING THEN GOTO 560
720 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.";
730 END
740 REM == HIGHLIGHT/CLEAR KEY ==
750 IF S<0 OR S>47 THEN RETURN
760 OC=INT(S/12):PC=S-OC*12
770 T=KT(PC):W=KI(PC)
780 IF T=1 THEN GOTO 820
790 REM WHITE KEY
800 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,KY+BH+1,X+KW-3,KY+KH-1
810 RETURN
820 REM BLACK KEY
830 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,KY+1,X+BW-2,KY+BH-1
840 RETURN
