10 REM ================================
20 REM  MOZART
30 REM  AVE VERUM CORPUS - SID CHIPTUNE
40 REM  NOVABASIC MML MUSIC ENGINE
50 REM ================================
60 PRINT CHR$(12)
70 MODE 1:COLOR 1,0:GCLS
80 REM -- SID INSTRUMENTS --
90 INSTRUMENT 1,64,0,6,5,4:REM PULSE HARPSICHORD
100 INSTRUMENT 2,32,0,8,7,3:REM SAW HARPSICHORD
110 REM -- VOICE 1: BAAVEVERUM --
120 MUSIC 1,"T108I1O3L4A2A2B2B2A2A2A2A2A2.AAAAAA2.AA1>C#2.C#C#DD2<B2.>DDC#C#2D2E2DC#<B2.B>C#1C#2.C#C#2C#CC<B-AGGAA2B2B>C#DEC#C#2D8C#8DC#2<B2.BBAG>C#C#2.C#C#<BA>DD2DD<A2.AB2>C2D2C2<B>DC#<BA2ABA2G.G8"
130 MUSIC 1,"F#1"
140 REM -- VOICE 2: BBAVEVERUM --
150 MUSIC 2,"I2O3L4D2D2D2D2C#2C#2D2D2A2.ADDC#C#D2.DA1A2.AABB2G#2EEE#F#F#2R2B2>C#2D<DE2.EA1A2.AAGG2C2.CCFF2F2.FEDC#AB-2AG#A2R2G2.F2F2E2GGF#EAA2.AAGF#BB2AG#A2.AB2R2R2A2B-2A2G#1G1F#BA2.AD1"
160 VOLUME 15
170 MUSIC PLAY
180 REM -- TITLE --
190 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
200 COLOR 15,0:PRINT "    MOZART"
210 COLOR 14,0:PRINT "           AVE VERUM CORPUS"
220 REM -- KEY LOOKUP TABLES --
230 DIM KT(11),KI(11)
240 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
250 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
260 REM -- KEYBOARD CONSTANTS --
270 KW=11:BW=7:KH=40:BH=24:SH=8
280 KX=6:Y1=36:Y2=90
290 MB=12:REM BASE MIDI C0
300 N1K=28:N2K=28
310 REM -- DRAW KEYBOARDS --
320 GCOLOR 1
330 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
340 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
350 GCOLOR 11
360 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
370 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
380 REM -- BLACK KEYS --
390 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
400 GCOLOR 0
410 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
420 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
430 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
440 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
450 REM -- OCTAVE LABELS --
460 COLOR 8,0
470 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
480 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
490 COLOR 10,0:LOCATE 1,18:PRINT "V1 BAAVEVER";
500 COLOR 12,0:LOCATE 14,18:PRINT "V2 BBAVEVER";
510 REM -- MAIN LOOP --
520 P1=0:P2=0
530 VSYNC
540 N1=MNOTE(1):N2=MNOTE(2)
550 REM -- UPDATE V1 --
560 IF N1=P1 THEN GOTO 600
570 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=8:GOSUB 690
580 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 690
590 P1=N1
600 REM -- UPDATE V2 --
610 IF N2=P2 THEN GOTO 650
620 IF P2>0 THEN S=P2:KC=1:BC=0:YO=33:BO=16:GOSUB 690
630 IF N2>0 THEN S=N2:KC=12:BC=4:YO=33:BO=16:GOSUB 690
640 P2=N2
650 IF PLAYING THEN GOTO 530
660 REM -- MUSIC FINISHED --
670 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
680 END
690 REM == HIGHLIGHT KEY ==
700 S=S-MB:IF S<0 OR S>95 THEN RETURN
710 OC=INT(S/12):PC=S-OC*12
720 T=KT(PC):W=KI(PC)
730 IF OC>3 THEN GOTO 800
740 REM UPPER ROW
750 IF T=1 THEN GOTO 780
760 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
770 RETURN
780 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
790 RETURN
800 REM LOWER ROW
810 OC=OC-4
820 IF T=1 THEN GOTO 850
830 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
840 RETURN
850 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
860 RETURN
