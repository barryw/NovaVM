10 REM =======================================
20 REM  SCROLLING TILE DEMO
30 REM =======================================
100 MODE 4:TILESIZE 8:TTRANS 0
110 TMIRROR 1:COLOR 1,14
120 GOSUB 1000:REM DEFINE TILES
130 REM
190 RS=PEEK(40968)*256+PEEK(40968)
200 IF RS=0 THEN RS=31337
210 CW=0:CL=0:GW=0:CH=0:CY=0:CT=0:BT=2
220 FOR C=0 TO 79:GOSUB 2000:NEXT
230 CW=0:CL=0:GW=0
240 REM
300 REM ==== SCROLL LOOP ====
310 SX=0:LC=79
320 SX=SX+2:IF SX>=640 THEN SX=SX-640
330 TSCROLL SX,0
340 NC=INT(SX/8)+40:IF NC>=80 THEN NC=NC-80
350 IF NC<>LC THEN C=NC:GOSUB 2000:LC=NC
360 VSYNC
370 GET K:IF K=0 THEN 320
380 MODE 0:CLS:PRINT "DONE.":END
400 REM
1000 REM ==== DEFINE TILES ====
1010 A=16384
1020 FOR I=0 TO 31:POKE A+I,238:NEXT:TDEF 0,A
1030 FOR I=0 TO 15:POKE A+I,85:NEXT
1040 FOR I=16 TO 31:POKE A+I,153:NEXT:TDEF 1,A
1050 FOR I=0 TO 3:POKE A+I,136:NEXT
1060 FOR R=1 TO 3:B=A+R*4:POKE B,34:POKE B+1,34:POKE B+2,34:POKE B+3,40:NEXT
1070 FOR I=16 TO 19:POKE A+I,136:NEXT
1080 FOR R=5 TO 7:B=A+R*4:POKE B,34:POKE B+1,40:POKE B+2,34:POKE B+3,34:NEXT
1090 TDEF 2,A
1100 FOR R=0 TO 7:B=A+R*4
1110 IF (R AND 1)=0 THEN POKE B,102:POKE B+1,54:POKE B+2,102:POKE B+3,99:GOTO 1130
1120 POKE B,99:POKE B+1,102:POKE B+2,54:POKE B+3,102
1130 NEXT:TDEF 3,A
1140 FOR I=0 TO 31:POKE A+I,0:NEXT
1150 POKE A+1,1:POKE A+2,16
1160 POKE A+4,1:POKE A+5,17:POKE A+6,17:POKE A+7,16
1170 FOR I=8 TO 15:POKE A+I,17:NEXT
1180 POKE A+16,1:POKE A+17,17:POKE A+18,17:POKE A+19,16
1190 POKE A+21,1:POKE A+22,16:TDEF 4,A
1200 FOR I=0 TO 31:POKE A+I,153:NEXT:TDEF 5,A
1210 FOR I=0 TO 3:POKE A+I,187:NEXT
1220 FOR R=1 TO 3:B=A+R*4:POKE B,204:POKE B+1,204:POKE B+2,204:POKE B+3,203:NEXT
1230 FOR I=16 TO 19:POKE A+I,187:NEXT
1240 FOR R=5 TO 7:B=A+R*4:POKE B,204:POKE B+1,203:POKE B+2,204:POKE B+3,204:NEXT
1250 TDEF 6,A:RETURN
1260 REM
1500 REM ==== PRNG ====
1510 RS=RS*5+PEEK(40968)
1520 RS=RS-INT(RS/65536)*65536
1530 RV=RS-INT(RS/256)*256
1540 RETURN
1550 REM
2000 REM ==== GENERATE COLUMN C ====
2010 NT=0:X=C:IF C>=40 THEN NT=1:X=C-40
2020 FOR Y=0 TO 24:TPUT NT,X,Y,0:NEXT:TPUT NT,X,18,1
2030 FOR I=19 TO 22:TPUT NT,X,I,5:NEXT
2040 FOR I=23 TO 24:TPUT NT,X,I,3:NEXT
2050 REM --- CLOUD ---
2060 IF CL>0 THEN TPUT NT,X,CY,4:CL=CL-1:GOTO 2100
2070 GOSUB 1500:IF RV<12 THEN GOSUB 1500:CL=2+(RV AND 3):GOSUB 1500:CY=1+(RV AND 3)
2080 IF CL>0 THEN TPUT NT,X,CY,4:CL=CL-1
2100 REM --- STRUCTURE ---
2110 IF CW>0 THEN GOTO 2200
2120 IF GW>0 THEN GW=GW-1:GOTO 2500
2130 GOSUB 1500:R=RV
2140 IF R<50 THEN GOSUB 1500:CW=2+(RV AND 1):GOSUB 1500:CH=4+(RV AND 3):CT=CW:BT=6:GOTO 2200
2150 IF R<120 THEN GOSUB 1500:CW=7+(RV AND 7):GOSUB 1500:CH=8+(RV AND 3):CT=CW:BT=2:GOTO 2200
2160 IF R<170 THEN GOSUB 1500:CW=3+(RV AND 3):CH=15:CT=CW:BT=2:GOTO 2200
2170 GOSUB 1500:GW=3+(RV AND 7):GOTO 2500
2200 REM ==== BUILD STRUCTURE IN BUFFER ====
2210 P=CT-CW
2220 FOR Y=CH TO 17:TPUT NT,X,Y,BT:NEXT
2230 REM CRENELLATION
2240 IF CH>=3 THEN IF P=0 OR P=CT-1 OR (P AND 1)=0 THEN TPUT NT,X,CH-1,BT
2250 REM DOOR
2260 IF CT<6 OR CH>12 THEN GOTO 2300
2270 M=INT(CT/2)
2280 IF P>=M-1 AND P<=M+1 THEN TPUT NT,X,15,0:TPUT NT,X,16,0:TPUT NT,X,17,0
2290 IF P=M THEN TPUT NT,X,14,0
2300 REM WINDOWS
2310 IF CT>=5 AND CH<=11 AND (P=2 OR P=CT-3) THEN TPUT NT,X,CH+2,0:TPUT NT,X,CH+3,0
2320 CW=CW-1
2330 IF CW=0 THEN GOSUB 1500:GW=2+(RV AND 5)
2500 REM ==== COLUMN COMPLETE ====
2530 RETURN
