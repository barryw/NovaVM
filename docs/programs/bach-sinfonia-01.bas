250 REM -- TITLE --
260 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
270 COLOR 15,0:PRINT "    J.S. BACH"
280 COLOR 14,0:PRINT "           SINFONIA 1 BWV 787"
290 REM -- KEY LOOKUP TABLES --
300 DIM KT(11),KI(11)
310 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
320 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
330 REM -- KEYBOARD CONSTANTS --
340 KW=11:BW=7:KH=39:BH=24:SH=5
350 KX=6:Y1=36:Y2=89
360 MB=12:REM BASE MIDI C0
370 N1K=28:N2K=28
380 REM -- DRAW KEYBOARDS --
390 GCOLOR 1
400 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
410 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
420 GCOLOR 11
430 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
440 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
450 REM -- BLACK KEYS --
460 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
470 GCOLOR 0
480 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
490 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
500 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
510 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
520 REM -- OCTAVE LABELS --
530 COLOR 8,0
540 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
550 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
560 COLOR 10,0:LOCATE 1,18:PRINT "V1 MELONE";
570 COLOR 12,0:LOCATE 14,18:PRINT "V2 MELTWO";
580 COLOR 14,0:LOCATE 27,18:PRINT "V3 MELTHREE";
590 REM -- MAIN LOOP --
600 P1=0:P2=0:P3=0
610 VSYNC
620 N1=MNOTE(1):N2=MNOTE(2):N3=MNOTE(3)
630 REM -- UPDATE V1 --
640 IF N1=P1 THEN GOTO 680
650 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=9:GOSUB 820
660 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=9:GOSUB 820
670 P1=N1
680 REM -- UPDATE V2 --
690 IF N2=P2 THEN GOTO 730
700 IF P2>0 THEN S=P2:KC=1:BC=0:YO=30:BO=14:GOSUB 820
710 IF N2>0 THEN S=N2:KC=12:BC=4:YO=30:BO=14:GOSUB 820
720 P2=N2
730 REM -- UPDATE V3 --
740 IF N3=P3 THEN GOTO 780
750 IF P3>0 THEN S=P3:KC=1:BC=0:YO=35:BO=19:GOSUB 820
760 IF N3>0 THEN S=N3:KC=14:BC=6:YO=35:BO=19:GOSUB 820
770 P3=N3
780 IF PLAYING THEN GOTO 610
790 REM -- MUSIC FINISHED --
800 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
810 END
820 REM == HIGHLIGHT KEY ==
830 S=S-MB:IF S<0 OR S>95 THEN RETURN
840 OC=INT(S/12):PC=S-OC*12
850 T=KT(PC):W=KI(PC)
860 IF OC>3 THEN GOTO 930
870 REM UPPER ROW
880 IF T=1 THEN GOTO 910
890 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
900 RETURN
910 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
920 RETURN
930 REM LOWER ROW
940 OC=OC-4
950 IF T=1 THEN GOTO 980
960 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
970 RETURN
980 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
990 RETURN
