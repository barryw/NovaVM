10 REM =======================================
20 REM  TILE ENGINE DEMO - CASTLE SCENE
30 REM  PHASE 1: 8X8   PHASE 2: 16X16
40 REM =======================================
50 A=16384:REM TILE DATA BUFFER
60 REM
100 REM ==== PHASE 1: 8X8 TILES ====
110 MODE 4:TILESIZE 8:TTRANS 0:TMIRROR 3
120 COLOR 1,14
130 REM
140 REM -- TILE 0: SKY (14=LIGHT BLUE) --
150 FOR I=0 TO 31:POKE A+I,238:NEXT
160 TDEF 0,A
170 REM -- TILE 1: GRASS (5=GREEN / 9=BROWN) --
180 FOR I=0 TO 15:POKE A+I,85:NEXT
190 FOR I=16 TO 31:POKE A+I,153:NEXT
200 TDEF 1,A
210 REM -- TILE 2: BRICK (2=RED / 8=ORANGE MORTAR) --
220 REM ROW 0: MORTAR
230 FOR I=0 TO 3:POKE A+I,136:NEXT
240 REM ROWS 1-3: RED, JOINT AT PIXEL 7
250 FOR R=1 TO 3:B=A+R*4
260 POKE B,34:POKE B+1,34:POKE B+2,34:POKE B+3,40
270 NEXT
280 REM ROW 4: MORTAR
290 FOR I=16 TO 19:POKE A+I,136:NEXT
300 REM ROWS 5-7: RED, JOINT AT PIXEL 3 (OFFSET)
310 FOR R=5 TO 7:B=A+R*4
320 POKE B,34:POKE B+1,40:POKE B+2,34:POKE B+3,34
330 NEXT
340 TDEF 2,A
350 REM -- TILE 3: WATER (6=BLUE / 3=CYAN WAVES) --
360 FOR R=0 TO 7:B=A+R*4
370 IF (R AND 1)=0 THEN POKE B,102:POKE B+1,54:POKE B+2,102:POKE B+3,99:GOTO 390
380 POKE B,99:POKE B+1,102:POKE B+2,54:POKE B+3,102
390 NEXT
400 TDEF 3,A
410 REM -- TILE 4: CLOUD (1=WHITE / 0=TRANSPARENT) --
420 FOR I=0 TO 31:POKE A+I,0:NEXT
430 REM ROW 0: NARROW TOP
440 POKE A+1,1:POKE A+2,16
450 REM ROW 1: WIDER
460 POKE A+4,1:POKE A+5,17:POKE A+6,17:POKE A+7,16
470 REM ROWS 2-3: FULL
480 FOR I=8 TO 15:POKE A+I,17:NEXT
490 REM ROW 4: WIDER
500 POKE A+16,1:POKE A+17,17:POKE A+18,17:POKE A+19,16
510 REM ROW 5: NARROW BOTTOM
520 POKE A+21,1:POKE A+22,16
530 TDEF 4,A
540 REM -- TILE 5: EARTH (9=BROWN) --
550 FOR I=0 TO 31:POKE A+I,153:NEXT
560 TDEF 5,A
570 REM
580 REM -- BUILD 8X8 SCENE --
590 TFILL 0,0:REM ALL SKY
600 REM CLOUDS
610 TPUT 0,5,1,4:TPUT 0,6,1,4
620 TPUT 0,20,2,4:TPUT 0,21,2,4:TPUT 0,22,2,4
630 TPUT 0,33,1,4:TPUT 0,34,1,4
640 REM CASTLE CRENELLATIONS (ROW 7)
650 FOR X=14 TO 26 STEP 2:TPUT 0,X,7,2:NEXT
660 REM CASTLE WALL (ROWS 8-14)
670 FOR Y=8 TO 14:FOR X=14 TO 26:TPUT 0,X,Y,2:NEXT:NEXT
680 REM WINDOWS (SKY OPENINGS)
690 TPUT 0,16,9,0:TPUT 0,16,10,0
700 TPUT 0,24,9,0:TPUT 0,24,10,0
710 REM DOOR (COLS 19-21, ROWS 12-14)
720 FOR Y=12 TO 14:FOR X=19 TO 21:TPUT 0,X,Y,0:NEXT:NEXT
730 REM DOOR ARCH (ROW 11)
740 TPUT 0,20,11,0
750 REM GRASS (ROW 15)
760 FOR X=0 TO 39:TPUT 0,X,15,1:NEXT
770 REM EARTH (ROWS 16-20)
780 FOR Y=16 TO 20:FOR X=0 TO 39:TPUT 0,X,Y,5:NEXT:NEXT
790 REM WATER (ROWS 21-24)
800 FOR Y=21 TO 24:FOR X=0 TO 39:TPUT 0,X,Y,3:NEXT:NEXT
810 REM
820 REM -- PRESS ANY KEY --
830 GET K:IF K=0 THEN 830
840 REM
900 REM ==== PHASE 2: 16X16 TILES ====
910 TCLS:TILESIZE 16
920 REM
930 REM -- TILE 0: SKY 16X16 --
940 FOR I=0 TO 127:POKE A+I,238:NEXT
950 TDEF 0,A
960 REM -- TILE 1: GRASS 16X16 --
970 FOR I=0 TO 63:POKE A+I,85:NEXT
980 FOR I=64 TO 127:POKE A+I,153:NEXT
990 REM LIGHT GREEN TIPS (13=LIGHT GREEN)
1000 POKE A,213:POKE A+3,93:POKE A+5,213
1010 TDEF 1,A
1020 REM -- TILE 2: BRICK 16X16 --
1030 FOR I=0 TO 127:POKE A+I,34:NEXT
1040 REM MORTAR ROWS 0 AND 8
1050 FOR I=0 TO 7:POKE A+I,136:POKE A+64+I,136:NEXT
1060 REM TOP COURSE JOINTS: PIXELS 7,15 (ROWS 1-7)
1070 FOR R=1 TO 7:POKE A+R*8+3,40:POKE A+R*8+7,40:NEXT
1080 REM BOTTOM COURSE JOINTS: PIXELS 3,11 (ROWS 9-15)
1090 FOR R=9 TO 15:POKE A+R*8+1,40:POKE A+R*8+5,40:NEXT
1100 TDEF 2,A
1110 REM -- TILE 3: WATER 16X16 --
1120 FOR I=0 TO 127:POKE A+I,102:NEXT
1130 REM WAVE ACCENTS ON EVEN ROWS
1140 FOR R=0 TO 14 STEP 2:B=A+R*8
1150 POKE B+1,54:POKE B+4,99:POKE B+6,54
1160 NEXT
1170 TDEF 3,A
1180 REM -- TILE 4: CLOUD 16X16 --
1190 FOR I=0 TO 127:POKE A+I,0:NEXT
1200 REM ROWS 3-10: FULL WHITE
1210 FOR R=3 TO 10:FOR I=0 TO 7:POKE A+R*8+I,17:NEXT:NEXT
1220 REM ROWS 2,11: WIDE
1230 FOR I=1 TO 6:POKE A+2*8+I,17:POKE A+11*8+I,17:NEXT
1240 REM ROWS 1,12: MEDIUM
1250 FOR I=2 TO 5:POKE A+1*8+I,17:POKE A+12*8+I,17:NEXT
1260 REM ROWS 0,13: NARROW
1270 FOR I=3 TO 4:POKE A+I,17:POKE A+13*8+I,17:NEXT
1280 TDEF 4,A
1290 REM -- TILE 5: EARTH 16X16 --
1300 FOR I=0 TO 127:POKE A+I,153:NEXT
1310 TDEF 5,A
1320 REM
1330 REM -- BUILD 16X16 SCENE --
1340 REM (VISIBLE: 20 COLS X ~13 ROWS)
1350 TFILL 0,0:REM ALL SKY
1360 REM CLOUDS
1370 TPUT 0,2,1,4:TPUT 0,3,1,4
1380 TPUT 0,12,0,4:TPUT 0,13,0,4
1390 TPUT 0,17,2,4
1400 REM CASTLE CRENELLATIONS (ROW 3)
1410 FOR X=6 TO 14 STEP 2:TPUT 0,X,3,2:NEXT
1420 REM CASTLE WALL (ROWS 4-8)
1430 FOR Y=4 TO 8:FOR X=6 TO 14:TPUT 0,X,Y,2:NEXT:NEXT
1440 REM WINDOWS
1450 TPUT 0,7,5,0:TPUT 0,7,6,0
1460 TPUT 0,13,5,0:TPUT 0,13,6,0
1470 REM DOOR (COLS 9-11, ROWS 7-8)
1480 FOR Y=7 TO 8:FOR X=9 TO 11:TPUT 0,X,Y,0:NEXT:NEXT
1490 REM DOOR ARCH
1500 TPUT 0,10,6,0
1510 REM GRASS (ROW 9)
1520 FOR X=0 TO 19:TPUT 0,X,9,1:NEXT
1530 REM EARTH (ROWS 10-11)
1540 FOR Y=10 TO 11:FOR X=0 TO 19:TPUT 0,X,Y,5:NEXT:NEXT
1550 REM WATER (ROW 12)
1560 FOR X=0 TO 19:TPUT 0,X,12,3:NEXT
1570 REM
1580 REM -- PRESS ANY KEY --
1590 GET K:IF K=0 THEN 1590
1600 REM
1610 REM -- DONE --
1620 MODE 0:CLS
1630 PRINT "TILE DEMO COMPLETE."
1640 END
