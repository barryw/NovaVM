320 REM -- TITLE --
330 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
340 COLOR 15,0:PRINT "    J.S. BACH"
350 COLOR 14,0:PRINT "           SINFONIA 2 BWV 788"
360 REM -- KEY LOOKUP TABLES --
370 DIM KT(11),KI(11)
380 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
390 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
400 REM -- KEYBOARD CONSTANTS --
410 KW=11:BW=7:KH=39:BH=24:SH=5
420 KX=6:Y1=36:Y2=89
430 MB=12:REM BASE MIDI C0
440 N1K=28:N2K=28
450 REM -- DRAW KEYBOARDS --
460 GCOLOR 1
470 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
480 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
490 GCOLOR 11
500 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
510 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
520 REM -- BLACK KEYS --
530 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
540 GCOLOR 0
550 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
560 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
570 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
580 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
590 REM -- OCTAVE LABELS --
600 COLOR 8,0
610 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
620 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
630 COLOR 10,0:LOCATE 1,18:PRINT "V1 MELONE";
640 COLOR 12,0:LOCATE 14,18:PRINT "V2 MELTWO";
650 COLOR 14,0:LOCATE 27,18:PRINT "V3 MELTHREE";
660 REM -- MAIN LOOP --
670 P1=0:P2=0:P3=0
680 VSYNC
690 N1=MNOTE(1):N2=MNOTE(2):N3=MNOTE(3)
700 REM -- UPDATE V1 --
710 IF N1=P1 THEN GOTO 750
720 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=9:GOSUB 890
730 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=9:GOSUB 890
740 P1=N1
750 REM -- UPDATE V2 --
760 IF N2=P2 THEN GOTO 800
770 IF P2>0 THEN S=P2:KC=1:BC=0:YO=30:BO=14:GOSUB 890
780 IF N2>0 THEN S=N2:KC=12:BC=4:YO=30:BO=14:GOSUB 890
790 P2=N2
800 REM -- UPDATE V3 --
810 IF N3=P3 THEN GOTO 850
820 IF P3>0 THEN S=P3:KC=1:BC=0:YO=35:BO=19:GOSUB 890
830 IF N3>0 THEN S=N3:KC=14:BC=6:YO=35:BO=19:GOSUB 890
840 P3=N3
850 IF PLAYING THEN GOTO 680
860 REM -- MUSIC FINISHED --
870 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
880 END
890 REM == HIGHLIGHT KEY ==
900 S=S-MB:IF S<0 OR S>95 THEN RETURN
910 OC=INT(S/12):PC=S-OC*12
920 T=KT(PC):W=KI(PC)
930 IF OC>3 THEN GOTO 1000
940 REM UPPER ROW
950 IF T=1 THEN GOTO 980
960 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
970 RETURN
980 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
990 RETURN
1000 REM LOWER ROW
1010 OC=OC-4
1020 IF T=1 THEN GOTO 1050
1030 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
1040 RETURN
1050 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1060 RETURN
