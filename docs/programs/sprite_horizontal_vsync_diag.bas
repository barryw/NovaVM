10 REM SPRITE HORIZONTAL VSYNC DIAGNOSTIC
20 REM ONE LOGICAL PIXEL PER FRAME, NO DIAGONAL MOTION
30 MODE 3
40 FOR R=0 TO 15
50 SPRITEDATA 0,R,$EE,$EE,$EE,$EE,$EE,$EE,$EE,$EE
60 NEXT R
70 SPRITESHAPE 0,0
80 SPRITESET 0,6,2
90 SPRITESET 0,7,0
100 X=0
110 Y=112
120 DX=1
130 SPRITE 0,ON
140 SPRITE 0,X,Y
150 X=X+DX
160 IF X<0 THEN X=0:DX=-DX
170 IF X>304 THEN X=304:DX=-DX
180 VSYNC
190 GOTO 140
