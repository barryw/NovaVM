240 VOLUME 15
250 MUSIC PLAY
260 REM -- TITLE --
270 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
280 COLOR 15,0:PRINT "    J.S. BACH"
290 COLOR 14,0:PRINT "           SINFONIA 3 BWV 789"
300 REM -- KEY LOOKUP TABLES --
310 DIM KT(11),KI(11)
320 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
330 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
340 REM -- KEYBOARD CONSTANTS --
350 KW=11:BW=7:KH=39:BH=24:SH=5
360 KX=6:Y1=36:Y2=89
370 MB=12:REM BASE MIDI C0
380 N1K=28:N2K=28
390 REM -- DRAW KEYBOARDS --
400 GCOLOR 1
410 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
420 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
430 GCOLOR 11
440 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
450 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
460 REM -- BLACK KEYS --
470 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
480 GCOLOR 0
490 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
500 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
510 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
520 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
530 REM -- OCTAVE LABELS --
540 COLOR 8,0
550 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
560 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
570 COLOR 10,0:LOCATE 1,18:PRINT "V1 MELONE";
580 COLOR 12,0:LOCATE 14,18:PRINT "V2 MELTWO";
590 COLOR 14,0:LOCATE 27,18:PRINT "V3 MELTHREE";
600 REM -- MAIN LOOP --
610 P1=0:P2=0:P3=0
620 VSYNC
630 N1=MNOTE(1):N2=MNOTE(2):N3=MNOTE(3)
640 REM -- UPDATE V1 --
650 IF N1=P1 THEN GOTO 690
660 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=9:GOSUB 830
670 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=9:GOSUB 830
680 P1=N1
690 REM -- UPDATE V2 --
700 IF N2=P2 THEN GOTO 740
710 IF P2>0 THEN S=P2:KC=1:BC=0:YO=30:BO=14:GOSUB 830
720 IF N2>0 THEN S=N2:KC=12:BC=4:YO=30:BO=14:GOSUB 830
730 P2=N2
740 REM -- UPDATE V3 --
750 IF N3=P3 THEN GOTO 790
760 IF P3>0 THEN S=P3:KC=1:BC=0:YO=35:BO=19:GOSUB 830
770 IF N3>0 THEN S=N3:KC=14:BC=6:YO=35:BO=19:GOSUB 830
780 P3=N3
790 IF PLAYING THEN GOTO 620
800 REM -- MUSIC FINISHED --
810 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
820 END
830 REM == HIGHLIGHT KEY ==
840 S=S-MB:IF S<0 OR S>95 THEN RETURN
850 OC=INT(S/12):PC=S-OC*12
860 T=KT(PC):W=KI(PC)
870 IF OC>3 THEN GOTO 940
880 REM UPPER ROW
890 IF T=1 THEN GOTO 920
900 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
910 RETURN
920 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
930 RETURN
940 REM LOWER ROW
950 OC=OC-4
960 IF T=1 THEN GOTO 990
970 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
980 RETURN
990 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1000 RETURN
