10 REM ================================
20 REM  J.S. BACH
30 REM  PRELUDE AND FUGUE BWV 536 - SID CHIPTUNE
40 REM  NOVABASIC MML MUSIC ENGINE
50 REM ================================
60 PRINT CHR$(12)
70 MODE 1:COLOR 1,0:GCLS
80 REM -- SID INSTRUMENTS --
90 INSTRUMENT 1,16,2,4,10,6:REM TRI RECORDER
100 INSTRUMENT 2,16,2,4,10,6:REM TRI RECORDER
110 INSTRUMENT 3,16,2,4,10,6:REM TRI RECORDER
120 INSTRUMENT 4,16,2,4,10,6:REM TRI RECORDER
130 REM -- VOICE 1: STAFF6 --
140 MUSIC 1,"T100I1O3L4DD"
150 REM -- VOICE 2: STAFF9 --
160 MUSIC 2,"I2O3L4DD"
170 REM -- VOICE 3: STAFF11 --
180 MUSIC 3,"I3O3L4DD"
190 REM -- VOICE 4: STAFF13 --
200 MUSIC 4,"I4O3L4DD"
210 VOLUME 15
220 MUSIC PLAY
230 REM -- TITLE --
240 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
250 COLOR 15,0:PRINT "    J.S. BACH"
260 COLOR 14,0:PRINT "           PRELUDE AND FUGUE BWV 536"
270 REM -- KEY LOOKUP TABLES --
280 DIM KT(11),KI(11)
290 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
300 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
310 REM -- KEYBOARD CONSTANTS --
320 KW=11:BW=7:KH=40:BH=24:SH=4
330 KX=6:Y1=36:Y2=90
340 MB=12:REM BASE MIDI C0
350 N1K=28:N2K=28
360 REM -- DRAW KEYBOARDS --
370 GCOLOR 1
380 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
390 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
400 GCOLOR 11
410 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
420 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
430 REM -- BLACK KEYS --
440 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
450 GCOLOR 0
460 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
470 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
480 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
490 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
500 REM -- OCTAVE LABELS --
510 COLOR 8,0
520 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
530 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
540 COLOR 10,0:LOCATE 1,18:PRINT "V1 STAFF6";
550 COLOR 12,0:LOCATE 14,18:PRINT "V2 STAFF9";
560 COLOR 14,0:LOCATE 27,18:PRINT "V3 STAFF11";
570 COLOR 9,0:LOCATE 1,19:PRINT "V4 STAFF13";
580 REM -- MAIN LOOP --
590 P1=0:P2=0:P3=0:P4=0
600 VSYNC
610 N1=MNOTE(1):N2=MNOTE(2):N3=MNOTE(3):N4=MNOTE(4)
620 REM -- UPDATE V1 --
630 IF N1=P1 THEN GOTO 670
640 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=8:GOSUB 860
650 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 860
660 P1=N1
670 REM -- UPDATE V2 --
680 IF N2=P2 THEN GOTO 720
690 IF P2>0 THEN S=P2:KC=1:BC=0:YO=29:BO=12:GOSUB 860
700 IF N2>0 THEN S=N2:KC=12:BC=4:YO=29:BO=12:GOSUB 860
710 P2=N2
720 REM -- UPDATE V3 --
730 IF N3=P3 THEN GOTO 770
740 IF P3>0 THEN S=P3:KC=1:BC=0:YO=33:BO=16:GOSUB 860
750 IF N3>0 THEN S=N3:KC=14:BC=6:YO=33:BO=16:GOSUB 860
760 P3=N3
770 REM -- UPDATE V4 --
780 IF N4=P4 THEN GOTO 820
790 IF P4>0 THEN S=P4:KC=1:BC=0:YO=37:BO=20:GOSUB 860
800 IF N4>0 THEN S=N4:KC=9:BC=1:YO=37:BO=20:GOSUB 860
810 P4=N4
820 IF PLAYING THEN GOTO 600
830 REM -- MUSIC FINISHED --
840 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
850 END
860 REM == HIGHLIGHT KEY ==
870 S=S-MB:IF S<0 OR S>95 THEN RETURN
880 OC=INT(S/12):PC=S-OC*12
890 T=KT(PC):W=KI(PC)
900 IF OC>3 THEN GOTO 970
910 REM UPPER ROW
920 IF T=1 THEN GOTO 950
930 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
940 RETURN
950 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
960 RETURN
970 REM LOWER ROW
980 OC=OC-4
990 IF T=1 THEN GOTO 1020
1000 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
1010 RETURN
1020 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1030 RETURN
