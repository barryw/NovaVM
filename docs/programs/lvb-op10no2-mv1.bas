670 REM -- TITLE --
680 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
690 COLOR 15,0:PRINT "    BEETHOVEN"
700 COLOR 14,0:PRINT "           OP.10 NO.2 - ALLEGRO"
710 REM -- KEY LOOKUP TABLES --
720 DIM KT(11),KI(11)
730 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
740 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
750 REM -- KEYBOARD CONSTANTS --
760 KW=11:BW=7:KH=40:BH=24:SH=8
770 KX=6:Y1=36:Y2=90
780 MB=12:REM BASE MIDI C0
790 N1K=28:N2K=28
800 REM -- DRAW KEYBOARDS --
810 GCOLOR 1
820 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
830 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
840 GCOLOR 11
850 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
860 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
870 REM -- BLACK KEYS --
880 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
890 GCOLOR 0
900 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
910 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
920 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
930 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
940 REM -- OCTAVE LABELS --
950 COLOR 8,0
960 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
970 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
980 COLOR 10,0:LOCATE 1,18:PRINT "V1 UP";
990 COLOR 12,0:LOCATE 14,18:PRINT "V2 DOWN";
1000 REM -- MAIN LOOP --
1010 P1=0:P2=0
1020 VSYNC
1030 N1=MNOTE(1):N2=MNOTE(2)
1040 REM -- UPDATE V1 --
1050 IF N1=P1 THEN GOTO 1090
1060 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=8:GOSUB 1180
1070 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 1180
1080 P1=N1
1090 REM -- UPDATE V2 --
1100 IF N2=P2 THEN GOTO 1140
1110 IF P2>0 THEN S=P2:KC=1:BC=0:YO=33:BO=16:GOSUB 1180
1120 IF N2>0 THEN S=N2:KC=12:BC=4:YO=33:BO=16:GOSUB 1180
1130 P2=N2
1140 IF PLAYING THEN GOTO 1020
1150 REM -- MUSIC FINISHED --
1160 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
1170 END
1180 REM == HIGHLIGHT KEY ==
1190 S=S-MB:IF S<0 OR S>95 THEN RETURN
1200 OC=INT(S/12):PC=S-OC*12
1210 T=KT(PC):W=KI(PC)
1220 IF OC>3 THEN GOTO 1290
1230 REM UPPER ROW
1240 IF T=1 THEN GOTO 1270
1250 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
1260 RETURN
1270 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
1280 RETURN
1290 REM LOWER ROW
1300 OC=OC-4
1310 IF T=1 THEN GOTO 1340
1320 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
1330 RETURN
1340 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1350 RETURN
