900 IF OC>3 THEN GOTO 970
910 REM UPPER ROW
920 IF T=1 THEN GOTO 950
930 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
940 RETURN
950 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
960 RETURN
970 REM LOWER ROW
980 OC=OC-4
990 IF T=1 THEN GOTO 1020
1000 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
1010 RETURN
1020 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1030 RETURN
