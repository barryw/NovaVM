290 REM -- TITLE --
300 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
310 COLOR 15,0:PRINT "    J.S. BACH"
320 COLOR 14,0:PRINT "           SINFONIA 9 BWV 795"
330 REM -- KEY LOOKUP TABLES --
340 DIM KT(11),KI(11)
350 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
360 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
370 REM -- KEYBOARD CONSTANTS --
380 KW=11:BW=7:KH=39:BH=24:SH=5
390 KX=6:Y1=36:Y2=89
400 MB=12:REM BASE MIDI C0
410 N1K=28:N2K=28
420 REM -- DRAW KEYBOARDS --
430 GCOLOR 1
440 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
450 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
460 GCOLOR 11
470 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
480 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
490 REM -- BLACK KEYS --
500 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
510 GCOLOR 0
520 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
530 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
540 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
550 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
560 REM -- OCTAVE LABELS --
570 COLOR 8,0
580 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
590 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
600 COLOR 10,0:LOCATE 1,18:PRINT "V1 MELONE";
610 COLOR 12,0:LOCATE 14,18:PRINT "V2 MELTWO";
620 COLOR 14,0:LOCATE 27,18:PRINT "V3 MELTHREE";
630 REM -- MAIN LOOP --
640 P1=0:P2=0:P3=0
650 VSYNC
660 N1=MNOTE(1):N2=MNOTE(2):N3=MNOTE(3)
670 REM -- UPDATE V1 --
680 IF N1=P1 THEN GOTO 720
690 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=9:GOSUB 860
700 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=9:GOSUB 860
710 P1=N1
720 REM -- UPDATE V2 --
730 IF N2=P2 THEN GOTO 770
740 IF P2>0 THEN S=P2:KC=1:BC=0:YO=30:BO=14:GOSUB 860
750 IF N2>0 THEN S=N2:KC=12:BC=4:YO=30:BO=14:GOSUB 860
760 P2=N2
770 REM -- UPDATE V3 --
780 IF N3=P3 THEN GOTO 820
790 IF P3>0 THEN S=P3:KC=1:BC=0:YO=35:BO=19:GOSUB 860
800 IF N3>0 THEN S=N3:KC=14:BC=6:YO=35:BO=19:GOSUB 860
810 P3=N3
