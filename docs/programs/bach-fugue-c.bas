280 REM -- TITLE --
290 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
300 COLOR 15,0:PRINT "    J.S. BACH"
310 COLOR 14,0:PRINT "           FUGUE IN C MAJOR BWV 952"
320 REM -- KEY LOOKUP TABLES --
330 DIM KT(11),KI(11)
340 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
350 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
360 REM -- KEYBOARD CONSTANTS --
370 KW=11:BW=7:KH=39:BH=24:SH=5
380 KX=6:Y1=36:Y2=89
390 MB=12:REM BASE MIDI C0
400 N1K=28:N2K=28
410 REM -- DRAW KEYBOARDS --
420 GCOLOR 1
430 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
440 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
450 GCOLOR 11
460 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
470 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
480 REM -- BLACK KEYS --
490 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
500 GCOLOR 0
510 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
520 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
530 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
540 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
550 REM -- OCTAVE LABELS --
560 COLOR 8,0
570 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
580 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
590 COLOR 10,0:LOCATE 1,18:PRINT "V1 PARTONE";
600 COLOR 12,0:LOCATE 14,18:PRINT "V2 PARTTWO";
610 COLOR 14,0:LOCATE 27,18:PRINT "V3 PARTTHRE";
620 REM -- MAIN LOOP --
630 P1=0:P2=0:P3=0
640 VSYNC
650 N1=MNOTE(1):N2=MNOTE(2):N3=MNOTE(3)
660 REM -- UPDATE V1 --
670 IF N1=P1 THEN GOTO 710
680 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=9:GOSUB 850
690 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=9:GOSUB 850
700 P1=N1
710 REM -- UPDATE V2 --
720 IF N2=P2 THEN GOTO 760
730 IF P2>0 THEN S=P2:KC=1:BC=0:YO=30:BO=14:GOSUB 850
740 IF N2>0 THEN S=N2:KC=12:BC=4:YO=30:BO=14:GOSUB 850
750 P2=N2
760 REM -- UPDATE V3 --
770 IF N3=P3 THEN GOTO 810
780 IF P3>0 THEN S=P3:KC=1:BC=0:YO=35:BO=19:GOSUB 850
790 IF N3>0 THEN S=N3:KC=14:BC=6:YO=35:BO=19:GOSUB 850
800 P3=N3
810 IF PLAYING THEN GOTO 640
820 REM -- MUSIC FINISHED --
830 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
840 END
850 REM == HIGHLIGHT KEY ==
860 S=S-MB:IF S<0 OR S>95 THEN RETURN
870 OC=INT(S/12):PC=S-OC*12
880 T=KT(PC):W=KI(PC)
890 IF OC>3 THEN GOTO 960
900 REM UPPER ROW
910 IF T=1 THEN GOTO 940
920 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
930 RETURN
940 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
950 RETURN
960 REM LOWER ROW
970 OC=OC-4
980 IF T=1 THEN GOTO 1010
990 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
1000 RETURN
1010 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1020 RETURN
