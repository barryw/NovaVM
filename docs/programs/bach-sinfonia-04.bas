270 REM -- TITLE --
280 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
290 COLOR 15,0:PRINT "    J.S. BACH"
300 COLOR 14,0:PRINT "           SINFONIA 4 BWV 790"
310 REM -- KEY LOOKUP TABLES --
320 DIM KT(11),KI(11)
330 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
340 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
350 REM -- KEYBOARD CONSTANTS --
360 KW=11:BW=7:KH=39:BH=24:SH=5
370 KX=6:Y1=36:Y2=89
380 MB=12:REM BASE MIDI C0
390 N1K=28:N2K=28
400 REM -- DRAW KEYBOARDS --
410 GCOLOR 1
420 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
430 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
440 GCOLOR 11
450 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
460 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
470 REM -- BLACK KEYS --
480 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
490 GCOLOR 0
500 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
510 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
520 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
530 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
540 REM -- OCTAVE LABELS --
550 COLOR 8,0
560 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
570 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
580 COLOR 10,0:LOCATE 1,18:PRINT "V1 MELONE";
590 COLOR 12,0:LOCATE 14,18:PRINT "V2 MELTWO";
600 COLOR 14,0:LOCATE 27,18:PRINT "V3 MELTHREE";
610 REM -- MAIN LOOP --
620 P1=0:P2=0:P3=0
630 VSYNC
640 N1=MNOTE(1):N2=MNOTE(2):N3=MNOTE(3)
650 REM -- UPDATE V1 --
660 IF N1=P1 THEN GOTO 700
670 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=9:GOSUB 840
680 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=9:GOSUB 840
690 P1=N1
700 REM -- UPDATE V2 --
710 IF N2=P2 THEN GOTO 750
720 IF P2>0 THEN S=P2:KC=1:BC=0:YO=30:BO=14:GOSUB 840
730 IF N2>0 THEN S=N2:KC=12:BC=4:YO=30:BO=14:GOSUB 840
740 P2=N2
750 REM -- UPDATE V3 --
760 IF N3=P3 THEN GOTO 800
770 IF P3>0 THEN S=P3:KC=1:BC=0:YO=35:BO=19:GOSUB 840
780 IF N3>0 THEN S=N3:KC=14:BC=6:YO=35:BO=19:GOSUB 840
790 P3=N3
800 IF PLAYING THEN GOTO 630
810 REM -- MUSIC FINISHED --
820 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
830 END
840 REM == HIGHLIGHT KEY ==
850 S=S-MB:IF S<0 OR S>95 THEN RETURN
860 OC=INT(S/12):PC=S-OC*12
870 T=KT(PC):W=KI(PC)
880 IF OC>3 THEN GOTO 950
890 REM UPPER ROW
900 IF T=1 THEN GOTO 930
910 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
920 RETURN
930 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
940 RETURN
950 REM LOWER ROW
960 OC=OC-4
970 IF T=1 THEN GOTO 1000
980 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
990 RETURN
1000 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1010 RETURN
