410 REM -- KEY LOOKUP TABLES --
420 DIM KT(11),KI(11)
430 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
440 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
450 REM -- KEYBOARD CONSTANTS --
460 KW=11:BW=7:KH=40:BH=24:SH=8
470 KX=6:Y1=36:Y2=90
480 MB=12:REM BASE MIDI C0
490 N1K=28:N2K=28
500 REM -- DRAW KEYBOARDS --
510 GCOLOR 1
520 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
530 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
540 GCOLOR 11
550 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
560 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
570 REM -- BLACK KEYS --
580 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
590 GCOLOR 0
600 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
610 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
620 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
630 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
640 REM -- OCTAVE LABELS --
650 COLOR 8,0
660 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
670 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
680 COLOR 10,0:LOCATE 1,18:PRINT "V1 RIGHT";
690 COLOR 12,0:LOCATE 14,18:PRINT "V2 LEFT";
700 REM -- MAIN LOOP --
710 P1=0:P2=0
720 VSYNC
730 N1=MNOTE(1):N2=MNOTE(2)
740 REM -- UPDATE V1 --
750 IF N1=P1 THEN GOTO 790
760 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=8:GOSUB 880
770 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 880
780 P1=N1
790 REM -- UPDATE V2 --
800 IF N2=P2 THEN GOTO 840
810 IF P2>0 THEN S=P2:KC=1:BC=0:YO=33:BO=16:GOSUB 880
820 IF N2>0 THEN S=N2:KC=12:BC=4:YO=33:BO=16:GOSUB 880
830 P2=N2
840 IF PLAYING THEN GOTO 720
850 REM -- MUSIC FINISHED --
860 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
870 END
880 REM == HIGHLIGHT KEY ==
890 S=S-MB:IF S<0 OR S>95 THEN RETURN
900 OC=INT(S/12):PC=S-OC*12
910 T=KT(PC):W=KI(PC)
920 IF OC>3 THEN GOTO 990
930 REM UPPER ROW
940 IF T=1 THEN GOTO 970
950 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
960 RETURN
970 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
980 RETURN
990 REM LOWER ROW
1000 OC=OC-4
1010 IF T=1 THEN GOTO 1040
1020 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
1030 RETURN
1040 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1050 RETURN
