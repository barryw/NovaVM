380 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
390 REM -- KEYBOARD CONSTANTS --
400 KW=11:BW=7:KH=40:BH=24:SH=8
