280 REM -- TITLE --
290 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
300 COLOR 15,0:PRINT "    BEETHOVEN"
310 COLOR 14,0:PRINT "           OP.2 NO.1 - MENUETTO"
320 REM -- KEY LOOKUP TABLES --
330 DIM KT(11),KI(11)
340 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
350 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
360 REM -- KEYBOARD CONSTANTS --
370 KW=11:BW=7:KH=40:BH=24:SH=8
380 KX=6:Y1=36:Y2=90
390 MB=12:REM BASE MIDI C0
400 N1K=28:N2K=28
410 REM -- DRAW KEYBOARDS --
420 GCOLOR 1
430 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
440 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
450 GCOLOR 11
460 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
470 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
480 REM -- BLACK KEYS --
490 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
500 GCOLOR 0
510 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
520 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
530 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
540 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
550 REM -- OCTAVE LABELS --
560 COLOR 8,0
570 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
580 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
590 COLOR 10,0:LOCATE 1,18:PRINT "V1 UP";
600 COLOR 12,0:LOCATE 14,18:PRINT "V2 DOWN";
610 REM -- MAIN LOOP --
620 P1=0:P2=0
630 VSYNC
640 N1=MNOTE(1):N2=MNOTE(2)
650 REM -- UPDATE V1 --
660 IF N1=P1 THEN GOTO 700
670 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=8:GOSUB 790
680 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 790
690 P1=N1
700 REM -- UPDATE V2 --
710 IF N2=P2 THEN GOTO 750
720 IF P2>0 THEN S=P2:KC=1:BC=0:YO=33:BO=16:GOSUB 790
730 IF N2>0 THEN S=N2:KC=12:BC=4:YO=33:BO=16:GOSUB 790
740 P2=N2
750 IF PLAYING THEN GOTO 630
760 REM -- MUSIC FINISHED --
770 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
780 END
790 REM == HIGHLIGHT KEY ==
800 S=S-MB:IF S<0 OR S>95 THEN RETURN
810 OC=INT(S/12):PC=S-OC*12
820 T=KT(PC):W=KI(PC)
830 IF OC>3 THEN GOTO 900
840 REM UPPER ROW
850 IF T=1 THEN GOTO 880
860 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
870 RETURN
880 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
890 RETURN
900 REM LOWER ROW
910 OC=OC-4
920 IF T=1 THEN GOTO 950
930 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
940 RETURN
950 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
960 RETURN
