300 REM -- TITLE --
310 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
320 COLOR 15,0:PRINT "    SCOTT JOPLIN"
330 COLOR 14,0:PRINT "           THE ENTERTAINER"
340 REM -- KEY LOOKUP TABLES --
350 DIM KT(11),KI(11)
360 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
370 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
380 REM -- KEYBOARD CONSTANTS --
390 KW=11:BW=7:KH=40:BH=24:SH=8
400 KX=6:Y1=36:Y2=90
410 MB=12:REM BASE MIDI C0
420 N1K=28:N2K=28
430 REM -- DRAW KEYBOARDS --
440 GCOLOR 1
450 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
460 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
470 GCOLOR 11
480 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
490 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
500 REM -- BLACK KEYS --
510 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
520 GCOLOR 0
530 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
540 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
550 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
560 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
570 REM -- OCTAVE LABELS --
580 COLOR 8,0
590 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
600 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
610 COLOR 10,0:LOCATE 1,18:PRINT "V1 TOP";
620 COLOR 12,0:LOCATE 14,18:PRINT "V2 BOTTOM";
630 REM -- MAIN LOOP --
640 P1=0:P2=0
650 VSYNC
660 N1=MNOTE(1):N2=MNOTE(2)
670 REM -- UPDATE V1 --
680 IF N1=P1 THEN GOTO 720
690 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=8:GOSUB 810
700 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 810
710 P1=N1
720 REM -- UPDATE V2 --
730 IF N2=P2 THEN GOTO 770
740 IF P2>0 THEN S=P2:KC=1:BC=0:YO=33:BO=16:GOSUB 810
750 IF N2>0 THEN S=N2:KC=12:BC=4:YO=33:BO=16:GOSUB 810
760 P2=N2
770 IF PLAYING THEN GOTO 650
780 REM -- MUSIC FINISHED --
790 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
800 END
810 REM == HIGHLIGHT KEY ==
820 S=S-MB:IF S<0 OR S>95 THEN RETURN
830 OC=INT(S/12):PC=S-OC*12
840 T=KT(PC):W=KI(PC)
850 IF OC>3 THEN GOTO 920
860 REM UPPER ROW
870 IF T=1 THEN GOTO 900
880 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
890 RETURN
900 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
910 RETURN
920 REM LOWER ROW
930 OC=OC-4
940 IF T=1 THEN GOTO 970
950 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
960 RETURN
970 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
980 RETURN
