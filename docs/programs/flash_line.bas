10 CLS
20 COLOR 7,0
30 LOCATE 0,2
40 PRINT "FLASH DEMO - NORMAL TEXT STAYS SOLID"
50 COLOR 14,0
60 LOCATE 0,5
70 FLASH
80 FOR I=1 TO 5:PRINT " FLASHING TEXT! ";:NEXT I
90 FLASHOFF
100 COLOR 7,0
110 LOCATE 0,8
120 PRINT "ROW 5 WAS PRINTED WHILE FLASH WAS ACTIVE."
130 PRINT "THE LETTERS SHOULD BLINK; THIS LINE SHOULD NOT."
140 GOTO 140
