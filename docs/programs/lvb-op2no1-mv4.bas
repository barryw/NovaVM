710 REM -- TITLE --
720 GCOLOR 14:LINE 10,6,309,6:LINE 10,7,309,7
730 COLOR 15,0:PRINT "    BEETHOVEN"
740 COLOR 14,0:PRINT "           OP.2 NO.1 - PRESTISSIMO"
750 REM -- KEY LOOKUP TABLES --
760 DIM KT(11),KI(11)
770 FOR I=0 TO 11:READ KT(I),KI(I):NEXT
780 DATA 0,0,1,0,0,1,1,1,0,2,0,3,1,3,0,4,1,4,0,5,1,5,0,6
790 REM -- KEYBOARD CONSTANTS --
800 KW=11:BW=7:KH=40:BH=24:SH=8
810 KX=6:Y1=36:Y2=90
820 MB=12:REM BASE MIDI C0
830 N1K=28:N2K=28
840 REM -- DRAW KEYBOARDS --
850 GCOLOR 1
860 FOR I=0 TO N1K-1:X=KX+I*KW:FILL X,Y1,X+KW-2,Y1+KH:NEXT I
870 FOR I=0 TO N2K-1:X=KX+I*KW:FILL X,Y2,X+KW-2,Y2+KH:NEXT I
880 GCOLOR 11
890 FOR I=0 TO N1K:X=KX+I*KW-1:LINE X,Y1,X,Y1+KH:NEXT I
900 FOR I=0 TO N2K:X=KX+I*KW-1:LINE X,Y2,X,Y2+KH:NEXT I
910 REM -- BLACK KEYS --
920 DIM BK(4):BK(0)=0:BK(1)=1:BK(2)=3:BK(3)=4:BK(4)=5
930 GCOLOR 0
940 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
950 FILL X,Y1,X+BW-1,Y1+BH:NEXT I:NEXT O
960 FOR O=0 TO 3:FOR I=0 TO 4:X=KX+(O*7+BK(I))*KW+KW-BW/2
970 FILL X,Y2,X+BW-1,Y2+BH:NEXT I:NEXT O
980 REM -- OCTAVE LABELS --
990 COLOR 8,0
1000 FOR O=0 TO 3:LOCATE 1+O*10,10:PRINT "C";:PRINT O;:NEXT O
1010 FOR O=0 TO 3:LOCATE 1+O*10,17:PRINT "C";:PRINT O+4;:NEXT O
1020 COLOR 10,0:LOCATE 1,18:PRINT "V1 UP";
1030 COLOR 12,0:LOCATE 14,18:PRINT "V2 DOWN";
1040 REM -- MAIN LOOP --
1050 P1=0:P2=0
1060 VSYNC
1070 N1=MNOTE(1):N2=MNOTE(2)
1080 REM -- UPDATE V1 --
1090 IF N1=P1 THEN GOTO 1130
1100 IF P1>0 THEN S=P1:KC=1:BC=0:YO=25:BO=8:GOSUB 1220
1110 IF N1>0 THEN S=N1:KC=10:BC=2:YO=25:BO=8:GOSUB 1220
1120 P1=N1
1130 REM -- UPDATE V2 --
1140 IF N2=P2 THEN GOTO 1180
1150 IF P2>0 THEN S=P2:KC=1:BC=0:YO=33:BO=16:GOSUB 1220
1160 IF N2>0 THEN S=N2:KC=12:BC=4:YO=33:BO=16:GOSUB 1220
1170 P2=N2
1180 IF PLAYING THEN GOTO 1060
1190 REM -- MUSIC FINISHED --
1200 VOLUME 0:COLOR 7,0:LOCATE 1,24:PRINT " Finished.       ";
1210 END
1220 REM == HIGHLIGHT KEY ==
1230 S=S-MB:IF S<0 OR S>95 THEN RETURN
1240 OC=INT(S/12):PC=S-OC*12
1250 T=KT(PC):W=KI(PC)
1260 IF OC>3 THEN GOTO 1330
1270 REM UPPER ROW
1280 IF T=1 THEN GOTO 1310
1290 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y1+YO,X+KW-3,Y1+YO+SH-1
1300 RETURN
1310 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y1+BO,X+BW-2,Y1+BO+SH-1
1320 RETURN
1330 REM LOWER ROW
1340 OC=OC-4
1350 IF T=1 THEN GOTO 1380
1360 X=KX+(OC*7+W)*KW:GCOLOR KC:FILL X+1,Y2+YO,X+KW-3,Y2+YO+SH-1
1370 RETURN
1380 X=KX+(OC*7+W)*KW+KW-BW/2:GCOLOR BC:FILL X+1,Y2+BO,X+BW-2,Y2+BO+SH-1
1390 RETURN
